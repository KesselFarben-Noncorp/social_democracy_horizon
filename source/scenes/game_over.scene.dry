{!</div>!}

{!<script>
(function() {
  function restructureCards() {
    document.querySelectorAll('.ach').forEach(function(div) {
      if (div.querySelector('.ach-text')) return;
      var strongEl = div.querySelector('strong');
      if (!strongEl) return;
      var badgeEl = div.querySelector('.ach-new');
      var nodes = Array.from(div.childNodes);
      var iconNodes = [];
      var subtitleText = '';
      var passedStrong = false;
      nodes.forEach(function(node) {
        if (node === strongEl) { passedStrong = true; return; }
        if (badgeEl && node === badgeEl) { return; }
        if (!passedStrong) {
          iconNodes.push(node);
        } else {
          subtitleText += node.textContent;
        }
      });
      subtitleText = subtitleText.replace(/^[\s\u2013\u2014-]+/, '').trim();
      div.innerHTML = '';
      iconNodes.forEach(function(n) { div.appendChild(n); });
      var textWrap = document.createElement('div');
      textWrap.className = 'ach-text';
      var titleDiv = document.createElement('div');
      titleDiv.className = 'ach-title';
      titleDiv.appendChild(strongEl);
      if (badgeEl) titleDiv.appendChild(badgeEl);
      var subDiv = document.createElement('div');
      subDiv.className = 'ach-subtitle';
      subDiv.textContent = subtitleText;
      textWrap.appendChild(titleDiv);
      textWrap.appendChild(subDiv);
      div.appendChild(textWrap);
    });
  }
  function reflow() {
    document.querySelectorAll('.ach-section').forEach(function(section) {
      var items = Array.from(section.querySelectorAll('.ach'));
      if (items.length === 0) return;
      var grid = document.createElement('div');
      grid.className = 'ach-grid';
      var col1 = document.createElement('div');
      col1.style.cssText = 'display:flex;flex-direction:column;gap:6px;';
      var col2 = document.createElement('div');
      col2.style.cssText = 'display:flex;flex-direction:column;gap:6px;';
      items.forEach(function(el, i) {
        el.parentNode.removeChild(el);
        (i % 2 === 0 ? col1 : col2).appendChild(el);
      });
      grid.appendChild(col1);
      grid.appendChild(col2);
      section.appendChild(grid);
    });
  }
  function init() {
    restructureCards();
    reflow();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>!}


