@tertiary_dvp
view-if: (dvp_votes > 0 or dvp_r > 0) and enemy_1 != "DVP" and enemy_2 != "DVP"
on-arrival: enemy_3 = "DVP"; dvp_relation -= 2; workers_dvp -= 1
go-to: enemies_done

@tertiary_bvp
view-if: (bvp_votes > 0 or bvp_r > 0) and enemy_1 != "BVP" and enemy_2 != "BVP"
on-arrival: enemy_3 = "BVP"; bvp_relation -= 2; workers_bvp *= 0.99
go-to: enemies_done

@tertiary_wp
view-if: (wp_votes > 0 or wp_r > 0) and enemy_1 != "WP" and enemy_2 != "WP"
on-arrival: enemy_3 = "WP"; wp_relation -= 2; old_middle_wp *= 0.995
go-to: enemies_done

@tertiary_ddp
view-if: (ddp_votes > 0 or ddp_r > 0) and enemy_1 != "DDP" and enemy_2 != "DDP"
on-arrival: enemy_3 = "DDP"; ddp_relation -= 2; reformist_dissent += 1
go-to: enemies_done

@tertiary_sapd
view-if: (sapd_votes > 0 or sapd_r > 0) and enemy_1 != "SAPD" and enemy_2 != "SAPD"
on-arrival: enemy_3 = "SAPD"; sapd_relation -= 2; left_dissent += 2
go-to: enemies_done

@tertiary_csvd
view-if: (csvd_votes > 0 or csvd_r > 0) and enemy_1 != "CSVD" and enemy_2 != "CSVD"
on-arrival: enemy_3 = "CSVD"; csvd_relation -= 2; catholics_csvd *= 0.99
go-to: enemies_done

@tertiary_cnbl
view-if: (cnbl_votes > 0 or cnbl_r > 0) and enemy_1 != "CNBL" and enemy_2 != "CNBL"
