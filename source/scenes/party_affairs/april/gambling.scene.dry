@start_menu
on-arrival: gambling_result = ""; last_payout = 0

You are betting **[+ current_bid +]** resources. The lights flicker in sync with the national ticker.

- @start: Pull the lever.
- @put: Change bet.

@start
on-arrival: {!

// ── GUARD: cap bid to what player actually has ───────────────────────────────
if (Q.current_bid > Q.resources) Q.current_bid = Q.resources;
if (Q.current_bid <= 0) { Q.gambling_result = "NO_BET"; return; }

// ════════════════════════════════════════════════════════════════════════════
// 1. BASE ROLL  (0–1 uniform)
// ════════════════════════════════════════════════════════════════════════════
const roll = Q.random_factor;   // engine-supplied

// ════════════════════════════════════════════════════════════════════════════
// 2. HOUSE EDGE  — casino always has a structural edge, but it shifts with the
//    economy.  In a boom the house loosens to attract whales; in depression
//    it tightens because it needs cash too.
// ════════════════════════════════════════════════════════════════════════════
let house_edge = 0.06;   // 6 % baseline (realistic Vegas take)

if      (Q.phase === "growth")        house_edge = 0.04;   // loose money era
else if (Q.phase === "overheating")   house_edge = 0.05;   // slight tightening
else if (Q.phase === "hyperinflation")house_edge = 0.12;   // house hikes fees vs inflation
else if (Q.phase === "correction")    house_edge = 0.08;   // cautious house
else if (Q.phase === "depression")    house_edge = 0.14;   // house is desperate too
else if (Q.phase === "stagflation")   house_edge = 0.11;   // high costs passed on

// ════════════════════════════════════════════════════════════════════════════
// 3. LUCK MODIFIERS  — real economic signals affect gambler behavior & odds
// ════════════════════════════════════════════════════════════════════════════

// 3a. Consumer confidence proxy:
//     Low unemployment + low inflation = people feel lucky & tip more → slight edge up
const confidence = Math.max(0, Math.min(1,
    1 - (Q.unemployed / 30) - (Math.max(0, Q.inflation - 3) / 40)
));

// 3b. Credit expansion: easy money era → gamblers bet recklessly, lose more
//     But jackpots are bigger because the pot is inflated
const credit_boost = (Q.credit_expansion || 0) * 0.15;

// 3c. Inflation tax on winnings: if inflation is high, real value of payout
//     is eroded; modeled as a multiplier on the payout, not the odds
const inflation_payout_tax = Math.max(0.5,
    1 - Math.max(0, Q.inflation - 5) * 0.015
);

// 3d. Capital flight / instability penalty: when capital_pressure is high,
//     the casino itself is unstable — rigged machines, unpaid jackpots
const instability_penalty = Math.min(0.20, (Q.capital_pressure || 0) * 0.18);

// 3e. Business cycle sinusoidal luck — the cycle literally modulates the roll
//     (small effect, but real — flush times = looser play)
const cycle_luck = (Q.business_cycle || 0) * 0.04;

// 3f. Expectations: unanchored inflation expectations = chaotic payouts
const chaos_factor = Q.expectations_anchored ? 0 : 0.08;
const chaos_swing  = (Math.random() * 2 - 1) * chaos_factor;

// ── Compose effective roll ───────────────────────────────────────────────────
let eff_roll = roll
    + confidence    * 0.06
    + credit_boost
    + cycle_luck
    + chaos_swing
    - house_edge
    - instability_penalty;

// Clamp to [0, 1]
eff_roll = Math.max(0, Math.min(1, eff_roll));

// ════════════════════════════════════════════════════════════════════════════
// 4. OUTCOME THRESHOLDS
//    Calibrated so that baseline (no modifiers) gives roughly:
//      JACKPOT      ~4 %   (eff_roll > 0.94)
//      WIN          ~28 %  (0.66 – 0.94)
//      LOSS         ~48 %  (0.18 – 0.66)
//      CRITICAL     ~20 %  (eff_roll < 0.18)
//    Economy shifts these bands meaningfully.
// ════════════════════════════════════════════════════════════════════════════
let payout_mult;

if (eff_roll > 0.94) {
    payout_mult          = 3.0 * inflation_payout_tax;
    Q.gambling_result    = "JACKPOT";
} else if (eff_roll > 0.66) {
    payout_mult          = 1.5 * inflation_payout_tax;
    Q.gambling_result    = "WIN";
} else if (eff_roll > 0.18) {
    payout_mult          = 0;      // lose the bet, nothing extra
    Q.gambling_result    = "LOSS";
} else {
    // Critical loss: house charges "maintenance fees" — scaled to instability
    const penalty_pct    = 0.30 + instability_penalty * 1.5;
    payout_mult          = -penalty_pct;
    Q.gambling_result    = "CRITICAL_LOSS";
}

// ════════════════════════════════════════════════════════════════════════════
// 5. RESOURCE SETTLEMENT
// ════════════════════════════════════════════════════════════════════════════
const net_change     = Math.floor(Q.current_bid * (payout_mult - 1));
Q.resources         += net_change;
Q.last_payout        = net_change;
Q.current_bid        = 0;

// ════════════════════════════════════════════════════════════════════════════
// 6. MACROECONOMIC BLOWBACK
//    The casino floor is part of the economy. Gambling activity has real
//    effects — especially at scale or in extremes.
// ════════════════════════════════════════════════════════════════════════════

// Gambling is consumption spending → demand impulse
Q.demand_impulse = (Q.demand_impulse || 0) + 0.04;

// Capital churn at the tables → minor capital pressure
Q.capital_pressure = (Q.capital_pressure || 0) + 0.015;

// Jackpots create local spending sprees → small additional demand
if (Q.gambling_result === "JACKPOT") {
    Q.demand_impulse  += 0.06;
    Q.distribution_shift = (Q.distribution_shift || 0) + 0.05; // inequality tick
}

// Critical losses = household distress → pulls demand down next cycle
if (Q.gambling_result === "CRITICAL_LOSS") {
    Q.demand_impulse  -= 0.05;
    Q.fiscal_stance   = (Q.fiscal_stance || 0) - 0.02; // pressure on social spending
}

// High-inflation environment: gamblers chase nominal wins, fueling price pressure
if (Q.inflation > 8) {
    Q.price_pressure = (Q.price_pressure || 0) + 0.04;
}

// Depression gambling: people gambling out of desperation → no demand benefit
if (Q.phase === "depression") {
    Q.demand_impulse -= 0.04;   // net zero or negative
}

// Store debug info players can inspect
Q.last_eff_roll      = Math.round(eff_roll * 1000) / 1000;
Q.last_house_edge    = Math.round(house_edge * 1000) / 1000;
Q.last_confidence    = Math.round(confidence * 1000) / 1000;

!}

