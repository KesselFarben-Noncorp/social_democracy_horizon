title: Status
new-page: true
is-special: true

= Status

[+ weeks +], [+ month : month +] [+ year +]

SPD position: [? if spd_toleration : toleration ?][? if spd_in_government : in government - ?][? if spd_toleration == 0 and spd_in_government == 0 and spd_caretaker == 0 : opposition ?][? if spd_caretaker : caretaker government ?]
[? if in_weimar_coalition and spd_in_government: Weimar Coalition ?][? if in_grand_coalition and spd_in_government: Grand Coalition ?][? if in_popular_front and spd_in_government: Popular Front ?][? if in_left_front and spd_in_government: Left Front ?][? if in_spd_majority and spd_in_government: SPD majority ?][? if in_minority_government and spd_in_government: minority government ?][? if in_emergency_government and spd_in_government: emergency government ?]

[? if spd_in_government and not in_spd_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if spd_in_government and (in_left_front or in_popular_front): KPD coalition dissent: [+ kpd_coalition_dissent : coalition_dissent +] ?]

Next election: [+ next_election_month : month +] [+ next_election_year +]

Next presidential election: [+ next_presidential_election_month : month +] [+ next_presidential_election_year +]

= Government

President: [+ president +] ([+ president_party +])

President's relation to government: [+ president_relation +]

[? if president = "Hindenburg": Hindenburg's patience to government: [+ hindenburg_patience +] ?]

Chancellor: [+ chancellor +] ([+ chancellor_party +])

Prussian Minister-President: Vacanted ([+ prussian_government +])

= Other Positions

Reichsbank President: [+ reichsbank_president +]

Reichstag President: [+ reichstag_president +]

= Resources

[? if spd_in_government = 1 : Budget: [+ budget +] ?]

Resources available: [+ resources +]


@politics
on-arrival: {!
Q.pro_republic_disp = Q.pro_republic;
Q.nationalism_disp = Q.nationalism;
Q.socialism_disp = Q.socialism;
Q.pacifism_disp = Q.pacifism;

import { useState } from "react";

const RELATIONSHIP_LEVELS = [
  { label: "Allied", min: 75, color: "#2d6a4f", bg: "#d8f3dc", icon: "★★★" },
  { label: "Friendly", min: 50, color: "#52b788", bg: "#b7e4c7", icon: "★★☆" },
  { label: "Cordial", min: 25, color: "#74c69d", bg: "#d8f3dc", icon: "★☆☆" },
  { label: "Neutral", min: 5, color: "#adb5bd", bg: "#e9ecef", icon: "◆◇◇" },
  { label: "Cool", min: -10, color: "#f4a261", bg: "#fde8d8", icon: "▼◇◇" },
  { label: "Hostile", min: -Infinity, color: "#c1121f", bg: "#ffe5e5", icon: "▼▼▼" },
];

const getLevel = (value) =>
  RELATIONSHIP_LEVELS.find((l) => value >= l.min) || RELATIONSHIP_LEVELS.at(-1);

const PARTIES = [
  { id: "z", name: "Z", full: "Centre Party", relation: 0, ideology: "Catholic Centre" },
  { id: "bvp", name: "BVP", full: "Bavarian People's Party", relation: 0, ideology: "Catholic Conservative" },
  { id: "bb", name: "BB", full: "Bavarian Peasants' Party", relation: 0, ideology: "Agrarian" },
  { id: "csrp", name: "CSRP", full: "Christian Social German Party", relation: 0, ideology: "Christian Social" },
  { id: "ddp", name: "DDP", full: "German Democratic Party", relation: 0, ideology: "Liberal Democracy" },
  { id: "dhp", name: "DHP", full: "German Hannover Party", relation: 0, ideology: "Regional Conservative" },
  { id: "dvp", name: "DVP", full: "German People's Party", relation: 0, ideology: "National Liberal" },
  { id: "wp", name: "WP", full: "Economic Party", relation: 0, ideology: "Agrarian/Mittelstand" },
  { id: "cnbl", name: "CNBL", full: "Christian National Farmers & Landowners", relation: 0, ideology: "Agrarian Conservative" },
  { id: "kpd", name: "KPD", full: "Communist Party of Germany", relation: 0, ideology: "Marxist-Leninist" },
  { id: "dnvp", name: "DNVP", full: "German National People's Party", relation: 0, ideology: "National Conservative" },
  { id: "nsdap", name: "NSDAP", full: "National Socialist German Workers' Party", relation: 0, ideology: "Fascist/Nazi" },
];

const SPECTRUM_COLORS = {
  far_left: "#8b0000",
  left: "#c1121f",
  center_left: "#e07b54",
  center: "#adb5bd",
  center_right: "#4a7c59",
  right: "#2d6a4f",
  far_right: "#1b4332",
};

export default function App() {
  const [parties, setParties] = useState(PARTIES);
  const [hoveredId, setHoveredId] = useState(null);
  const [editMode, setEditMode] = useState(false);

  const sorted = [...parties].sort((a, b) => b.relation - a.relation);

  const maxAbs = Math.max(100, ...parties.map((p) => Math.abs(p.relation)));

  return (
    <div style={{
      minHeight: "100vh",
      background: "#f5f0e8",
      fontFamily: "'IM Fell English', 'Palatino Linotype', Georgia, serif",
      padding: "0",
      color: "#2c1a0e",
    }}>
      <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=IM+Fell+English+SC&display=swap" rel="stylesheet" />

      {/* Header */}
      <div style={{
        background: "#2c1a0e",
        color: "#f5f0e8",
        padding: "24px 32px 20px",
        borderBottom: "4px double #8b6914",
        textAlign: "center",
      }}>
        <div style={{ fontSize: 11, letterSpacing: "0.3em", color: "#c9a84c", marginBottom: 4, fontStyle: "italic" }}>
          SOZIALDEMOKRATISCHE PARTEI DEUTSCHLANDS
        </div>
        <h1 style={{
          margin: 0,
          fontSize: 28,
          fontFamily: "'IM Fell English SC', serif",
          letterSpacing: "0.08em",
          color: "#f5f0e8",
        }}>
          Inter-Party Relations
        </h1>
        <div style={{ fontSize: 11, letterSpacing: "0.2em", color: "#8b6914", marginTop: 6 }}>
          REICHSTAG · WEIMAR REPUBLIC
        </div>
      </div>

      <div style={{ maxWidth: 780, margin: "0 auto", padding: "24px 20px" }}>

        {/* Legend */}
        <div style={{
          display: "flex", flexWrap: "wrap", gap: 8,
          marginBottom: 24,
          justifyContent: "center",
        }}>
          {RELATIONSHIP_LEVELS.map((l) => (
            <div key={l.label} style={{
              display: "flex", alignItems: "center", gap: 6,
              background: l.bg,
              border: `1px solid ${l.color}`,
              borderRadius: 2,
              padding: "3px 10px",
              fontSize: 11,
              letterSpacing: "0.08em",
            }}>
              <div style={{ width: 8, height: 8, borderRadius: "50%", background: l.color }} />
              <span style={{ color: l.color, fontWeight: "bold" }}>{l.label}</span>
            </div>
          ))}
        </div>

        {/* Edit mode toggle */}
        <div style={{ textAlign: "right", marginBottom: 16 }}>
          <button
            onClick={() => setEditMode(!editMode)}
            style={{
              background: editMode ? "#2c1a0e" : "transparent",
              color: editMode ? "#f5f0e8" : "#2c1a0e",
              border: "1px solid #2c1a0e",
              padding: "4px 14px",
              fontSize: 11,
              letterSpacing: "0.1em",
              cursor: "pointer",
              fontFamily: "inherit",
            }}
          >
            {editMode ? "▲ DONE EDITING" : "✎ EDIT VALUES"}
          </button>
        </div>

        {/* Chart */}
        <div style={{
          background: "#fffdf7",
          border: "1px solid #c9a84c",
          borderTop: "4px solid #8b6914",
          padding: "0 0 8px",
        }}>
          {/* Column headers */}
          <div style={{
            display: "grid",
            gridTemplateColumns: "120px 1fr 80px 100px",
            gap: 0,
            padding: "10px 16px 8px",
            borderBottom: "1px solid #e0d5b0",
            fontSize: 10,
            letterSpacing: "0.15em",
            color: "#8b6914",
            fontStyle: "italic",
          }}>
            <div>PARTY</div>
            <div style={{ textAlign: "center" }}>RELATIONSHIP SCALE</div>
            <div style={{ textAlign: "center" }}>VALUE</div>
            <div style={{ textAlign: "center" }}>STATUS</div>
          </div>

          {sorted.map((party, i) => {
            const level = getLevel(party.relation);
            const barPct = (party.relation / maxAbs) * 50; // -50 to +50 % from center
            const isHovered = hoveredId === party.id;

            return (
              <div
                key={party.id}
                onMouseEnter={() => setHoveredId(party.id)}
                onMouseLeave={() => setHoveredId(null)}
                style={{
                  display: "grid",
                  gridTemplateColumns: "120px 1fr 80px 100px",
                  gap: 0,
                  padding: "9px 16px",
                  borderBottom: i < sorted.length - 1 ? "1px solid #f0e8cc" : "none",
                  background: isHovered ? "#faf5e4" : "transparent",
                  transition: "background 0.15s",
                  alignItems: "center",
                }}
              >
                {/* Party name */}
                <div>
                  <div style={{ fontWeight: "bold", fontSize: 14 }}>{party.name}</div>
                  <div style={{ fontSize: 10, color: "#8b7355", fontStyle: "italic", lineHeight: 1.2 }}>
                    {party.full}
                  </div>
                </div>

                {/* Bar */}
                <div style={{ position: "relative", height: 20, margin: "0 12px" }}>
                  {/* Center line */}
                  <div style={{
                    position: "absolute", left: "50%", top: 0, bottom: 0,
                    width: 1, background: "#c9a84c", opacity: 0.5,
                  }} />
                  {/* Track */}
                  <div style={{
                    position: "absolute", top: "50%", left: 0, right: 0,
                    height: 2, background: "#e0d5b0", transform: "translateY(-50%)",
                  }} />
                  {/* Bar fill */}
                  {party.relation !== 0 && (
                    <div style={{
                      position: "absolute",
                      top: "50%",
                      height: 12,
                      transform: "translateY(-50%)",
                      background: level.color,
                      opacity: 0.85,
                      borderRadius: 1,
                      left: party.relation >= 0 ? "50%" : `calc(50% + ${barPct}%)`,
                      width: `${Math.abs(barPct)}%`,
                      transition: "all 0.3s ease",
                    }} />
                  )}
                  {/* Dot at center for zero */}
                  {party.relation === 0 && (
                    <div style={{
                      position: "absolute", left: "50%", top: "50%",
                      width: 8, height: 8, borderRadius: "50%",
                      background: level.color,
                      transform: "translate(-50%, -50%)",
                    }} />
                  )}
                </div>

                {/* Value */}
                <div style={{ textAlign: "center" }}>
                  {editMode ? (
                    <input
                      type="number"
                      value={party.relation}
                      onChange={(e) => {
                        const val = parseInt(e.target.value) || 0;
                        setParties(parties.map((p) =>
                          p.id === party.id ? { ...p, relation: val } : p
                        ));
                      }}
                      style={{
                        width: 60, textAlign: "center",
                        border: "1px solid #c9a84c",
                        background: "#fffdf7",
                        fontFamily: "inherit",
                        fontSize: 13,
                        padding: "2px 4px",
                        color: "#2c1a0e",
                      }}
                    />
                  ) : (
                    <span style={{ fontSize: 15, fontWeight: "bold", color: level.color }}>
                      {party.relation > 0 ? "+" : ""}{party.relation}
                    </span>
                  )}
                </div>

                {/* Status badge */}
                <div style={{ textAlign: "center" }}>
                  <span style={{
                    display: "inline-block",
                    background: level.bg,
                    color: level.color,
                    border: `1px solid ${level.color}`,
                    padding: "2px 8px",
                    fontSize: 10,
                    letterSpacing: "0.08em",
                    borderRadius: 1,
                  }}>
                    {level.label.toUpperCase()}
                  </span>
                </div>
              </div>
            );
          })}
        </div>

        {/* Summary infographic */}
        <div style={{
          marginTop: 24,
          display: "grid",
          gridTemplateColumns: "repeat(auto-fit, minmax(120px, 1fr))",
          gap: 8,
        }}>
          {RELATIONSHIP_LEVELS.map((level) => {
            const count = parties.filter((p) => getLevel(p.relation).label === level.label).length;
            if (count === 0) return null;
            return (
              <div key={level.label} style={{
                background: level.bg,
                border: `1px solid ${level.color}`,
                padding: "10px 12px",
                textAlign: "center",
              }}>
                <div style={{ fontSize: 28, fontWeight: "bold", color: level.color, lineHeight: 1 }}>
                  {count}
                </div>
                <div style={{ fontSize: 10, letterSpacing: "0.12em", color: level.color, marginTop: 4 }}>
                  {level.label.toUpperCase()}
                </div>
              </div>
            );
          })}
        </div>

        <div style={{
          marginTop: 16,
          fontSize: 10,
          color: "#8b7355",
          textAlign: "center",
          fontStyle: "italic",
          letterSpacing: "0.05em",
        }}>
          All values reflect SPD inter-party relations. Click "Edit Values" to update from your game.
        </div>
      </div>
    </div>
  );
}

!}

