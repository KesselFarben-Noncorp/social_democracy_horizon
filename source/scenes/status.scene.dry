@foreign
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(2);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(2);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(2);
}
!}

{!
"<style>
.status-wrap { font-family: Georgia, serif; color: #2b2b2b; max-width: 700px; }
.status-section { margin-bottom: 22px; }
.status-title { font-size: 1.1em; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; border-bottom: 2px solid #6b1414; padding-bottom: 4px; margin-bottom: 8px; color: #6b1414; }
table.status-table { width: 100%; border-collapse: collapse; }
table.status-table td, table.status-table th { padding: 5px 10px; text-align: left; border-bottom: 1px solid #ddd; }
table.status-table tr:nth-child(even) { background-color: #f6f3ee; }
table.status-table td:first-child { font-weight: bold; width: 45%; color: #444; }
</style>

<div class='status-wrap'>

<div class='status-section'>
<div class='status-title'>Government &mdash; Cabinet Composition</div>
<table class='status-table'>
<tr><th>Ministry</th><th>Party (Minister)</th></tr>
<tr><td>Foreign Ministry</td><td>" + foreign_minister_party + " (" + foreign_minister + ")</td></tr>
<tr><td>Interior Ministry</td><td>" + interior_minister_party + " (" + interior_minister + ")</td></tr>
<tr><td>Justice Ministry</td><td>" + justice_minister_party + " (" + justice_minister + ")</td></tr>
<tr><td>Labor Ministry</td><td>" + labor_minister_party + " (" + labor_minister + ")</td></tr>
<tr><td>Economic Ministry</td><td>" + economic_minister_party + " (" + economic_minister + ")</td></tr>
<tr><td>Finance Ministry</td><td>" + finance_minister_party + " (" + finance_minister + ")</td></tr>
<tr><td>Agriculture Ministry</td><td>" + agriculture_minister_party + " (" + agriculture_minister + ")</td></tr>
<tr><td>Transport Ministry</td><td>" + transport_minister_party + " (" + transport_minister + ")</td></tr>
<tr><td>Reichswehr Ministry</td><td>" + reichswehr_minister + "</td></tr>
</table>
</div>

<div class='status-section'>
<div class='status-title'>Relationships</div>
<table class='status-table'>
<tr><th>Nation / Bloc</th><th>Relationship</th></tr>
<tr><td>UK / France</td><td>" + west_relation + "</td></tr>
<tr><td>United Kingdom</td><td>" + britain_relation + "</td></tr>
<tr><td>France</td><td>" + france_relation + "</td></tr>
<tr><td>USSR</td><td>" + soviet_relation + "</td></tr>
<tr><td>Italy</td><td>" + italy_relation + "</td></tr>
<tr><td>Poland</td><td>" + poland_relation + "</td></tr>
<tr><td>Czechoslovakia</td><td>" + czech_relation + "</td></tr>
<tr><td>Hungary</td><td>" + hungary_relation + "</td></tr>
</table>
</div>

" + (eu == 1 ? (
"<div class='status-section'>
<div class='status-title'>European Union Status</div>
<p>Membership of the European Union: Germany, United Kingdom, France, Netherlands, Belgium, Luxembourg, Denmark, Norway, Poland, Czechoslovakia, Romania, Bulgaria, Albania, Yugoslavia" + (austria_victory ? ", Austria" : (austria_peace ? ", Austria." : "")) + "</p>
<p><strong>Leading Thought:</strong> " + (eu_identity == "spinelli" ? "Spinellist Federation" : (eu_identity == "kalergi" ? "Pan European Movement" : (eu_identity == "briand" ? "European Pragmatism" : ""))) + "</p>
</div>"
) : "") + "

<div class='status-section'>
<div class='status-title'>Policies</div>
<table class='status-table'>
<tr><th>Policy Area</th><th>Status</th></tr>
<tr><td>Judiciary Reformation Progress</td><td>" + judicial_reform + (full_reform_initiated ? " &mdash; Judiciary System is fully reformed!" : "") + "</td></tr>
<tr><td>Land Reform Progress</td><td>" + land_reform + (state_buyer ? " &mdash; State Buyer is active!" : "") + "</td></tr>
<tr><td>Welfare Status</td><td>" + welfare + "</td></tr>
<tr><td>Workers Aid Status</td><td>" + workers_aid + "</td></tr>
<tr><td>Pro-Consumer Policies</td><td>" + pro_consumer + "</td></tr>
<tr><td>Agricultural Financial Funding</td><td>" + agricultural_finance + "</td></tr>
<tr><td>Women's Rights</td><td>" + womens_rights + "</td></tr>
<tr><td>Women's Rights in Workplace</td><td>" + womens_work + "</td></tr>
<tr><td>Women's Rights in Family Place</td><td>" + family_law + (abortion_rights ? " &mdash; Abortion rights: " + abortion_rights : "") + "</td></tr>
<tr><td>Trans Rights</td><td>" + trans_rights + "</td></tr>
<tr><td>Homosexual Rights</td><td>" + homosexual_rights + (reformed_183 ? " &mdash; Public display decriminalized (reformed 183rd)" : "") + (repealed_175 ? " &mdash; Homosexual acts decriminalized (175th repealed)" : "") + "</td></tr>
<tr><td>Economic Democratization</td><td>" + economic_democracy + "</td></tr>
<tr><td>Work Councils Progress</td><td>" + works_councils + "</td></tr>
<tr><td>Nationalization Progress</td><td>" + socialization + "</td></tr>
<tr><td>Worker and Consumer Cooperatives</td><td>" + cooperatives + (commonwealth_cooperation > 0 ? " &mdash; Commonwealth Cooperation Progress: " + commonwealth_cooperation : "") + "</td></tr>
</table>
</div>

<div class='status-section'>
<div class='status-title'>Economics</div>
<table class='status-table'>
<tr><th>Metric</th><th>Value</th></tr>
<tr><td>Inflation</td><td>" + inflation_2 + "%</td></tr>
<tr><td>Unemployment</td><td>" + unemployed_2 + "%</td></tr>
<tr><td>Economic Growth</td><td>" + economic_growth_2 + "%</td></tr>
<tr><td>Current Phase</td><td>" + phase + "</td></tr>
</table>
</div>

<div class='status-section'>
<div class='status-title'>Quality of Life</div>
<table class='status-table'>
<tr><th>Group</th><th>QOL</th></tr>
<tr><td>Workers</td><td>" + workers_qol_display + "</td></tr>
<tr><td>Old Middle</td><td>" + old_middle_qol_display + "</td></tr>
<tr><td>Unemployed</td><td>" + unemployed_qol_display + "</td></tr>
<tr><td>New Middle</td><td>" + new_middle_qol_display + "</td></tr>
<tr><td>Rural</td><td>" + rural_qol_display + "</td></tr>
</table>
</div>

<div class='status-section'>
<div class='status-title'>Miscellaneous</div>
<table class='status-table'>
<tr><th>Value</th><th>Amount</th></tr>
<tr><td>Business Unrest Value</td><td>" + capital_strike_progress + "</td></tr>
<tr><td>Coup Progress Value</td><td>" + coup_progress + "</td></tr>
<tr><td>General Strike Value</td><td>" + general_strike_progress + "</td></tr>
<tr><td>Seed</td><td>" + rng_seed + "</td></tr>
</table>
</div>

" + (end == 1 ? "<p><em>This is simply mere end, you mortal.</em></p>" : "") + "
" + (deterministic_mode == 1 ? "<p><em>Deterministic mode on.</em></p>" : "") + "

</div>"
!}


@legis
on-display: {!
document.getElementById('bill-queue-display').innerHTML = Q.bill_list_html || Q.bill_list_text;
!}

