@politics
on-arrival: {!
Q.pro_republic_disp = Q.pro_republic;
Q.nationalism_disp = Q.nationalism;
Q.socialism_disp = Q.socialism;
Q.pacifism_disp = Q.pacifism;

// Display-name overrides for the "Parties" (ideology/leadership) section.
// Original used a hardcoded literal "DDP/DStP" there (not ddp_name).
var partyNameOverrideIdeology = {
    ddp: 'DDP/DStP'
};

// Display-name overrides for the "Inter-party Relations" section.
// Original dynamically used ddp_name (falling back to literal "DDP")
// and dsbp_name (no fallback shown, printed as-is) there instead.
var partyNameOverrideRelations = {
    ddp: Q.ddp_name || 'DDP',
    dsbp: Q.dsbp_name
};

function partyLabelIdeology(p) {
    if (partyNameOverrideIdeology.hasOwnProperty(p)) return partyNameOverrideIdeology[p];
    return p.toUpperCase();
}

function partyLabelRelations(p) {
    if (partyNameOverrideRelations.hasOwnProperty(p)) return partyNameOverrideRelations[p];
    return p.toUpperCase();
}

// --- Build "Parties" ideology/leadership block ---
var ideologyHtml = "";
for (var i = 0; i < Q.parties.length; i++) {
    var p = Q.parties[i];
    var votes = Q[p + '_votes'];
    if (votes !== undefined && votes > 1) {
        var ideology = Q[p + '_ideology'];
        var leader = Q[p + '_party_leader'];
        var label = partyLabelIdeology(p);
        ideologyHtml += label + " Ideology: " + ideology + "<br>" +
                         label + " Leadership: " + leader + "<br><br>";
    }
}
Q.party_ideology_leadership_html = ideologyHtml;

// --- "relationships" qdisplay formatter, ported from relationships.qdisplay.dry ---
// (..5) hostile | (5..14.9) frigid | (14.9..29.9) cold | (29.9..39.9) cool
// (39.9..54.9) neutral | (54.9..64.9) warm | (64.9..74.9) friendly | (74.9..) very friendly
function formatRelationship(val) {
    if (val < 5) return "hostile";
    if (val < 14.9) return "frigid";
    if (val < 29.9) return "cold";
    if (val < 39.9) return "cool";
    if (val < 54.9) return "neutral";
    if (val < 64.9) return "warm";
    if (val < 74.9) return "friendly";
    return "very friendly";
}

// --- Build "Inter-party Relations" block ---
var relationsHtml = "";
for (var i = 0; i < Q.parties.length; i++) {
    var p = Q.parties[i];
    var votes = Q[p + '_votes'];
    if (!(votes > 0)) continue;

    var label = partyLabelRelations(p);

    var rawVal = Q[p + '_relation'];
    var formatted = formatRelationship(rawVal);

    relationsHtml += label + ": " + formatted +
                      (Q.deterministic_mode == 1 ? " " + rawVal : "") +
                      "<br>";
}
Q.party_relations_html = relationsHtml;
!}

