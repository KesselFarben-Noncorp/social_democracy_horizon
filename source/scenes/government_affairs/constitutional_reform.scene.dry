@ban_kpd_menu
on-arrival: {!
    Q.ban_support = 0;

    // SPD support depends heavily on internal balance
    if (Q.reformist_strength >= 60 && Q.kpd_relation < 40) {
        Q.ban_support += Q.spd_normalized * 0.8;
    } else if (Q.reformist_strength >= 45 && Q.kpd_relation < 30) {
        Q.ban_support += Q.spd_normalized * 0.5;
    }
    // Left wing or good KPD relations means SPD blocks this entirely

    if (Q.z_relation >= 60) {
        Q.ban_support += Q.z_normalized;
    }
    if (Q.ddp_relation >= 50 && Q.kpd_relation < 30) {
        Q.ban_support += Q.ddp_normalized * 0.6;
    }
    if (Q.dvp_relation >= 55) {
        Q.ban_support += Q.dvp_normalized;
    }
    if (Q.dnvp_line === 1 && Q.dnvp_relation >= 40) {
        Q.ban_support += Q.dnvp_normalized * 0.7;
    }
    if (Q.srpd_formed && Q.srpd_relation >= 50) {
        Q.ban_support += Q.srpd_normalized * 0.5;
    }

    Q.ban_threshold = 0.55;
    if (Q.pro_republic < 65) Q.ban_threshold = 0.62;

    // Left wing blocks regardless
    Q.can_ban_kpd = (Q.ban_support >= Q.ban_threshold
                     && Q.left_strength < 40
                     && Q.kpd_relation < 50) ? 1 : 0;
!}

