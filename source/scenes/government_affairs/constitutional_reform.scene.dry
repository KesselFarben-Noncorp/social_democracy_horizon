@ban_kpd_menu
go-to: kpd_ban_check

Should we initiate proceedings to ban the KPD?

@kpd_ban_check
on-arrival: {!
    Q.ban_support = 0;
    Q.evidence_strength = 0;
    
    // Evidence
    if (Q.rfb_banned == 0 && Q.rfb_strength > 100) {
        Q.evidence_strength += 3;
    }
    if (Q.kpd_party_leader === "Thälmann") {
        Q.evidence_strength += 2; // Moscow-directed
    }
    if (Q.communist_coup_seen || Q.red_rising_seen) {
        Q.evidence_strength += 4;
    }
    if (Q.rfb_militancy >= 0.5) {
        Q.evidence_strength += 2;
    }
    
    // Support - much harder to get
    if (Q.z_relation >= 60) {
        Q.ban_support += Q.z_normalized;
    }
    
    if (Q.ddp_relation >= 50 && Q.kpd_relation < 30) {
        Q.ban_support += Q.ddp_normalized * 0.6;
    }
    
    if (Q.dvp_relation >= 55) {
        Q.ban_support += Q.dvp_normalized;
    }
    
    if (Q.dnvp_line === 1 && Q.dnvp_relation >= 40) {
        Q.ban_support += Q.dnvp_normalized * 0.7;
    }
    
    // SPD support depends on internal balance
    if (Q.reformist_strength >= 60 && Q.kpd_relation < 40) {
        Q.ban_support += Q.spd_normalized * 0.8;
    } else if (Q.reformist_strength >= 45 && Q.kpd_relation < 30) {
        Q.ban_support += Q.spd_normalized * 0.5;
    }
    // If left-wing or good KPD relations, SPD blocks this
    
    Q.ban_threshold = 0.55;
    if (Q.pro_republic < 65) {
        Q.ban_threshold = 0.62;
    }
    
    Q.can_ban_kpd = (Q.evidence_strength >= 6 && Q.ban_support >= Q.ban_threshold);
!}

