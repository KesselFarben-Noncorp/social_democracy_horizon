title: Post Event
new-page: true
on-arrival: {!

// === ACHIEVEMENT CHECKS (tick scene, on-arrival) ===

// Conservative Revolution
if (Q.dnvp_votes >= 20 && !Q._ach_konservolution_shown) {
    this.achieve('konservolution');
    Q._ach_konservolution_shown = 1;
}

// National Breakthrough
if (Q.nsdap_votes >= 30 && !Q._ach_durchbruch_shown) {
    this.achieve('durchbruch');
    Q._ach_durchbruch_shown = 1;
}

// KPD surge
if (Q.kpd_votes >= 28 && !Q._ach_oktobersturm_shown) {
    this.achieve('oktobersturm');
    Q._ach_oktobersturm_shown = 1;
}

function _mkrng(seed) {
    let s = seed >>> 0;
    return function() {
        s += 0x6d2b79f5;
        let t = Math.imul(s ^ (s >>> 15), 1 | s);
        t ^= t + Math.imul(t ^ (t >>> 7), 61 | t);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
}

// Derive a per-tick RNG from the fixed seed + tick counter
// Same seed + same tick = identical results every time
const _r = _mkrng((Q.rng_seed + Q.tick * 0x9e3779b9) >>> 0);

Q.random_factor = function(f, variance = 0.65) {
    return f * (1 - variance / 2 + _r() * variance);
};





if (Q.dvp_left - Q.dvp_right > 10) {
   Q.dvp_ideology = "National Liberalism (Left)"
} else if (Q.dvp_left - Q.dvp_right < -10) {
   Q.dvp_ideology = "National Liberalism (Right)"
} else {
   Q.dvp_ideology = "National Liberalism"
}

// QOL. REMOVES PHANTON PARTIES.

const inGov = Object.keys(Q)
  .filter(key => key.endsWith("_in_government") && Q[key] == 1)
  .map(key => key.replace("_in_government", ""))
  .filter(party => (Q[party + "_votes"] > 0) && (Q[party + "_r"] > 0))
  .map(party => party.toUpperCase());

Q.parties_in_government_display = inGov.length > 0
  ? inGov.join(", ")
  : "None";

// UPDATE PARTY RELATIONSHIPS EACH TIME.

function updatePartyRelations() {
    // 1. Direct mappings to variables that events already alter
    Q.party_relations.KPD.SPD   = Q.kpd_relation;
    Q.party_relations.KPD.SRPD  = Q.kpd_relation + 5;
    Q.party_relations.SPD.KPD   = Q.kpd_relation;
    Q.party_relations.SPD.DDP   = Q.ddp_relation;
    Q.party_relations.SPD.Z     = Q.z_relation;
    Q.party_relations.SPD.DVP   = Q.dvp_relation;
    Q.party_relations.SPD.CSRP  = Q.csrp_relation;
    Q.party_relations.SPD.DNVP  = Q.dnvp_relation;
    Q.party_relations.SPD.KVP   = Q.kvp_relation;
    Q.party_relations.SPD.DHP   = Q.dhp_relation;
    Q.party_relations.SPD.BB    = Q.bb_relation;
    Q.party_relations.SPD.DVFP  = Q.dvfp_relation;
    Q.party_relations.SRPD.KPD  = Q.kpd_relation - 10;
    Q.party_relations.SRPD.DDP  = Q.ddp_relation + 10;
    Q.party_relations.SRPD.Z    = Q.z_relation + 5;
    Q.party_relations.DDP.SPD   = Q.ddp_relation;
    Q.party_relations.DDP.SRPD  = Q.ddp_relation + 10;
    Q.party_relations.Z.SPD     = Q.z_relation;
    Q.party_relations.Z.SRPD    = Q.z_relation + 5;
    Q.party_relations.CSRP.SPD  = Q.csrp_relation;
    Q.party_relations.CSRP.SRPD = Q.csrp_relation + 5;
    Q.party_relations.DNVP.SPD  = Q.dnvp_relation;
    Q.party_relations.DNVP.SRPD = Q.dnvp_relation - 5;
    Q.party_relations.DVFP.SPD  = Q.dvfp_relation;
    Q.party_relations.VRP.SPD   = Q.vrp_relation;
    Q.party_relations.ASPD.KPD  = Q.kpd_relation - 10;
    Q.party_relations.ASPD.DDP  = Q.ddp_relation + 5;
    Q.party_relations.ASPD.Z    = Q.z_relation;
    Q.party_relations.ASPD.DVP  = Q.dvp_relation + 10;

    // 2. Re-evaluate Booleans for Coalition Blocks based on the live numbers
    Q.coalition_blocks = {
        DBP_KPD:   true,
        DBP_SAPD:  true,
        DBP_NSDAP: true,
        DBP_DVFP:  true,
        DBP_DTSP:  true,
        DBP_CNBL:  false,
        DBP_BB:    false,
        
        KPD_Z:     Q.party_relations.Z.SPD < 65 || Q.kpd_relation < 65,
        KPD_BVP:   true,
        KPD_DVP:   true,
        KPD_WP:    true,
        KPD_CNBL:  true,
        KPD_DNVP:  true,
        KPD_NSDAP: true,
        KPD_DVFP:  true,
        KPD_VRP:   true,
        KPD_DDP:   Q.kpd_relation < 65,
        KPD_SPD:   Q.communist_coalition < 3,

        SAPD_DVP:   true,
        SAPD_WP:    true,
        SAPD_CNBL:  true,
        SAPD_DNVP:  true,
        SAPD_NSDAP: true,
        SAPD_VRP:   true,

        SPD_NSDAP: true,
        SPD_DNVP:  Q.dnvp_relation < 60 || Q.dnvp_line === 3,
        SPD_KPD:   Q.communist_coalition < 3,
        SPD_VRP:   Q.vrp_relation < 35,

        SRPD_KPD:   Q.kpd_relation < 40,
        SRPD_NSDAP: true,
        SRPD_DNVP:  Q.dnvp_line === 3,
        SRPD_VRP:   Q.vrp_relation < 30,

        DDP_KPD:   true,
        DDP_NSDAP: true,
        DDP_DNVP:  Q.dnvp_line === 3,

        Z_KPD:    Q.kpd_relation < 65 || Q.z_relation < 45,
        Z_NSDAP:  Q.nazi_urgency >= 6,
        Z_DNVP:   Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",

        BVP_KPD:   true,
        BVP_SAPD:  true,
        BVP_NSDAP: Q.nazi_urgency >= 6,

        DVP_KPD:   true,
        DVP_SAPD:  true,
        DVP_NSDAP: Q.nazi_urgency >= 7 && Q.capital_strike_progress < 4,
        DVP_VRP:   Q.dvp_right_shift >= 2,

