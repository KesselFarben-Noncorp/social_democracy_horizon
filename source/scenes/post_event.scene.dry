title: Post Event
new-page: true
on-arrival: {!

// === ACHIEVEMENT CHECKS (tick scene, on-arrival) ===

function _mkrng(seed) {
    let s = seed >>> 0;
    return function() {
        s += 0x6d2b79f5;
        let t = Math.imul(s ^ (s >>> 15), 1 | s);
        t ^= t + Math.imul(t ^ (t >>> 7), 61 | t);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
}

// Derive a per-tick RNG from the fixed seed + tick counter
// Same seed + same tick = identical results every time
const _r = _mkrng((Q.rng_seed + Q.tick * 0x9e3779b9) >>> 0);

Q.random_factor = function(f, variance = 0.65) {
    return f * (1 - variance / 2 + _r() * variance);
};


if (Q.inverted_ideos != 1) {

// ============================================================
// AUTO IDEOLOGY SCORER — derives 1 (far-left) to 10 (far-right)

const IDEO_KEYWORDS = [
    // 0 — revolutionary / Leninist left
    [/marxism-leninism/i,                 1],
    [/council communism/i,                0],

    // 2 — revolutionary but non-Leninist / left socialist
    [/revolutionary socialism/i,          2],
    [/left-wing socialism/i,              3],

    // 5 — mainstream social democracy
    [/social democracy/i,                 6],
    [/social republicanism/i,             7],

    // 7 — right social democracy / soft-left liberal
    [/right-wing social democracy/i,      7],

    // 10 — center / centrist liberal / cross-class Christian
    [/social liberalism/i,                10],
    [/christian socialism/i,              6],  // Moved "a bit left" from center (10)
    [/catholic tent/i,                    12],
    [/middle-class interest/i,            13],

    // 13 — moderate conservative / regional Catholic conservative
    [/bavarian conservatism/i,            13],
    [/protestant social conservatism/i,   13],
    [/moderate conservatism/i,            14],
    [/liberal agrarianism/i,              12],

    // 15 — national liberal / agrarian-liberal right-center
    [/national liberalism/i,              15],
    [/hanoverian agrarianism/i,           15],
    [/hanseatic agrarian conservatism/i,  15],

    // 17 — hard agrarian conservative
    [/agrarian conservatism/i,            17],

    // 18 — national conservative
    [/national conservatism/i,            18],

    // 20 — far-right nationalist / völkisch / Nazi
    [/national socialism/i,               20],
    [/völkisch nationalism/i,             20],
    [/völkisch liberalism/i,              16],  // Moved "a lot left" from its old right-wing spot
];

function ideoScore(ideologyString) {
    if (!ideologyString) return 10; // Fallback to absolute center (10)
    for (const [pattern, score] of IDEO_KEYWORDS) {
        if (pattern.test(ideologyString)) return score;
    }
    return 10; // Unrecognized ideology string -> treat as centrist/unknown
}

// Apply to every active party, reading straight from Q.[party]_ideology
for (const p of Q.parties) {
    const key = p + '_ideology';
    Q[p + '_ideo_score'] = ideoScore(Q[key]);
}

// Also cover parties tracked outside Q.parties but referenced in
// party_relations / coalition_blocks (splinters, KPO, LB, etc.)
const EXTRA_IDEO_PARTIES = [
    'kpo', 'sl', 'sapd', 'srpd', 'ddp', 'z', 'bvp', 'csrp', 'dvp', 'wp',
    'cnbl', 'csvd', 'dnvp', 'vrp', 'kvp', 'dhp', 'bb', 'dvfp',
    'aspd', 'vnr', 'hl', 'lb', 'rdp', 'cvp', 'sls', 'dtsp', 'dbp', 'dsbp', 'dnf', 'rlb', 'faud', 'kapd'
];
for (const p of EXTRA_IDEO_PARTIES) {
    const key = p + '_ideology';
    if (Q[key] !== undefined) {
        Q[p + '_ideo_score'] = ideoScore(Q[key]);
    }
}

}



// REMOVE DUPLICATES 

Q.parties = [...new Set(Q.parties)];


// CODE EXAMPLE FOR REMOVING Tolerator...
// Q.tolerating_parties = Q.tolerating_parties.filter(function(p) { return p !== 'DVP'; });
// Q.dvp_tolerating = 0;

// QOL. TRACK GOVERNMENT VOTES.

// ============================================
// GOVERNMENT VOTE/SEAT TRACKER
// ============================================
Q.government_total_votes = 0;

for (var i = 0; i < Q.parties.length; i++) {
    var p = Q.parties[i];
    if (Q[p + '_in_government'] === 1) {
        Q.government_total_votes += Q[p + '_r'] || 0;
    }
}

Q.government_total_votes = Math.round(Q.government_total_votes * 10) / 10;


// ============================================
// CONSTITUTIONAL SUPERMAJORITY CHECK (2/3)
// ============================================
Q.has_supermajority = (Q.government_effective_pct >= 66.7) ? 1 : 0;



// ============================================
// GOVERNMENT COLLAPSE CHECK
// ============================================

var gov_count = 0;
for (var i = 0; i < Q.parties.length; i++) {
    if (Q[Q.parties[i] + '_in_government'] === 1) gov_count++;
}

if (gov_count > 0) {
    var effective_votes = Q.government_total_votes;

    if (Q.tolerating_parties) {
        for (var i = 0; i < Q.tolerating_parties.length; i++) {
            var tp = Q.tolerating_parties[i].toLowerCase();
            if (Q[tp + '_in_government'] !== 1) {
                effective_votes += Q[tp + '_r'] || 0;
            }
        }
    }

    Q.government_effective_pct = Math.round(effective_votes * 10) / 10;

    if (effective_votes < 50) {
        Q.government_collapsed = 1;
        Q.next_election_year = Q.year;
        Q.next_election_month = Q.month + 2;
        if (Q.next_election_month > 12) {
            Q.next_election_month = 1;
            Q.next_election_year += 1;
        }
        for (var i = 0; i < Q.parties.length; i++) {
            Q[Q.parties[i] + '_in_government'] = 0;
        }
        Q.government_parties = [];
        Q.tolerating_parties = [];
        Q.spd_toleration = 0;
        Q.is_minority_government = 0;
    }
}


// QOL. REMOVES PHANTON PARTIES.

const inGov = Object.keys(Q)
  .filter(key => key.endsWith("_in_government") && Q[key] == 1)
  .map(key => key.replace("_in_government", ""))
  .filter(party => (Q[party + "_votes"] > 0) && (Q[party + "_r"] > 0))
  .map(party => party.toUpperCase());

Q.parties_in_government_display = inGov.length > 0
  ? inGov.join(", ")
  : "None";



// === PARTY RELATION GRAVITY ===
Q.relation_gravity = function(value) {
    var abs = Math.abs(value);
    if (abs <= 80) return value;
    var pull = (abs - 80) * 0.04;
    return value > 0 ? value - pull : value + pull;
};

for (var i = 0; i < Q.parties.length; i++) {
    var p = Q.parties[i];
    Q[p + '_relation'] = Q.relation_gravity(Q[p + '_relation'] || 0);
    if (!Q.math_broken) {
        Q[p + '_relation'] = Math.max(-100, Math.min(100, Q[p + '_relation']));
    } else {
        Q[p + '_relation'] = Q.impossible_add(Q[p + '_relation'], 0);
    }
}

// === CHECK FOR LOW-RELATION COALITION PARTNER ===
Q.coalition_low_relation = 0;

// Check full government parties (threshold: <= 30)
for (var i = 0; i < Q.parties.length; i++) {
    var p = Q.parties[i];
    if (p === "spd") continue;
    if (Q[p + '_in_government'] === 1 && Q[p + '_relation'] <= 30) {
        Q.coalition_low_relation = 1;
        break;
    }
}

// Check tolerating parties (threshold: <= 20), only if not already triggered
if (!Q.coalition_low_relation && Q.tolerating_parties) {
    for (var i = 0; i < Q.tolerating_parties.length; i++) {
        var tp = Q.tolerating_parties[i].toLowerCase();
        if (tp === "spd") continue;
        if (Q[tp + '_relation'] <= 20) {
            Q.coalition_low_relation = 1;
            break;
        }
    }
}


// === CHECK FOR LOW-RELATION COALITION PARTNER ===
Q.coalition_mid_relation = 0;
Q.mad_party = "";
Q.mad_party_key = "";
var lowest_relation = 999;

for (var i = 0; i < Q.parties.length; i++) {
    var p = Q.parties[i];
    if (p === "spd") continue;
    if (Q[p + '_in_government'] === 1 && Q[p + '_relation'] < 45 && Q[p + '_relation'] < lowest_relation) {
        Q.coalition_mid_relation = 1;
        Q.mad_party = p.toUpperCase();
        Q.mad_party_key = p;
        lowest_relation = Q[p + '_relation'];
    }
}





// === MINISTRY REASSIGNMENT (runs every tick) ===
var portfolios = ["foreign_minister", "interior_minister", "justice_minister", "labor_minister",
                   "economic_minister", "finance_minister", "agriculture_minister", "transport_minister"];

for (var i = 0; i < portfolios.length; i++) {
    var port = portfolios[i];
    var partyField = port + "_party";
    var currentParty = (Q[partyField] || "").toLowerCase();

    // If held party isn't in government anymore, reassign
    if (Q[currentParty + '_in_government'] !== 1) {
        // Find the largest remaining government party by seat share
        var bestParty = "";
        var bestVotes = -1;
        for (var j = 0; j < Q.parties.length; j++) {
            var p = Q.parties[j];
            if (Q[p + '_in_government'] === 1 && (Q[p + '_r'] || 0) > bestVotes) {
                bestVotes = Q[p + '_r'] || 0;
                bestParty = p;
            }
        }

        if (bestParty !== "") {
            Q[partyField] = bestParty.toUpperCase();
            Q[port] = (Q.ministry_roster[bestParty] && Q.ministry_roster[bestParty][port]) || 0;
        }
    }
}

// === MINISTER NAME / PARTY CONSISTENCY CHECK ===
// Ensures the displayed minister name always matches the party
// currently holding that portfolio. Catches any drift caused by
// party-field changes that happen outside the reassignment loop above
// (e.g. a death, resignation, or manual Q.<port>_party edit elsewhere).

if (!Q.minister_name_table) {
    Q.minister_name_table = {
        foreign_minister:     { KPD:'Pieck', SAPD:'Rosenfeld', SPD:'Breitscheid', SRPD:'Breitscheid', DDP:'Koch-Weser', Z:'Curtius', BVP:'Held', DVP:'Stresemann', WP:'Lambach', CNBL:'Hepp', DNVP:'Westarp' },
        interior_minister:    { KPD:'Ulbricht', SAPD:'Seydewitz', SPD:'Severing', SRPD:'Braun', DDP:'Koch-Weser', Z:'Wirth', BVP:'Schätzel', DVP:'Scholz', WP:'Petersen', CNBL:'Behrens', DNVP:'Hergt' },
        justice_minister:     { KPD:'Heckert', SAPD:'Ledebour', SPD:'Radbruch', SRPD:'Heilmann', DDP:'Koch-Weser', Z:'Bredt', BVP:'Gürtner', DVP:'Heinze', WP:'Drewitz', CNBL:'von Rohr', DNVP:'Schiele' },
        labor_minister:       { KPD:'Münzenberg', SAPD:'Seydewitz', SPD:'Wissell', SRPD:'Aufhäuser', DDP:'Dietrich', Z:'Stegerwald', BVP:'Stützel', DVP:'Brauns', WP:'Petersen', CNBL:'Lohse', DNVP:'Schiele' },
        economic_minister:    { KPD:'Remmele', SAPD:'Rosenfeld', SPD:'Hilferding', SRPD:'Schmidt', DDP:'Dietrich', Z:'Bredt', BVP:'Held', DVP:'Curtius', WP:'Lambach', CNBL:'Heim', DNVP:'Schiele' },
        finance_minister:     { KPD:'Neumann', SAPD:'Rosenfeld', SPD:'Hilferding', SRPD:'Hilferding', DDP:'Dietrich', Z:'Köhler', BVP:'Krausneck', DVP:'Moldenhauer', WP:'Drewitz', CNBL:'Hepp', DNVP:'Schiele' },
        agriculture_minister: { KPD:'Hoernle', SAPD:'Baade', SPD:'Baade', SRPD:'Baade', DDP:'Dietrich', Z:'Hermes', BVP:'Wutzlhofer', DVP:'Schiele', WP:'Bredt', CNBL:'Hamkens', DNVP:'Schiele' },
        transport_minister:   { KPD:'Hoernle', SAPD:'Baade', SPD:'Baade', SRPD:'Baade', DDP:'Dietrich', Z:'Guerard', BVP:'Wutzlhofer', DVP:'Schiele', WP:'Bredt', CNBL:'Hamkens', DNVP:'Schiele' }
    };
}

for (var i = 0; i < portfolios.length; i++) {
    var port = portfolios[i];
    var party = (Q[port + '_party'] || '').toUpperCase();

    var expectedName = (Q.minister_name_table[port] && Q.minister_name_table[port][party]) || 'Unbesetzt';

    // Special case: Stresemann's death reassigns the DVP foreign minister slot to Curtius
    if (port === 'foreign_minister' && party === 'DVP' && Q.stresemann_dead) {
        expectedName = 'Curtius';
    }

    if (Q[port] !== expectedName) {
        Q[port] = expectedName;
    }
}








// UPDATE PARTY RELATIONSHIPS EACH TIME.

function updatePartyRelations() {
    // 1. Direct mappings to variables that events already alter
    Q.party_relations.KPD.SPD   = Q.kpd_relation;
    Q.party_relations.KPD.SRPD  = Q.kpd_relation + 5;
    Q.party_relations.SPD.KPD   = Q.kpd_relation;
    Q.party_relations.SPD.DDP   = Q.ddp_relation;
    Q.party_relations.SPD.Z     = Q.z_relation;
    Q.party_relations.SPD.DVP   = Q.dvp_relation;
    Q.party_relations.SPD.CSRP  = Q.csrp_relation;
    Q.party_relations.SPD.DNVP  = Q.dnvp_relation;
    Q.party_relations.SPD.KVP   = Q.kvp_relation;
    Q.party_relations.SPD.DHP   = Q.dhp_relation;
    Q.party_relations.SPD.BB    = Q.bb_relation;
    Q.party_relations.SPD.DVFP  = Q.dvfp_relation;
    Q.party_relations.SPD.BVP  =  Q.bvp_relation;
    Q.party_relations.SRPD.KPD  = Q.kpd_relation - 10;
    Q.party_relations.SRPD.DDP  = Q.ddp_relation + 10;
    Q.party_relations.SRPD.Z    = Q.z_relation + 5;
    Q.party_relations.DDP.SPD   = Q.ddp_relation;
    Q.party_relations.DDP.SRPD  = Q.ddp_relation + 10;
    Q.party_relations.Z.SPD     = Q.z_relation;
    Q.party_relations.Z.SRPD    = Q.z_relation + 5;
    Q.party_relations.CSRP.SPD  = Q.csrp_relation;
    Q.party_relations.CSRP.SRPD = Q.csrp_relation + 5;
    Q.party_relations.DNVP.SPD  = Q.dnvp_relation;
    Q.party_relations.DNVP.SRPD = Q.dnvp_relation - 5;
    Q.party_relations.DVFP.SPD  = Q.dvfp_relation;
    Q.party_relations.VRP.SPD   = Q.vrp_relation;
    Q.party_relations.ASPD.KPD  = Q.kpd_relation - 10;
    Q.party_relations.ASPD.DDP  = Q.ddp_relation + 5;
    Q.party_relations.ASPD.Z    = Q.z_relation;
    Q.party_relations.ASPD.DVP  = Q.dvp_relation + 10;

    // 2. Re-evaluate Booleans for Coalition Blocks based on the live numbers
    Q.coalition_blocks = {
        DBP_KPD:   true,
        DBP_SAPD:  true,
        DBP_NSDAP: true,
        DBP_DVFP:  true,
        DBP_DTSP:  true,
        DBP_CNBL:  false,
        DBP_BB:    false,
        
        KPD_Z:     Q.party_relations.Z.SPD < 65 || Q.kpd_relation < 65,
        KPD_BVP:   true,
        KPD_DVP:   true,
        KPD_WP:    true,
        KPD_CNBL:  true,
        KPD_DNVP:  true,
        KPD_NSDAP: true,
        KPD_DVFP:  true,
        KPD_VRP:   true,
        KPD_DDP:   Q.kpd_relation < 65,
        KPD_SPD:   Q.communist_coalition < 3,

        SAPD_DVP:   true,
        SAPD_WP:    true,
        SAPD_CNBL:  true,
        SAPD_DNVP:  true,
        SAPD_NSDAP: true,
        SAPD_VRP:   true,

        SPD_NSDAP: true,
        SPD_DNVP:  Q.dnvp_relation < 60 || Q.dnvp_line === 3,
        SPD_KPD:   Q.communist_coalition < 3,
        SPD_VRP:   Q.vrp_relation < 35,

        SRPD_KPD:   Q.kpd_relation < 40,
        SRPD_NSDAP: true,
        SRPD_DNVP:  Q.dnvp_line === 3,
        SRPD_VRP:   Q.vrp_relation < 30,

        DDP_KPD:   true,
        DDP_NSDAP: true,
        DDP_DNVP:  Q.dnvp_line === 3,

        Z_KPD:    Q.kpd_relation < 65 || Q.z_relation < 45,
        Z_NSDAP:  Q.nazi_urgency >= 6,
        Z_DNVP:   Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",

        BVP_KPD:   true,
        BVP_SAPD:  true,
        BVP_NSDAP: Q.nazi_urgency >= 6,

        DVP_KPD:   true,
        DVP_SAPD:  true,
        DVP_NSDAP: Q.nazi_urgency >= 7 && Q.capital_strike_progress < 4,
        DVP_VRP:   Q.dvp_right_shift >= 2,

        WP_KPD:   true,
        WP_SAPD:  true,
        WP_NSDAP: Q.capital_strike_progress < 5,
        WP_VRP:   true,

        CNBL_KPD:  true,
        CNBL_SAPD: true,
        CNBL_SPD:  Q.party_relations.CNBL.SPD < 30,

        DNVP_KPD:  true,
        DNVP_SAPD: true,
        DNVP_SPD:  Q.dnvp_line === 3 || Q.dnvp_relation < 40,
        DNVP_DDP:  Q.dnvp_line === 3,
        DNVP_Z:    Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
        DNVP_VRP:  Q.dnvp_line === 3,

        NSDAP_KPD:                  true,
        NSDAP_DBP:                  true,
        NSDAP_SPD:                  true,
        NSDAP_SAPD:                 true,
        NSDAP_SRPD:                 true,
        NSDAP_DDP:                  true,
        NSDAP_CSRP:                 true,
        NSDAP_VRP:                  true,
        NSDAP_BVP:                  Q.nazi_urgency >= 6,
        NSDAP_Z:                    Q.nazi_urgency >= 6,
        NSDAP_COALITIONS_GENERALLY: Q.nsdap_r < 35 || Q.year < 1932,

        VRP_KPD:   true,
        VRP_SAPD:  true,
        VRP_WP:    true,
        VRP_NSDAP: true,
        VRP_DNVP:  Q.dnvp_line === 3,
        VRP_DVP:   Q.dvp_right_shift >= 1,
        VRP_SPD:   Q.vrp_relation < 35,

        KVP_KPD:   true,
        KVP_SAPD:  true,
        KVP_NSDAP: true,
        KVP_DNVP:  Q.dnvp_line === 3,
        KVP_SPD:   false,

        DHP_KPD:   true,
        DHP_SAPD:  true,
        DHP_NSDAP: Q.nazi_urgency >= 5,

        BB_KPD:   true,
        BB_SAPD:  true,
        BB_NSDAP: Q.nazi_urgency >= 7,
        BB_WP:    false,
        BB_DVP:   true,

        LB_KPD:    false,
        LB_SPD:    Q.party_relations.LB.SPD < 30,
        LB_NSDAP:  true,
        LB_DNVP:   true,
        LB_DVP:    true,
        LB_WP:     true,
        LB_CNBL:   true,
        LB_DVFP:   true,
        LB_DTSP:   true,

        RDP_KPD:   true,
        RDP_NSDAP: true,
        RDP_DVFP:  true,
        RDP_DTSP:  true,
        RDP_DNVP:  Q.dnvp_line === 3,

        CVP_KPD:   true,
        CVP_SAPD:  true,
        CVP_NSDAP: true,
        CVP_DVFP:  true,
        CVP_DTSP:  true,
        CVP_SPD:   Q.z_in_government && Q.spd_in_government,

        SLS_KPD:   true,
        SLS_NSDAP: true,
        SLS_DVFP:  true,
        SLS_DTSP:  true,
        SLS_DNVP:  Q.dnvp_line === 3,

        DTSP_KPD:   true,
        DTSP_SAPD:  true,
        DTSP_SPD:   true,
        DTSP_SRPD:  true,
        DTSP_DDP:   true,
        DTSP_Z:     true,
        DTSP_BVP:   true,
        DTSP_CSRP:  true,
        DTSP_LB:    true,
        DTSP_RDP:   true,
        DTSP_SLS:   true,
        DTSP_CVP:   true,
        DTSP_DBP:   true,

        DVFP_DBP:   true,
    };
}

updatePartyRelations();



































Q.last_advisor_action = 0;
Q.last_cabinet_action = 0;
// make sure no stat is below 0.

// 1. update dates
if (Q.month_actions >= 1) {
    Q.time += 1;
    Q.month_actions = 0;
    Q.ma = 1;
    console.log(Q.month);
    console.log(Q.time);
    
    // Advance by 2 weeks
    Q.weeks = (Q.weeks || 0) + 2;
    
    // Roll over to next month when 4+ weeks pass
    if (Q.weeks >= 4) {
        Q.weeks -= 4;
        Q.month += 1;
        
        if (Q.month >= 13) {
            Q.month = 1;
            Q.year += 1;
            if (Q.historical_mode) {
                Q.resources += 2;
            }
        }
    }
    
    // decrement timers
    for (timer of Q.timers) {
        if (Q[timer+'_timer'] && Q[timer+'_timer'] > 0) {
            Q[timer+'_timer'] -= 1;
        }
    }





// DNVP GAMEPLAY

if (Q.lambach_exile == 1) {
    Q.hugenberg_momentum += 3.6;
    Q.delegate_power_christsoc -= 1.4;   // DHV wing bleeds most
    Q.delegate_power_yocon -= 0.6;
    Q.delegate_power_b -= 1.0;
} else if (Q.lambach_reinstated == 1) {
    Q.hugenberg_momentum += 1.6;
    Q.delegate_power_a += 1.0;
    Q.delegate_power_christsoc += 0.4;
    Q.delegate_power_yocon += 0.2;
} else if (Q.lambach_exile == 0) {
    Q.delegate_power_christsoc += 5.6; // DHV vindicated
    Q.delegate_power_yocon += 2.0;
} else {
    Q.hugenberg_momentum += 2.0;
}

if (Q.cnbl_crisis == 1) {
    Q.hugenberg_momentum += 4.0;
} else {
    Q.delegate_power_b += 2.0;
    Q.delegate_power_yocon += 0.8;
    Q.delegate_power_christsoc += 0.5;
}

if (Q.vnr_momentum == 0) {
    Q.delegate_power_yocon += 0.5;    
    Q.delegate_power_christsoc += 1.4;
    Q.delegate_power_a += 0.5;
} else {
    Q.delegate_power_b += 2.0;
    Q.hugenberg_momentum += 3.0;
}

if (Q.geest_wildfire == 0) {
    Q.delegate_power_yocon += 1.3;
    Q.delegate_power_christsoc += 1.2;
    Q.delegate_power_a += 1.8;
    Q.delegate_power_b += 1.1;
    Q.hugenberg_momentum -= 1.2;
} else {
    Q.hugenberg_momentum += 5.0;
    Q.delegate_power_yocon += 1.5;    // split the old +10 to c
    Q.delegate_power_christsoc += 1.1;
    Q.delegate_power_a += 0.3;
    Q.delegate_power_b -= 1.0;
}

// 3b. Media Dominance Check
if (Q.commercialized_media >= 1 || Q.radio >= 1) {
    Q.hugenberg_momentum -= 2.0;
}

// Media beating

if (Q.hugenberg_media_attack >= 1 ) {
    Q.hugenberg_momentum -= 10.0;
}

// 3c. Land Reform Threat
if (Q.land_reform > 0) {
    Q.hugenberg_momentum += 4.0 * Q.land_reform;
}

// 3d. Government Participation Bonus
if (Q.dnvp_in_government) {
    Q.delegate_power_a += 4.0;
    Q.delegate_power_b += 2.0;
    Q.delegate_power_yocon += 2.2;
    Q.delegate_power_christsoc += 1.8;
}

if (Q.ideology == "reformist") {
    Q.delegate_power_a -= 0.3;
    Q.delegate_power_b -= 0.3;
    Q.delegate_power_yocon -= 0.1;
    Q.delegate_power_christsoc += 0.8;
    Q.hugenberg_momentum -= 0.1;
}
if (Q.ideology == "labor") {
    Q.delegate_power_christsoc -= 0.5;
    Q.delegate_power_a += 0.3;
    Q.delegate_power_b += 0.3;
    Q.delegate_power_yocon += 0.3;
    Q.hugenberg_momentum += 0.1;
}
if (Q.ideology == "left") {
    Q.hugenberg_momentum += 1;
    Q.delegate_power_a += 0.5;
    Q.delegate_power_b -= 1.2;
    Q.delegate_power_yocon += 0.5;
    Q.delegate_power_christsoc -= 0.5;
}

if (Q.welfare < 0) Q.delegate_power_christsoc += 2.5 * Math.abs(Q.welfare);

if (Q.unions_independent) Q.delegate_power_christsoc *= 1.06;

// 4. Class Influence
Q.hugenberg_momentum += (Q.old_middle_dnvp_display * 0.27);
Q.hugenberg_momentum += (Q.rural_dnvp_display * 0.17);

Q.delegate_power_a += (Q.new_middle_dnvp_display * 0.32);
Q.delegate_power_a += (Q.old_middle_dnvp_display * 0.11);

Q.delegate_power_b += (Q.rural_dnvp_display * 0.20);
Q.delegate_power_b += (Q.old_middle_dnvp_display * 0.08);

// Young Conservatives: new middle class + small worker slice + some old middle
Q.delegate_power_yocon += (Q.workers_dnvp_display * 0.16) + (Q.new_middle_dnvp_display * 0.25) + (Q.old_middle_dnvp_display * 0.06);
// Christian Socials: worker-heavy + half of new middle
Q.delegate_power_christsoc += (Q.workers_dnvp_display * 0.6) + (Q.new_middle_dnvp_display * 0.33);

// 5. Ideological Reinforcements
Q.hugenberg_momentum += Q.nationalism * 4.0;
Q.delegate_power_b += Q.nationalism * 0.13 * Q.pro_republic * 0.1;
Q.delegate_power_a += Q.pro_republic * 0.034 + Q.nationalism * 0.056;
Q.delegate_power_yocon += Q.pro_republic * 0.25;
Q.delegate_power_christsoc += Q.socialism * 0.28 + Q.pro_republic * 0.12;

// 6. Failure Penalty
if (Q.dnvp_votes_display < 13) {
    Q.delegate_power_a -= 2.0;
    Q.delegate_power_b -= 2.0;
    Q.hugenberg_momentum += 3.0;
} else if (Q.dnvp_votes_display < 14) {
    Q.delegate_power_a -= 0.6;
    Q.delegate_power_b -= 1.0;
    Q.hugenberg_momentum += 1.0;
    Q.delegate_power_yocon += 0.6;
    Q.delegate_power_christsoc += 0.4;
} else if (Q.dnvp_votes_display < 16) {
    Q.delegate_power_a -= 0.2;
    Q.delegate_power_b -= 0.4;
    Q.hugenberg_momentum += 0.6;
    Q.delegate_power_yocon += 1.0;
    Q.delegate_power_christsoc += 0.6;
} else if (Q.dnvp_votes_display < 18) {
    Q.delegate_power_a += 1.2;
    Q.delegate_power_b -= 0.5;
    Q.hugenberg_momentum -= 1.0;
    Q.delegate_power_yocon += 2.0;
    Q.delegate_power_christsoc += 1.7;
} else {
    Q.delegate_power_a += 1.5;
    Q.delegate_power_b -= 0.6;
    Q.hugenberg_momentum -= 1.2;
    Q.delegate_power_yocon += 2.3;
    Q.delegate_power_christsoc += 2.0;
}

// 7. Global regulation: cap combined total of all 6 tracked vars at 1000
{
    const _dnvp_total_cap = 1000;
    const _dnvp_tracked = [
        'hugenberg_momentum',
        'delegate_power_a',
        'delegate_power_b',
        'delegate_power_yocon',
        'delegate_power_christsoc'
    ];

    const _dnvp_sum = _dnvp_tracked.reduce((sum, key) => sum + Q[key], 0);

    if (_dnvp_sum > _dnvp_total_cap) {
        const _dnvp_scale = _dnvp_total_cap / _dnvp_sum;
        _dnvp_tracked.forEach(key => {
            Q[key] *= _dnvp_scale;
        });
    }
}









