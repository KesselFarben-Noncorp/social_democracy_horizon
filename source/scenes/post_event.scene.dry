      on_pass: function() { Q.workers_aid=(Q.workers_aid||0)+1; Q.welfare=(Q.welfare||0)+1; } },

    // ── DEMOCRATIC LEFT (ideo 2–3) ───────────────────────────
    { id: 'land_reform',        name: 'Agricultural Land Reform',
