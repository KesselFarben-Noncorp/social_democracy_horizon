    },
    agriculture: {
        KPD:  'Hoernle',
        SAPD: 'Baade',
        SPD:  'Baade',
        SRPD: 'Baade',
        DDP:  'Dietrich',
        Z:    'Hermes',
        BVP:  'Wutzlhofer',
        DVP:  'Schiele',
        WP:   'Bredt',
        CNBL: 'Hamkens',
        DNVP: 'Schiele',
        NSDAP:'Hugenberg',
    },
    transport: {
        KPD:  'Hoernle',
        SAPD: 'Baade',
        SPD:  'Baade',
        SRPD: 'Baade',
        DDP:  'Dietrich',
        Z:    'Guerard',
        BVP:  'Wutzlhofer',
        DVP:  'Schiele',
        WP:   'Bredt',
        CNBL: 'Hamkens',
        DNVP: 'Schiele',
        NSDAP:'Eltz-Rübenach',
    },
    reichswehr: {
        // Always independent — single entry
        I: 'Groener',
    },
};

// === MINISTRY PRIORITIES BY PARTY ===
const MINISTRY_PRIORITIES = {
    KPD:  ['labor', 'interior', 'economic', 'finance', 'justice', 'foreign', 'agriculture', 'transport'],
    SAPD: ['labor', 'interior', 'justice', 'economic', 'finance', 'foreign', 'agriculture', 'transport'],
    SPD:  ['labor', 'interior', 'justice', 'finance', 'economic', 'foreign', 'agriculture', 'transport'],
    SRPD: ['labor', 'justice', 'interior', 'finance', 'economic', 'foreign', 'agriculture', 'transport'],
    DDP:  ['justice', 'economic', 'finance', 'interior', 'foreign', 'labor', 'agriculture', 'transport'],
    Z:    ['interior', 'foreign', 'finance', 'labor', 'agriculture', 'justice', 'economic', 'transport'],
    BVP:  ['agriculture', 'justice', 'interior', 'finance', 'economic', 'foreign', 'labor', 'transport'],
    DVP:  ['economic', 'finance', 'foreign', 'justice', 'interior', 'labor', 'agriculture', 'transport'],
    WP:   ['economic', 'finance', 'justice', 'agriculture', 'interior', 'foreign', 'labor', 'transport'],
    CNBL: ['agriculture', 'finance', 'economic', 'justice', 'interior', 'foreign', 'labor', 'transport'],
    CSVD: ['agriculture', 'justice', 'interior', 'finance', 'economic', 'foreign', 'labor', 'transport'],
    DNVP: ['interior', 'finance', 'agriculture', 'foreign', 'economic', 'justice', 'labor', 'transport'],
    NSDAP:['interior', 'economic', 'foreign', 'finance', 'agriculture', 'justice', 'labor', 'transport'],
    CSRP: ['labor', 'justice', 'interior', 'economic', 'finance', 'foreign', 'agriculture', 'transport'],
};

// ========================================
// CORE FUNCTIONS
// ========================================

// --- Resolve minister name ---
// Handles both string values and function values (for conditional names)
Q._resolve_minister = function(ministry, party) {
    const ministry_table = MINISTER_NAMES[ministry];
    if (!ministry_table) return 'Unbesetzt';
    
    const entry = ministry_table[party];
    if (!entry) return 'Unbesetzt';
    
    // If it's a function (like DVP foreign minister), call it
    return typeof entry === 'function' ? entry() : entry;
};

// --- Clear all ministry assignments ---
Q.clear_ministries = function() {
    for (const ministry of ALL_MINISTRIES) {
        Q[ministry + '_minister']       = 'Unbesetzt';
        Q[ministry + '_minister_party'] = 'I';
    }
    // Reichswehr always stays independent
    Q.reichswehr_minister       = Q._resolve_minister('reichswehr', 'I');
    Q.reichswehr_minister_party = 'I';
};

// --- Appoint a single minister directly ---
// Use this for player-chosen appointments or special events
// e.g. Q.appoint_minister('interior', 'SPD')
// or   Q.appoint_minister('interior', 'SPD', 'Severing') to override name
Q.appoint_minister = function(ministry, party, override_name) {
    if (!ALL_MINISTRIES.includes(ministry) && !INDEPENDENT_MINISTRIES.includes(ministry)) {
        console.warn("appoint_minister: unknown ministry: " + ministry);
        return;
    }
    Q[ministry + '_minister_party'] = party || 'I';
    Q[ministry + '_minister']       = override_name || Q._resolve_minister(ministry, party) || 'Unbesetzt';
};

// ========================================
// LEVERAGE CALCULATION
// ========================================

Q._calculate_leverage = function(coalition) {
    let total_votes = 0;
    for (const party of coalition) {
        total_votes += Q[party.toLowerCase() + '_r'] || 0;
    }
    if (total_votes === 0) total_votes = 1; // Prevent divide-by-zero

    const leverage = {};

    for (const party of coalition) {
        let base = ((Q[party.toLowerCase() + '_r'] || 0) / total_votes) * 100;

        // Relation modifier
        const relation = Q[party.toLowerCase() + '_relation'] || 50;
        base += (relation - 50) / 5;

        // Chancellor party gets slight penalty — they already have the top job
        if (Q.chancellor_party === party) base -= 10;

        // President bonus
        if (Q.president === "Braun" && party === "SPD") base += 5;

        // Party leader bonuses
        if (party === "Z"   && Q.z_party_leader === "Brüning")    base += 5;
        if (party === "DVP" && !Q.stresemann_dead)                 base += 3;
        if (party === "KPD" && Q.kpd_party_leader === "Conciliators") base += 5;

        // Special conditions
        if (Q.in_grand_coalition && party === "DVP" && 
            Q.capital_strike_progress >= 3) base += 5;
        if (Q.in_left_front && party === "KPD") base -= 5;

        // Hugenberg DNVP demands more
        if (party === "DNVP" && Q.dnvp_line === 3) base += 8;

        // Floor — every coalition partner gets at least something
        leverage[party] = Math.max(base, 10);
    }

    return leverage;
};

// ========================================
// ALLOCATION CALCULATION
// ========================================

Q._calculate_allocation = function(coalition, leverage) {
    const count = ALL_MINISTRIES.length;
    let total_leverage = 0;
    for (const party of coalition) total_leverage += leverage[party];
    if (total_leverage === 0) total_leverage = 1;

    const allocation = {};
    for (const party of coalition) {
        allocation[party] = Math.round((leverage[party] / total_leverage) * count);
    }

    // Fix rounding errors
    let assigned = 0;
    for (const party of coalition) assigned += allocation[party];

    // Over-allocated: trim from largest non-chancellor party
    while (assigned > count) {
        let target = null, max = 0;
        for (const party of coalition) {
            if (allocation[party] > max && party !== Q.chancellor_party) {
                target = party;
                max = allocation[party];
            }
        }
        if (!target) break;
        allocation[target]--;
        assigned--;
    }

    // Under-allocated: add to highest leverage party
    const leverage_copy = Object.assign({}, leverage);
    while (assigned < count) {
        let target = null, max = 0;
        for (const party of coalition) {
            if (leverage_copy[party] > max) {
                target = party;
                max = leverage_copy[party];
            }
        }
        if (!target) break;
        allocation[target]++;
        assigned++;
        leverage_copy[target] -= 10;
    }

    // Guarantee chancellor party has at least 1
    if (Q.chancellor_party && coalition.includes(Q.chancellor_party)) {
        if ((allocation[Q.chancellor_party] || 0) < 1) {
            allocation[Q.chancellor_party] = 1;
        }
    }

    return allocation;
};

// ========================================
// FULL COALITION MINISTRY ALLOCATION
// ========================================

Q.allocate_ministries = function(coalition) {
    if (!coalition || coalition.length === 0) {
        console.warn("allocate_ministries: empty coalition");
        Q.clear_ministries();
        return;
    }

    // Clear first
    Q.clear_ministries();

    // Calculate leverage and allocation counts
    const leverage   = Q._calculate_leverage(coalition);
    const allocation = Q._calculate_allocation(coalition, leverage);

    // Track how many each party has claimed
    const claimed = {};
    for (const party of coalition) claimed[party] = 0;

    // Track which ministries are filled
    const assignments = {};
    for (const m of ALL_MINISTRIES) assignments[m] = null;

    // Sort coalition by leverage descending — higher leverage picks first
    const sorted = coalition.slice().sort((a, b) => leverage[b] - leverage[a]);

    // Assign in rounds until all ministries filled
    for (let round = 0; round < ALL_MINISTRIES.length; round++) {
        for (const party of sorted) {
            if (claimed[party] >= allocation[party]) continue;

            const priorities = MINISTRY_PRIORITIES[party] || ALL_MINISTRIES;

            for (const ministry of priorities) {
                if (assignments[ministry] === null) {
                    assignments[ministry] = party;
                    claimed[party]++;
                    break;
                }
            }
        }
    }

    // Apply assignments
    for (const ministry of ALL_MINISTRIES) {
        const party = assignments[ministry] || 'I';
        Q.appoint_minister(ministry, party);
    }

    // Reichswehr always independent
    Q.appoint_minister('reichswehr', 'I');

    // Build display string
    Q.ministry_display_list = "";
    for (const party of coalition) {
        const votes   = Math.round((Q[party.toLowerCase() + '_r'] || 0) * 10) / 10;
        const lev     = Math.round(leverage[party] * 10) / 10;
        const count   = allocation[party] || 0;
        Q.ministry_display_list += 
            `- **${party}**: ${count} ministr${count === 1 ? 'y' : 'ies'} `+
            `(${votes}% votes, leverage: ${lev})\n`;
    }

    // Store for reference
    Q.ministry_allocation = allocation;
    Q.ministry_leverage   = leverage;

    // Hindenburg reacts to government formation
    Q.hindenburg_patience += 10;
};

// ========================================
// INTEGRITY CHECK
// ========================================

Q.ministry_integrity_check = function() {
    const issues = [];

    for (const ministry of ALL_MINISTRIES) {
        const party = Q[ministry + '_minister_party'];
        const name  = Q[ministry + '_minister'];

        // Minister set but no party
        if (name && name !== 'Unbesetzt' && (!party || party === 'I')) {
            issues.push(`WARN: ${ministry} has minister ${name} but party is Independent`);
        }

        // Party set but no minister name
        if (party && party !== 'I' && (!name || name === 'Unbesetzt')) {
            issues.push(`WARN: ${ministry} party is ${party} but minister name is empty — fixing`);
            Q[ministry + '_minister'] = Q._resolve_minister(ministry, party);
        }

        // Party in ministry but not in government
        if (party && party !== 'I' && !Q[party.toLowerCase() + '_in_government']) {
            issues.push(`WARN: ${ministry} held by ${party} but they are not in government — clearing`);
            Q.appoint_minister(ministry, 'I');
        }
    }

    if (issues.length > 0) {
        console.warn("=== MINISTRY INTEGRITY CHECK ===");
        for (const issue of issues) console.warn(issue);
        console.warn("================================");
    }

    return issues.length;
};














// ÷====================== SMALL CHECKERS FOR CABINETS ===============÷=======

Q.bruning_cabinet = (Q.chancellor === "Brüning") ? 1 : 0;

// === CABINET TYPE FLAGS ===
Q.papen_cabinet     = (Q.chancellor === "Papen")      ? 1 : 0;
Q.schleicher_cabinet = (Q.chancellor === "Schleicher") ? 1 : 0;

// Generic x_cabinet check for any chancellor with that flag pattern
const CABINET_CHANCELLORS = ["Papen", "Schleicher", "Brüning", "Luther", "Marx", "Stegerwald"];
for (const name of CABINET_CHANCELLORS) {
    const key = name.toLowerCase().replace("ü", "u") + "_cabinet";
    Q[key] = (Q.chancellor === name) ? 1 : 0;
}












Q.last_advisor_action = 0;
Q.last_cabinet_action = 0;
// make sure no stat is below 0.

// 1. update dates
if (Q.month_actions >= 1) {
    Q.time += 1;
    Q.month_actions = 0;
    Q.ma = 1;
    console.log(Q.month);
    console.log(Q.time);
    
    // Advance by 2 weeks
    Q.weeks = (Q.weeks || 0) + 2;
    
    // Roll over to next month when 4+ weeks pass
    if (Q.weeks >= 4) {
        Q.weeks -= 4;
        Q.month += 1;
        
        if (Q.month >= 13) {
            Q.month = 1;
            Q.year += 1;
            if (Q.historical_mode) {
                Q.resources += 2;
            }
        }
    }
    
    // decrement timers
    for (timer of Q.timers) {
        if (Q[timer+'_timer'] && Q[timer+'_timer'] > 0) {
            Q[timer+'_timer'] -= 1;
        }
    }




// EVENTS

if (Q.inflation > 10) {
        Q.inflation_crisis_event = 0;
        }


if (Q.year == 1930 && Q.month == 5 && Q.weeks >= 1 && Q.young_plan_seen == 1) {
    Q.economic_growth += 0.5; // already have this

    // Improved foreign credit access
    Q.capital_pressure     -= 0.12;
    Q.trade_pressure       -= 0.08;
    Q.budget               += 1.5;

    Q.demand_impulse       -= 0.10;
    Q.distribution_shift   += 0.05;
    Q.hindenburg_trust_spd -= 5;
    Q.camarilla_strength += 5;
    Q.z_relation -= 5;
    Q.dvp_relation -= 5;
    Q.bvp_relation -= 5;
}
















    
    // ============================================================
// ECONOMIC SIMULATION — PHASE-CYCLING MODEL
// ============================================================

// === INITIALIZATION ===
if (!Q.economyInitialized) {
    Q.inflation = 2.5;
    Q.unemployed = 6.0;
    Q.economic_growth = 2.5;
    Q.budget = 0;
    Q.inflation_expectations = 2.5;
    Q.demand_impulse = 0;
    Q.supply_impulse = 0;
    Q.price_pressure = 0;
    Q.trade_pressure = 0;
    Q.capital_pressure = 0;
    Q.fiscal_stance = 0;
    Q.distribution_shift = 0;
    Q.fiscal_demand = 0;
    Q.cycle_phase = 0;
    Q.shock_residual = 0;
    Q.tax_drag = 0;
    Q.investment_chill = 0;

    Q.phase = "growth";
    Q.phase_duration = 0;
    Q.last_phase_change = 0;
    Q.tick = 0;

    Q.expectations_anchored = true;
    Q.high_inflation_streak = 0;
    Q.low_inflation_streak = 0;

    Q.supply_cost_drag = 0;
    Q.credit_expansion = 0;

    Q.economyInitialized = true;
}

Q.NAIRU = Q.NAIRU || 6.0;
Q.POTENTIAL_GROWTH = 2.5;
Q.dt = 1;
Q.tick = (Q.tick || 0) + 1;

// ============================================================
// SECTION 1 — PHASE STATE MACHINE
// ============================================================

const MIN_PHASE_DURATION = 3;
Q.phase_duration = (Q.phase_duration || 0) + 1;

if (Q.phase_duration >= MIN_PHASE_DURATION) {
    const prev_phase = Q.phase;

    if (Q.phase === "growth") {
        if (Q.inflation > 5 && Q.unemployed < Q.NAIRU)
            Q.phase = "overheating";
        else if (Q.economic_growth < 0 && Q.inflation < 2)
            Q.phase = "correction";
    }
    else if (Q.phase === "overheating") {
        if (Q.inflation > 8 && !Q.expectations_anchored)
            Q.phase = "hyperinflation";
        else if (Q.economic_growth < 0)
            Q.phase = "correction";
        else if (Q.inflation < 4 && Q.economic_growth > 1)
            Q.phase = "growth";
    }
    else if (Q.phase === "hyperinflation") {
        if (Q.economic_growth < -2 && Q.unemployed > 10)
            Q.phase = (Q.inflation > 4) ? "stagflation" : "depression";
        else if (Q.inflation < 5 && Q.expectations_anchored)
            Q.phase = "correction";
    }
    else if (Q.phase === "correction") {
        if (Q.economic_growth < -3 && Q.inflation < 1)
            Q.phase = "depression";
        else if (Q.inflation > 4 && Q.unemployed > Q.NAIRU + 2)
            Q.phase = "stagflation";
        else if (Q.economic_growth > 1 && Q.inflation < 4)
            Q.phase = "growth";
    }
    else if (Q.phase === "depression") {
        if (Q.economic_growth > 0 && Q.inflation > -1)
            Q.phase = "correction";
        else if ((Q.price_pressure || 0) > 0.3 && Q.unemployed > 12)
            Q.phase = "stagflation";
    }
    else if (Q.phase === "stagflation") {
        if (Q.inflation < 3 && Q.economic_growth > 0)
            Q.phase = "growth";
        else if (Q.inflation < 1 && Q.economic_growth < -2)
            Q.phase = "depression";
        else if (Q.inflation > 9)
            Q.phase = "hyperinflation";
    }

    if (Q.phase !== prev_phase) {
        Q.phase_duration = 0;
        Q.last_phase_change = Q.tick;
    }
}

// ============================================================
// SECTION 2 — PHASE-SPECIFIC DECAY MULTIPLIERS
// ============================================================

let decay_demand  = 0.35;
let decay_supply  = 0.25;
let decay_price   = 0.50;
let decay_trade   = 0.30;
let decay_capital = 0.20;
let decay_fiscal  = 0.15;
let decay_distrib = 0.08;

switch (Q.phase) {
    case "growth":
        decay_demand  *= 0.45;
        decay_capital *= 0.60;
        break;
    case "overheating":
        decay_price   *= 0.35;
        decay_demand  *= 0.55;
        break;
    case "hyperinflation":
        decay_price   *= 0.10;
        decay_supply  *= 0.30;
        decay_trade   *= 0.45;
        break;
    case "correction":
        decay_capital *= 0.50;
        decay_trade   *= 0.60;
        break;
    case "depression":
        decay_capital *= 0.20;
        decay_trade   *= 0.35;
        decay_supply  *= 0.40;
        break;
    case "stagflation":
        decay_price   *= 0.25;
        decay_capital *= 0.30;
        decay_trade   *= 0.30;
        decay_demand  *= 0.70;
        break;
}

// ============================================================
// SECTION 3 — BUSINESS CYCLE (phase-scaled amplitude)
// ============================================================

Q.cycle_phase = (Q.cycle_phase || 0) + 0.018 * Q.dt;
const cycle_amps = {
    growth: 1.4, overheating: 1.8, hyperinflation: 1.2,
    correction: 0.9, depression: 0.3, stagflation: 0.6
};
Q.cycle_amplitude = (cycle_amps[Q.phase] || 1.0) * (1 + (Q.shock_residual || 0) * 0.3);
Q.business_cycle = Q.cycle_amplitude * Math.sin(Q.cycle_phase);

// ============================================================
// SECTION 4 — PASSIVE DRIFTS
// ============================================================

Q.productivity_trend = 0.01 * Q.dt * (1 - (Q.capital_pressure || 0) * 0.2);

Q.labor_churn = 0;
if (Q.unemployed > Q.NAIRU) {
    const u_gap = Q.unemployed - Q.NAIRU;
    Q.labor_churn = -0.02 * u_gap * (1 + Math.max(0, u_gap - 10) * 0.15) * Q.dt;
} else {
    Q.labor_churn = 0.015 * (Q.NAIRU - Q.unemployed) * Q.dt;
}

Q.inflation_momentum = 0.005 * Q.inflation * Q.dt;

Q.trade_pressure = (Q.trade_pressure || 0);
if (Q.economic_growth > Q.POTENTIAL_GROWTH + 2)
    Q.trade_pressure += 0.02 * Q.dt;
else if (Q.economic_growth < Q.POTENTIAL_GROWTH - 2)
    Q.trade_pressure -= 0.015 * Q.dt;

Q.capital_pressure = (Q.capital_pressure || 0);
if (Q.economic_growth > 4 && Q.capital_pressure < 0.3)
    Q.capital_pressure -= 0.01 * Q.dt;
else if (Q.economic_growth < 0)
    Q.capital_pressure += 0.025 * Q.dt;
Q.capital_pressure = Math.max(0, Q.capital_pressure);

if (Q.unemployed < Q.NAIRU - 2 && Q.inflation > 3) {
    Q.price_pressure = (Q.price_pressure || 0)
        + 0.05 * (Q.NAIRU - Q.unemployed) * (Q.inflation / 10) * Q.dt;
}

// NAIRU drift
if (Q.phase === "depression" || Q.phase === "correction")
    Q.NAIRU += (6.0 - Q.NAIRU) * 0.01 * Q.dt;
else if (Q.phase !== "stagflation")
    Q.NAIRU += 0.003 * Q.dt;

// Financial sector
if (Q.inflation > 8 || Q.budget < -20)
    Q.capital_pressure += 0.02 * Q.dt;
else if (Q.inflation < 2 && Q.economic_growth > 3)
    Q.capital_pressure -= 0.015 * Q.dt;

// Random shocks
if (Math.random() < 0.03 * Q.dt) {
    const shock = (Math.random() - 0.5) * 0.12 * (Q.unemployed > 20 || Q.inflation > 12 ? 1.5 : 1);
    Q.price_pressure = (Q.price_pressure || 0) + shock;
    Q.shock_residual = (Q.shock_residual || 0) + shock * 0.3;
}
Q.shock_residual = (Q.shock_residual || 0) * Math.exp(-0.4 * Q.dt);

// ============================================================
// SECTION 5 — BOOM CREDIT EXPANSION
// ============================================================

Q.credit_expansion = Q.credit_expansion || 0;
if (Q.phase === "growth" && Q.unemployed < Q.NAIRU - 1) {
    Q.credit_expansion += 0.04 * Math.max(0, Q.NAIRU - 1 - Q.unemployed) * Q.dt;
    Q.credit_expansion = Math.min(Q.credit_expansion, 0.8);
} else {
    Q.credit_expansion *= Math.exp(-0.2 * Q.dt);
}
Q.demand_impulse = (Q.demand_impulse || 0) + Q.credit_expansion * 0.15;
Q.capital_pressure = Math.max(0, Q.capital_pressure - Q.credit_expansion * 0.02);

// ============================================================
// SECTION 6 — STAGFLATION SUPPLY-DEMAND COUPLING
// ============================================================

Q.supply_cost_drag = Q.supply_cost_drag || 0;
if (Q.phase === "stagflation" || (Q.price_pressure || 0) > 0.3) {
    Q.supply_cost_drag += (Q.price_pressure || 0) * 0.06 * Q.dt;
    Q.supply_cost_drag = Math.min(Q.supply_cost_drag, 0.5);
} else {
    Q.supply_cost_drag *= Math.exp(-0.15 * Q.dt);
}
Q.supply_impulse = (Q.supply_impulse || 0) - Q.supply_cost_drag * 0.3;

// ============================================================
// SECTION 7 — NONLINEAR EXPECTATIONS WITH HYSTERESIS
// ============================================================

Q.high_inflation_streak = Q.high_inflation_streak || 0;
Q.low_inflation_streak = Q.low_inflation_streak || 0;

if (Q.inflation > 5) {
    Q.high_inflation_streak += Q.dt;
    Q.low_inflation_streak = 0;
} else if (Q.inflation < 3 && !Q.expectations_anchored) {
    Q.low_inflation_streak += Q.dt;
    Q.high_inflation_streak *= 0.85;
} else {
    Q.high_inflation_streak *= 0.85;
}

if (Q.expectations_anchored && Q.high_inflation_streak > 4)
    Q.expectations_anchored = false;
if (!Q.expectations_anchored && Q.low_inflation_streak > 6) {
    Q.expectations_anchored = true;
    Q.high_inflation_streak = 0;
}

Q.inflation_expectations = Q.inflation_expectations || Q.inflation;
if (Q.expectations_anchored) {
    Q.inflation_expectations += 0.03 * (Q.inflation - Q.inflation_expectations) * Q.dt;
    Q.inflation_expectations += 0.04 * (2.5 - Q.inflation_expectations) * Q.dt;
} else {
    const lead = 0.10 + (Q.phase === "hyperinflation" ? 0.08 : 0);
    Q.inflation_expectations += lead * (Q.inflation - Q.inflation_expectations) * Q.dt;
    Q.inflation_expectations += 0.05 * Math.max(0, Q.inflation - 4) * Q.dt;
}

// ============================================================
// SECTION 8 — FISCAL & TAX
// ============================================================

Q.budget += Q.fiscal_stance * 0.4 * Q.dt;
Q.fiscal_demand = -Q.fiscal_stance * 0.2;

Q.consumption_demand = (Q.demand_impulse || 0)
    * (1 + (Q.distribution_shift || 0) * 0.15);

Q.upper_tax_base = (Q.old_middle + Q.new_middle) / 100;
Q.lower_tax_base = (Q.workers + Q.unemployedc + Q.rural) / 100;
Q.tax_efficiency = Math.max(0.5, Math.min(1.5,
    1 + (Q.economic_growth / 100) - (Q.unemployed / 100)));
Q.tax_revenue = (Q.upper_tax_rates * Q.upper_tax_base * 0.035
    + Q.lower_tax_rates * Q.lower_tax_base * 0.018) * Q.tax_efficiency;
Q.budget += Q.tax_revenue * Q.dt;

if (Q.tax_drag && Math.abs(Q.tax_drag) > 0.01) {
    Q.consumption_demand -= Q.tax_drag * 0.2;
    Q.tax_drag *= 0.94;
    if (Math.abs(Q.tax_drag) < 0.01) Q.tax_drag = 0;
}

Q.total_demand = Q.consumption_demand + Q.fiscal_demand;
Q.investment_effect = (Q.supply_impulse || 0) * (1 - (Q.capital_pressure || 0) * 0.3);

if (Q.investment_chill && Math.abs(Q.investment_chill) > 0.01) {
    Q.investment_effect -= Q.investment_chill * 0.25;
    Q.capital_pressure += Math.abs(Q.investment_chill) * 0.08;
    Q.investment_chill *= 0.92;
    if (Math.abs(Q.investment_chill) < 0.01) Q.investment_chill = 0;
}

Q.budget = Math.round(Q.budget * 100) / 100;

// ============================================================
// SECTION 9 — INFLATION DYNAMICS
// ============================================================

Q.output_gap = Q.economic_growth - Q.POTENTIAL_GROWTH;
Q.overheating = Math.max(0, Q.economic_growth - 6);
Q.dInflation = 0;

Q.dInflation += 0.016 * (Q.NAIRU - Q.unemployed);
Q.dInflation += 0.010 * Q.output_gap;

if (Q.budget < 0) {
    const tanh_factor = Math.max(0.30, 1 - Math.tanh((Q.unemployed - 10) / 5));
    Q.dInflation += -Q.budget * 0.008 * tanh_factor;
}

if (Q.inflation < 0 && Q.inflation_expectations < 1.0)
    Q.dInflation -= 0.08 * (Q.inflation - Math.max(Q.inflation_expectations, 1.0));
else
    Q.dInflation -= 0.05 * (Q.inflation - Q.inflation_expectations);

if (!Q.expectations_anchored)
    Q.dInflation += 0.06 * Math.max(0, Q.inflation_expectations - Q.inflation);

Q.dInflation += (Q.price_pressure || 0) * 0.10;
Q.dInflation += (Q.trade_pressure || 0) * 0.05;
Q.dInflation += Q.inflation_momentum;

if (Q.inflation < 0) {
    const dm = Math.abs(Q.inflation), damp = 0.7;
    Q.dInflation -= (0.015 * dm / (1 + dm * damp)) * (Q.unemployed / 20);
    if (Q.inflation < -3) {
        const ds = dm - 3;
        Q.dInflation -= Math.min(0.03 * ds / (1 + ds * damp), 0.2);
        Q.demand_impulse = (Q.demand_impulse || 0) - Math.min(0.008 * ds / (1 + ds * damp), 0.10);
    }
    if (Q.inflation < -6)
        Q.capital_pressure += Math.min(0.05 * (dm - 6) / (1 + (dm - 6) * damp), 0.15);
}

Q.dInflation += (Math.random() - 0.5) * 2 * 0.02;

// ============================================================
// SECTION 10 — UNEMPLOYMENT DYNAMICS
// ============================================================

Q.dUnemployment = 0;
Q.growth_gap = Q.economic_growth - Q.POTENTIAL_GROWTH;
Q.dUnemployment -= (Q.growth_gap < 0 ? 0.032 : 0.020)
    * Q.growth_gap / (1 + Math.abs(Q.growth_gap) * 0.12);

Q.dUnemployment += 0.005 * Math.max(0, Q.inflation - 6);
Q.dUnemployment -= Q.total_demand * 0.35;
Q.dUnemployment += Math.min((Q.capital_pressure || 0) * 0.06, 1.5);
Q.dUnemployment += Math.min((Q.trade_pressure || 0) * 0.04, 1.0);
Q.dUnemployment += Q.labor_churn;

if (Q.phase === "stagflation")
    Q.dUnemployment += Q.supply_cost_drag * 0.4;

if (Q.inflation < 0) {
    const dm = Math.abs(Q.inflation), damp = 0.7;
    Q.dUnemployment += Math.min((0.03 * dm / (1 + dm * damp))
        * (1 - Math.exp(-Q.unemployed / 20)), 0.6);
    if (Q.inflation < -5)
        Q.dUnemployment += Math.min(0.05 * (dm-5) / (1 + (dm-5) * damp), 0.4);
    if (Q.inflation < -8)
        Q.dUnemployment += Math.min(0.07 * (dm-8) / (1 + (dm-8) * damp), 0.3);
}

Q.dUnemployment += (Math.random() - 0.5) * 2 * 0.01;
Q.dUnemployment = Math.max(-2, Math.min(2, Q.dUnemployment));

// ============================================================
// SECTION 11 — GROWTH DYNAMICS
// ============================================================

Q.dGrowth = 0;
Q.dGrowth += 0.020 * (Q.output_gap / (1 + Math.abs(Q.output_gap) * 0.25));
Q.dGrowth += Q.business_cycle * 0.05;
Q.dGrowth += Q.productivity_trend * 0.4;

if (Q.inflation > 6) Q.dGrowth -= Math.min(0.015 * (Q.inflation - 6), 2.0);

if (Q.inflation < -2) {
    const dm = Math.abs(Q.inflation), damp = 0.7;
    Q.dGrowth -= Math.min(0.03 * (dm-2) / (1 + (dm-2) * damp), 0.8);
    if (Q.inflation < -5) {
        const ds5 = dm - 5;
        Q.dGrowth -= Math.min(0.05 * ds5 / (1 + ds5 * damp), 0.7);
        Q.supply_impulse = (Q.supply_impulse||0) - Math.min(0.010 * ds5 / (1 + ds5*damp), 0.2);
        Q.trade_pressure += Math.min(0.020 * ds5 / (1 + ds5 * damp), 0.3);
    }
    if (Q.inflation < -8) {
        Q.dGrowth -= Math.min(0.05 * (dm-8) / (1 + (dm-8) * damp), 0.5);
        Q.capital_pressure += 0.03;
    }
}

Q.dGrowth -= Math.min(0.003 * Math.pow(Math.abs(Q.inflation), 1.5), 0.7);
const u_gap_g = Math.max(0, Q.unemployed - Q.NAIRU);
Q.dGrowth -= Math.min(0.004 * u_gap_g / (1 + u_gap_g * 0.10), 1.5);
if (Q.unemployed > 10)
    Q.dGrowth -= Math.min(0.007 * (Q.unemployed-10) / (1 + (Q.unemployed-10) * 0.18), 1.0);

Q.dGrowth -= 0.007 * Q.overheating;
if (Q.economic_growth > 8) Q.dGrowth -= 0.005 * (Q.economic_growth - 8);

Q.dGrowth += Q.total_demand * 1.3;
Q.dGrowth += Q.investment_effect * 1.6;
Q.dGrowth -= Math.min((Q.trade_pressure || 0) * 0.07, 1.5);
Q.dGrowth -= Math.min((Q.capital_pressure || 0) * 0.08, 1.5);
Q.dGrowth += (Math.random() - 0.5) * 2 * 0.015;
Q.dGrowth = Math.max(-3, Math.min(3, Q.dGrowth));

// ============================================================
// SECTION 12 — TIERED EMERGENCY STABILIZERS
// ============================================================

if (Q.inflation < -4) {
    const t1 = Math.min(1, (-4 - Q.inflation) / 3);
    Q.dInflation += 0.06 * t1;
    Q.demand_impulse = (Q.demand_impulse||0) + 0.03 * t1;
}
if (Q.inflation < -7) {
    const t2 = Math.min(1, (-7 - Q.inflation) / 2);
    Q.dInflation += 0.10 * t2;
    Q.price_pressure = (Q.price_pressure||0) + 0.15 * t2;
    Q.demand_impulse = (Q.demand_impulse||0) + 0.05 * t2;
}
if (Q.inflation <= -9 && Q.inflation_expectations > Q.inflation + 2) {
    Q.dInflation += 0.15 * (Q.inflation_expectations - Q.inflation);
    Q.demand_impulse = (Q.demand_impulse||0) + 0.08;
    Q.price_pressure = (Q.price_pressure||0) + 0.25;
    Q.fiscal_stance = (Q.fiscal_stance||0) - 0.08;
}

if (Q.economic_growth < -4) {
    const t1 = Math.min(1, (-4 - Q.economic_growth) / 5);
    Q.dGrowth += 0.08 * t1;
    Q.demand_impulse = (Q.demand_impulse||0) + 0.05 * t1;
}
if (Q.economic_growth < -7) {
    const t2 = Math.min(1, (-7 - Q.economic_growth) / 2);
    Q.dGrowth += 0.12 * t2;
    Q.demand_impulse = (Q.demand_impulse||0) + 0.08 * t2;
}
if (Q.economic_growth < -9) {
    Q.dGrowth += (Q.POTENTIAL_GROWTH - Q.economic_growth) * 0.05;
    Q.demand_impulse = (Q.demand_impulse||0) + 0.15;
}

if (Q.unemployed > 18) {
    Q.dUnemployment -= 0.10 * Math.min(1, (Q.unemployed - 18) / 7);
}
if (Q.unemployed > 25) {
    Q.dUnemployment += -(Q.unemployed - 35) * 0.08;
}

// ============================================================
// SECTION 13 — APPLY CHANGES
// ============================================================

const in_crisis = (Q.phase === "depression" || Q.phase === "hyperinflation");
Q.inflation       += Q.dInflation    * Q.dt * ((in_crisis && Q.dInflation > 0)    ? 0.95 : 0.86);
Q.unemployed      += Q.dUnemployment * Q.dt * ((in_crisis && Q.dUnemployment < 0) ? 0.95 : 0.86);
Q.economic_growth += Q.dGrowth       * Q.dt * ((in_crisis && Q.dGrowth > 0)       ? 0.95 : 0.86);

// ============================================================
// SECTION 14 — DECAY (phase-adjusted rates)
// ============================================================

Q.demand_impulse    = (Q.demand_impulse    || 0) * Math.exp(-decay_demand  * Q.dt);
Q.supply_impulse    = (Q.supply_impulse    || 0) * Math.exp(-decay_supply  * Q.dt);
Q.price_pressure    = (Q.price_pressure    || 0) * Math.exp(-decay_price   * Q.dt);
Q.trade_pressure    = (Q.trade_pressure    || 0) * Math.exp(-decay_trade   * Q.dt);
Q.capital_pressure  = (Q.capital_pressure  || 0) * Math.exp(-decay_capital * Q.dt);
Q.fiscal_stance     = (Q.fiscal_stance     || 0) * Math.exp(-decay_fiscal  * Q.dt);
Q.distribution_shift= (Q.distribution_shift|| 0) * Math.exp(-decay_distrib * Q.dt);

// ============================================================
// EMERGENCY ECONOMIC GUARDS
// Extreme inflation or unemployment — hard push back to center
// ============================================================

// --- INFLATION GUARDS (30%+) ---
if (Q.inflation >= 30) {

    // How far into danger zone are we? 0 at 30%, 1 at 99%
    const inf_severity = Math.min(1, (Q.inflation - 30) / 69);

    // Kill demand and price spirals
    Q.demand_impulse     -= 0.15 + inf_severity * 0.35;
    Q.price_pressure     -= 0.20 + inf_severity * 0.50;
    Q.fiscal_stance      -= 0.10 + inf_severity * 0.20;

    // Crush trade and capital flight
    Q.trade_pressure     += 0.10 + inf_severity * 0.25;  // imports collapse
    Q.capital_pressure   += 0.05 + inf_severity * 0.15;  // flight pressure

    // Direct inflation brake — harder the worse it gets
    Q.dInflation         -= 0.30 + inf_severity * 1.20;

    // Expectations unanchor — spiral accelerates expectations
    Q.inflation_expectations += 0.08 + inf_severity * 0.25;
    Q.expectations_anchored   = false;

    // Growth collapses under hyperinflation
    Q.dGrowth            -= 0.15 + inf_severity * 0.60;

    // Unemployment spikes — firms shut down
    Q.dUnemployment      += 0.10 + inf_severity * 0.40;
}

// --- UNEMPLOYMENT GUARDS (30%+) ---
if (Q.unemployed >= 30) {

    const unemp_severity = Math.min(1, (Q.unemployed - 30) / 69);

    // Demand destruction — mass poverty crushes consumption
    Q.demand_impulse     -= 0.20 + unemp_severity * 0.40;
    Q.fiscal_demand      -= 0.10 + unemp_severity * 0.20;

    // Supply side seizes — investment flees
    Q.supply_impulse     -= 0.15 + unemp_severity * 0.30;
    Q.capital_pressure   += 0.08 + unemp_severity * 0.20;

    // Growth accelerates downward
    Q.dGrowth            -= 0.25 + unemp_severity * 0.80;

    // Unemployment self-corrects slightly — floor effect
    // (people leave labor force, emigrate, subsistence farming etc.)
    Q.dUnemployment      -= 0.12 + unemp_severity * 0.35;

    // Deflation deepens — no demand means falling prices
    Q.dInflation         -= 0.08 + unemp_severity * 0.20;

    // NAIRU drifts up — structural unemployment sets in
    Q.NAIRU              += 0.05 + unemp_severity * 0.15;
}

// --- COMBINED CRISIS (both simultaneously) ---
if (Q.inflation >= 30 && Q.unemployed >= 30) {

    // Stagflation death spiral — compound the damage
    Q.dGrowth            -= 0.20;
    Q.capital_pressure   += 0.10;
    Q.trade_pressure     += 0.10;

    // Hard brake on both
    Q.dInflation         -= 0.15;
    Q.dUnemployment      -= 0.10;
}

// ============================================================
// SECTION 15 — CONSTRAINTS
// ============================================================

if (!Q.math_broken) {
    Q.inflation          = Math.max(-12, Math.min(99, Q.inflation));
    Q.unemployed         = Math.max(0,   Math.min(75, Q.unemployed));
    Q.economic_growth    = Math.max(-15, Math.min(20, Q.economic_growth));
    Q.inflation_expectations = Math.max(-9, Math.min(99, Q.inflation_expectations));
    Q.budget             = Math.max(-50, Math.min(50, Q.budget));
    Q.capital_pressure   = Math.max(0,   Math.min(1.0, Q.capital_pressure));
    Q.credit_expansion   = Math.max(0,   Math.min(0.8, Q.credit_expansion));
    Q.supply_cost_drag   = Math.max(0,   Math.min(0.5, Q.supply_cost_drag));
} else {
    Q.inflation       = Q.impossible_add(Q.inflation, 0);
    Q.unemployed      = Q.impossible_percentage(Q.unemployed);
    Q.economic_growth = Q.impossible_subtract(Q.economic_growth, 0);
    Q.budget          = Q.impossible_multiply(Q.budget, 1);
    Q.capital_pressure= Q.impossible_add(Q.capital_pressure, 0);
}





    // Science support/economic changes
    if (Q.major_curriculum && Q.major_curriculum == "democratic") {
        if (Q.pro_republic < 80) {
            Q.pro_republic += 0.3;
        } 
    }
    if (Q.minor_curriculum && Q.minor_curriculum == "democratic") {
        if (Q.pro_republic < 60) {
            Q.pro_republic += 0.6;
        } 
    }

    if (Q.major_curriculum && Q.major_curriculum == "traditional") {
        if (Q.nationalism < 60) {
            Q.nationalism += 0.1;
        } 
    }
    if (Q.minor_curriculum && Q.minor_curriculum == "traditional") {
        if (Q.nationalism < 40) {
            Q.nationalism += 0.3;
        } 
    }


    // science bonus to economic growth
    // education bonus
    Q.science_bonus = 0;
    if (Q.education_science) {
        Q.science_bonus += Q.education_science;
    }
    if (Q.science) {
        if (Q.science >= 1) {
            Q.science_bonus += 1;
        } else if (Q.science >= 3) {
            Q.science_bonus += 2;
        } else if (Q.science >= 5) {
            Q.science_bonus += 3;
        }
    }
    if (Q.applied_research && Q.applied_research >= 1) {
        Q.science_bonus += 0.5*Q.applied_research;
    }
    // cap the science bonus at 6
    if (Q.science_bonus > 6) {
        Q.science_bonus = 6;
    }
    console.log(Q.science_bonus);
    // this is kinda messy but basically more science -> higher levels of baseline growth
    if (Q.science_bonus >= 1) {
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus + 3) {
            Q.economic_growth += 0.1;
        }
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus) {
            Q.economic_growth += 0.1;
        }
        if (Q.economic_growth < Q.science_bonus - 3) {
            Q.economic_growth += 0.1;
        }
    }
    // accumulated economic growth/decline
    // Maybe there should be differences for positive/negative growth?
    if (Q.economic_growth < 0) {
        if (Q.economic_expansion > 0) {
            Q.economic_expansion = 0;
        } else {
            Q.economic_expansion += Q.economic_growth;
        }
    }
    if (Q.economic_growth > 0 && Q.reparations <= -2 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth;
    } else if (Q.economic_growth > 0 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth/2;
    }




/// SMALL SETTINGS

Q.progressive_coalition = Q.spd_r + Q.kpd_r + Q.ddp_r + Q.srpd_r + Q.sapd_r + Q.csrp_r;





// === PARTY RELATION GRAVITY ===
// Pulls extreme values back toward centre, stronger the further they are

Q.relation_gravity = function(value) {
    var abs = Math.abs(value);
    
    // Only activates beyond 80, scales up to 100
    if (abs <= 80) return value;
    
    // How far past 80 are we? (0 to 20)
    var excess = abs - 80;
    
    // Pull strength scales with excess: gentle at 81, strong at 100
    var pull = excess * 0.04; // At 100: pulls by 0.8/turn. At 90: pulls by 0.4/turn
    
    // Pull toward centre (opposite sign of value)
    if (value > 0) {
        return value - pull;
    } else {
        return value + pull;
    }
};

var relations = ['z', 'kpd', 'sapd', 'srpd', 'cnbl', 'csvd', 'csrp', 'dhp', 'bb', 'kvp', 'ddp', 'vrp', 'bvp', 'dvp', 'wp', 'dnvp', 'nsdap'];
for (var rel of relations) {
    Q[rel + '_relation'] = Q.relation_gravity(Q[rel + '_relation']);
    // Hard cap just in case
    Q[rel + '_relation'] = Math.max(-100, Math.min(100, Q[rel + '_relation']));
}




































    
    // ============================================================
// OPINION DYNAMICS
// Rule: a party in power takes credit/blame for the economy.
//       A party in opposition gains when its rivals are blamed.
//       Phase-aware: Q.phase modulates which pressures bite hardest.
// ============================================================

// --- Helpers ---
function scale(value, low, high) {
    return Math.max(0, Math.min(1, (value - low) / (high - low)));
}

// --- Base economic stress/relief signals ---
var unemp_stress  = scale(Q.unemployed, 8, 25);
var unemp_relief  = 1 - scale(Q.unemployed, 3, 10);
var inflation_stress = scale(Q.inflation, 5, 15);
var inflation_stable = 1 - scale(Math.abs(Q.inflation), 3, 8);
var growth_boost  = scale(Q.economic_growth, 1, 6);
var growth_penalty = scale(-Q.economic_growth, 1, 10);

// --- Phase multipliers ---
// Each phase amplifies the pressures most associated with it historically.
// Depression: unemployment dominates. Hyperinflation: inflation dominates.
// Stagflation: both hurt, centrists uniquely exposed. Overheating: optimism.
var phase_unemp_mult    = 1.0;
var phase_inflation_mult = 1.0;
var phase_growth_mult   = 1.0;
var phase_centrist_penalty = 0.0; // extra drain on republic when centrists hold bag

switch (Q.phase) {
    case "growth":
        phase_unemp_mult    = 0.7;
        phase_inflation_mult = 0.8;
        phase_growth_mult   = 1.4;
        break;
    case "overheating":
        phase_unemp_mult    = 0.8;
        phase_inflation_mult = 1.3;
        phase_growth_mult   = 1.2;
        break;
    case "hyperinflation":
        // Inflation crisis: nationalists gain most, republic bleeds fast
        phase_unemp_mult    = 0.9;
        phase_inflation_mult = 2.2;
        phase_growth_mult   = 1.0;
        phase_centrist_penalty = 0.8;
        break;
    case "correction":
        phase_unemp_mult    = 1.2;
        phase_inflation_mult = 1.0;
        phase_growth_mult   = 1.3;
        break;
    case "depression":
        // Unemployment crisis: socialism and nationalism both surge
        phase_unemp_mult    = 2.0;
        phase_inflation_mult = 0.7;
        phase_growth_mult   = 1.6;
        phase_centrist_penalty = 1.0;
        break;
    case "stagflation":
        // Both pressures active, neither resolves — uniquely punishes centrists
        phase_unemp_mult    = 1.4;
        phase_inflation_mult = 1.4;
        phase_growth_mult   = 1.2;
        phase_centrist_penalty = 1.4;
        break;
}

// Apply phase scaling to base signals
var eff_unemp_stress   = unemp_stress   * phase_unemp_mult;
var eff_unemp_relief   = unemp_relief   * (2.0 - phase_unemp_mult); // relief shrinks when phase amplifies stress
var eff_inflation_stress = inflation_stress * phase_inflation_mult;
var eff_inflation_stable = inflation_stable * (2.0 - phase_inflation_mult);
var eff_growth_boost   = growth_boost   * phase_growth_mult;
var eff_growth_penalty = growth_penalty * phase_growth_mult;

// Clamp effective values so multipliers don't push past [0,1] range on base signals
eff_unemp_relief    = Math.max(0, Math.min(1, eff_unemp_relief));
eff_inflation_stable = Math.max(0, Math.min(1, eff_inflation_stable));

// --- Economy state flags ---
var economy_good  = (Q.unemployed < 8 && Q.inflation > -2 && Q.inflation < 6 && Q.economic_growth > 1);
var economy_bad   = (Q.unemployed > 15 || Math.abs(Q.inflation) > 8 || Q.economic_growth < -2);
var economy_mixed = !economy_good && !economy_bad;

// --- Party bloc counts and influence ---
var socialist_party_count  = 0;
var centrist_party_count   = 0;
var nationalist_party_count = 0;

if (Q.ideology === "left" && Q.spd_in_government) socialist_party_count++;
if (Q.kpd_in_government)  socialist_party_count++;
if (Q.sapd_in_government) socialist_party_count++;

if (Q.spd_in_government && Q.ideology !== "left") centrist_party_count++;
if (Q.z_in_government)    centrist_party_count++;
if (Q.ddp_in_government)  centrist_party_count++;
if (Q.dvp_in_government && (Q.dvp_right_shift || 0) < 1) centrist_party_count++;
if (Q.srpd_in_government) centrist_party_count++;
if (Q.wp_in_government)   centrist_party_count++;
if (Q.bvp_in_government)  centrist_party_count++;
if (Q.dnvp_in_government && Q.dnvp_line === 1) centrist_party_count++;

if (Q.dnvp_in_government && Q.dnvp_line !== 1) nationalist_party_count++;
if (Q.cnbl_in_government)  nationalist_party_count++;
if (Q.nsdap_in_government) nationalist_party_count++;
if (Q.dvp_in_government && (Q.dvp_right_shift || 0) >= 1) nationalist_party_count++;

// 1 party = 0.35, 2 = 0.70, 3+ = 1.0
var socialist_influence  = Math.min(socialist_party_count  * 0.35, 1.0);
var centrist_influence   = Math.min(centrist_party_count   * 0.25, 1.0);
var nationalist_influence = Math.min(nationalist_party_count * 0.35, 1.0);

var socialist_in_power   = socialist_party_count > 0;
var centrist_in_power    = centrist_party_count > 0;
var nationalist_in_power = nationalist_party_count > 0;

// ============================================================
// PRO_REPUBLIC
// ============================================================
// Republic is tied to economic stability, not ideology.
// Good economy helps it regardless of who governs.
// Bad economy hurts it, especially without a strong anchor party.
// Phase centrist_penalty bleeds republic when the moderate bloc
// is left holding an unsolvable crisis (depression, stagflation).

var pr_push = 0;
var pr_pull = 0;

if (economy_good) {
    pr_push += (eff_unemp_relief * 2.0) + (eff_inflation_stable * 1.0) + (eff_growth_boost * 1.5);
}

if (economy_bad) {
    pr_pull += (eff_unemp_stress * 3.5) + (eff_inflation_stress * 1.5) + (eff_growth_penalty * 3.0);

    // Weak government anchor accelerates republic decline
    if (!Q.spd_in_government && !Q.z_in_government) {
        pr_pull += 1.0;
    }

    // Centrist-only government in an unsolvable crisis bleeds republic
    // (they're blamed for inaction on problems ideology can't fix)
    if (centrist_in_power && !socialist_in_power && !nationalist_in_power) {
        pr_pull += phase_centrist_penalty * centrist_influence;
    }
}

var pr_delta = (pr_push - pr_pull) * 0.65;

// Soft ceiling/floor — diminishing returns near extremes
if (pr_delta > 0 && Q.pro_republic > 70) pr_delta *= (1 - scale(Q.pro_republic, 70, 90));
if (pr_delta < 0 && Q.pro_republic < 25) pr_delta *= (1 - scale(25 - Q.pro_republic, 0, 15));

Q.pro_republic += pr_delta;

// ============================================================
// NATIONALISM
// ============================================================
// Gains from economic pain when NOT in power.
// Gains credit when IN power during good times.
// Takes blame when IN power during bad times.
// Hyperinflation phase specifically boosts nationalism (scapegoating, foreign blame).
// Depression phase also boosts it but more gradually (unemployment-driven).

var nat_push = 0;
var nat_pull = 0;

if (economy_bad) {
    nat_push += (eff_unemp_stress * 4.0) + (eff_inflation_stress * 1.5) + (eff_growth_penalty * 3.0);

    if (nationalist_in_power) {
        // In power during crisis: takes proportional blame
        nat_pull += 2.0 * nationalist_influence;
    }

    if (socialist_in_power || centrist_in_power) {
        // Rivals are in power during crisis: nationalism gains as opposition
        var other_influence = Math.max(socialist_influence, centrist_influence);
        nat_push += 1.5 * other_influence;
    }
}

if (economy_good) {
    nat_pull += (eff_unemp_relief * 1.5) + (eff_inflation_stable * 1.0);

    if (nationalist_in_power) {
        // In power during good times: takes credit
        nat_push += 1.5 * nationalist_influence;
    }

    if (socialist_in_power) {
        // Left in power during good times: nationalism loses ground
        nat_pull += 1.0 * socialist_influence;
    }
}

var nat_delta = (nat_push - nat_pull) * 0.65;

if (nat_delta > 0 && Q.nationalism > 70) nat_delta *= (1 - scale(Q.nationalism, 70, 90));
if (nat_delta < 0 && Q.nationalism < 20) nat_delta *= (1 - scale(20 - Q.nationalism, 0, 15));

Q.nationalism += nat_delta;

// ============================================================
// SOCIALISM
// ============================================================
// Mirror of nationalism logic but on the left axis.
// Depression phase hits unemp_stress hardest — socialism's natural terrain.
// Gains when nationalists or centrists hold power during a crisis.
// Takes blame when in power during a crisis.

var soc_push = 0;
var soc_pull = 0;

if (economy_bad) {
    soc_push += (eff_unemp_stress * 4.0) + (eff_inflation_stress * 1.2) + (eff_growth_penalty * 2.5);

    if (socialist_in_power) {
        soc_pull += 2.0 * socialist_influence;
    }

    if (nationalist_in_power && !Q.in_grand_coalition) {
        // Right in power during crisis: socialism gains as opposition
        soc_push += 1.5 * nationalist_influence;
    }
}

if (economy_good) {
    soc_pull += (eff_unemp_relief * 1.5) + (eff_inflation_stable * 1.0);

    if (socialist_in_power) {
        soc_push += 1.5 * socialist_influence;
    }

    if (nationalist_in_power && !socialist_in_power) {
        // Right in power during good times: socialism loses ground
        soc_pull += 1.0 * nationalist_influence;
    }
}

var soc_delta = (soc_push - soc_pull) * 0.65;

if (soc_delta > 0 && Q.socialism > 70) soc_delta *= (1 - scale(Q.socialism, 70, 90));
if (soc_delta < 0 && Q.socialism < 20) soc_delta *= (1 - scale(20 - Q.socialism, 0, 15));

Q.socialism += soc_delta;

// ============================================================
// COMPETENCE COUNTERS
// Tracks sustained good/bad performance to build or destroy legitimacy.
// FIX: Previously soc_pull/nat_pull were modified AFTER soc_delta/nat_delta
// were already computed, so those multiplications did nothing.
// Now legitimacy bonuses apply directly to the opinion variable.
// ============================================================

if (Q.socialist_govt_success_counter  === undefined) Q.socialist_govt_success_counter  = 0;
if (Q.nationalist_govt_success_counter === undefined) Q.nationalist_govt_success_counter = 0;

if (economy_good && socialist_in_power) {
    Q.socialist_govt_success_counter += socialist_influence;
    if (Q.socialist_govt_success_counter > 4) {
        // Sustained good performance builds genuine legitimacy
        Q.socialism += 0.15 * socialist_influence;
    }
} else if (economy_bad && socialist_in_power) {
    Q.socialist_govt_success_counter = Math.max(0,
        Q.socialist_govt_success_counter - socialist_influence);
}

if (economy_good && nationalist_in_power) {
    Q.nationalist_govt_success_counter += nationalist_influence;
    if (Q.nationalist_govt_success_counter > 4) {
        Q.nationalism += 0.15 * nationalist_influence;
    }
} else if (economy_bad && nationalist_in_power) {
    Q.nationalist_govt_success_counter = Math.max(0,
        Q.nationalist_govt_success_counter - nationalist_influence);
}

// ============================================================
// CROSS-PRESSURE
// When an extreme rises, republic bleeds proportionally.
// If both rise simultaneously, effects are additive — no cap.
// The losing extreme also nudges the other down (they compete for the same
// alienated voter pool, so one dominating crowds out the other).
// ============================================================

if (Q.nationalism > 40 || Q.socialism > 40) {

    // Republic bleeds from each rising extreme independently
    if (nat_delta > 0) {
        Q.pro_republic -= nat_delta * 0.25;
    }
    if (soc_delta > 0) {
        Q.pro_republic -= soc_delta * 0.25;
    }

    // Extremes compete: whichever gained less gets nudged down
    // (they're drawing from the same pool of republic-skeptic voters)
    if (nat_delta > 0 && soc_delta > 0) {
        // Both rising: smaller one gets crowded out
        if (nat_delta > soc_delta) {
            Q.socialism -= (nat_delta - soc_delta) * 0.15;
        } else if (soc_delta > nat_delta) {
            Q.nationalism -= (soc_delta - nat_delta) * 0.15;
        }
    } else if (nat_delta > 0 && soc_delta <= 0) {
        // Only nationalism rising: nudges socialism down (and vice versa)
        Q.socialism -= nat_delta * 0.15;
    } else if (soc_delta > 0 && nat_delta <= 0) {
        Q.nationalism -= soc_delta * 0.15;
    }
}

// ============================================================
// BROKEN PROMISES
// Parties in power during severe crises take ideology-specific damage.
// ============================================================

if (economy_bad) {
    // Socialists: unemployment is their core promise — high unemployment is a betrayal
    if (socialist_in_power && Q.unemployed > 20) {
        Q.socialism    -= 0.5  * socialist_influence;
        Q.pro_republic -= 0.15 * socialist_influence;
    }

    // Nationalists: inflation and collapse are their core failure modes
    if (nationalist_in_power && (Q.inflation > 15 || Q.economic_growth < -5)) {
        Q.nationalism  -= 0.5  * nationalist_influence;
        Q.pro_republic -= 0.15 * nationalist_influence;
    }

    // Centrist-only government: neither extreme takes blame, so both gain
    // and the republic pays the price for having no strong anchor
    if (!socialist_in_power && !nationalist_in_power && centrist_in_power) {
        Q.socialism    += 0.3 * centrist_influence;
        Q.nationalism  += 0.3 * centrist_influence;
        Q.pro_republic -= 0.3 * centrist_influence;
    }
}

// ============================================================
// HISTORICAL PRECEDENT (scaled version)
// Past crisis victories/failures compound over time, scaled by
// how many parties of that bloc are currently in government.
// ============================================================

if (Q.spd_crisis_victories && Q.spd_crisis_victories > 0
        && economy_good && socialist_in_power) {
    Q.socialism += 0.1 * Q.spd_crisis_victories * socialist_influence;
}

if (Q.nationalist_crisis_failures && Q.nationalist_crisis_failures > 0
        && nationalist_in_power) {
    Q.nationalism -= 0.07 * Q.nationalist_crisis_failures * nationalist_influence;
}

// ============================================================
// CLAMP & ROUND
// ============================================================

Q.pro_republic = Math.round(Math.max(0, Math.min(100, Q.pro_republic)) * 10) / 10;
Q.nationalism  = Math.round(Math.max(0, Math.min(100, Q.nationalism))  * 10) / 10;
Q.socialism    = Math.round(Math.max(0, Math.min(100, Q.socialism))    * 10) / 10;













// =========================== CABINET ECONOMICAL EFFECTS ====================




// ============================================================
// BRÜNING AUSTERITY / LAUTENBACH PLAN — mutually exclusive
// ============================================================

if (Q.bruning_cabinet === 1 && Q.lautenbach_plan_active !== 1 && Q.lautenbach_plan_rejected === 1) {

    // Budget improves modestly — spending cuts and tax enforcement
    Q.budget += 0.18;

    // Deflation pressure — wage cuts, price controls, tight money
    Q.dInflation        -= 0.12;
    Q.price_pressure    -= 0.06;

    // Demand collapses — less public spending, lower wages
    Q.demand_impulse    -= 0.09;
    Q.fiscal_stance     -= 0.07;

    // Unemployment creeps up — layoffs from public sector cuts
    Q.dUnemployment     += 0.08;

    // Capital pressure eases slightly — creditor confidence
    Q.capital_pressure  -= 0.04;

    // Trade pressure eases — deflation makes exports cheaper
    Q.trade_pressure    -= 0.03;

} else if (Q.bruning_cabinet === 1 && Q.lautenbach_plan_active === 1 && !Q.return_to_normalcy) {

    // --------------------------------------------------------
    // LAUTENBACH PLAN — credit-financed public investment
    // Semi-WTB, pre-Keynesian demand stimulus
    // Overrides austerity but carries inflation/debt risk
    // --------------------------------------------------------

    // Budget takes a hit — deficit spending is the mechanism
    Q.budget            -= 0.20;

    // Demand recovers — public works and credit expansion
    Q.demand_impulse    += 0.12;
    Q.fiscal_stance     += 0.10;

    // Supply side benefits — infrastructure investment
    Q.supply_impulse    += 0.06;

    // Unemployment falls slightly — job creation programs
    Q.dUnemployment     -= 0.07;

    // Growth gets a nudge upward
    Q.dGrowth           += 0.08;

    // Inflation creeps back up — more money chasing goods
    Q.dInflation        += 0.07;
    Q.price_pressure    += 0.04;

    // Capital pressure rises — creditors nervous about deficit
    Q.capital_pressure  += 0.05;

    // Trade pressure ticks up slightly — imports rise with demand
    Q.trade_pressure    += 0.03;
}


if (Q.wagemann_plan_active === 1 && Q.year >= 1932 && Q.year < 1933) {
    Q.lautenbach_plan_active = 0;
    Q.lautenbach_plan_rejected = 0;
    

    // Money supply expansion — core of the Wagemann mechanism
    // Directly pressures inflation expectations
    Q.dInflation                += 0.14;
    Q.price_pressure            += 0.08;
    Q.inflation_expectations    += 0.06;

    // If expectations already unanchored, spiral risk kicks in
    // Wagemann's plan was terrifying to anyone who remembered 1923
    if (!Q.expectations_anchored) {
        Q.dInflation            += 0.10;
        Q.price_pressure        += 0.06;
        Q.inflation_expectations+= 0.08;
    }

    // Demand recovers — reflation puts money into circulation
    Q.demand_impulse            += 0.10;
    Q.credit_expansion          += 0.06;

    // Unemployment nudges down — but slower than Lautenbach
    // Monetary stimulus is less targeted than direct job creation
    Q.dUnemployment             -= 0.05;

    // Growth benefits modestly
    Q.dGrowth                   += 0.06;

    // Budget is largely neutral — this is monetary not fiscal
    // Slight improvement from tax base recovery
    Q.budget                    += 0.05;

    // Capital flight risk — foreign creditors panic at moneyprinting
    Q.capital_pressure          += 0.08;
    Q.trade_pressure            += 0.05;

    // If inflation already above 4, compounding risk
    // The 1923 memory makes markets overreact
    if (Q.inflation > 4) {
        Q.capital_pressure      += 0.06;
        Q.dInflation            += 0.05;
    }
}

// ============================================================
// WTB TIMER EFFECTS
// ============================================================

if ((Q.wtb_timer || 0) > 0) {

    const diminish = Q.wtb_implemented >= 4 ? 0.70 : 1.0;

    Q.demand_impulse  = (Q.demand_impulse  || 0) + 0.04  * diminish;
    Q.fiscal_stance   = (Q.fiscal_stance   || 0) - 0.03  * diminish;
    Q.price_pressure  = (Q.price_pressure  || 0) + 0.02  * diminish;
    Q.supply_impulse  = (Q.supply_impulse  || 0) + 0.02  * diminish;
    Q.capital_pressure = Math.max(0, (Q.capital_pressure || 0) - 0.01 * diminish);
}




















// === PARTY RELATIONS DYNAMIC PATCH (runs every tick) ===

// KPD
Q.party_relations.KPD.SPD  = Q.kpd_relation;
Q.party_relations.KPD.SRPD = Q.kpd_relation + 5;
Q.party_relations.KPD.SAPD = 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0);

// SAPD
Q.party_relations.SAPD.SPD = 55 + (Q.left_strength >= 50 ? 15 : 0);
Q.party_relations.SAPD.KPD = 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0);

// SPD
Q.party_relations.SPD.KPD  = Q.kpd_relation;
Q.party_relations.SPD.DDP  = Q.ddp_relation;
Q.party_relations.SPD.Z    = Q.z_relation;
Q.party_relations.SPD.BVP  = Q.bvp_relation  ?? 35;
Q.party_relations.SPD.DVP  = Q.dvp_relation;
Q.party_relations.SPD.CSRP = Q.csrp_relation;
Q.party_relations.SPD.WP   = Q.wp_relation   ?? 25;
Q.party_relations.SPD.CNBL = Q.cnbl_relation  ?? 20;
Q.party_relations.SPD.CSVD = Q.csvd_relation  ?? 35;
Q.party_relations.SPD.DNVP = Q.dnvp_relation;
Q.party_relations.SPD.VRP  = Q.vrp_relation   ?? 20;
Q.party_relations.SPD.NSDAP= Q.nsdap_relation;
Q.party_relations.SPD.KVP  = Q.kvp_relation;
Q.party_relations.SPD.DHP  = Q.dhp_relation;
Q.party_relations.SPD.BB   = Q.bb_relation;

// SRPD
Q.party_relations.SRPD.KPD  = Q.kpd_relation - 10;
Q.party_relations.SRPD.DDP  = Q.ddp_relation + 10;
Q.party_relations.SRPD.Z    = Q.z_relation + 5;
Q.party_relations.SRPD.BVP  = (Q.bvp_relation  ?? 35) + 5;
Q.party_relations.SRPD.DVP  = Q.dvp_relation - 5;
Q.party_relations.SRPD.CSRP = Q.csrp_relation + 5;
Q.party_relations.SRPD.WP   = (Q.wp_relation   ?? 25) - 5;
Q.party_relations.SRPD.CNBL = (Q.cnbl_relation  ?? 20) + 5;
Q.party_relations.SRPD.CSVD = (Q.csvd_relation  ?? 35) + 5;
Q.party_relations.SRPD.DNVP = Q.dnvp_line === 3 ? 0 : Q.dnvp_relation - 10;

// DDP
Q.party_relations.DDP.SPD  = Q.ddp_relation;
Q.party_relations.DDP.SRPD = Q.ddp_relation + 10;
Q.party_relations.DDP.DVP  = 65 - (Q.dvp_right_shift ?? 0) * 10;

// Z
Q.party_relations.Z.SPD    = Q.z_relation;
Q.party_relations.Z.SRPD   = Q.z_relation + 5;
Q.party_relations.Z.DVP    = 60 + (Q.z_party_leader === "Kaas" ? 10 : 0);
Q.party_relations.Z.DNVP   = (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10);
Q.party_relations.Z.NSDAP  = Q.nazi_urgency >= 7 ? 0 : Math.max(0, 25 - Q.nazi_urgency * 5);

// BVP
Q.party_relations.BVP.SPD   = Q.bvp_relation ?? 35;
Q.party_relations.BVP.SRPD  = (Q.bvp_relation ?? 35) + 5;
Q.party_relations.BVP.NSDAP = Math.max(0, 15 - Q.nazi_urgency * 3);

// DVP
Q.party_relations.DVP.SPD   = Q.dvp_relation;
Q.party_relations.DVP.SRPD  = Q.dvp_relation - 5;
Q.party_relations.DVP.DDP   = 65 - (Q.dvp_right_shift ?? 0) * 10;
Q.party_relations.DVP.Z     = 60 + (Q.z_party_leader === "Kaas" ? 10 : 0);
Q.party_relations.DVP.DNVP  = 50 + (Q.dvp_right_shift ?? 0) * 15;
Q.party_relations.DVP.NSDAP = 20 + (Q.capital_strike_progress * 6) + (Q.dvp_right_shift ?? 0) * 12;

// WP
Q.party_relations.WP.SPD   = Q.wp_relation ?? 25;
Q.party_relations.WP.SRPD  = (Q.wp_relation ?? 25) - 5;
Q.party_relations.WP.NSDAP = 35 + (Q.capital_strike_progress * 4);

// CNBL
Q.party_relations.CNBL.SPD   = Q.cnbl_relation ?? 20;
Q.party_relations.CNBL.SRPD  = (Q.cnbl_relation ?? 20) + 5;
Q.party_relations.CNBL.NSDAP = 30 + (Q.capital_strike_progress * 4) + (Q.year >= 1930 ? 10 : 0);

// CSVD
Q.party_relations.CSVD.SPD  = Q.csvd_relation ?? 40;
Q.party_relations.CSVD.SRPD = (Q.csvd_relation ?? 40) + 5;
Q.party_relations.CSVD.DNVP = Q.dnvp_line === 3 ? 5 : 55;

// DNVP
Q.party_relations.DNVP.SPD  = Q.dnvp_relation;
Q.party_relations.DNVP.SRPD = Q.dnvp_relation - 5;
Q.party_relations.DNVP.DDP  = Q.dnvp_line === 3 ? 5 : 30;
Q.party_relations.DNVP.Z    = (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10);
Q.party_relations.DNVP.CSVD = Q.dnvp_line === 3 ? 5 : 55;
Q.party_relations.DNVP.NSDAP= Q.dnvp_line === 3 ? 70 : 40;
Q.party_relations.DNVP.KVP  = Q.dnvp_line === 3 ? 5 : 60;
Q.party_relations.DNVP.DHP  = Q.dnvp_line === 3 ? 15 : 55;

// NSDAP
Q.party_relations.NSDAP.Z    = Q.nazi_urgency >= 7 ? 0 : Math.max(0, 20 - Q.nazi_urgency * 4);
Q.party_relations.NSDAP.BVP  = Math.max(0, 15 - Q.nazi_urgency * 3);
Q.party_relations.NSDAP.DVP  = 20 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift ?? 0) * 10;
Q.party_relations.NSDAP.WP   = 30 + (Q.capital_strike_progress * 3);
Q.party_relations.NSDAP.DNVP = Q.dnvp_line === 3 ? 70 : 40;
Q.party_relations.NSDAP.VRP  = 25 + (Q.capital_strike_progress * 3);

// VRP
Q.party_relations.VRP.SPD  = Q.vrp_relation;
Q.party_relations.VRP.DNVP = Q.dnvp_line === 3 ? 10 : 35;




// === COALITION BLOCKS DYNAMIC PATCH (runs every tick) ===

if (!Q.coalition_blocks) {
    // Blocks not initialized yet — skip patch this tick
} else {

Q.coalition_blocks.KPD_Z     = Q.z_relation < 65 || Q.kpd_relation < 65;
Q.coalition_blocks.KPD_DDP   = Q.kpd_relation < 65;
Q.coalition_blocks.KPD_SPD   = Q.communist_coalition < 3;

Q.coalition_blocks.SPD_DNVP  = Q.dnvp_relation < 60 || Q.dnvp_line === 3;
Q.coalition_blocks.SPD_KPD   = Q.communist_coalition < 3;
Q.coalition_blocks.SPD_VRP   = Q.vrp_relation < 35;

Q.coalition_blocks.SRPD_KPD  = Q.kpd_relation < 40;
Q.coalition_blocks.SRPD_DNVP = Q.dnvp_line === 3;
Q.coalition_blocks.SRPD_VRP  = Q.vrp_relation < 30;

Q.coalition_blocks.DDP_DNVP  = Q.dnvp_line === 3;

Q.coalition_blocks.Z_KPD     = Q.kpd_relation < 65 || Q.z_relation < 45;
Q.coalition_blocks.Z_NSDAP   = Q.nazi_urgency >= 6;
Q.coalition_blocks.Z_DNVP    = Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas";

Q.coalition_blocks.BVP_NSDAP = Q.nazi_urgency >= 6;

Q.coalition_blocks.DVP_NSDAP = Q.nazi_urgency >= 7 && Q.capital_strike_progress < 4;
Q.coalition_blocks.DVP_VRP   = Q.dvp_right_shift >= 2;

Q.coalition_blocks.WP_NSDAP  = Q.capital_strike_progress < 5;

Q.coalition_blocks.CNBL_SPD  = Q.cnbl_relation < 30;

Q.coalition_blocks.DNVP_SPD  = Q.dnvp_line === 3 || Q.dnvp_relation < 40;
Q.coalition_blocks.DNVP_DDP  = Q.dnvp_line === 3;
Q.coalition_blocks.DNVP_Z    = Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas";
Q.coalition_blocks.DNVP_VRP  = Q.dnvp_line === 3;

Q.coalition_blocks.NSDAP_BVP = Q.nazi_urgency >= 6;
Q.coalition_blocks.NSDAP_Z   = Q.nazi_urgency >= 6;
Q.coalition_blocks.NSDAP_COALITIONS_GENERALLY = Q.nsdap_r < 35 || Q.year < 1932;

Q.coalition_blocks.VRP_DNVP  = Q.dnvp_line === 3;
Q.coalition_blocks.VRP_DVP   = Q.dvp_right_shift >= 1;
Q.coalition_blocks.VRP_SPD   = Q.vrp_relation < 35;

Q.coalition_blocks.KVP_DNVP  = Q.dnvp_line === 3;

Q.coalition_blocks.DHP_NSDAP = Q.nazi_urgency >= 5;

Q.coalition_blocks.BB_NSDAP  = Q.nazi_urgency >= 7;

}












// ============================================================
// IDENTITY POPULATION DRIFT
// These are overlapping shares, not a normalized pool.
// ============================================================

// --- SECULARS ---
// Grows slowly with education and science policy
// Shrinks if traditional curriculum dominates
Q.secular_growth = 0;
if (Q.education_science >= 2)   Q.secular_growth += 0.08;
if (Q.education_science >= 4)   Q.secular_growth += 0.06;
if (Q.secularized >= 1)         Q.secular_growth += 0.10;
if (Q.major_curriculum === 'traditional') Q.secular_growth -= 0.10;
if (Q.minor_curriculum === 'traditional') Q.secular_growth -= 0.05;
// Baseline slow drift upward — modernization is a tide
Q.secular_growth += 0.02;
Q.seculars = Math.max(3, Math.min(40, Q.seculars + Q.secular_growth));

// --- CATHOLICS ---
// Mostly stable — shifts only from major events
// Slow natural decline as seculars grow, mostly from Protestant pool
Q.catholics = Math.max(20, Math.min(40, Q.catholics - Q.secular_growth * 0.3));

// --- PROTESTANTS ---
// Derived residual — takes the bulk of secular drift loss
Q.protestants = Math.max(30, Math.min(75, 100 - Q.catholics - Q.seculars));

// --- YOUTH ---
// 18-30 cohort radicalization level, not raw population share
// Rises with economic crisis, street violence, unemployment
// Falls with stability, successful youth policy
Q.youth_crisis_pressure = 0;
Q.youth_crisis_pressure += Math.max(0, Q.unemployed - 8) * 0.15;
Q.youth_crisis_pressure += Math.max(0, -Q.economic_growth) * 0.10;
Q.youth_crisis_pressure += ((Q.sa_strength * Q.sa_militancy) + 
                            (Q.rfb_strength * Q.rfb_militancy)) / 8000;
// Normalization pressure — always pulls back toward baseline over time
Q.youth_normalization = (Q.youth - 18) * 0.05;
// Policy counters
Q.youth_policy_effect = 0;
if (Q.youth_organizations >= 1) Q.youth_policy_effect -= 0.15 * Q.youth_organizations;
if (Q.education_science >= 2)   Q.youth_policy_effect -= 0.08;
if (Q.womens_rights >= 2)       Q.youth_policy_effect -= 0.04;

Q.youth = Math.max(10, Math.min(55, 
    Q.youth + Q.youth_crisis_pressure - Q.youth_normalization + Q.youth_policy_effect
));







// ============================================================
// IDENTITY MODIFIERS
// Applied to ideology_caps.base as multipliers.
// Each variable is a population share 0-100.
// Normalized to 0-1 for multiplication.
// ============================================================

var cath_share  = Q.catholics  / 100;
var prot_share  = Q.protestants / 100;
var sec_share   = Q.seculars   / 100;
var youth_share = Q.youth      / 100;

// Pre-compute identity bonuses/penalties per party
// Format: base multiplier applied after all other cap calculations
Q.identity_modifier = {
    // SPD: secular and youth friendly, loses ground with catholics
    spd:   1 + (sec_share * 0.20) + (youth_share * 0.08) - (cath_share * 0.10),

    // SRPD: similar to SPD
    srpd:  1 + (sec_share * 0.15) + (youth_share * 0.06) - (cath_share * 0.08),

    // KPD: strongly secular, youth volatile — gains youth in crisis
    kpd:   1 + (sec_share * 0.30) + (youth_share * 0.15) - (cath_share * 0.15),

    // SAPD: similar to KPD but weaker
    sapd:  1 + (sec_share * 0.20) + (youth_share * 0.10) - (cath_share * 0.10),

    // NSDAP: Protestant and youth are its hunting ground
    // Catholics resist strongly, seculars partially resist
    nsdap: 1 + (prot_share * 0.25) + (youth_share * 0.35) 
             - (cath_share * 0.40) - (sec_share * 0.10),

    // DNVP: Protestant conservative base, loses youth
    dnvp:  1 + (prot_share * 0.20) - (youth_share * 0.15) - (cath_share * 0.10),

    // DVP: secular liberal business, loses catholics and youth extremes
    dvp:   1 + (sec_share * 0.15) + (prot_share * 0.10) - (youth_share * 0.12),

    // DDP: strongly secular, loses heavily in crisis youth environment
    ddp:   1 + (sec_share * 0.25) + (prot_share * 0.05) - (youth_share * 0.20),

    // Z: Catholic party — catholic share is its lifeline
    z:     1 + (cath_share * 0.60) - (sec_share * 0.30) - (youth_share * 0.10),

    // BVP: same as Z, even more catholic-dependent
    bvp:   1 + (cath_share * 0.70) - (sec_share * 0.35) - (youth_share * 0.08),

    // CNBL: rural Protestant, weak youth appeal
    cnbl:  1 + (prot_share * 0.15) - (youth_share * 0.10),

    // WP: middle class secular-ish, neutral on religion
    wp:    1 + (sec_share * 0.10) - (youth_share * 0.18),

    // CSVD: Protestant conservative, anti-Nazi but still nationalist
    csvd:  1 + (prot_share * 0.20) - (youth_share * 0.12) - (cath_share * 0.08),

    // CSRP: small, secular-left
    csrp:  1 + (sec_share * 0.15) - (cath_share * 0.10),

    // VRP: secular, youth hostile
    vrp:   1 + (sec_share * 0.10) - (youth_share * 0.25),

    // BB: rural Protestant agrarian
    bb:    1 + (prot_share * 0.12) - (youth_share * 0.08),

    // DHB: Protestant conservative regional
    dhp:   1 + (prot_share * 0.15) - (youth_share * 0.10),

    // KVP: Protestant moderate conservative
    kvp:   1 + (prot_share * 0.12) - (youth_share * 0.15),

    // OTHER: catch-all, slight youth boost (protest votes)
    other: 1 + (youth_share * 0.10)
};














    
    // --- Begin Reworked Randomized Monthly Party Drift ---

    Q.drift_base = 1.13;

    // Dynamic factors with randomness
    if (Q.inflation >= 0) {
        Q.inflation_component = Q.inflation / 5;          // positive inflation
    } else {
        Q.inflation_component = Math.abs(Q.inflation) / 3; // deflation is worse
    };

    // === EXPONENTIAL UNREST FACTOR (FIXED) ===
    Q.unemployment_threshold = 7.0;  // Lower threshold (7% is "full employment" for Weimar)
    Q.inflation_threshold = 3.0;     // Lower threshold (3% is normal)

    Q.unemployment_excess = Math.max(0, Q.unemployed - Q.unemployment_threshold);

    // Deflation handling
    if (Q.inflation >= 0) {
        Q.inflation_excess = Math.max(0, Q.inflation - Q.inflation_threshold);
    } else {
        // Deflation is WORSE - counts 1.5x
        Q.inflation_excess = Math.abs(Q.inflation) * 1.5;
    }

    // STEEPER exponential curve
    Q.unrest_factor = Q.random_factor(
        0.3 + // Lower baseline
        Math.pow(Q.unemployment_excess / 8, 2.2) + // Steeper exponent (was 2.0)
        Math.pow(Q.inflation_excess / 6, 1.8),     // Steeper inflation penalty
        0.35
    );

    // Cap at reasonable maximum
    Q.unrest_factor = Math.min(Q.unrest_factor, 12.0);


    // FACTORS
    Q.pro_republic_factor = Q.random_factor(
        Math.min(Math.max(Q.pro_republic / 33, 0.5), 1.5), 
        0.15
    );
    Q.nationalism_factor = Q.random_factor(
        Math.min(Math.max(Q.nationalism / 33, 0.5), 1.5), 
        0.20
    );
    Q.socialism_factor = Q.random_factor(
        Math.min(Math.max(Q.socialism / 33, 0.5), 1.5), 
        0.20
    );
    Q.street_pressure_factor = Q.random_factor(Math.min(Math.max((Q.sa_strength * Q.sa_militancy + Q.rfb_strength * Q.rfb_militancy + Q.sh_strength * Q.sh_militancy) / 3500,  0.7 ), 1.8 ), 0.25);

        // Paramilitary influence (randomized)
        // SA is banned if NSDAP is banned
    Q.sa_influence  = Q.nsdap_banned ? 0 : Q.random_factor((Q.sa_strength/100 + Q.sa_militancy) * 0.25, 0.3);
        // Stahlhelm is banned if DNVP is banned or separately
    Q.sh_influence  = (Q.dnvp_banned || Q.sh_banned) ? 0 : Q.random_factor((Q.sh_strength/100 + Q.sh_militancy) * 0.2, 0.25);
    Q.rfb_influence = Q.kpd_banned ? 0 : Q.random_factor((Q.rfb_strength/100 + Q.rfb_militancy) * 0.2, 0.25);
    Q.rb_influence  = Q.random_factor((Q.rb_strength/100 + Q.rb_militancy) * 0.15, 0.25);
       
    // Class-specific scaling
    Q.class_influences = {
        workers:    1.3 + Q.rfb_influence,
        old_middle: 1 + Q.sh_influence,
        new_middle: 1 + Q.sh_influence,
        rural:      1 + Q.sh_influence,
        unemployedc: 1.3 + Q.sa_influence,
        }


    Q.ideology_elasticity = 1.7;

     // === CAMPAIGN FOCUS MODIFIER ===
     // Decays each tick so player must re-campaign to maintain
     if (Q.campaign_intensity > 0) {
         Q.campaign_intensity -= 0.08; // ~12 ticks to fade
     }
     Q.campaign_intensity = Math.max(0, Q.campaign_intensity);

     const ci = Q.campaign_intensity;

     Q.ideology_caps = {
     nsdap: {
        base: Q.nsdap_banned ? 0 : (() => {
        // Nationalism provides a stable floor (3–8% range)
        let nat_floor = Q.nationalism_factor * 8;

        // Crisis ramp — sigmoid shape
        // unrest 0.3 (stable)   → ramp ≈ 0
        // unrest 1.5 (tense)    → ramp ≈ 8
        // unrest 2.5 (crisis)   → ramp ≈ 22
        // unrest 4.0 (collapse) → ramp ≈ 34
        let u = Math.max(0, Q.unrest_factor - 0.4);
        let crisis_ramp = 38 / (1 + Math.exp(-1.4 * (u - 1.8)));

        // Hard ceiling on the combined base before identity modifier
        let raw = Math.min(nat_floor + crisis_ramp, 43);
        return raw * Q.identity_modifier.nsdap;
        })(),
        workers: (() => {
            let m = 0.70;
            if (Q.peoples_party === 1) m *= 1.02;
            return m;
        })(),
        old_middle: (() => {
            let m = 1.35;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.25);
            if (Q.peoples_party === 1) m *= 0.95;
            return m;
        })(),
        new_middle: (() => {
            let m = 1.20;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.20);
            if (Q.peoples_party === 1) m *= 0.95;
            return m;
        })(),
        rural: (() => {
            let m = 1.45;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.22);
            if (Q.peoples_party === 1) m *= 0.95;
            return m;
        })(),
        unemployedc: (() => {
            let m = 1.40;
            m += Math.min(Q.unemployed / 20, 0.60);  // up to 2.00 at 12%+ unemployment
            if (Q.peoples_party === 1) m *= 1.03;
            return m;
        })(),
    },

    dnvp: {
        base: Q.dnvp_banned ? 0 : (() => {
            let nat = Q.nationalism_factor;
            let rep = Q.pro_republic_factor;
            let scale = Q.dnvp_line === 1 ? 
                (nat * 28 * 2.0 + rep * 30 * 1.8) :
                Q.dnvp_line === 3 ?
                (nat * 56 * 2.5) :
                (nat * 56 * 2.2) * Q.identity_modifier.dnvp;
            return scale;
        })(),
        workers: (() => {
            let m = 0.30;
            if (Q.peoples_party === 1) m *= 0.90;
            return m;
        })(),
        old_middle: (() => {
            let m = 1.40;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.28);
            if (Q.peoples_party === 1) m *= 0.95;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.90;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.18);
            if (Q.peoples_party === 1) m *= 0.95;
            return m;
        })(),
        rural: (() => {
            let m = 1.60;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.30);
            if (Q.peoples_party === 1) m *= 0.95;
            return m;
        })(),
        unemployedc: (() => {
            let m = 0.50;
            if (Q.peoples_party === 1) m *= 0.92;
            return m;
        })(),
    },

    dvp: {
        base: Q.dvp_banned ? 0 : (() => {
        let factor = Q.dvp_right_shift 
            ? Q.nationalism_factor * 0.85
            : Q.pro_republic_factor * 0.88;

        // Deflation is bad, inflation is bad, both from opposite ends
        // Optimal around 1-3% inflation
        let inflation_penalty = Math.pow(Math.abs(Q.inflation - 1.5) / 8, 1.4);
        
        // Unemployment damages business confidence directly
        let unemp_penalty = Math.pow(Math.max(0, Q.unemployed - 5) / 15, 1.3);
        
        // Combined economic confidence, floored at 0.15 so DVP doesn't vanish entirely
        let econ_confidence = Math.max(0.15, 1 - inflation_penalty - unemp_penalty);
        
        let scale = Q.dvp_right_shift ? 2.0 : 1.6;
        return factor * 55 * scale * econ_confidence * Q.identity_modifier.dvp;
    })(),
        workers: (() => {
            let m = 0.40;
            if (Q.peoples_party === 1) m *= 0.92;
            return m;
        })(),
        old_middle: (() => {
            let m = 1.30;
            if (Q.dvp_right_shift) {
                let nat = Math.min(Q.nationalism / 100, 1);
                m *= (1 + nat * 0.22);
            }
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        new_middle: (() => {
            let m = 1.40;
            if (Q.dvp_right_shift) {
                let nat = Math.min(Q.nationalism / 100, 1);
                m *= (1 + nat * 0.18);
            }
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        rural: (() => {
            let m = 0.70;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        unemployedc: (() => {
            let m = 0.35;
            if (Q.peoples_party === 1) m *= 0.92;
            return m;
        })(),
    },

    wp: {
        base: Q.wp_banned ? 0 : (() => {
            let rep = Q.pro_republic_factor;
            // Middle class size and inflation sensitivity baked in
            let middle_norm = (Q.old_middle + Q.new_middle) / 102;
            let crisis = 1 + (Q.inflation * 0.18) - (Q.unemployed * 0.12);
            return rep * 37 * middle_norm * Math.max(0.3, crisis) * Q.identity_modifier.wp;
        })(),
        workers: 0.50,
        old_middle: (() => {
            let m = 1.50;
            // Rentiers hit harder by inflation
            m *= (1 + Math.max(0, Q.inflation * 0.008));
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        new_middle: (() => {
            let m = 1.30;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        rural: 0.70,
        unemployedc: 0.50,
    },

    cnbl: {
        base: Q.cnbl_banned ? 0 : (() => {
            let rep = Q.pro_republic_factor;
            let nat = Q.nationalism_factor;
            // Rural population baked into base
            return (rep * 23 + nat * 25) * (1 + Q.rural * 0.012) * Q.identity_modifier.cnbl;
        })(),
        workers: 0.25,
        old_middle: 0.60,
        new_middle: 0.40,
        rural: (() => {
            let m = 1.80;
            // Stronger cap when rural population is high
            m *= (1 + Math.min(Q.rural / 100, 0.4));
            return m;
        })(),
        unemployedc: 0.30,
    },

    kpd: {
        base: Q.kpd_banned ? 0 : (() => {
            let soc = Q.socialism_factor;
            let unr = Q.unrest_factor;
            return soc * 45 * 2.2 * (1 + unr * 0.15) * Q.identity_modifier.kpd;
        })(),
        workers: (() => {
            let m = 1.50;
            if (Q.peoples_party === 1) m *= 1.08;
            return m;
        })(),
        old_middle: (() => {
            let m = 0.20;
            if (Q.peoples_party === 1) m *= 0.92;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.35;
            if (Q.peoples_party === 1) m *= 0.92;
            return m;
        })(),
        rural: (() => {
            let m = 0.15;
            if (Q.peoples_party === 1) m *= 0.92;
            return m;
        })(),
        unemployedc: (() => {
            let m = 1.40;
            if (Q.peoples_party === 1) m *= 1.08;
            return m;
        })(),
    },

    sapd: {
        base: Q.sapd_banned ? 0 : (() => {
            let soc = Q.socialism_factor;
            let unr = Q.unrest_factor;
            return soc * 10 * 2.0 * (1 + unr * 0.12) * Q.identity_modifier.sapd;
        })(),
        workers: (() => {
            let m = 1.30;
            if (Q.peoples_party === 1) m *= 1.07;
            return m;
        })(),
        old_middle: (() => {
            let m = 0.25;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.40;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
        rural: (() => {
            let m = 0.20;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
        unemployedc: (() => {
            let m = 1.20;
            if (Q.peoples_party === 1) m *= 1.07;
            return m;
        })(),
    },

    csrp: {
        base: Q.csrp_banned ? 0 : Q.pro_republic_factor * 16 * Q.identity_modifier.csrp,
        workers: 0.20,
        old_middle: 0.05,
        new_middle: 0.15,
        rural: 0.10,
        unemployedc: 0.30,
    },

    vrp: {
        base: Q.vrp_banned ? 0 : (() => {
            return Q.pro_republic_factor * 10 + Math.max(0, Q.inflation) * 0.05 * Q.identity_modifier.vrp;
        })(),
        workers: 0.25,
        old_middle: 0.01,
        new_middle: 0.10,
        rural: 0.04,
        unemployedc: 0.40,
    },

    srpd: {
        base: Q.srpd_banned ? 0 : (() => {
            let soc = Q.socialism_factor;
            let rep = Q.pro_republic_factor;
            let rb = Q.rb_strength * 0.0008;
            return (soc * 13 * 2.0 + rep * 29 * 1.8 + rb) * Q.identity_modifier.srpd;
        })(),
        workers: (() => {
            let m = 1.25;
            if (Q.peoples_party === 1) m *= 1.06;
            return m;
        })(),
        old_middle: (() => {
            let m = 0.80;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.90;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
        rural: (() => {
            let m = 0.70;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
        unemployedc: (() => {
            let m = 1.10;
            if (Q.peoples_party === 1) m *= 1.06;
            return m;
        })(),
    },

    spd: {
        base: Q.spd_banned ? 0 : (() => {
            let soc = Q.socialism_factor;
            let rep = Q.pro_republic_factor;

            if (Q.peoples_party === 1) {
                soc *= 0.80;
                rep *= 1.15;
            }

            if (Q.ideology === 'left') {
                soc *= 1.15;
                rep *= 0.90;
            } else if (Q.ideology === 'reformist') {
                rep *= 1.10;
                soc *= 0.90;
            } else if (Q.ideology === 'neorev') {
                soc *= 1.05;
                rep *= 1.05;
            }

            // CAMPAIGN BONUS TO BASE CAP
             let campaign_boost = 1.0;
             if (Q.campaign_focus === 'workers' && ci > 0)
                 campaign_boost += ci * 0.54;
             if (Q.campaign_focus === 'new_middle' && ci > 0)
                 campaign_boost += ci * 0.42;
             if (Q.campaign_focus === 'old_middle' && ci > 0)
                 campaign_boost += ci * 0.36;
             if (Q.campaign_focus === 'rural' && ci > 0)
                 campaign_boost += ci * 0.39;
             if (Q.campaign_focus === 'unemployed' && ci > 0)
                 campaign_boost += ci * 0.45;
             if (Q.campaign_focus === 'women' && ci > 0)
                 campaign_boost += ci * 0.30; // spread across classes
             if (Q.campaign_focus === 'middle' && ci > 0)
                 campaign_boost += ci * 0.33;

             return (rep * 105 + soc * 54) * Q.identity_modifier.spd * campaign_boost;
         })(),
        workers: (() => {
            let m = 1.20;
            if (Q.peoples_party === 1) m *= 0.88;
            if (Q.ideology === 'left')      m *= 1.12;
            if (Q.ideology === 'reformist') m *= 0.92;
            if (Q.campaign_focus === 'workers' && ci > 0) m += ci * 0.20;
            if (Q.campaign_focus === 'unemployed' && ci > 0) m += ci * 0.08;
            if (Q.dues_workers > 0) m -= Q.dues_workers * 0.086;
            if (Q.wtb_timer > 0) m += (Q.workers / 100) * 0.75;
            return m;
        })(),
        old_middle: (() => {
            let m = 0.70;
            if (Q.peoples_party === 1) m *= 1.15;
            if (Q.ideology === 'left')      m *= 0.88;
            if (Q.ideology === 'reformist') m *= 1.10;
            if (Q.ideology === 'neorev')    m *= 1.05;
            if (Q.campaign_focus === 'old_middle' && ci > 0) m += ci * 0.16;
            if (Q.campaign_focus === 'middle' && ci > 0) m += ci * 0.12;
            if (Q.campaign_focus === 'women' && ci > 0) m += ci * 0.07;
            if (Q.campaign_focus === 'catholics' && ci > 0) m += ci * 0.12 * (Q.catholics / 35);
            if (Q.dues_old_middle > 0) m -= Q.dues_old_middle * 0.12;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.85;
            if (Q.peoples_party === 1) m *= 1.15;
            if (Q.ideology === 'left')      m *= 0.88;
            if (Q.ideology === 'reformist') m *= 1.10;
            if (Q.ideology === 'neorev')    m *= 1.05;
            if (Q.campaign_focus === 'new_middle' && ci > 0) m += ci * 0.18;
            if (Q.campaign_focus === 'women' && ci > 0) m += ci * 0.10;
            if (Q.campaign_focus === 'middle' && ci > 0) m += ci * 0.12;
            if (Q.campaign_focus === 'catholics' && ci > 0) m += ci * 0.07 * (Q.catholics / 35);
            if (Q.dues_new_middle > 0) m -= Q.dues_new_middle * 0.094;
            if (Q.wtb_timer > 0) m += (Q.new_middle / 100) * 0.27;
            return m;
        })(),
        rural: (() => {
            let m = 0.80;
            if (Q.peoples_party === 1) m *= 1.12;
            if (Q.campaign_focus === 'rural' && ci > 0) m += ci * 0.20;
            if (Q.campaign_focus === 'catholics' && ci > 0) m += ci * 0.13 * (Q.catholics / 35);
            if (Q.dues_rural > 0) m -= Q.dues_rural * 0.11;
            return m;
        })(),
        unemployedc: (() => {
            let m = 1.10;
            if (Q.peoples_party === 1) m *= 0.88;
            if (Q.ideology === 'left') m *= 1.10;
            if (Q.campaign_focus === 'unemployed' && ci > 0) m += ci * 0.22;
            if (Q.campaign_focus === 'workers' && ci > 0) m += ci * 0.08;
            if (Q.dues_unemployedc > 0) m -= Q.dues_unemployedc * 0.086;
            if (Q.dues_unemployedc == 0) m *= 1.17;
            if (Q.wtb_timer > 0) m += (Q.unemployedc / 100) * 1.03;
            return m;
        })(),
    },

    ddp: {
        base: Q.ddp_banned ? 0 : (() => {
            let rep = Q.pro_republic_factor;
            let nat = Q.nationalism_factor;
            // Education bonuses baked into base cap
            let edu_bonus = (Q.education_science || 0) * 0.03
                          + (Q.secularized || 0) * 0.05
                          + (Q.science || 0) * 0.10
                          + (Q.womens_rights || 0) * 0.05;
            if (!Q.ddp_name || Q.ddp_name === "DDP") {
                let sec_bonus = (100 - Q.catholics) / 100 * 0.10;
                let nat_pen = (Q.nationalism / 100) * 0.15;
                return (rep * 53 * (1.1 + sec_bonus - nat_pen + edu_bonus)) * Q.identity_modifier.ddp;
            } else {
                // DStP
                let jungdo = (Q.jungdo_strength || 0) * 0.0003;
                let edu_pen = (Q.education_science || 0) * 0.01
                            + (Q.secularized || 0) * 0.05
                            + (Q.science || 0) * 0.10
                            + (Q.womens_rights || 0) * 0.05;
                return (rep * 0.39 + nat * 0.29 + jungdo - edu_pen) * 59 * Q.identity_modifier.ddp;
            }
        })(),
        workers: (() => {
            let m = (!Q.ddp_name || Q.ddp_name === "DDP") ? 0.60 : 0.50;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
        old_middle: (() => {
            let m = (!Q.ddp_name || Q.ddp_name === "DDP") ? 0.85 : 1.05;
            if (Q.peoples_party === 1) m *= 1.08;
            return m;
        })(),
        new_middle: (() => {
            let m = (!Q.ddp_name || Q.ddp_name === "DDP") ? 1.40 : 1.10;
            if (Q.peoples_party === 1) m *= 1.08;
            // Education science bonus to new middle cap
            if (Q.education_science >= 2 || Q.womens_rights >= 3) m *= 1.05;
            return m;
        })(),
        rural: (() => {
            let m = (!Q.ddp_name || Q.ddp_name === "DDP") ? 0.50 : 1.15;
            if (Q.peoples_party === 1) m *= 1.05;
            return m;
        })(),
        unemployedc: (() => {
            let m = 0.55;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
    },

    z: {
        base: Q.z_banned ? 0 : (() => {
            let rep = Q.pro_republic_factor;
            let cath_bonus = Q.catholics / 12;
            let leader_mod = Q.z_party_leader === "Kaas" ? 0.94 :
                             Q.z_party_leader === "Joos" ? 1.06 : 1.0;
            let gov_mod = Q.z_in_government ? 1.12 : 0.93;
            return (rep * 85 + cath_bonus) * leader_mod * gov_mod * Q.identity_modifier.z;
        })(),
        workers: (() => {
            let m = 0.80;
            if (Q.z_party_leader !== "Kaas") m *= 1.03;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
        old_middle: (() => {
            let m = 1.10;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.90;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        rural: (() => {
            let m = 1.05;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        unemployedc: (() => {
            let m = 0.70;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
    },

    bvp: {
        base: Q.bvp_banned ? 0 : (() => {
            let rep = Q.pro_republic_factor;
            let cath = Q.catholics * 0.05;
            let rur  = Q.rural * 0.03;
            return Math.min(4.5, rep * 30 * Q.identity_modifier.bvp + cath + rur);
        })(),
        workers: (() => {
            let m = 0.80;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
        old_middle: (() => {
            let m = 1.10;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        new_middle: (() => {
            let m = 0.90;
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        rural: (() => {
            let m = 1.15;
            m *= (1 + Math.min(Q.rural / 100, 0.25));
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        unemployedc: (() => {
            let m = 0.70;
            if (Q.peoples_party === 1) m *= 0.94;
            return m;
        })(),
    },

    csvd: {
        base: Q.csvd_banned ? 0 : (() => {
            let nat = Q.nationalism_factor || Q.random_factor(
                Math.min(Math.max(Q.nationalism / 33, 0.5), 1.5), 0.20
            );
        return nat * 26 * 2.3 * Q.identity_modifier.csvd;
        })(),
        workers: (() => {
            let m = 0.50;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
        old_middle: (() => {
            let m = 1.20;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.22);
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        new_middle: (() => {
            let m = 1.10;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.18);
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        rural: (() => {
            let m = 1.30;
            let nat = Math.min(Q.nationalism / 100, 1);
            m *= (1 + nat * 0.25);
            if (Q.peoples_party === 1) m *= 0.96;
            return m;
        })(),
        unemployedc: (() => {
            let m = 0.60;
            if (Q.peoples_party === 1) m *= 0.93;
            return m;
        })(),
    },

    other: {
        base: Q.other_banned ? 0 : (() => {
            return (Q.nationalism_factor + Q.pro_republic_factor) * 6 * Q.identity_modifier.other;
        })(),
        workers: 0.30,
        old_middle: 1.00,
        new_middle: 1.00,
        rural: 1.00,
        unemployedc: 0.30,
    },

    kvp: {
        base: Q.kvp_banned ? 0 : (() => {
        let rep = Q.pro_republic_factor;
        let nat = Q.nationalism_factor;
        // Only viable when Hugenberg DNVP alienates moderates
        let split_bonus = Q.dnvp_line === 3 ? 2.2 : 0.8;
        return (rep * 18 + nat * 14) * split_bonus * Q.identity_modifier.kvp;
    })(),
    workers:    0.25,
    old_middle: 1.45,
    new_middle: 1.20,
    rural:      0.90,
    unemployedc: 0.30,
    },

    dhp: {
        base: Q.dhp_banned ? 0 : (() => {
            let rep = Q.pro_republic_factor;
            let nat = Q.nationalism_factor;
            // Hard national ceiling — regional party
            return Math.min(3.5, (rep * 30 + nat * 10) * 0.8 * Q.identity_modifier.dhp);
        })(),
        workers:    0.20,
        old_middle: 1.35,
        new_middle: 0.60,
        rural:      1.70,  // Its actual base
        unemployedc: 0.25,
    },

    bb: {
    base: Q.bb_banned ? 0 : (() => {
        let rep = Q.pro_republic_factor;
        let nat = Q.nationalism_factor;
        let rural_weight = Q.rural / 60;
        // Deflation bonus — agrarian debt crisis
        let deflation_bonus = Q.inflation < 0 ? 
            (1 + Math.abs(Q.inflation) * 0.08) : 1.0;
        return (rep * 10 + nat * 12) * rural_weight * deflation_bonus * Q.identity_modifier.bb;
    })(),
    workers:    0.10,
    old_middle: 0.40,
    new_middle: 0.20,
    rural:      2.10,  // Highest rural cap of any party
    unemployedc: 0.35,  // Catholic but not clericalist
    },

    default: {
        base: Q.other_banned ? 0 : (() => {
            return (Q.nationalism_factor + Q.pro_republic_factor) * 6 * Q.identity_modifier.other;
        })(),
        workers: 0.30,
        old_middle: 1.00,
        new_middle: 1.00,
        rural: 1.00,
        unemployedc: 0.30,
    },

};




    // Reworked drift per class
    for (Q.c of Q.classes) {
        Q.class_total = 0;
        for (Q.party of Q.parties) {
            Q.base = Q[Q.c+'_'+Q.party] || 0;
            
            // === BANNED PARTY HANDLING ===
            // Redistribution map: [targetParty, share, condition]
            const BANNED_REDISTRIBUTION = {
                nsdap: [
                    ['dnvp',  0.50, () => !Q.dnvp_banned],
                    ['dvp',   0.25, () => Q.dvp_right_shift && !Q.dvp_banned],
                    ['other', 0.25, () => true]
                ],
                dnvp: [
                    ['nsdap', 0.60, () => !Q.nsdap_banned && Q.dnvp_line === 3],
                    ['nsdap', 0.30, () => !Q.nsdap_banned && Q.dnvp_line !== 3],
                    ['dvp',   0.20, () => !Q.dvp_banned],
                    ['other', 0.20, () => true]
                ],
                dvp: [
                    ['dnvp',  0.35, () => !Q.dnvp_banned],
                    ['nsdap', 0.25, () => !Q.nsdap_banned && Q.dvp_right_shift],
                    ['wp',    0.20, () => !Q.wp_banned && !Q.dvp_right_shift],
                    ['other', 0.20, () => true]
                ],
                wp: [
                    ['spd',   0.30, () => !Q.spd_banned],
                    ['ddp',   0.25, () => !Q.ddp_banned],
                    ['srpd',  0.20, () => !Q.srpd_banned],
                    ['other', 0.25, () => true]
                ],
                cnbl: [
                    ['z',     0.35, () => !Q.z_banned],
                    ['bvp',   0.20, () => !Q.bvp_banned],
                    ['dnvp',  0.20, () => !Q.dnvp_banned],
                    ['other', 0.25, () => true]
                ],
                kpd: [
                    ['sapd',  0.40, () => Q.sapd_formed && !Q.sapd_banned],
                    ['spd',   0.35, () => !Q.spd_banned && (Q.ideology === 'left' || Q.ideology === 'neorev')],
                    ['spd',   0.20, () => !Q.spd_banned && Q.ideology !== 'left' && Q.ideology !== 'neorev'],
                    ['other', 0.25, () => true]
                ],
                sapd: [
                    ['kpd',   0.40, () => !Q.kpd_banned],
                    ['spd',   0.30, () => !Q.spd_banned],
                    ['srpd',  0.15, () => !Q.srpd_banned],
                    ['other', 0.15, () => true]
                ],
                csvd: [
                    ['dnvp',  0.30, () => !Q.dnvp_banned],
                    ['nsdap', 0.25, () => !Q.nsdap_banned],
                    ['other', 0.45, () => true]
                ],
                srpd: [
                    ['spd',   0.45, () => !Q.spd_banned],
                    ['sapd',  0.25, () => Q.sapd_formed && !Q.sapd_banned],
                    ['kpd',   0.15, () => !Q.kpd_banned],
                    ['other', 0.15, () => true]
                ],
                spd: [
                    ['srpd',  0.35, () => !Q.srpd_banned],
                    ['sapd',  0.25, () => Q.sapd_formed && !Q.sapd_banned],
                    ['ddp',   0.20, () => !Q.ddp_banned],
                    ['other', 0.20, () => true]
                ],
                ddp: [
                    ['spd',   0.30, () => !Q.spd_banned],
                    ['wp',    0.25, () => !Q.wp_banned],
                    ['z',     0.20, () => !Q.z_banned],
                    ['other', 0.25, () => true]
                ],
                z: [
                    ['bvp',   0.40, () => !Q.bvp_banned],
                    ['cnbl',  0.25, () => !Q.cnbl_banned],
                    ['ddp',   0.15, () => !Q.ddp_banned],
                    ['other', 0.20, () => true]
                ],
                bvp: [
                    ['z',     0.45, () => !Q.z_banned],
                    ['cnbl',  0.25, () => !Q.cnbl_banned],
                    ['other', 0.30, () => true]
                ],
                other: [
                    ['dnvp',  0.20, () => !Q.dnvp_banned],
                    ['spd',   0.20, () => !Q.spd_banned],
                    ['z',     0.20, () => !Q.z_banned],
                    ['other', 0.40, () => true]  // abstention
                ],
                kvp: [
                    ['dnvp',  0.45, () => !Q.dnvp_banned],
                    ['csvd',  0.30, () => !Q.csvd_banned],
                    ['other', 0.25, () => true]
                ],
                dhp: [
                    ['cnbl',  0.40, () => !Q.cnbl_banned],
                    ['dnvp',  0.30, () => !Q.dnvp_banned],
                    ['other', 0.30, () => true]
                ],
                bb: [
                    ['cnbl',  0.35, () => !Q.cnbl_banned],
                    ['bvp',   0.30, () => !Q.bvp_banned],
                    ['nsdap', 0.20, () => !Q.nsdap_banned],
                    ['other', 0.15, () => true]
                ]
            };

            // === BANNED CHECK (single block, covers all parties) ===
            const banned_flag = Q.party + '_banned';
            if (Q[banned_flag] && BANNED_REDISTRIBUTION[Q.party]) {
                if (Q.base > 0) {
                    const routes = BANNED_REDISTRIBUTION[Q.party];
                    for (let i = 0; i < routes.length; i++) {
                        const [target, share, condition] = routes[i];
                        if (condition()) {
                            Q[Q.c + '_' + target] += Q.base * share;
                        }
                    }
                }

                // Zero out the banned party
                Q[Q.c + '_' + Q.party] = 0;
                continue; // Skip normal drift calculation
            }
            
            Q.ideology_factor = 1.0;

            switch (Q.party) {
                case 'nsdap':
                    // Single crisis signal, sigmoid-shaped, with nationalism floor
                    let u = Math.max(0, Q.unrest_factor - 0.4);
                    let crisis_signal = 1 / (1 + Math.exp(-1.2 * (u - 1.8)));
    
                    // Nationalism provides baseline activity even in calm conditions
                    let nat_base = Q.nationalism_factor * 0.10;
    
                    // Street presence amplifies but with diminishing returns
                    let street_amp = 1 + Math.log1p(Q.street_pressure_factor * 0.5) * 0.3;
    
                    Q.ideology_factor = Q.random_factor(
                        (nat_base + crisis_signal * 0.9) * street_amp,
                        0.25  // tighter variance than before
                    );

                    // Class modifiers unchanged from your current version
                    if (Q.c === 'workers')       Q.ideology_factor *= 0.88;
                    else if (Q.c === 'old_middle')  Q.ideology_factor *= (0.95 + Math.min(crisis_signal * 0.15, 0.30));
                    else if (Q.c === 'rural' && Q.unemployed > 10) Q.ideology_factor *= (1.10 + Math.min((Q.unemployed - 10) * 0.02, 0.25));
                    else if (Q.c === 'unemployedc') Q.ideology_factor *= (1.15 + Math.min(Q.unemployed / 22, 0.80));
                break;
                case 'csvd':
                    if (Q.csvd_flee === 1) {
                        // === DNVP SPLIT FACTOR ===
                        var dnvp_split_bonus = 0;
                        if (Q.dnvp_line === 3) {
                            // Hugenberg DNVP - major split
                            dnvp_split_bonus = 0.5 + (Q.dnvp_r * 0.03); // Stronger if DNVP was strong
                        } else if (Q.dnvp_line === 1 && Q.year >= 1930) {
                            // Traditional DNVP but pressure to split
                            dnvp_split_bonus = 0.2;
                        }
        
                        // === PROTESTANT VOTERS ===
                        var protestant_base = 0.3;
                        // Stronger in rural Protestant areas
                        if (Q.rural_spd < 15) protestant_base += 0.2;
                        // Weaker in Catholic areas
        
                        // === ANTI-NAZI POSITIONING ===
                        var anti_nazi_appeal = 0;
                        if (Q.nsdap_r >= 15 && Q.nsdap_r < 30) {
                            // Sweet spot: Nazis strong enough to scare moderates, not so strong they're inevitable
                            anti_nazi_appeal = 0.3;
                            if (Q.church_resist_nazis) anti_nazi_appeal += 0.15;
                        } else if (Q.nsdap_r >= 30) {
                            // Nazis too strong - voters flee to them or hunker down
                            anti_nazi_appeal = -0.2;
                        }
        
                        // === WEIMAR COALITION STABILITY ===
                        var coalition_stability = 0;
                        if (Q.in_weimar_coalition || Q.in_grand_coalition) {
                            coalition_stability = -0.15; // coalitition kills off popularity for csvd
                        }
                        if (Q.constitutional_reform >= 2) {
                            coalition_stability += 0.1; // Democratic stability
                        }
        
                        // === ECONOMIC CRISIS PENALTY ===
                        var crisis_factor = 1.0;
                        if (Q.unemployed >= 20) {
                            crisis_factor = 0.6; // Severe crisis kills moderates
                        } else if (Q.unemployed >= 12) {
                            crisis_factor = 0.8;
                        } else if (Q.unemployed >= 8) {
                            crisis_factor = 0.85;
                        } 
        
                        Q.ideology_factor = Q.random_factor(
                            (Q.pro_republic_factor * 0.5) + 
                            dnvp_split_bonus + 
                            anti_nazi_appeal + 
                            coalition_stability,
                            0.15
                        ) * crisis_factor;
                    }
                break;
                case 'dnvp':
                    if (Q.dnvp_line === 1) {
                        Q.ideology_factor = Q.random_factor(
                            (Q.pro_republic_factor * 0.75 + Q.nationalism_factor * 0.6),
                            0.15
                        );
                    } else if (Q.dnvp_line === 3) {
                        Q.ideology_factor = Q.random_factor(
                            Q.nationalism_factor * 1.15 * (1 + Q.unrest_factor * 0.30),
                            0.3
                        );
                    } else {
                        Q.ideology_factor = Q.random_factor(
                            Q.nationalism_factor * 1.0 * (1 + Q.unrest_factor * 0.15),
                            0.20
                        );
                    }
                    
                    if (Q.c === 'rural') {
                        Q.ideology_factor *= 1.30;
                    } else if (Q.c === 'old_middle') {
                        Q.ideology_factor *= 1.20;
                    } else if (Q.c === 'new_middle') {
                        Q.ideology_factor *= 0.95;
                    } else if (Q.c === 'workers' || Q.c === 'unemployed') {
                        Q.ideology_factor *= 0.65;
                    }
                    
                    if (Q.dnvp_line === 3) {
                        Q.ideology_factor *= 0.90;
                    }
                    break;
                case 'kpd':
                    Q.ideology_factor = Q.random_factor(Q.socialism_factor * Q.unrest_factor * Q.street_pressure_factor, 0.30);

                    if (Q.c === 'unemployed') {
                        Q.ideology_factor *= 1.20;
                        }
                    break;
                case 'sapd':
                    if (Q.sapd_formed === 1) {
                        Q.ideology_factor = Q.random_factor(
                            (Q.socialism_factor * 0.25) * Q.unrest_factor * 0.45,
                            0.25
                        );
                    }
                    break;
                case 'srpd':
                    if (Q.srpd_formed === 1) {
                        Q.ideology_factor = Q.random_factor(
                            (Q.pro_republic_factor * 0.98) + ((Q.rb_strength * Q.rb_militancy) * 0.000980),
                            0.25
                        );
                    }
                    break;
                case 'spd':
                    Q.ideology_factor = Q.random_factor(Q.socialism_factor * Q.pro_republic_factor * (Q.spd_in_government ? 1.15 : 0.90) * 1.03, 0.2);
                    // BASE preference.
                    if (Q.c === 'workers' && Q.sandbox === 1) {
                            Q.ideology_factor *= 1.15;
                    }
                    // State Buyer assist preference.
                    if (Q.c === 'rural' && Q.state_buyer === 1) {
                            Q.ideology_factor *= 1.10;
                    }
                    if (Q.ideology === 'left') {
                        if (Q.c === 'workers' || Q.c === 'unemployed') {
                            Q.ideology_factor *= 1.15;
                        } else if (Q.c === 'old_middle' || Q.c === 'new_middle') {
                            Q.ideology_factor *= 0.85;
                        }
                    } else if (Q.ideology === 'reformist') {
                        if (Q.c === 'old_middle' || Q.c === 'new_middle') {
                            Q.ideology_factor *= 1.12;
                        } else if (Q.c === 'workers') {
                            Q.ideology_factor *= 0.93;
                        }
                    } else if (Q.ideology === 'labor') {
                        if (Q.c === 'workers') {
                            Q.ideology_factor *= 1.08;
                        }
                        if (Q.c === 'unemployed') {
                            Q.ideology_factor *= 1.08;
                        }
                    } else if (Q.ideology === 'neorev') {
                        if (Q.c === 'workers' || Q.c === 'unemployed') {
                            Q.ideology_factor *= 1.04;
                        }
                        if (Q.c === 'old_middle' || Q.c === 'new_middle') {
                            Q.ideology_factor *= 1.05;
                        }
                    }
                    
                    if (Q.peoples_party === 1) {
                        if (Q.c === 'old_middle' || Q.c === 'new_middle') {
                            Q.ideology_factor *= 1.10;
                        } else if (Q.c === 'workers' || Q.c === 'unemployed') {
                            Q.ideology_factor *= 0.93;
                        }
                    }
                    break;
                case 'wp':
                    // BUFFED: Changed to multiplicative, increased coefficients
                    Q.middle_class_base = (Q.old_middle + Q.new_middle) / 102; // Normalize to 0-1
                    Q.crisis_modifier = 1 + (Q.inflation * 0.15) - (Q.unemployed * 0.10); // Increased sensitivity
                    Q.ideology_factor = Q.random_factor(
                        Q.pro_republic_factor * 0.35 * Q.middle_class_base * Q.crisis_modifier, // Multiplicative!
                        0.15
                    );
                    break;
                case 'cnbl':
                    Q.ideology_factor = Q.random_factor((Q.pro_republic_factor * 0.05) + (Q.nationalism_factor * 0.20) - (Q.unemployed * 0.02) + (Q.rural * 0.04), 0.15);
                    
                    if (Q.c === 'rural') {
                        Q.ideology_factor *= 1.05;
                    } else if (Q.c === 'old_middle') {
                        Q.ideology_factor *= 0.35;
                    } else if (Q.c === 'new_middle') {
                        Q.ideology_factor *= 0.15;
                    } else if (Q.c === 'workers') {
                        Q.ideology_factor *= 0.15;
                    } else if (Q.c === 'unemployed') {
                        Q.ideology_factor *= 0.25;
                    }
                    
                    if (Q.c === 'catholics') {
                        Q.ideology_factor *= 0.20;
                    }
                    break;
                case 'z':
                    Q.catholic_bonus = Math.min(0.5, Q.catholics/100); // Cap at +50%
                    Q.ideology_factor = Q.random_factor((Q.pro_republic_factor * 1.03) * (1 + Q.catholic_bonus), 0.15);
                    if (Q.z_party_leader === "Kaas") {
                        Q.ideology_factor *= 0.96;
                    } else if (Q.z_party_leader === "Joos") {
                        Q.ideology_factor *= 1.06;
                    }
                    
                    if (Q.c === 'catholics') {
                        Q.ideology_factor *= 1.35;
                    } else if (Q.c === 'workers' && Q.z_party_leader !== "Kaas") {
                        Q.ideology_factor *= 1.03;
                    } else if (Q.c === 'old_middle') {
                        Q.ideology_factor *= 1.03;
                    }
                    
                    if (Q.z_in_government) {
                        Q.ideology_factor *= 1.12;
                    }
                    else {
                        Q.ideology_factor *= 0.93;
                    }
                    break;
                case 'bvp':
                    Q.ideology_factor = Q.random_factor(
                        Q.pro_republic_factor * 0.60 * (1 + Q.catholics/155 + Q.rural/85), 
                        0.15
                    );
                    
                    if (Q.c === 'catholics') {
                        Q.ideology_factor *= 1.10;
                    } else if (Q.c === 'rural') {
                        Q.ideology_factor *= 1.09;
                    } else if (Q.c === 'old_middle') {
                        Q.ideology_factor *= 1.03;
                    } else if (Q.c === 'workers') {
                        Q.ideology_factor *= 0.86;
                    }
                    
                    Q.ideology_factor *= Math.max(0.75, 1 - Q.unrest_factor * 0.04);
                    break;
                case 'ddp':
                     if (!Q.ddp_name || Q.ddp_name === "DDP") {
                         Q.secular_bonus = ((100 - Q.catholics) / 100) * 0.10;
                         Q.nationalism_penalty = (Q.nationalism / 100) * 0.15;
        
                         Q.ideology_factor = Q.random_factor(Q.pro_republic_factor * 0.55 + Q.secular_bonus - Q.nationalism_penalty - (Q.unemployed / 100) * 0.20 - (Q.street_pressure_factor * 0.50), 0.15);
        
                          if (Q.c === 'new_middle') {
                             Q.ideology_factor *= 1.25;
                         } else if (Q.c === 'old_middle') {
                             Q.ideology_factor *= 0.85;
                         } else if (Q.c === 'workers') {
                             Q.ideology_factor *= 0.70;
                         } else if (Q.c === 'rural') {
                             Q.ideology_factor *= 0.75;
                         }
        
                     } else if (Q.ddp_name === "DStP") {
                         Q.jungdo_bonus = (Q.jungdo_strength || 0) * 0.0003;
        
                         Q.ideology_factor = Q.random_factor(Q.pro_republic_factor * 0.42 + Q.nationalism_factor * 0.25 + Q.jungdo_bonus - (Q.unemployed / 100) * 0.30 + (Q.street_pressure_factor * 0.25), 0.15);
        
                         if (Q.c === 'new_middle') {
                             Q.ideology_factor *= 1.10;
                         } else if (Q.c === 'old_middle') {
                             Q.ideology_factor *= 1.05;
                         } else if (Q.c === 'workers') {
                             Q.ideology_factor *= 0.50;
                         } else if (Q.c === 'rural') {
                             Q.ideology_factor *= 1.15;
                         }
                     }
                     break;
                case 'dvp':
                    let base_factor = Q.dvp_right_shift 
                        ? Q.nationalism_factor * 0.87 
                        : Q.pro_republic_factor * 0.65;

                    // Same consistent penalty logic
                    let infl_pen = Math.pow(Math.abs(Q.inflation - 1.5) / 8, 1.4);
                    let unemp_pen = Math.pow(Math.max(0, Q.unemployed - 5) / 15, 1.3);
                    let confidence = Math.max(0.15, 1 - infl_pen - unemp_pen);

                    Q.ideology_factor = Q.random_factor(
                        base_factor * confidence,
                        0.15
                    );

                    if (Q.c === 'old_middle' || Q.c === 'new_middle') Q.ideology_factor *= 1.20;
                    break;
                case 'csrp':
                    Q.ideology_factor = Q.random_factor(Q.pro_republic_factor * 0.06, 0.2);
                    break;
                case 'vrp':
                    Q.ideology_factor = Q.random_factor(Q.pro_republic_factor * 0.10 + Q.inflation * 0.0093, 0.6);
                    break;
                case 'other':
                    Q.ideology_factor = Q.random_factor((Q.nationalism_factor + Q.pro_republic_factor)/5.4 + (1 - Q.unrest_factor), 0.2);
                    break;
                case 'kvp':
                    if (Q.kvp_flee === 1) {
                        Q.ideology_factor = Q.random_factor(
                        (Q.pro_republic_factor * 0.55 + Q.nationalism_factor * 0.45)
                        * (Q.dnvp_line === 3 ? 1.6 : 0.7),
                        0.20
                    );
                    if (Q.c === 'old_middle') Q.ideology_factor *= 1.25;
                    if (Q.c === 'rural')      Q.ideology_factor *= 0.90;
                    if (Q.c === 'workers' || Q.c === 'unemployed') Q.ideology_factor *= 0.55;
                    }
                    break;
                case 'dhp':
                    Q.ideology_factor = Q.random_factor(
                        Q.pro_republic_factor * 0.28 + Q.nationalism_factor * 0.10,
                        0.25
                    );
                    break;
                case 'bb':
                    let deflation_mod = Q.inflation < 0 ?
                        (1 + Math.abs(Q.inflation) * 0.05) : 1.0;
                    Q.ideology_factor = Q.random_factor(
                        (Q.pro_republic_factor * 0.15 + Q.nationalism_factor * 0.18)
                        * (Q.rural / 50) * deflation_mod,
                        0.25
                    );
                    if (Q.c === 'rural')      Q.ideology_factor *= 1.60;
                    if (Q.c === 'workers' || Q.c === 'unemployed') Q.ideology_factor *= 0.25;
                    break;
                default:
                    Q.ideology_factor = Q.random_factor(1, 0.1);
            }

        function softCap(value, cap) {
            if (cap === Infinity) return Math.max(value, 0.5);
            if (cap <= 0) return 0.5; // add this line
    
            const ratio = value / cap;
    
            if (ratio <= 0.75) {
                // Below 75% of cap - no resistance at all
                return Math.max(value, 0.5);
            } else if (ratio <= 1.0) {
                // 75-100% of cap - increasing resistance
                const resistance = Math.pow((ratio - 0.75) / 0.25, 2);
                const compressed = cap * (0.75 + (ratio - 0.75) * (1 - resistance * 0.6));
                return Math.max(compressed, 0.5);
            } else {
                // At ratio=1.0 boundary, resistance was 0.4, so overshoot continues that compression
                const overshoot = (value - cap) * 0.40;
                const max_overshoot = Q.unrest_factor > 8 ? 1.35 :
                                      Q.unrest_factor > 5 ? 1.25 : 1.20;
                const breakthrough_cap = cap * max_overshoot;
                return Math.max(Math.min(cap + overshoot, breakthrough_cap), 0.5);
            }
        }

        // === ENEMIES MODIFIER ===
        // Attacking a party suppresses their drift among workers/unemployed
        // and slightly boosts SPD's own drift against the same classes
        const worker_classes = ['workers', 'unemployedc'];
        const is_worker_class = worker_classes.includes(Q.c);

        if (Q.enemies && is_worker_class) {
            const target_map = {
                'NSDAP':              ['nsdap'],
                'KPD':                ['kpd'],
                'far right':          ['nsdap', 'dnvp'],
                'DNVP':               ['dnvp'],
                'anti-democratic parties': ['nsdap', 'dnvp', 'kpd'],
                'bourgeois parties':  ['dvp', 'wp', 'z'],
                'DVP':                ['dvp'],
                'Z':                  ['z'],
                'BVP':                ['bvp'],
                'WP':                 ['wp'],
                'DDP':                ['ddp'],
            };

            const targets = target_map[Q.enemies] || [];

            if (targets.includes(Q.party)) {
                // Suppress drift toward enemy parties
                Q.ideology_factor *= 0.87;
            }
            if (Q.party === 'spd' && targets.length > 0) {
                // SPD benefits slightly from negative campaigning
                Q.ideology_factor *= 1.05;
            }
        }
            

        Q.delta = Q.drift_base * Q.ideology_factor * Q.class_influences[Q.c] / 6;
        Q.delta *= (0.7 + _r() * 0.6);

        // CRITICAL: If party is banned, prevent ALL positive drift
        const party_banned = Q.party + '_banned';
        if (Q[party_banned]) {
            Q.delta = Math.min(Q.delta, 0);
        }

        // === APPLY CLASS-SPECIFIC CAP ===
        const cap_data = Q.ideology_caps[Q.party];
        let final_cap = Infinity;
        
        if (cap_data) {
            const class_multiplier = cap_data[Q.c] || 1.0;
            final_cap = cap_data.base * class_multiplier;
        }
        
        const proposed = Q.base + Q.delta;
        Q[Q.c+'_'+Q.party] = softCap(proposed, final_cap);

        Q.class_total += Q[Q.c+'_'+Q.party];
    }
}

    // === CLASS VOTE RE-NORMALIZATION AFTER DRIFT (SKIP IN CHAOS MODE) ===
    if (!Q.math_broken) {
        for (var c of Q.classes) {
            var class_votes = 0;
            for (var party of Q.parties) {
                class_votes += Q[c+'_'+party];
            }
            for (var party of Q.parties) {
                Q[c + '_' + party + '_normalized'] = class_votes > 0 ? Q[c + '_' + party] / class_votes : 0;
                Q[c+'_'+party+'_display'] = (Q[c+'_'+party+'_normalized']*100).toFixed(1);
            }
        }
    } else {
        for (var c of Q.classes) {
            var class_votes = Q.impossible_add(0, 0);
            for (var party of Q.parties) {
                class_votes = Q.impossible_add(class_votes, Q[c+'_'+party]);
            }
            for (var party of Q.parties) {
                Q[c + '_' + party + '_normalized'] = Q.impossible_multiply(Q[c + '_' + party], 1/class_votes);
                Q[c+'_'+party+'_display'] = Q.impossible_percentage(Q[c+'_'+party+'_normalized']*100).toFixed(1);
            }
        }
    }

// === PARAMILITARY STRENGTH UPDATES ===

if (Q.nsdap_banned) {
    Q.sa_strength *= 0.70;
    Q.sa_militancy = Math.max(0, Q.sa_militancy - 0.1);
} else {
    Q.sa_strength += Q.random_factor(Q.unrest_factor / 3, 0.3);
}

if (Q.dnvp_banned || Q.sh_banned) {
    Q.sh_strength *= 0.75;
    Q.sh_militancy = Math.max(0, Q.sh_militancy - 0.3);
} else {
    Q.sh_strength += Q.random_factor(Q.unrest_factor / 6, 0.3);
}

if (Q.kpd_banned) {
    Q.rfb_strength *= 0.65;
    Q.rfb_militancy = Math.max(0, Q.rfb_militancy - 0.6);
} else {
    Q.rfb_strength += Q.random_factor(Q.unrest_factor / 5, 0.3);
}

Q.rb_strength     += Q.random_factor(Q.unrest_factor / 20, 0.3);
Q.jungdo_strength += Q.random_factor(Q.new_middle/50 + Q.old_middle/100 + Q.nationalism/100, 0.3);

// Decay factors — FIXED
// stability_decay: only applies when things are genuinely calm (low unrest)
// Multiplier reduced from 10 → 2 so it doesn't obliterate growth
Q.stability_decay = Math.max(0, (0.4 - Q.unrest_factor)) * 2;

// prosperity_factor: INVERTED so economic collapse REDUCES decay instead of adding to it
// Previously this was always ~3-4 even in crisis — now crisis = near zero decay from this term
// Formula: high unemployment and inflation push this toward 0, stable economy pushes toward 1
Q.prosperity_factor = Math.max(0, Q.inflation / 100 + Q.unemployed / 50) * 1.5;
// This now reads: the worse the economy, the MORE this subtracts from decay pressure

// Combined decay = calm conditions + good economy both reduce paramilitaries
// Crisis conditions = both terms shrink toward 0, so decay is minimal
Q.combined_decay = Math.max(0, Q.stability_decay - Q.prosperity_factor);

// Apply natural decay
Q.sa_strength     -= Q.random_factor(Q.combined_decay, 0.25);
Q.sh_strength     -= Q.random_factor(Q.combined_decay, 0.25);
Q.rfb_strength    -= Q.random_factor(Q.combined_decay, 0.25);
Q.rb_strength     -= Q.random_factor(Q.combined_decay, 0.25);
Q.jungdo_strength -= Q.random_factor(Q.combined_decay, 0.25);

// Caps for banned orgs
if (Q.nsdap_banned) Q.sa_strength     = Math.min(Q.sa_strength, 10);
if (Q.dnvp_banned || Q.sh_banned) Q.sh_strength = Math.min(Q.sh_strength, 15);
if (Q.kpd_banned)  Q.rfb_strength    = Math.min(Q.rfb_strength, 5);


// Caps for RB.

if (!Q.prussian_police_training) Q.rb_militancy = Math.min(Q.rb_militancy, 0.20)


        // === PARAMILITARY CONSTRAINTS (SKIP IN CHAOS MODE) ===
    if (!Q.math_broken) {
        // NORMAL: Constrain paramilitary strength
        Q.sa_strength  = Math.min(Math.max(Q.sa_strength, 0), 10000);
        Q.sh_strength  = Math.min(Math.max(Q.sh_strength, 0), 10000);
        Q.rfb_strength = Math.min(Math.max(Q.rfb_strength, 0), 10000);
        Q.rb_strength  = Math.min(Math.max(Q.rb_strength, 0), 10000);
        Q.jungdo_strength  = Math.min(Math.max(Q.jungdo_strength, 0), 10000);
    } else {
        // MATH BROKEN: Paramilitary numbers can be anything
        Q.sa_strength = Q.impossible_add(Q.sa_strength, 0);
        Q.sh_strength = Q.impossible_multiply(Q.sh_strength, 1);
        Q.rfb_strength = Q.impossible_subtract(Q.rfb_strength, 0);
        Q.rb_strength = Q.impossible_percentage(Q.rb_strength / 100) * 100;
        Q.jungdo_strength = Q.impossible_add(Q.jungdo_strength, 0);
    }
    
    // --- End Reworked Randomized Monthly Party Drift ---
























