};

// ============================================
// SECTION B: CONDITION MODIFIERS
// ============================================

function get_push_multiplier(party) {
    var m = 1.0;
    switch (party) {
        case 'KPD':
            if (Q.workers < 35)         m += 0.4;
            if (Q.unemployed > 20)      m += 0.3;
            if (Q.kpd_banned)           m  = 0;
            break;
        case 'SAPD':
            if (!Q.sapd_formed)         m  = 0;
            if (Q.sapd_banned)          m  = 0;
            break;
        case 'SPD':
            if (Q.spd_in_government)    m -= 0.3;
            if (Q.unemployed > 18)      m -= 0.3;
            if (Q.spd_banned)           m  = 0;
            break;
        case 'DDP':
            if (Q.ddp_banned)           m  = 0;
            if (Q.pro_republic > 60)    m += 0.2;
            break;
        case 'Z':
            if (Q.z_in_government)      m -= 0.2;
            if (Q.catholics > 30)       m += 0.2;
            if (Q.z_banned)             m  = 0;
            break;
        case 'BVP':
            if (Q.bvp_banned)           m  = 0;
            break;
        case 'DVP':
            if (Q.dvp_in_government)    m -= 0.3;
            if (Q.economic_growth < -1) m += 0.3;
            if (Q.dvp_banned)           m  = 0;
            break;
        case 'WP':
            if (Q.wp_banned)            m  = 0;
            if (Q.inflation > 4)        m += 0.3;
            break;
        case 'CNBL':
            if (Q.cnbl_banned)          m  = 0;
            if (Q.rural > 35)           m += 0.2;
            break;
        case 'DNVP':
            if (Q.dnvp_banned)          m  = 0;
            if (Q.dnvp_line === 3)      m += 0.4;
            if (Q.dnvp_in_government)   m -= 0.3;
            break;
        case 'NSDAP':
            if (Q.nsdap_banned)         m  = 0;
            if (Q.nsdap_r > 20)         m += 0.5;
            if (Q.nsdap_r > 35)         m += 0.5;
            break;
        case 'DVFP':
            if (!Q.dvfp_formed)         m  = 0;
            if (Q.dvfp_banned)          m  = 0;
            if (Q.nationalism > 50)     m += 0.2;
            break;
    }
    return Math.max(0, m);
}

// ============================================
// SECTION C: PHASE 1A — TIMER DECAY
// ============================================

for (var i = 0; i < 10; i++) {
    if (!Q['bill_' + i + '_id'])    continue;
    if (Q['bill_' + i + '_frozen']) continue;

    Q['bill_' + i + '_timer']--;

    if (Q['bill_' + i + '_timer'] <= 0) {
        Q['bill_' + i + '_timer']  = 0;
        Q['bill_' + i + '_frozen'] = 1;
    }
}

// ============================================
// SECTION D: PHASE 1B — CRISIS STAGING
// Only picks a new bill if no crisis in progress.
// Staging vars are never touched while one is active.
// ============================================

if (!Q.bill_crisis_in_progress) {
    Q.any_bill_crisis = 0;

    for (var i = 0; i < 10; i++) {
        if (!Q['bill_' + i + '_id'])     continue;
        if (!Q['bill_' + i + '_frozen']) continue;

        Q.crisis_slot     = i;
        Q.crisis_id       = Q['bill_' + i + '_id'];
        Q.crisis_name     = Q['bill_' + i + '_name'];
        Q.crisis_party    = Q['bill_' + i + '_party'];
        Q.crisis_type     = Q['bill_' + i + '_type'];
        Q.crisis_ideo     = Q['bill_' + i + '_ideo'];
        Q.crisis_ministry = Q['bill_' + i + '_ministry'];

        Q.any_bill_crisis         = 1;
        Q.bill_crisis_in_progress = 1;
        break;
    }
}

// ============================================
// SECTION E: PHASE 1C — PRNG PUSH LOOP
// Runs always — crisis does not block new bills.
// ============================================

var _push_parties = Object.keys(PARTY_BILLS);

for (var pi = 0; pi < _push_parties.length; pi++) {
    var _party = _push_parties[pi];
    var _pool  = PARTY_BILLS[_party];
    var _mult  = get_push_multiplier(_party);

    if (_mult <= 0) continue;

    // Find empty slot before rolling
    var _slot = -1;
    for (var si = 0; si < 10; si++) {
        if (!Q['bill_' + si + '_id']) { _slot = si; break; }
    }
    if (_slot === -1) break; // queue full

    var _shuffled = _pool.slice().sort(function() { return _r() - 0.5; });

    for (var bi = 0; bi < _shuffled.length; bi++) {
        var _bill = _shuffled[bi];

        if (Q['bill_done_' + _bill.id])      continue; // already resolved
        if (Q.crisis_id === _bill.id)        continue; // in staging
        if (Q['bill_stall_id'] === _bill.id) continue; // in stall

        // Check if already in queue
        var _already = false;
        for (var qi = 0; qi < 10; qi++) {
            if (Q['bill_' + qi + '_id'] === _bill.id) { _already = true; break; }
        }
        if (_already) continue;

        if (_r() < _bill.push_weight * _mult) {
            Q['bill_' + _slot + '_id']       = _bill.id;
            Q['bill_' + _slot + '_name']     = _bill.name;
            Q['bill_' + _slot + '_party']    = _party;
            Q['bill_' + _slot + '_type']     = _bill.type;
            Q['bill_' + _slot + '_ideo']     = _bill.ideo;
            Q['bill_' + _slot + '_timer']    = _bill.timer;
            Q['bill_' + _slot + '_frozen']   = 0;
            Q['bill_' + _slot + '_ministry'] = _bill.ministry;
            break;
        }
    }
}

// ============================================
// SECTION F: STALL TIMER TICK
// ============================================

if (Q.bill_stall_timer > 0) {
    Q.bill_stall_timer--;

    if (Q.bill_stall_timer <= 0) {

        if ((Q.bill_stall_attempt || 0) >= 2) {
            // Second stall expired — bill dies
            var _sp      = Q.bill_stall_party || '';
            var _diss_k  = _sp.toLowerCase() + '_dissent';
            var _rel_k   = _sp.toLowerCase() + '_relation';
            Q[_diss_k]   = Math.min(99,   (Q[_diss_k] || 0)  + 3);
            Q[_rel_k]    = Math.max(-100, (Q[_rel_k]  || 50) - 4);

            Q.bill_done_[Q.bill_stall_id] = 1;
            Q.bill_stall_id       = '';
            Q.bill_stall_name     = '';
            Q.bill_stall_party    = '';
            Q.bill_stall_type     = '';
            Q.bill_stall_ideo     = 0;
            Q.bill_stall_ministry = '';
            Q.bill_stall_timer    = 0;
            Q.bill_stall_attempt  = 0;

        } else if (!Q.bill_crisis_in_progress) {
            // Re-surface for second ratification attempt via crisis staging
            Q.crisis_slot     = -1;
            Q.crisis_id       = Q.bill_stall_id;
            Q.crisis_name     = Q.bill_stall_name;
            Q.crisis_party    = Q.bill_stall_party;
            Q.crisis_type     = Q.bill_stall_type;
            Q.crisis_ideo     = Q.bill_stall_ideo;
            Q.crisis_ministry = Q.bill_stall_ministry;

            Q.any_bill_crisis         = 1;
            Q.bill_crisis_in_progress = 1;

            Q.bill_stall_id       = '';
            Q.bill_stall_name     = '';
            Q.bill_stall_party    = '';
            Q.bill_stall_type     = '';
            Q.bill_stall_ideo     = 0;
            Q.bill_stall_ministry = '';
            Q.bill_stall_timer    = 0;
        }
    }
}

// ============================================
// SECTION G: BUILD DISPLAY VARS
// ============================================

var _text = '';
var _html = '<table style="width:100%;border-collapse:collapse;font-size:0.93em;">';
_html += '<tr style="border-bottom:1px solid #555;">'
       + '<th style="text-align:left;padding:3px 6px;">Bill</th>'
       + '<th style="padding:3px 6px;">Party</th>'
       + '<th style="padding:3px 6px;">Type</th>'
       + '<th style="padding:3px 6px;">Timer</th>'
       + '<th style="padding:3px 6px;">Status</th>'
       + '</tr>';

var TYPE_COLORS = {
    economic:       '#c8a84b',
    labor:          '#e3000f',
    social:         '#a0c4a0',
    civil:          '#7eb8d4',
    foreign:        '#9b8ec4',
    constitutional: '#d47f7f',
    administrative: '#b0b0b0',
};

var _filled = 0;
for (var i = 0; i < 10; i++) {
    if (!Q['bill_' + i + '_id']) continue;
    _filled++;

    var _name   = Q['bill_' + i + '_name'];
    var _party  = Q['bill_' + i + '_party'];
    var _type   = Q['bill_' + i + '_type'];
    var _timer  = Q['bill_' + i + '_timer'];
    var _frozen = Q['bill_' + i + '_frozen'];
    var _status = _frozen          ? '⚠ Crisis'  :
                  _timer <= 1      ? '🔴 Urgent'  :
                  _timer <= 5      ? '🟡 Soon'    : '🟢 Active';
    var _color  = TYPE_COLORS[_type] || '#888';

    _text += (i+1) + '. ' + _name + ' (' + _party + ') — '
           + _type + ' — ' + (_frozen ? 'CRISIS' : 'T-' + _timer) + '\n';

    _html += '<tr style="border-bottom:1px solid #333;">'
           + '<td style="padding:3px 6px;">' + _name + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">' + _party + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">'
           +   '<span style="background:' + _color + ';color:#111;border-radius:3px;padding:1px 5px;font-size:0.85em;">' + _type + '</span>'
           + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">' + (_frozen ? '—' : _timer) + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">' + _status + '</td>'
           + '</tr>';
}

if (_filled === 0) {
    _text = 'No bills currently in queue.';
    _html += '<tr><td colspan="5" style="padding:6px;text-align:center;color:#888;">No bills in queue</td></tr>';
}

_html += '</table>';

Q.bill_list_text   = _text;
Q.bill_list_html   = _html;
Q.bill_queue_count = _filled;
Q.bill_queue_full  = (_filled >= 10) ? 1 : 0;

Q.bill_proposed_this_month = 0;

}























// === PARAMILITARY BALANCE OF POWER ===

// Gather all force strengths
const forces = {
    prussian_police:       Q.prussian_police_strength || 0,
    interior_police:       Q.interior_police_strength || 0,
    reichswehr:            Q.reichswehr_strength || 0,
    reichsbanner:          Q.rb_strength || 0,
    jungdo:                Q.jungdo_strength || 0,
    rfb:                   Q.rfb_strength || 0,
    stahlhelm:             Q.sh_strength || 0,
    sa:                    Q.sa_strength || 0,
};

// Militancy weights — raw strength alone isn't threat; multiply by militancy
const militancy_weights = {
    prussian_police:  (Q.prussian_police_loyalty || 50) / 100,  // loyalty replaces militancy for police
    interior_police:  (Q.interior_police_loyalty || 50) / 100,
    reichswehr:       (Q.reichswehr_militancy || 1) / 5,
    reichsbanner:     (Q.rb_militancy || 1) / 5,
    jungdo:           (Q.jungdo_militancy || 1) / 5,
    rfb:              (Q.rfb_militancy || 1) / 5,
    stahlhelm:        (Q.sh_militancy || 1) / 5,
    sa:               (Q.sa_militancy || 1) / 5,
};

// Effective strength = raw * militancy weight
let total_effective = 0;
const effective = {};
for (const [key, raw] of Object.entries(forces)) {
    effective[key] = raw * (militancy_weights[key] || 1);
    total_effective += effective[key];
}

// Normalize to percentages
const para_share = {};
for (const [key, eff] of Object.entries(effective)) {
    para_share[key] = total_effective > 0
        ? Math.round((eff / total_effective) * 1000) / 10  // one decimal
        : 0;
}

// Write back to Q
Q.para_share_prussian_police  = para_share.prussian_police;
Q.para_share_interior_police  = para_share.interior_police;
Q.para_share_reichswehr       = para_share.reichswehr;
Q.para_share_reichsbanner     = para_share.reichsbanner;
Q.para_share_jungdo           = para_share.jungdo;
Q.para_share_rfb              = para_share.rfb;
Q.para_share_stahlhelm        = para_share.stahlhelm;
Q.para_share_sa               = para_share.sa;

// Faction blocs (useful for coup/civil war checks)
Q.para_bloc_pro_republic = 
    para_share.prussian_police + 
    para_share.interior_police + 
    para_share.reichsbanner + 
    para_share.jungdo;

Q.para_bloc_left     = para_share.rfb;
Q.para_bloc_right    = para_share.stahlhelm + para_share.sa;
Q.para_bloc_military = para_share.reichswehr;









Q.has_event = 0;
// check if there are any cards in #event, and then go to main if not.
