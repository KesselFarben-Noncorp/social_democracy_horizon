// === CLASS VOTE NORMALIZATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Class votes normalize to 100%
    for (var c of Q.classes) {
        let class_votes = 0;

        for (var party of Q.parties) {
            Q[c + '_' + party] = Math.max(0, Q[c + '_' + party]);
            class_votes += Q[c + '_' + party];
        }

        for (var party of Q.parties) {
            Q[c + '_' + party + '_normalized'] = class_votes > 0 ? Q[c + '_' + party] / class_votes : 0;
            Q[c + '_' + party + '_display'] = (Q[c + '_' + party + '_normalized'] * 100).toFixed(1);
        }
    }
} else {
    // MATH BROKEN: Class votes don't normalize
    for (var c of Q.classes) {
        let class_votes = Q.impossible_add(0, 0); // "Zero" that isn't zero

        for (var party of Q.parties) {
            Q[c + '_' + party] = Q.impossible_add(Q[c + '_' + party], 0); // Can go negative
            class_votes = Q.impossible_add(class_votes, Q[c + '_' + party]);
        }

        for (var party of Q.parties) {
            // Division that doesn't work properly
            if (Math.random() < 0.5) {
                Q[c + '_' + party + '_normalized'] = Q.impossible_multiply(Q[c + '_' + party], 1/class_votes);
            } else {
                Q[c + '_' + party + '_normalized'] = Q.impossible_subtract(Q[c + '_' + party], -class_votes);
            }
            Q[c + '_' + party + '_display'] = Q.impossible_percentage(Q[c + '_' + party + '_normalized'] * 100).toFixed(1);
        }
    }
}


// === PARTY SUPPORT CALCULATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Party support calculated correctly
    var total_support = 0;
    for (var party of Q.parties) {
        let party_support = 0;
        for (var c of Q.classes) {
            if (Q.old_demographics) {
                party_support += Q[c] * Q[c + '_' + party];
            } else {
                party_support += Q[c] * Q[c + '_' + party + '_normalized'];
            }
        }
        Q[party + '_support'] = party_support;
        total_support += party_support;
    }
} else {
    // MATH BROKEN: Party support calculation is nonsense
    var total_support = Q.impossible_add(0, 0);
