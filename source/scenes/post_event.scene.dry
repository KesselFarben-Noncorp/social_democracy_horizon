      on_pass: function() { Q.state_buyer=(Q.state_buyer||0)+1; } },

    { id: 'womens_workplace',   name: 'Women in the Workplace Act',
      type: 'social',   base_ideo: 3, affinity: ['civil','reform'],
      timer: 35, push_weight: 0.12, ministry: 'labor',       cooldown: 40,
      on_pass: function() { Q.womens_rights=(Q.womens_rights||0)+1; Q.womens_work=(Q.womens_work||0)+1; } },

    // ── LIBERAL CENTRE (ideo 4–5) ────────────────────────────
    { id: 'secular_schools',    name: 'Secular School Reform',
      type: 'social',   base_ideo: 5, affinity: ['civil','secular'],
      timer: 40, push_weight: 0.12, ministry: 'interior',    cooldown: 40,
      on_pass: function() { Q.secularized=(Q.secularized||0)+1; Q.school_boards=(Q.school_boards||0)+1; } },

    { id: 'consumer_protect',   name: 'Consumer Protection Reform',
      type: 'economic', base_ideo: 5, affinity: ['reform','bourgeois'],
      timer: 30, push_weight: 0.10, ministry: 'economic',    cooldown: 35,
      on_pass: function() { Q.pro_consumer=(Q.pro_consumer||0)+1; } },

    { id: 'para_175_reform',    name: 'Reform of Paragraph 175',
      type: 'civil',    base_ideo: 5, affinity: ['civil','secular'],
      timer: 45, push_weight: 0.08, ministry: 'justice',     cooldown: 60,
      on_pass: function() { Q.homosexual_rights=(Q.homosexual_rights||0)+1; Q.reformed_183=1; } },

    // ── CHRISTIAN CENTRE (ideo 5–6) ──────────────────────────
    { id: 'church_concordat',   name: 'Church-State Concordat',
      type: 'social',   base_ideo: 5, affinity: ['catholic','conservative'],
      timer: 50, push_weight: 0.16, ministry: 'chancellor',  cooldown: 60,
      on_pass: function() { Q.prussian_concordate=1; } },

    { id: 'confessional_schools',name: 'Confessional Schools Protection',
      type: 'social',   base_ideo: 5, affinity: ['catholic','conservative'],
      timer: 40, push_weight: 0.14, ministry: 'interior',    cooldown: 40,
      on_pass: function() { Q.secularized=Math.max(0,(Q.secularized||0)-1); Q.school_boards=Math.max(0,(Q.school_boards||0)-1); } },

    { id: 'family_law',         name: 'Family Law Preservation Act',
