    { id: 'unemployment_ins',   name: 'Unemployment Insurance Extension',
      type: 'welfare',  base_ideo: 3, affinity: ['welfare','labor'],
      timer: 30, push_weight: 0.20, ministry: 'labor',       cooldown: 35,
      on_pass: function() { Q.workers_aid=(Q.workers_aid||0)+1; Q.welfare=(Q.welfare||0)+1; } },

    { id: 'public_works',       name: 'WTB Public Works Programme',
      type: 'economic', base_ideo: 3, affinity: ['labor','reform'],
