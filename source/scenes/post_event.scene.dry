// ========================================
// CORE FUNCTIONS
// ========================================

// --- Resolve minister name ---
// Handles both string values and function values (for conditional names)
Q._resolve_minister = function(ministry, party) {
    const ministry_table = MINISTER_NAMES[ministry];
    if (!ministry_table) return 'Unbesetzt';
    
    const entry = ministry_table[party];
    if (!entry) return 'Unbesetzt';
    
    // If it's a function (like DVP foreign minister), call it
    return typeof entry === 'function' ? entry() : entry;
};

// --- Clear all ministry assignments ---
Q.clear_ministries = function() {
    for (const ministry of ALL_MINISTRIES) {
        Q[ministry + '_minister']       = 'Unbesetzt';
        Q[ministry + '_minister_party'] = 'I';
    }
    // Reichswehr always stays independent
    Q.reichswehr_minister       = Q._resolve_minister('reichswehr', 'I');
    Q.reichswehr_minister_party = 'I';
};

// --- Appoint a single minister directly ---
// Use this for player-chosen appointments or special events
// e.g. Q.appoint_minister('interior', 'SPD')
// or   Q.appoint_minister('interior', 'SPD', 'Severing') to override name
Q.appoint_minister = function(ministry, party, override_name) {
    if (!ALL_MINISTRIES.includes(ministry) && !INDEPENDENT_MINISTRIES.includes(ministry)) {
        console.warn("appoint_minister: unknown ministry: " + ministry);
        return;
    }
    Q[ministry + '_minister_party'] = party || 'I';
    Q[ministry + '_minister']       = override_name || Q._resolve_minister(ministry, party) || 'Unbesetzt';
};

// ========================================
// LEVERAGE CALCULATION
// ========================================

Q._calculate_leverage = function(coalition) {
    let total_votes = 0;
    for (const party of coalition) {
        total_votes += Q[party.toLowerCase() + '_r'] || 0;
    }
    if (total_votes === 0) total_votes = 1; // Prevent divide-by-zero

    const leverage = {};

    for (const party of coalition) {
        let base = ((Q[party.toLowerCase() + '_r'] || 0) / total_votes) * 100;

        // Relation modifier
        const relation = Q[party.toLowerCase() + '_relation'] || 50;
        base += (relation - 50) / 5;

        // Chancellor party gets slight penalty — they already have the top job
        if (Q.chancellor_party === party) base -= 10;

        // President bonus
        if (Q.president === "Braun" && party === "SPD") base += 5;

        // Party leader bonuses
        if (party === "Z"   && Q.z_party_leader === "Brüning")    base += 5;
        if (party === "DVP" && !Q.stresemann_dead)                 base += 3;
        if (party === "KPD" && Q.kpd_party_leader === "Conciliators") base += 5;

        // Special conditions
        if (Q.in_grand_coalition && party === "DVP" && 
            Q.capital_strike_progress >= 3) base += 5;
        if (Q.in_left_front && party === "KPD") base -= 5;

        // Hugenberg DNVP demands more
        if (party === "DNVP" && Q.dnvp_line === 3) base += 8;

        // Floor — every coalition partner gets at least something
        leverage[party] = Math.max(base, 10);
    }

    return leverage;
};

// ========================================
// ALLOCATION CALCULATION
// ========================================

Q._calculate_allocation = function(coalition, leverage) {
    const count = ALL_MINISTRIES.length;
    let total_leverage = 0;
    for (const party of coalition) total_leverage += leverage[party];
    if (total_leverage === 0) total_leverage = 1;

    const allocation = {};
    for (const party of coalition) {
        allocation[party] = Math.round((leverage[party] / total_leverage) * count);
    }

    // Fix rounding errors
    let assigned = 0;
    for (const party of coalition) assigned += allocation[party];

    // Over-allocated: trim from largest non-chancellor party
    while (assigned > count) {
        let target = null, max = 0;
        for (const party of coalition) {
            if (allocation[party] > max && party !== Q.chancellor_party) {
                target = party;
                max = allocation[party];
            }
        }
        if (!target) break;
        allocation[target]--;
        assigned--;
    }

    // Under-allocated: add to highest leverage party
    const leverage_copy = Object.assign({}, leverage);
    while (assigned < count) {
        let target = null, max = 0;
        for (const party of coalition) {
            if (leverage_copy[party] > max) {
                target = party;
                max = leverage_copy[party];
            }
        }
        if (!target) break;
        allocation[target]++;
        assigned++;
        leverage_copy[target] -= 10;
    }

    // Guarantee chancellor party has at least 1
    if (Q.chancellor_party && coalition.includes(Q.chancellor_party)) {
        if ((allocation[Q.chancellor_party] || 0) < 1) {
            allocation[Q.chancellor_party] = 1;
        }
    }

    return allocation;
};

// ========================================
// FULL COALITION MINISTRY ALLOCATION
// ========================================

Q.allocate_ministries = function(coalition) {
    if (!coalition || coalition.length === 0) {
        console.warn("allocate_ministries: empty coalition");
        Q.clear_ministries();
        return;
    }

    // Clear first
    Q.clear_ministries();

    // Calculate leverage and allocation counts
    const leverage   = Q._calculate_leverage(coalition);
    const allocation = Q._calculate_allocation(coalition, leverage);

    // Track how many each party has claimed
    const claimed = {};
    for (const party of coalition) claimed[party] = 0;

    // Track which ministries are filled
    const assignments = {};
    for (const m of ALL_MINISTRIES) assignments[m] = null;

    // Sort coalition by leverage descending — higher leverage picks first
    const sorted = coalition.slice().sort((a, b) => leverage[b] - leverage[a]);

    // Assign in rounds until all ministries filled
    for (let round = 0; round < ALL_MINISTRIES.length; round++) {
        for (const party of sorted) {
            if (claimed[party] >= allocation[party]) continue;

            const priorities = MINISTRY_PRIORITIES[party] || ALL_MINISTRIES;

            for (const ministry of priorities) {
                if (assignments[ministry] === null) {
                    assignments[ministry] = party;
                    claimed[party]++;
                    break;
                }
            }
        }
    }

    // Apply assignments
    for (const ministry of ALL_MINISTRIES) {
        const party = assignments[ministry] || 'I';
        Q.appoint_minister(ministry, party);
    }

    // Reichswehr always independent
    Q.appoint_minister('reichswehr', 'I');

    // Build display string
    Q.ministry_display_list = "";
    for (const party of coalition) {
        const votes   = Math.round((Q[party.toLowerCase() + '_r'] || 0) * 10) / 10;
        const lev     = Math.round(leverage[party] * 10) / 10;
        const count   = allocation[party] || 0;
        Q.ministry_display_list += 
            `- **${party}**: ${count} ministr${count === 1 ? 'y' : 'ies'} `+
            `(${votes}% votes, leverage: ${lev})\n`;
    }

    // Store for reference
    Q.ministry_allocation = allocation;
    Q.ministry_leverage   = leverage;

    // Hindenburg reacts to government formation
    Q.hindenburg_patience += 10;
};

// ========================================
// INTEGRITY CHECK
// ========================================

Q.ministry_integrity_check = function() {
    const issues = [];

    for (const ministry of ALL_MINISTRIES) {
        const party = Q[ministry + '_minister_party'];
        const name  = Q[ministry + '_minister'];

        // Minister set but no party
        if (name && name !== 'Unbesetzt' && (!party || party === 'I')) {
            issues.push(`WARN: ${ministry} has minister ${name} but party is Independent`);
        }

        // Party set but no minister name
        if (party && party !== 'I' && (!name || name === 'Unbesetzt')) {
            issues.push(`WARN: ${ministry} party is ${party} but minister name is empty — fixing`);
            Q[ministry + '_minister'] = Q._resolve_minister(ministry, party);
        }

        // Party in ministry but not in government
        if (party && party !== 'I' && !Q[party.toLowerCase() + '_in_government']) {
            issues.push(`WARN: ${ministry} held by ${party} but they are not in government — clearing`);
            Q.appoint_minister(ministry, 'I');
        }
    }

    if (issues.length > 0) {
        console.warn("=== MINISTRY INTEGRITY CHECK ===");
        for (const issue of issues) console.warn(issue);
        console.warn("================================");
    }

    return issues.length;
};














// ÷====================== SMALL CHECKERS FOR CABINETS ===============÷=======

Q.bruning_cabinet = (Q.chancellor === "Brüning") ? 1 : 0;

// === CABINET TYPE FLAGS ===
Q.papen_cabinet     = (Q.chancellor === "Papen")      ? 1 : 0;
Q.schleicher_cabinet = (Q.chancellor === "Schleicher") ? 1 : 0;

// Generic x_cabinet check for any chancellor with that flag pattern
const CABINET_CHANCELLORS = ["Papen", "Schleicher", "Brüning", "Luther", "Marx", "Stegerwald"];
for (const name of CABINET_CHANCELLORS) {
    const key = name.toLowerCase().replace("ü", "u") + "_cabinet";
    Q[key] = (Q.chancellor === name) ? 1 : 0;
}




/// FOR COALITION DISSENT SCENE OF MAX DISSENT.

var max_dissent = 0;
var party_list = Q.parties.map(function(p) { return p.toUpperCase(); });

for (var i = 0; i < party_list.length; i++) {
    var p = party_list[i].toLowerCase();
    if (!Q[p + '_in_government'] && !Q[p + '_tolerating']) continue;
    var d = Q[p + '_dissent'] || 0;
    if (d > max_dissent) max_dissent = d;
}

Q.max_coalition_dissent = max_dissent;

























Q.last_advisor_action = 0;
Q.last_cabinet_action = 0;
// make sure no stat is below 0.

// 1. update dates
if (Q.month_actions >= 1) {
    Q.time += 1;
    Q.month_actions = 0;
    Q.ma = 1;
    console.log(Q.month);
    console.log(Q.time);
    
    // Advance by 2 weeks
    Q.weeks = (Q.weeks || 0) + 2;
    
    // Roll over to next month when 4+ weeks pass
    if (Q.weeks >= 4) {
        Q.weeks -= 4;
        Q.month += 1;
        
        if (Q.month >= 13) {
            Q.month = 1;
            Q.year += 1;
            if (Q.historical_mode) {
                Q.resources += 2;
            }
        }
    }
    
    // decrement timers
    for (timer of Q.timers) {
        if (Q[timer+'_timer'] && Q[timer+'_timer'] > 0) {
            Q[timer+'_timer'] -= 1;
        }
    }




// EVENTS

if (Q.inflation > 10) {
        Q.inflation_crisis_event = 0;
        }

if (Q.year >= 1928 && Q.month == 2 && Q.weeks >= 0 && Q.bayernbund_flavor_1 == 0) {
    Q.bayernbund_flavor_1 = 1;
    Q.parties.push('bb');
}

if (Q.year >= 1929 && Q.vnr_momentum_trigger_flavor_1 == 0) { 
Q.vnr_momentum = 0;
Q.vnr_momentum_trigger_flavor_1 = 1;
}


if (Q.year == 1928 && Q.month >= 9 && Q.lambach_exile == 1 && Q.weeks >= 0) {
    if ((Q.anti_lambach - Q.pro_lambach) < 20) {
        Q.lambach_reinstated = 1;
    } else {
        Q.lambach_reinstated = -1;
    }
}


if (Q.year == 1930 && Q.month == 5 && Q.weeks >= 1 && Q.young_plan_seen == 1) {
    Q.economic_growth += 0.5; // already have this

    // Improved foreign credit access
    Q.capital_pressure     -= 0.12;
    Q.trade_pressure       -= 0.08;
    Q.budget               += 1.5;

    Q.demand_impulse       -= 0.10;
    Q.distribution_shift   += 0.05;
    Q.hindenburg_trust_spd -= 5;
    Q.camarilla_strength += 5;
    Q.z_relation -= 5;
    Q.dvp_relation -= 5;
    Q.bvp_relation -= 5;
}

if (Q.year >= 1930 && Q.year < 1933) {
    Q.capital_pressure += 0.1;
    Q.trade_pressure += 0.1;
    Q.demand_impulse -= 0.1;
    Q.price_pressure -= 0.05;
    Q.budget -= 0.1;
    Q.investment_chill += 0.15;
    Q.shock_residual += 0.05;
    Q.unemployed += 0.1;
    Q.inflation -= 0.1;
    Q.economic_growth -= 0.15;
}

if (Q.year >= 1928 && Q.year < 1929 && Q.geest_wildfire == 1 && (Q.state_buyer == 1 || Q.agricultural_finance == 1 || Q.land_reform == 1 || Q.tariffs > 1) && Q.landvolkbewegung_flavor != 1)  {
    Q.landvolkbewegung_flavor_1 = 1;
    Q.rural_dnvp += 5;
    Q.cnbl_dnvp += 2;
    Q.landvolk_fury = 0;
}














    
// ============================================================
// ECONOMIC SIMULATION — CLEAN PIPELINE REWRITE
//
// Architecture:
//   1. Initialize
//   2. Phase state machine
//   3. Structural updates (NAIRU, expectations, credit, fiscal)
//   4. Force computation (all inputs → demandForce, supplyForce)
//   5. Capital & trade pressure updates (single location each)
//   6. Delta computation (forces → dInflation, dUnemployment, dGrowth)
//   7. Apply deltas
//   8. Decay persistent signals
//   9. Constraints (single pass)
// ============================================================


// ============================================================
// ECONOMIC SIMULATION — v3
//
// Tuning changes from v2:
//   T1 — Depression demand decay starts at 0.03 (not ramping from 0.35)
//   T2 — Demand→unemployment coefficient 0.35 → 0.60
//   T3 — FIX D bypass cap 0.15 → 0.30
//   T4 — WTB impulse values moved to policy_constants.js
//
// Target: u=30% → u=15% over 48 fortnightly ticks with
//         WTB initial + 2 continuations. Survivable with
//         correct sustained play, not with one lucky pick.
// ============================================================


// ============================================================
// SECTION 1 — INITIALIZATION
// ============================================================

if (!Q.economyInitialized) {
    Q.inflation             = 2.5;
    Q.unemployed            = 6.0;
    Q.economic_growth       = 2.5;
    Q.budget                = 0;

    Q.demand_pressure       = 0;
    Q.supply_pressure       = 0;
    Q.price_pressure        = 0;
    Q.trade_pressure        = 0;
    Q.capital_pressure      = 0;

    Q.inflation_expectations    = 2.5;
    Q.expectations_anchored     = true;
    Q.high_inflation_streak     = 0;
    Q.low_inflation_streak      = 0;

    Q.NAIRU                 = 6.0;
    Q.supply_cost_drag      = 0;
    Q.credit_expansion      = 0;
    Q.shock_residual        = 0;

    Q.fiscal_stance         = 0;
    Q.distribution_shift    = 0;

    Q.phase                 = "growth";
    Q.phase_duration        = 0;
    Q.post_crisis_ticks     = 0;
    Q.cycle_phase           = 0;
    Q.tick                  = 0;

    Q.economyInitialized    = true;
}

const POTENTIAL_GROWTH  = 2.5;
const dt                = 1;
Q.tick                  = (Q.tick || 0) + 1;
Q.phase_duration        = (Q.phase_duration || 0) + 1;


// ============================================================
// POLICY IMPULSE ABSORPTION
// Policy scripts write Q.demand_impulse / Q.supply_impulse /
// Q.capital_relief. Absorbed here with crisis scaling, then cleared.
// Actual impulse values live in policy_constants.js.
// ============================================================

function _policyScale() {
    let scale = 1.0;
    if (Q.unemployed > 15)      scale += Math.min(1.2, (Q.unemployed - 15) * 0.08);
    if (Q.inflation < -3)       scale += Math.min(0.8, Math.abs(Q.inflation + 3) * 0.10);
    if (Q.economic_growth < -5) scale += Math.min(0.5, Math.abs(Q.economic_growth + 5) * 0.06);
    return Math.min(3.5, scale);
}

if (Q.demand_impulse) {
    Q.demand_pressure += Q.demand_impulse * _policyScale();
    Q.demand_impulse   = 0;
}
if (Q.supply_impulse) {
    Q.supply_pressure += Q.supply_impulse * _policyScale();
    Q.supply_impulse   = 0;
}
if (Q.distribution_shift_impulse) {
    Q.distribution_shift += Q.distribution_shift_impulse;
    Q.distribution_shift_impulse = 0;
}


// ============================================================
// SECTION 2 — PHASE STATE MACHINE
// ============================================================

const MIN_PHASE_DURATION = 3;

if (Q.phase_duration >= MIN_PHASE_DURATION) {
    const prev  = Q.phase;
    const inf   = Q.inflation;
    const unem  = Q.unemployed;
    const grw   = Q.economic_growth;
    const nairu = Q.NAIRU;

    if (Q.phase === "growth") {
        if      (inf > 5 && unem < nairu)               Q.phase = "overheating";
        else if (grw < 0 && inf < 2)                    Q.phase = "correction";
    }
    else if (Q.phase === "overheating") {
        if      (inf > 8 && !Q.expectations_anchored)   Q.phase = "hyperinflation";
        else if (grw < 0)                               Q.phase = "correction";
        else if (inf < 4 && grw > 1)                    Q.phase = "growth";
    }
    else if (Q.phase === "hyperinflation") {
        if      (grw < -2 && unem > 10)
            Q.phase = (inf > 4) ? "stagflation" : "depression";
        else if (inf < 5 && Q.expectations_anchored)    Q.phase = "correction";
    }
    else if (Q.phase === "correction") {
        if      (grw < -3 && inf < 1)                   Q.phase = "depression";
        else if (inf > 4 && unem > nairu + 2)           Q.phase = "stagflation";
        else if (grw > 1 && inf < 4)                    Q.phase = "growth";
    }
    else if (Q.phase === "depression") {
        const longDep  = Q.phase_duration > 15;
        const growthOk = grw > (longDep ? -0.5 : 0);
        const inflOk   = inf > (longDep ? -2.5 : -1);
        if (growthOk && inflOk) Q.phase = "correction";
        else if (longDep && growthOk && Q.demand_pressure > 0.10) Q.phase = "correction";
        else if (longDep && inflOk  && Q.supply_pressure > 0.08) Q.phase = "correction";
        else if (Q.price_pressure > 0.3 && unem > 12)  Q.phase = "stagflation";
        else if (Q.phase_duration > 25)                 Q.phase = "correction";
    }
    else if (Q.phase === "stagflation") {
        if      (inf < 3 && grw > 0)                    Q.phase = "growth";
        else if (inf < 1 && grw < -2)                   Q.phase = "depression";
        else if (inf > 9)                               Q.phase = "hyperinflation";
    }

    if (Q.phase !== prev) {
    if (prev === "depression" || prev === "hyperinflation")
        Q.post_crisis_ticks = 0;
    Q.phase_duration = 0;

    if (Q.phase === "depression") {
        Q.capital_pressure = Math.min(Q.capital_pressure, 0.6);
        Q.demand_pressure  = Math.max(Q.demand_pressure, -0.3);
        }
    }

}

if (Q.phase === "correction") {
    Q.post_crisis_ticks = (Q.post_crisis_ticks || 0) + 1;
} else if (Q.phase !== "depression" && Q.phase !== "hyperinflation") {
    Q.post_crisis_ticks = 0;
}


// ============================================================
// SECTION 3 — BUSINESS CYCLE
// ============================================================

Q.cycle_phase = (Q.cycle_phase || 0) + 0.018 * dt;

const CYCLE_AMP = {
    growth:         1.4,
    overheating:    1.8,
    hyperinflation: 1.2,
    correction:     0.9,
    depression:     0.3 + Math.min(0.9, Q.phase_duration * 0.04),
    stagflation:    0.6,
};
const cycleAmp      = (CYCLE_AMP[Q.phase] || 1.0) * (1 + (Q.shock_residual || 0) * 0.3);
const businessCycle = cycleAmp * Math.sin(Q.cycle_phase);

if (Math.random() < 0.03 * dt) {
    const shock         = (Math.random() - 0.5) * 0.12;
    Q.price_pressure   += shock;
    Q.shock_residual   += shock * 0.3;
}
Q.shock_residual *= Math.exp(-0.4 * dt);


// ============================================================
// SECTION 4 — STRUCTURAL UPDATES
// ============================================================

// --- NAIRU ---
if (Q.phase === "depression") {
    if (Q.phase_duration > 8) {
        const reversal = Math.min(0.04, (Q.phase_duration - 8) * 0.003) * dt;
        Q.NAIRU += (5.0 - Q.NAIRU) * reversal;
    } else {
        Q.NAIRU += (6.0 - Q.NAIRU) * 0.01 * dt;
    }
} else if (Q.phase === "correction") {
    Q.NAIRU += (6.0 - Q.NAIRU) * 0.01 * dt;
} else if (Q.phase !== "stagflation") {
    Q.NAIRU += 0.003 * dt;
}

// --- Inflation expectations ---
if (Q.inflation > 5) {
    Q.high_inflation_streak += dt;
    Q.low_inflation_streak   = 0;
} else if (Q.inflation < 3 && !Q.expectations_anchored) {
    Q.low_inflation_streak  += dt;
    Q.high_inflation_streak *= 0.85;
} else {
    Q.high_inflation_streak *= 0.85;
}

if ( Q.expectations_anchored && Q.high_inflation_streak > 4)  Q.expectations_anchored = false;
if (!Q.expectations_anchored && Q.low_inflation_streak  > 6) {
    Q.expectations_anchored  = true;
    Q.high_inflation_streak  = 0;
}

if (Q.expectations_anchored) {
    Q.inflation_expectations += 0.03 * (Q.inflation - Q.inflation_expectations) * dt;
    Q.inflation_expectations += 0.04 * (2.5 - Q.inflation_expectations) * dt;
} else {
    const lead = 0.10 + (Q.phase === "hyperinflation" ? 0.08 : 0);
    Q.inflation_expectations += lead * (Q.inflation - Q.inflation_expectations) * dt;
    Q.inflation_expectations += 0.05 * Math.max(0, Q.inflation - 4) * dt;
}

// --- Supply-cost drag ---
if (Q.phase === "stagflation" || Q.price_pressure > 0.3) {
    Q.supply_cost_drag = Math.min(0.5, Q.supply_cost_drag + Q.price_pressure * 0.06 * dt);
} else {
    Q.supply_cost_drag *= Math.exp(-0.15 * dt);
}

// --- Credit expansion ---
if (Q.phase === "growth" && Q.unemployed < Q.NAIRU - 1) {
    Q.credit_expansion = Math.min(0.8, Q.credit_expansion + 0.04 * Math.max(0, Q.NAIRU - 1 - Q.unemployed) * dt);
} else {
    Q.credit_expansion *= Math.exp(-0.2 * dt);
}

// --- Budget ---
Q.budget += Q.fiscal_stance * 0.4 * dt;
if (Q.upper_tax_rates && Q.lower_tax_rates) {
    const upperBase     = ((Q.old_middle || 0) + (Q.new_middle || 0)) / 100;
    const lowerBase     = ((Q.workers || 0) + (Q.unemployedc || 0) + (Q.rural || 0)) / 100;
    const taxEfficiency = Math.max(0.5, Math.min(1.5, 1 + Q.economic_growth / 100 - Q.unemployed / 100));
    Q.budget += (Q.upper_tax_rates * upperBase * 0.035
               + Q.lower_tax_rates * lowerBase * 0.018) * taxEfficiency * dt;
}
Q.budget = Math.max(-50, Math.min(50, Math.round(Q.budget * 100) / 100));


// ============================================================
// SECTION 5 — FORCE COMPUTATION
// ============================================================

const outputGap   = Q.economic_growth - POTENTIAL_GROWTH;
const u_gap       = Q.unemployed - Q.NAIRU;
const overheating = Math.max(0, Q.economic_growth - 6);

// ---- Demand force ----
let demandForce = 0;
demandForce += Q.demand_pressure;
demandForce += Q.credit_expansion * 0.15;
demandForce -= Q.fiscal_stance    * 0.20;
demandForce += (Q.distribution_shift || 0) * 0.15;

if (Q.budget < 0)
    demandForce += -Q.budget * 0.008 * Math.max(0.3, 1 - Math.tanh((Q.unemployed - 10) / 5));

if (Q.phase === "depression" && Q.phase_duration > 5) {
    demandForce += Math.min(0.02, Q.phase_duration * 0.001) * dt;
    if (Q.phase_duration % 6 === 0) demandForce += 0.15;
}

// ---- Supply force ----
let supplyForce = 0;
supplyForce += Q.supply_pressure;
supplyForce += 0.01 * dt * (1 - Q.capital_pressure * 0.2);
supplyForce -= Q.supply_cost_drag * 0.3;
supplyForce -= Q.capital_pressure * 0.3;

if (Q.phase === "depression" && Q.phase_duration > 5 && Q.phase_duration % 6 === 0)
    supplyForce += 0.10;


// ============================================================
// SECTION 6 — CAPITAL & TRADE PRESSURE
// ============================================================

if (Q.capital_relief) {
    const effective    = Math.min(Q.capital_relief * _policyScale(), 0.70);
    Q.capital_pressure = Math.max(0, Q.capital_pressure - effective);
    Q.capital_relief   = 0;
}

if (Q.economic_growth < 0) {
    const capRateCap = Q.phase === "depression"
    ? Math.max(0.004, 0.012 - Q.phase_duration * 0.0005)
    : 0.018;
    const rate = Math.min(capRateCap, 0.008 + Math.abs(Q.economic_growth) * 0.0008);
}
if (Q.inflation > 8 || Q.budget < -20) Q.capital_pressure += 0.020 * dt;

if (Q.inflation < 2 && Q.economic_growth > 3) Q.capital_pressure -= 0.015 * dt;
if (Q.economic_growth > 4)                    Q.capital_pressure -= 0.010 * dt;

if (Q.phase === "depression") {
    if (Q.phase_duration > 5) {
        const liquidation = Math.min(0.06, 0.005 + Q.phase_duration * 0.004) * dt;
        Q.capital_pressure = Math.max(0, Q.capital_pressure - liquidation);
    }
    if (Q.unemployed > 18) {
        const fireSale = Math.min(0.05, (Q.unemployed - 18) * 0.003) * dt;
        Q.capital_pressure  = Math.max(0, Q.capital_pressure - fireSale);
        supplyForce        += fireSale * 0.5;
    }
    if (Q.phase_duration > 0 && Q.phase_duration % 12 === 0) {
        const strength      = Math.min(1.0, Q.phase_duration / 29);
        Q.capital_pressure  = Math.max(0, Q.capital_pressure - 0.30 * strength);
        Q.supply_cost_drag  = Math.max(0, Q.supply_cost_drag  - 0.15 * strength);
        demandForce        += 0.33 * strength;
        supplyForce        += 0.22 * strength;
        Q.fiscal_stance    -= 0.16 * strength;
    }
}

Q.capital_pressure = Math.max(0, Math.min(1.2, Q.capital_pressure));

if (Q.economic_growth > POTENTIAL_GROWTH + 2)      Q.trade_pressure += 0.020 * dt;
else if (Q.economic_growth < POTENTIAL_GROWTH - 2) Q.trade_pressure -= 0.015 * dt;
if (Q.phase === "depression")                       Q.trade_pressure *= Math.exp(-0.04 * dt);


// ============================================================
// SECTION 7 — DELTA COMPUTATION
// ============================================================

// ---- dINFLATION ----
let dInflation = 0;

dInflation += 0.016 * -u_gap;
dInflation += 0.010 * outputGap;
dInflation += Q.price_pressure * 0.10;
dInflation += Q.trade_pressure * 0.05;
dInflation += 0.005 * Q.inflation * dt;

dInflation -= 0.05 * (Q.inflation - Q.inflation_expectations);
if (!Q.expectations_anchored)
    dInflation += 0.06 * Math.max(0, Q.inflation_expectations - Q.inflation);

if (Q.inflation < 0) {
    const dm = Math.abs(Q.inflation);
    dInflation -= 0.015 * dm / (1 + dm * 0.7) * (Q.unemployed / 20);
    if (Q.inflation < -3)
        dInflation -= Math.min(0.03 * (dm - 3) / (1 + (dm - 3) * 0.7), 0.2);
}

dInflation += (Math.random() - 0.5) * 0.02;


// ---- dUNEMPLOYMENT ----
let dUnemployment = 0;

// Okun's law — softened at extreme negative growth
// Raw coefficient 0.032 at grwGap=-17.5 gives +0.19/tick regardless of policy.
// Denominator widened so deep collapse doesn't permanently lock unemployment.
const growthGap = Q.economic_growth - POTENTIAL_GROWTH;
const okunsCoeff = growthGap < 0 ? 0.032 : 0.020;
const okunsDepthScale = Q.phase === "depression"
    ? 0.20 + Math.min(0.40, Q.phase_duration * 0.018)
    : 0.20;
dUnemployment -= okunsCoeff * growthGap / (1 + Math.abs(growthGap) * okunsDepthScale);

dUnemployment += 0.005 * Math.max(0, Q.inflation - 6);

// T2 — Demand→unemployment coefficient raised 0.35 → 0.60 in depression/correction.
// In normal phases stays at 0.35 so stimulus doesn't trivially cure mild unemployment.
const demandUCoeff = (Q.phase === "depression" || Q.phase === "correction") ? 0.60 : 0.35;
dUnemployment -= demandForce * demandUCoeff;

dUnemployment += Q.capital_pressure * 0.06;
dUnemployment += Math.min(Q.trade_pressure * 0.04, 1.0);

if (Q.phase === "stagflation") dUnemployment += Q.supply_cost_drag * 0.4;

if (Q.unemployed > Q.NAIRU) {
    const uGap = Q.unemployed - Q.NAIRU;
    if (Q.phase === "depression" || Q.phase === "correction") {
        dUnemployment -= Math.min(0.08, (uGap - 8) * 0.006) * dt;
    } else {
        dUnemployment -= 0.02 * uGap * (1 + Math.max(0, uGap - 10) * 0.15) * dt;
    }
}

// Deflation unemployment tiers — capped total (FIX 3)
{
    let deflUnempTotal = 0;
    if (Q.inflation < 0) {
        const dm = Math.abs(Q.inflation);
        deflUnempTotal += 0.05 * dm / (1 + dm * 0.3) * (1 - Math.exp(-Q.unemployed / 15));
    }
    if (Q.inflation < -5) {
        const dm = Math.abs(Q.inflation);
        deflUnempTotal += 0.07 * (dm - 5) / (1 + (dm - 5) * 0.3);
    }
    if (Q.inflation < -8) {
        const dm = Math.abs(Q.inflation);
        deflUnempTotal += 0.09 * (dm - 8) / (1 + (dm - 8) * 0.3);
    }
    dUnemployment += Math.min(deflUnempTotal, 0.14);
}

// T3 — Direct demand bypass, cap raised 0.15 → 0.30.
// Requires u>20 AND active demand_pressure>0.15 simultaneously.
// Represents public works directly absorbing workers.
if (Q.unemployed > 20 && Q.demand_pressure > 0.15) {
    const uDepth    = Math.min(1.0, (Q.unemployed - 20) / 20);
    const dStrength = Math.min(1.0, (Q.demand_pressure - 0.15) / 0.4);
    dUnemployment  -= 0.30 * uDepth * dStrength;   // was 0.15
}

dUnemployment += (Math.random() - 0.5) * 0.01;
dUnemployment  = Math.max(-2, Math.min(2, dUnemployment));


// ---- dGROWTH ----
let dGrowth = 0;

// Triple crisis drag softener (FIX A)
const _infCrisis = Math.max(0, Math.min(1, (-Q.inflation - 2) / 10));
const _grwCrisis = Math.max(0, Math.min(1, (-Q.economic_growth - 5) / 10));
const _uCrisis   = Math.max(0, Math.min(1, (Q.unemployed - 15) / 20));
const DS = 1 - 0.48 * Math.max(
    _infCrisis * _grwCrisis * _uCrisis,          // all three
    0.55 * Math.max(_infCrisis * _grwCrisis,     // any two
                    _infCrisis * _uCrisis,
                    _grwCrisis * _uCrisis)
);

dGrowth += 0.020 * (outputGap / (1 + Math.abs(outputGap) * 0.25));
dGrowth += businessCycle * 0.05;
dGrowth += 0.01 * dt * (1 - Q.capital_pressure * 0.2) * 0.4;

// Inflation drag — softened under triple crisis
if (Q.inflation > 6) dGrowth -= Math.min(0.015 * (Q.inflation - 6), 2.0);
if (Q.inflation < -2) {
    const dm = Math.abs(Q.inflation);
    dGrowth -= Math.min(0.03 * (dm - 2) / (1 + (dm - 2) * 0.7), 0.8) * DS;
    if (Q.inflation < -5) dGrowth -= Math.min(0.05 * (dm - 5) / (1 + (dm - 5) * 0.7), 0.7) * DS;
    if (Q.inflation < -8) dGrowth -= Math.min(0.05 * (dm - 8) / (1 + (dm - 8) * 0.7), 0.5) * DS;
}
dGrowth -= Math.min(0.003 * Math.pow(Math.abs(Q.inflation), 1.5), 0.7) * DS;

// Unemployment drag — softened under triple crisis
const uGapG = Math.max(0, Q.unemployed - Q.NAIRU);
dGrowth -= Math.min(0.004 * uGapG / (1 + uGapG * 0.10), 1.5) * DS;
if (Q.unemployed > 10)
    dGrowth -= Math.min(0.007 * (Q.unemployed - 10) / (1 + (Q.unemployed - 10) * 0.18), 1.0) * DS;

dGrowth -= 0.007 * overheating;
if (Q.economic_growth > 8) dGrowth -= 0.005 * (Q.economic_growth - 8);

// Depth boost on stimulus (FIX B)
const depthBoost = 1 + Math.max(0, -Q.economic_growth - 5) * 0.04;
dGrowth += demandForce * 1.3 * depthBoost;
dGrowth += supplyForce * 1.6 * depthBoost;

// External drag — softened under triple crisis
dGrowth -= Math.min(Q.trade_pressure   * 0.07, 1.5) * DS;
dGrowth -= Math.min(Q.capital_pressure * 0.08, 1.5) * DS;

if (Q.phase === "depression") {
    if (Q.economic_growth < -10) {
        const floorStrength = Math.min(1.0, (-10 - Q.economic_growth) / 5);
        dGrowth += 0.15 * floorStrength;
    }
    if (Q.phase_duration > 5 && Q.phase_duration % 6 === 0)
        dGrowth += 0.08;
}

dGrowth += (Math.random() - 0.5) * 0.015;

// Dynamic cap (FIX C)
const growthDepthCap = Q.economic_growth < -10
    ? 3.0 + Math.min(1.5, (-10 - Q.economic_growth) * 0.15)
    : 3.0;
dGrowth = Math.max(-3, Math.min(growthDepthCap, dGrowth));


// ============================================================
// SECTION 8 — APPLY DELTAS
// ============================================================

const inCrisis = (Q.phase === "depression" || Q.phase === "hyperinflation");
const momentum = inCrisis ? 0.95 : 1.05;

Q.inflation       += dInflation    * dt * momentum;
Q.unemployed      += dUnemployment * dt * momentum;
Q.economic_growth += dGrowth       * dt * momentum;


// ============================================================
// SECTION 9 — DECAY PERSISTENT SIGNALS
// T1 — Depression demand decay starts at 0.03, not ramping from 0.35.
//       Player policies persist long enough to actually stack.
// FIX 5 — Post-crisis grace period in correction for 10 ticks.
// ============================================================

const depDur = Q.phase === "depression" ? Q.phase_duration : 0;

const BASE_DR = {
    growth:         { demand: 0.16, supply: 0.25, price: 0.25, trade: 0.30 },
    overheating:    { demand: 0.19, supply: 0.25, price: 0.18, trade: 0.30 },
    hyperinflation: { demand: 0.35, supply: 0.08, price: 0.05, trade: 0.14 },
    correction:     { demand: 0.35, supply: 0.25, price: 0.50, trade: 0.18 },
    // T1: demand decay floor lowered from ramping-toward-0.03 to starting at 0.03
    depression:     { demand: Math.max(0.03, 0.08 - depDur * 0.004),   // was 0.35 - depDur*0.008
                      supply: Math.max(0.03, 0.25 - depDur * 0.006),
                      price:  0.50,
                      trade:  Math.max(0.04, 0.30 - depDur * 0.007) },
    stagflation:    { demand: 0.25, supply: 0.25, price: 0.13, trade: 0.09 },
};

let dr = BASE_DR[Q.phase] || { demand: 0.16, supply: 0.25, price: 0.25, trade: 0.30 };

// FIX 5: grace period — interpolate from depression toward correction over 10 ticks
if (Q.phase === "correction" && (Q.post_crisis_ticks || 0) < 10) {
    const t     = Q.post_crisis_ticks / 10;
    const depDr = BASE_DR.depression;
    const corDr = BASE_DR.correction;
    dr = {
        demand: depDr.demand + (corDr.demand - depDr.demand) * t,
        supply: depDr.supply + (corDr.supply - depDr.supply) * t,
        price:  depDr.price  + (corDr.price  - depDr.price)  * t,
        trade:  depDr.trade  + (corDr.trade  - depDr.trade)  * t,
    };
}

Q.demand_pressure = (Q.demand_pressure || 0) < 0
    ? Q.demand_pressure * Math.exp(-0.25 * dt)
    : Q.demand_pressure * Math.exp(-dr.demand * dt);
Q.supply_pressure    = (Q.supply_pressure   || 0) * Math.exp(-dr.supply * dt);
Q.price_pressure     = (Q.price_pressure    || 0) * Math.exp(-dr.price  * dt);
Q.trade_pressure     = (Q.trade_pressure    || 0) * Math.exp(-dr.trade  * dt);
Q.fiscal_stance      = (Q.fiscal_stance     || 0) * Math.exp(-0.15 * dt);
Q.distribution_shift = (Q.distribution_shift|| 0) * Math.exp(-0.08 * dt);


// ============================================================
// SECTION 10 — CONSTRAINTS (single pass)
// ============================================================

if (!Q.math_broken) {
    // NORMAL: Hard clamps keep economic variables in valid ranges
    Q.inflation              = Math.max(-12, Math.min(99, Q.inflation));
    Q.unemployed             = Math.max(0,   Math.min(75, Q.unemployed));
    Q.economic_growth        = Math.max(-15, Math.min(20, Q.economic_growth));
    Q.inflation_expectations = Math.max(-9,  Math.min(99, Q.inflation_expectations));
    Q.capital_pressure       = Math.max(0,   Math.min(1.2, Q.capital_pressure));
    if (Q.phase === "depression") Q.demand_pressure = Math.max(-0.5, Q.demand_pressure);
    Q.supply_cost_drag       = Math.max(0,   Math.min(0.5, Q.supply_cost_drag));
    Q.credit_expansion       = Math.max(0,   Math.min(0.8, Q.credit_expansion));
} else {
    // MATH BROKEN: Constraints become suggestions
    Q.inflation              = Q.impossible_add(Q.inflation, 0);
    Q.unemployed             = Q.impossible_percentage(Q.unemployed);
    Q.economic_growth        = Q.impossible_subtract(Q.economic_growth, 0);
    Q.inflation_expectations = Q.impossible_multiply(Q.inflation_expectations, 1);
    Q.capital_pressure       = Q.impossible_add(Q.capital_pressure, 0); // Can exceed 1.2 or go negative
    // supply_cost_drag and credit_expansion left unconstrained — anything goes
    console.log("CONSTRAINT CHAOS: inflation=" + Q.inflation + " unemployed=" + Q.unemployed + " growth=" + Q.economic_growth);
}





















    // Science support/economic changes
    if (Q.major_curriculum && Q.major_curriculum == "democratic") {
        if (Q.pro_republic < 80) {
            Q.pro_republic += 0.3;
        } 
    }
    if (Q.minor_curriculum && Q.minor_curriculum == "democratic") {
        if (Q.pro_republic < 60) {
            Q.pro_republic += 0.6;
        } 
    }

    if (Q.major_curriculum && Q.major_curriculum == "traditional") {
        if (Q.nationalism < 60) {
            Q.nationalism += 0.1;
        } 
    }
    if (Q.minor_curriculum && Q.minor_curriculum == "traditional") {
        if (Q.nationalism < 40) {
            Q.nationalism += 0.3;
        } 
    }


    // science bonus to economic growth
    // education bonus
    Q.science_bonus = 0;
    if (Q.education_science) {
        Q.science_bonus += Q.education_science;
    }
    if (Q.science) {
        if (Q.science >= 5) {
            Q.science_bonus += 3;
        } else if (Q.science >= 3) {
            Q.science_bonus += 2;
        } else if (Q.science >= 1) {
            Q.science_bonus += 1;
        }
    }
    if (Q.applied_research && Q.applied_research >= 1) {
        Q.science_bonus += 0.5*Q.applied_research;
    }
    // cap the science bonus at 6
    if (Q.science_bonus > 6) {
        Q.science_bonus = 6;
    }
    console.log(Q.science_bonus);
    // this is kinda messy but basically more science -> higher levels of baseline growth
    if (Q.science_bonus >= 1) {
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus + 3) {
            Q.economic_growth += 0.1;
        }
        if (Q.return_to_normalcy && Q.economic_growth < Q.science_bonus) {
            Q.economic_growth += 0.1;
        }
        if (Q.economic_growth < Q.science_bonus - 3) {
            Q.economic_growth += 0.1;
        }
    }
    // accumulated economic growth/decline
    // Maybe there should be differences for positive/negative growth?
    if (Q.economic_growth < 0) {
        if (Q.economic_expansion > 0) {
            Q.economic_expansion = 0;
        } else {
            Q.economic_expansion += Q.economic_growth;
        }
    }
    if (Q.economic_growth > 0 && Q.reparations <= -2 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth;
    } else if (Q.economic_growth > 0 && Q.spd_in_government) {
        Q.economic_expansion += Q.economic_growth/2;
    }




/// SMALL SETTINGS

if (!Q.math_broken) {
    // NORMAL: Sum of progressive party support
    Q.progressive_coalition = Q.spd_r + Q.kpd_r + Q.ddp_r + Q.srpd_r + Q.sapd_r + Q.csrp_r;
} else {
    // MATH BROKEN: Coalition math doesn't add up
    Q.progressive_coalition = Q.impossible_add(
        Q.impossible_add(Q.spd_r, Q.kpd_r),
        Q.impossible_add(Q.impossible_add(Q.ddp_r, Q.srpd_r), Q.impossible_add(Q.sapd_r, Q.csrp_r))
    );
    console.log("COALITION CHAOS: Progressive coalition = " + Q.progressive_coalition + "%");
}

if (Q.year >= 1932 && Q.communist_revolution_timer > 10 && Q.april_challenge == 1) {
    Q.communist_revolution_timer -= 2;
    Q.rfb_strength += 20;
}





// === PARTY RELATION GRAVITY ===
// Pulls extreme values back toward centre, stronger the further they are

Q.relation_gravity = function(value) {
    var abs = Math.abs(value);
    
    // Only activates beyond 80, scales up to 100
    if (abs <= 80) return value;
    
    // How far past 80 are we? (0 to 20)
    var excess = abs - 80;
    
    // Pull strength scales with excess: gentle at 81, strong at 100
    var pull = excess * 0.04; // At 100: pulls by 0.8/turn. At 90: pulls by 0.4/turn
    
    // Pull toward centre (opposite sign of value)
    if (value > 0) {
        return value - pull;
    } else {
        return value + pull;
    }
};

var relations = ['z', 'kpd', 'sapd', 'srpd', 'cnbl', 'csvd', 'csrp', 'dhp', 'bb', 'kvp', 'ddp', 'vrp', 'bvp', 'dvp', 'wp', 'dnvp', 'nsdap', 'dvfp'];
for (var rel of relations) {
    Q[rel + '_relation'] = Q.relation_gravity(Q[rel + '_relation']);
    if (!Q.math_broken) {
        // NORMAL: Hard cap just in case
        Q[rel + '_relation'] = Math.max(-100, Math.min(100, Q[rel + '_relation']));
    } else {
        // MATH BROKEN: Relations can exceed bounds — a party might be 150% friendly or -200% hostile
        Q[rel + '_relation'] = Q.impossible_add(Q[rel + '_relation'], 0);
    }
}




































    
// ============================================================
// OPINION DYNAMICS — v2
// Tick = 2 weeks (semi-month)
//
// Key changes from v1:
//   - Velocity/momentum tracking (trajectory matters, not just position)
//   - Continuous economy signal instead of binary good/bad gates
//   - Differentiated inertia: nationalism spikes fast/bleeds slow,
//     socialism is sticky, republic legitimacy is sluggish both ways
//   - Faction-weighted influence (junior partners absorb more blame)
//   - Honeymoon/fatigue: grace period on entry, erosion over time
//   - TSE effects multiply into signals rather than stacking additively
//   - All base magnitudes scaled down for fortnightly ticks
// ============================================================

// ============================================================
// HELPERS
// ============================================================

function scale(value, low, high) {
    return Math.max(0, Math.min(1, (value - low) / (high - low)));
}

function lerp(a, b, t) {
    return a + (b - a) * Math.max(0, Math.min(1, t));
}

// Soft sigmoid approach to ceilings/floors — replaces hard clamp logic.
// Returns a multiplier that tapers toward zero as value approaches wall.
function wall_damp(value, wall, width, pushing_toward_wall) {
    if (!pushing_toward_wall) return 1.0;
    var dist = Math.abs(value - wall);
    return Math.max(0, Math.min(1, dist / width));
}

// ============================================================
// VELOCITY TRACKING
// Last-tick deltas stored on Q to compute momentum.
// ============================================================

if (Q.nat_vel  === undefined) Q.nat_vel  = 0;
if (Q.soc_vel  === undefined) Q.soc_vel  = 0;
if (Q.pr_vel   === undefined) Q.pr_vel   = 0;

// Momentum factor: a signal moving fast in one direction amplifies
// further movement in that direction (bandwagon), but only up to a cap.
// Negative momentum (reversals) face friction.
function momentum_mult(velocity, direction) {
    // direction: +1 or -1 for which way we're currently pushing
    var alignment = velocity * direction; // positive = bandwagon, negative = reversal
    if (alignment > 0) {
        // Bandwagon: up to 1.35x amplification, saturating around vel=3
        return 1.0 + Math.min(0.35, alignment * 0.12);
    } else {
        // Reversal friction: harder to turn a fast-moving trend
        return Math.max(0.55, 1.0 + alignment * 0.08);
    }
}

// ============================================================
// TSE FLAG
// ============================================================

var tse = Q.transformed_socialist_economy ? 1 : 0;

// ============================================================
// TICK SCALING
// Base tick = 2 weeks. All deltas are approximately 1/26 of
// annual-scale effects. We don't divide everything by 26 literally —
// instead we reduce the master scaling constants and let the
// continuous signals carry the weight.
// ============================================================

var TICK = 0.38; // master scalar (replaces the flat 0.65 everywhere)

// ============================================================
// CONTINUOUS ECONOMY SIGNAL
// Replaces binary economy_good / economy_bad.
// Returns a value in [-1, +1]:
//   +1 = unambiguous prosperity
//   -1 = severe crisis
//    0 = neutral / mixed
// This feeds into push/pull as a continuous weight rather than a gate.
// ============================================================

var unemp_score     = 1 - scale(Q.unemployed,       3, 22);   // 1=good, 0=bad
var inflation_score = 1 - scale(Math.abs(Q.inflation), 2, 14); // 1=stable, 0=bad
var growth_score    = scale(Q.economic_growth,      -4, 6);   // 1=growing, 0=shrinking

// Weighted composite: unemployment dominates, then growth, then inflation
var econ_composite = (unemp_score * 0.40) + (growth_score * 0.35) + (inflation_score * 0.25);
// Remap from [0,1] to [-1,+1]
var econ_signal = (econ_composite - 0.5) * 2.0;

// TSE raises the bar — transformation promised structural full employment.
// Shift the signal downward slightly if TSE active (harder to reach "good")
if (tse) {
    econ_signal -= scale(Q.unemployed, 4, 10) * 0.25;
}

// Clamp to [-1, +1]
econ_signal = Math.max(-1, Math.min(1, econ_signal));

// Convenience aliases for partial-signal zones
var econ_positive = Math.max(0,  econ_signal);  // 0 when bad, >0 when good
var econ_negative = Math.max(0, -econ_signal);  // 0 when good, >0 when bad
var econ_mixed    = 1 - Math.abs(econ_signal);  // peaks at 0, 1 when perfectly mixed

// ============================================================
// PHASE MULTIPLIERS
// Now applied as multipliers on specific components of econ_negative/positive,
// rather than flat scalars on pre-computed stress values.
// ============================================================

var phase_unemp_mult       = 1.0;
var phase_inflation_mult   = 1.0;
var phase_growth_mult      = 1.0;
var phase_centrist_penalty = 0.0;

switch (Q.phase) {
    case "growth":
        phase_unemp_mult     = 0.7;
        phase_inflation_mult = 0.8;
        phase_growth_mult    = 1.4;
        break;
    case "overheating":
        phase_unemp_mult     = 0.8;
        phase_inflation_mult = 1.3;
        phase_growth_mult    = 1.2;
        break;
    case "hyperinflation":
        phase_unemp_mult       = 0.9;
        phase_inflation_mult   = 2.2;
        phase_growth_mult      = 1.0;
        phase_centrist_penalty = 0.8;
        break;
    case "correction":
        phase_unemp_mult     = 1.2;
        phase_inflation_mult = 1.0;
        phase_growth_mult    = 1.3;
        break;
    case "depression":
        phase_unemp_mult       = 2.0;
        phase_inflation_mult   = 0.7;
        phase_growth_mult      = 1.6;
        phase_centrist_penalty = 1.0;
        break;
    case "stagflation":
        phase_unemp_mult       = 1.4;
        phase_inflation_mult   = 1.4;
        phase_growth_mult      = 1.2;
        phase_centrist_penalty = 1.4;
        break;
}

// Phase-weighted economy signal for unemployment, inflation, and growth
// components separately — lets phases tilt which dimension of distress bites
var unemp_neg    = scale(Q.unemployed,           8, 25) * phase_unemp_mult;
var unemp_pos    = (1 - scale(Q.unemployed,      3, 10)) * (2.0 - phase_unemp_mult);
var infl_neg     = scale(Math.abs(Q.inflation),  5, 15) * phase_inflation_mult;
var infl_pos     = (1 - scale(Math.abs(Q.inflation), 3, 8)) * (2.0 - phase_inflation_mult);
var growth_pos   = scale(Q.economic_growth,      1,  6) * phase_growth_mult;
var growth_neg   = scale(-Q.economic_growth,     1, 10) * phase_growth_mult;

// TSE amplifies unemployment signals bidirectionally
if (tse) {
    unemp_neg *= 1.4;
    unemp_pos *= 1.3;
}

unemp_pos  = Math.max(0, Math.min(1, unemp_pos));
infl_pos   = Math.max(0, Math.min(1, infl_pos));

// ============================================================
// PARTY BLOC COUNTS AND INFLUENCE
// Junior coalition partners now weighted differently —
// the smallest partner absorbs disproportionate blame.
// ============================================================

var socialist_party_count   = 0;
var centrist_party_count    = 0;
var nationalist_party_count = 0;

if (Q.ideology === "left" && Q.spd_in_government && Q.social_fascism_adopted != 1) socialist_party_count++;
if (Q.kpd_in_government)  socialist_party_count++;
if (Q.sapd_in_government) socialist_party_count++;
if (Q.sl_in_government)   socialist_party_count++;
if (Q.kpo_in_government)  socialist_party_count++;
if (Q.lb_in_government) socialist_party_count++;

if (Q.spd_in_government && Q.ideology !== "left") centrist_party_count++;
if (Q.z_in_government)    centrist_party_count++;
if (Q.ddp_in_government)  centrist_party_count++;
if (Q.dvp_in_government && (Q.dvp_right_shift || 0) < 1) centrist_party_count++;
if (Q.srpd_in_government) centrist_party_count++;
if (Q.wp_in_government)   centrist_party_count++;
if (Q.bvp_in_government)  centrist_party_count++;
if (Q.dnvp_in_government && Q.dnvp_line === 1) centrist_party_count++;
if (Q.aspd_in_government) centrist_party_count++;
if (Q.vnr_in_government)  centrist_party_count++;
if (Q.hl_in_government)   centrist_party_count++;
if (Q.sls_in_government)   centrist_party_count++;
if (Q.cvp_in_government)   centrist_party_count++;
if (Q.rdp_in_government)   centrist_party_count++;

if (Q.vnr_in_government)  nationalist_party_count++;
if (Q.dtsp_in_government)  nationalist_party_count++;
if (Q.dnvp_in_government && Q.dnvp_line !== 1) nationalist_party_count++;
if (Q.cnbl_in_government) nationalist_party_count++;
if (Q.nsdap_in_government) nationalist_party_count++;
if (Q.dvfp_in_government) nationalist_party_count++;
if (Q.dvp_in_government && (Q.dvp_right_shift || 0) >= 1) nationalist_party_count++;

// Influence: junior partners (single-party-count blocs in large coalitions)
// take amplified blame. The smaller you are relative to the coalition,
// the more exposed you are to voter punishment.
var total_govt_parties = socialist_party_count + centrist_party_count + nationalist_party_count;
var coalition_size_factor = total_govt_parties > 0 ? total_govt_parties : 1;

function bloc_influence(count) {
    if (count === 0) return 0;
    var base = Math.min(count * 0.35, 1.0);
    // Junior penalty: lone bloc in a large coalition gets +15% blame exposure
    if (count === 1 && coalition_size_factor >= 3) base *= 1.15;
    return Math.min(base, 1.0);
}

var socialist_influence   = bloc_influence(socialist_party_count);
var centrist_influence    = bloc_influence(centrist_party_count);
var nationalist_influence = bloc_influence(nationalist_party_count);

var socialist_in_power    = socialist_party_count > 0;
var centrist_in_power     = centrist_party_count > 0;
var nationalist_in_power  = nationalist_party_count > 0;

// ============================================================
// HONEYMOON / FATIGUE
// New governments get a grace period where blame is muted.
// Long-serving governments face credibility fatigue.
// Stored as Q.govt_tenure_ticks — caller must increment this
// each tick a government persists (or reset on change).
// ============================================================

if (Q.govt_tenure_ticks === undefined) Q.govt_tenure_ticks = 0;

// Honeymoon: first ~12 ticks (6 months), blame absorption is 40% lower
var honeymoon_factor = 1.0 - (0.40 * Math.max(0, 1 - Q.govt_tenure_ticks / 12));
// Fatigue: after ~52 ticks (2 years), credit absorption starts dropping too
var fatigue_factor   = 1.0 - (0.25 * scale(Q.govt_tenure_ticks, 52, 104));

// ============================================================
// PRO_REPUBLIC
// Sluggish in both directions — institutions change slowly.
// ============================================================

var pr_push = 0;
var pr_pull = 0;

// Positive economy feeds republic legitimacy — but slowly,
// institutions earn trust over time more than via single events
pr_push += (unemp_pos * 1.2 + infl_pos * 0.7 + growth_pos * 1.0) * econ_positive * fatigue_factor;

// Negative economy bleeds republic — faster than recovery
pr_pull += (unemp_neg * 2.2 + infl_neg * 1.0 + growth_neg * 1.8) * econ_negative * honeymoon_factor;

// Blame attribution — only when economy is clearly bad
if (econ_negative > 0.3) {
    if (!Q.spd_in_government && !Q.z_in_government) {
        pr_pull += 0.6 * econ_negative;
    }
    if (centrist_in_power && !socialist_in_power && !nationalist_in_power) {
        pr_pull += phase_centrist_penalty * centrist_influence * econ_negative;
    }
}

// TSE: multiplied into existing push/pull rather than additive
if (tse) {
    if (econ_positive > 0.3) {
        // Transformation + prosperity: "the republic can deliver"
        pr_push *= (1.0 + 0.4 * socialist_influence);
    } else if (econ_negative > 0.3) {
        // Transformation + crisis: constitutional anxiety
        pr_pull *= (1.0 + 0.7 * socialist_influence);
    } else {
        // Mixed: structural anxiety
        pr_pull += 0.25 * socialist_influence;
    }
}

var raw_pr_delta = (pr_push - pr_pull);

// Republic legitimacy: asymmetric inertia.
// Recovers at ~60% the speed it falls — institutions bleed faster than they heal.
var pr_inertia = raw_pr_delta > 0 ? 0.60 : 1.0;
raw_pr_delta *= pr_inertia;

// Momentum
var pr_mom = momentum_mult(Q.pr_vel, raw_pr_delta > 0 ? 1 : -1);
raw_pr_delta *= pr_mom;

// Wall damping
raw_pr_delta *= wall_damp(Q.pro_republic, raw_pr_delta > 0 ? 90 : 10, 18, true);

var pr_delta = raw_pr_delta * TICK;
Q.pr_vel = lerp(Q.pr_vel, raw_pr_delta, 0.3); // velocity updates toward raw signal

// ============================================================
// NATIONALISM
// Fast to spike, slow to bleed.
// Explanatory simplicity (scapegoating, betrayal) makes it
// the fastest absorber of economic anxiety.
// ============================================================

var nat_push = 0;
var nat_pull = 0;

// Crisis: nationalism absorbs anxiety fastest of the three
nat_push += (unemp_neg * 2.8 + infl_neg * 1.0 + growth_neg * 2.0) * econ_negative;

if (econ_negative > 0.25) {
    if (nationalist_in_power) {
        // In power during bad times: takes blame, but less than left would
        nat_pull += 1.3 * nationalist_influence * econ_negative * honeymoon_factor;
    }
    if (socialist_in_power || centrist_in_power) {
        var other_influence = Math.max(socialist_influence, centrist_influence);
        nat_push += 1.0 * other_influence * econ_negative;
    }
}

// Prosperity: nationalism loses its core message
nat_pull += (unemp_pos * 1.0 + infl_pos * 0.7) * econ_positive;

if (econ_positive > 0.25) {
    if (nationalist_in_power) {
        // In power during good times: gets some credit but also scrutiny
        nat_push += 1.0 * nationalist_influence * econ_positive * fatigue_factor;
    }
    if (socialist_in_power) {
        nat_pull += 0.8 * socialist_influence * econ_positive;
    }
}

// TSE opposition effect: multiplied into the push/pull
if (tse) {
    if (econ_negative > 0.25 && !nationalist_in_power) {
        // "We told you so" — amplified by how badly transformation is failing
        nat_push *= (1.0 + 0.6 * (1 - socialist_influence) * econ_negative);
    }
    if (econ_positive > 0.25 && !nationalist_in_power) {
        // Successful transformation: ideological defeat for nationalism
        nat_pull *= (1.0 + 0.35 * socialist_influence);
    }
}

var raw_nat_delta = (nat_push - nat_pull);

// Nationalism: FAST spike, SLOW bleed.
// Rising: 1.25x speed. Falling: 0.65x speed.
var nat_inertia = raw_nat_delta > 0 ? 1.25 : 0.65;
raw_nat_delta *= nat_inertia;

var nat_mom = momentum_mult(Q.nat_vel, raw_nat_delta > 0 ? 1 : -1);
raw_nat_delta *= nat_mom;

raw_nat_delta *= wall_damp(Q.nationalism, raw_nat_delta > 0 ? 90 : 10, 18, true);

var nat_delta = raw_nat_delta * TICK;
Q.nat_vel = lerp(Q.nat_vel, raw_nat_delta, 0.35);

// ============================================================
// SOCIALISM
// Slower to move than nationalism, stickier once established.
// Class consciousness builds gradually; it also dissolves gradually.
// ============================================================

var soc_push = 0;
var soc_pull = 0;

// Crisis: socialism gains, but more slowly than nationalism
soc_push += (unemp_neg * 2.8 + infl_neg * 0.8 + growth_neg * 1.6) * econ_negative;

if (econ_negative > 0.25) {
    if (socialist_in_power) {
        var soc_blame_mult = tse ? 0.55 : 1.0; // TSE enables blame deflection
        soc_blame_mult *= honeymoon_factor;
        soc_pull += 1.3 * socialist_influence * econ_negative * soc_blame_mult;
    }
    if (nationalist_in_power && !Q.in_grand_coalition) {
        soc_push += 1.0 * nationalist_influence * econ_negative;
    }
}

// Prosperity: socialism loses urgency narrative
soc_pull += (unemp_pos * 1.0 + infl_pos * 0.7) * econ_positive;

if (econ_positive > 0.25) {
    if (socialist_in_power) {
        soc_push += 1.0 * socialist_influence * econ_positive * fatigue_factor;
    }
    if (nationalist_in_power && !socialist_in_power) {
        soc_pull += 0.7 * nationalist_influence * econ_positive;
    }
}

// TSE structural legitimacy — multiplied into existing signals
if (tse && socialist_in_power) {
    // The transformation itself generates ongoing ideological momentum
    soc_push += 0.25 * socialist_influence;

    if (econ_positive > 0.3) {
        // Vindication narrative amplifies what's already happening
        soc_push *= (1.0 + 0.5 * socialist_influence);
    }
}

var raw_soc_delta = (soc_push - soc_pull);

// Socialism: moderate speed both ways, stickier than nationalism.
// Rising: 0.95x. Falling: 0.75x (class loyalty persists under pressure).
var soc_inertia = raw_soc_delta > 0 ? 0.95 : 0.75;
raw_soc_delta *= soc_inertia;

var soc_mom = momentum_mult(Q.soc_vel, raw_soc_delta > 0 ? 1 : -1);
raw_soc_delta *= soc_mom;

raw_soc_delta *= wall_damp(Q.socialism, raw_soc_delta > 0 ? 90 : 10, 18, true);

var soc_delta = raw_soc_delta * TICK;
Q.soc_vel = lerp(Q.soc_vel, raw_soc_delta, 0.25); // slowest velocity update = stickiest

// ============================================================
// COMPETENCE COUNTERS
// Now continuous rather than threshold-gated.
// ============================================================

if (Q.socialist_govt_success_counter  === undefined) Q.socialist_govt_success_counter  = 0;
if (Q.nationalist_govt_success_counter === undefined) Q.nationalist_govt_success_counter = 0;

if (socialist_in_power) {
    // Counter drifts toward econ_signal — good times build it, bad times erode it
    var soc_counter_drift = econ_signal * socialist_influence * 0.3;
    Q.socialist_govt_success_counter = Math.max(0, Math.min(8,
        Q.socialist_govt_success_counter + soc_counter_drift));

    // Sustained competence compounds socialism score (slowly)
    if (Q.socialist_govt_success_counter > 4) {
        soc_delta += 0.08 * socialist_influence *
            scale(Q.socialist_govt_success_counter, 4, 8) * TICK;
    }
}

if (nationalist_in_power) {
    var nat_counter_drift = econ_signal * nationalist_influence * 0.3;
    Q.nationalist_govt_success_counter = Math.max(0, Math.min(8,
        Q.nationalist_govt_success_counter + nat_counter_drift));

    if (Q.nationalist_govt_success_counter > 4) {
        nat_delta += 0.08 * nationalist_influence *
            scale(Q.nationalist_govt_success_counter, 4, 8) * TICK;
    }
}

// ============================================================
// CROSS-PRESSURE
// Extremes rising bleeds the republic.
// Polarization is bidirectional but asymmetric:
// nationalism rising suppresses socialism more than vice versa
// (fear displaces class solidarity faster than it's rebuilt).
// ============================================================

var cross_mult = tse ? 1.4 : 1.0;

if (Q.nationalism > 35 || Q.socialism > 35) {

    if (nat_delta > 0) {
        pr_delta  -= nat_delta * 0.20 * cross_mult;
        soc_delta -= nat_delta * 0.12; // fear displaces solidarity
    }
    if (soc_delta > 0) {
        pr_delta  -= soc_delta * 0.20 * cross_mult;
        nat_delta -= soc_delta * 0.08; // weaker displacement in this direction
    }

    // If both rising simultaneously: they partially cancel each other
    // rather than both compounding freely
    if (nat_delta > 0 && soc_delta > 0) {
        var smaller = Math.min(nat_delta, soc_delta);
        nat_delta -= smaller * 0.10;
        soc_delta -= smaller * 0.10;
    }
}

// ============================================================
// BROKEN PROMISES
// TSE raises the unemployment betrayal threshold.
// Now uses continuous signal rather than hard threshold.
// ============================================================

if (econ_negative > 0.35) {
    if (socialist_in_power) {
        var unemp_threshold  = tse ? 12 : 20;
        var betrayal_signal  = scale(Q.unemployed, unemp_threshold, unemp_threshold + 8);

        if (betrayal_signal > 0) {
            var betrayal_mag = tse ? 0.55 : 0.30;
            var rep_bleed    = tse ? 0.18 : 0.09;
            soc_delta -= betrayal_mag * socialist_influence * betrayal_signal * TICK;
            pr_delta  -= rep_bleed   * socialist_influence * betrayal_signal * TICK;
        }
    }

    if (nationalist_in_power && (Q.inflation > 15 || Q.economic_growth < -5)) {
        nat_delta -= 0.30 * nationalist_influence * TICK;
        pr_delta  -= 0.09 * nationalist_influence * TICK;
    }

    if (!socialist_in_power && !nationalist_in_power && centrist_in_power) {
        soc_delta += 0.18 * centrist_influence * TICK;
        nat_delta += 0.18 * centrist_influence * TICK;
        pr_delta  -= 0.18 * centrist_influence * TICK;
    }
}

// ============================================================
// TSE PHASE INTERACTIONS
// Now multiplicative into the running deltas rather than flat additive.
// Smaller base values reflect the fortnightly tick — these are
// slow ideological tides, not overnight conversions.
// ============================================================

if (tse) {
    if (Q.phase === "depression") {
        soc_delta += 0.28 * socialist_influence * TICK;
        nat_delta += 0.16 * TICK;
        pr_delta  -= 0.22 * TICK;
    }

    if (Q.phase === "hyperinflation") {
        soc_delta -= 0.45 * socialist_influence * TICK;
        nat_delta += 0.35 * TICK;
        pr_delta  -= 0.35 * TICK;
    }

    if (Q.phase === "stagflation") {
        soc_delta -= 0.18 * socialist_influence * TICK;
        nat_delta += 0.22 * TICK;
        pr_delta  -= 0.28 * TICK;
    }

    if (Q.phase === "growth") {
        soc_delta += 0.22 * socialist_influence * TICK;
        nat_delta -= 0.16 * socialist_influence * TICK;
        pr_delta  += 0.11 * socialist_influence * TICK;
    }
}

// ============================================================
// HISTORICAL PRECEDENT
// ============================================================

if (Q.spd_crisis_victories && Q.spd_crisis_victories > 0
        && econ_positive > 0.3 && socialist_in_power) {
    soc_delta += 0.06 * Q.spd_crisis_victories * socialist_influence * TICK;
}

if (Q.nationalist_crisis_failures && Q.nationalist_crisis_failures > 0
        && nationalist_in_power) {
    nat_delta -= 0.04 * Q.nationalist_crisis_failures * nationalist_influence * TICK;
}

// ============================================================
// APPLY DELTAS
// ============================================================

Q.pro_republic += pr_delta;
Q.nationalism  += nat_delta;
Q.socialism    += soc_delta;

// ============================================================
// CLAMP & ROUND
// ============================================================

if (!Q.math_broken) {
    // NORMAL: Clamp to [0, 100] and round to 1 decimal
    Q.pro_republic = Math.round(Math.max(0, Math.min(100, Q.pro_republic)) * 10) / 10;
    Q.nationalism  = Math.round(Math.max(0, Math.min(100, Q.nationalism))  * 10) / 10;
    Q.socialism    = Math.round(Math.max(0, Math.min(100, Q.socialism))    * 10) / 10;
} else {
    // MATH BROKEN: Values can exceed 100, go negative, or become nonsense
    Q.pro_republic = Q.impossible_percentage(Q.pro_republic);
    Q.nationalism  = Q.impossible_percentage(Q.nationalism);
    Q.socialism    = Q.impossible_percentage(Q.socialism);
    console.log("OPINION CHAOS: PR=" + Q.pro_republic + " Nat=" + Q.nationalism + " Soc=" + Q.socialism + " Total=" + (Q.pro_republic + Q.nationalism + Q.socialism));
}










// =========================== CABINET ECONOMICAL EFFECTS ====================




// ============================================================
// BRÜNING AUSTERITY / LAUTENBACH PLAN — mutually exclusive
// ============================================================

if (Q.bruning_cabinet === 1 && Q.lautenbach_plan_active !== 1 && Q.lautenbach_plan_rejected === 1) {

    // Budget improves modestly — spending cuts and tax enforcement
    Q.budget += 0.07;

    // Deflation pressure — wage cuts, price controls, tight money
    Q.dInflation        -= 0.03;
    Q.price_pressure    -= 0.03;

    // Demand collapses — less public spending, lower wages
    Q.demand_impulse    -= 0.07;
    Q.fiscal_stance     -= 0.06;

    // Unemployment creeps up — layoffs from public sector cuts
    Q.dUnemployment     += 0.07;

    // Capital pressure eases slightly — creditor confidence
    Q.capital_pressure  -= 0.03;

    // Trade pressure eases — deflation makes exports cheaper
    Q.trade_pressure    -= 0.03;

} else if (Q.bruning_cabinet === 1 && Q.lautenbach_plan_active === 1 && !Q.return_to_normalcy) {

    // --------------------------------------------------------
    // LAUTENBACH PLAN — credit-financed public investment
    // Semi-WTB, pre-Keynesian demand stimulus
    // Overrides austerity but carries inflation/debt risk
    // --------------------------------------------------------

    // Budget takes a hit — deficit spending is the mechanism
    Q.budget            -= 0.16;

    // Demand recovers — public works and credit expansion
    Q.demand_impulse    += 0.10;
    Q.fiscal_stance     += 0.04;

    // Supply side benefits — infrastructure investment
    Q.supply_impulse    += 0.05;

    // Unemployment falls slightly — job creation programs
    Q.dUnemployment     -= 0.05;

    // Growth gets a nudge upward
    Q.dGrowth           += 0.05;

    // Inflation creeps back up — more money chasing goods
    Q.dInflation        += 0.04;
    Q.price_pressure    += 0.04;

    // Capital pressure rises — creditors nervous about deficit
    Q.capital_pressure  += 0.04;

    // Trade pressure ticks up slightly — imports rise with demand
    Q.trade_pressure    += 0.03;
}


if (Q.wagemann_plan_active === 1 && Q.year >= 1932 && Q.year < 1933) {
    Q.lautenbach_plan_active = 0;
    Q.lautenbach_plan_rejected = 0;
    

    // Money supply expansion — core of the Wagemann mechanism
    // Directly pressures inflation expectations
    Q.dInflation                += 0.14;
    Q.price_pressure            += 0.08;
    Q.inflation_expectations    += 0.06;

    // If expectations already unanchored, spiral risk kicks in
    // Wagemann's plan was terrifying to anyone who remembered 1923
    if (!Q.expectations_anchored) {
        Q.dInflation            += 0.10;
        Q.price_pressure        += 0.06;
        Q.inflation_expectations+= 0.08;
    }

    // Demand recovers — reflation puts money into circulation
    Q.demand_impulse            += 0.10;
    Q.credit_expansion          += 0.06;

    // Unemployment nudges down — but slower than Lautenbach
    // Monetary stimulus is less targeted than direct job creation
    Q.dUnemployment             -= 0.05;

    // Growth benefits modestly
    Q.dGrowth                   += 0.06;

    // Budget is largely neutral — this is monetary not fiscal
    // Slight improvement from tax base recovery
    Q.budget                    += 0.05;

    // Capital flight risk — foreign creditors panic at moneyprinting
    Q.capital_pressure          += 0.08;
    Q.trade_pressure            += 0.05;

    // If inflation already above 4, compounding risk
    // The 1923 memory makes markets overreact
    if (Q.inflation > 4) {
        Q.capital_pressure      += 0.06;
        Q.dInflation            += 0.05;
    }
}

// ============================================================
// WTB TIMER EFFECTS
// ============================================================

if ((Q.wtb_timer || 0) > 0) {

    const diminish = Q.wtb_implemented >= 4 ? 0.70 : 1.0;

    Q.demand_impulse  = (Q.demand_impulse  || 0) + 0.04  * diminish;
    Q.fiscal_stance   = (Q.fiscal_stance   || 0) - 0.03  * diminish;
    Q.price_pressure  = (Q.price_pressure  || 0) + 0.02  * diminish;
    Q.supply_impulse  = (Q.supply_impulse  || 0) + 0.02  * diminish;
    Q.capital_pressure = Math.max(0, (Q.capital_pressure || 0) - 0.01 * diminish);
}



























// === PARTY RELATIONS DYNAMIC PATCH (runs every tick) ===

// KPD
Q.party_relations.KPD.SPD  = Q.kpd_relation;
Q.party_relations.KPD.SRPD = Q.kpd_relation + 5;
Q.party_relations.KPD.SAPD = 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0);

// SAPD
Q.party_relations.SAPD.SPD = 55 + (Q.left_strength >= 50 ? 15 : 0);
Q.party_relations.SAPD.KPD = 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0);

// SPD
Q.party_relations.SPD.KPD  = Q.kpd_relation;
Q.party_relations.SPD.DDP  = Q.ddp_relation;
Q.party_relations.SPD.Z    = Q.z_relation;
Q.party_relations.SPD.BVP  = Q.bvp_relation  ?? 35;
Q.party_relations.SPD.DVP  = Q.dvp_relation;
Q.party_relations.SPD.CSRP = Q.csrp_relation;
Q.party_relations.SPD.WP   = Q.wp_relation   ?? 25;
Q.party_relations.SPD.CNBL = Q.cnbl_relation  ?? 20;
Q.party_relations.SPD.CSVD = Q.csvd_relation  ?? 35;
Q.party_relations.SPD.DNVP = Q.dnvp_relation;
Q.party_relations.SPD.VRP  = Q.vrp_relation   ?? 20;
Q.party_relations.SPD.NSDAP= Q.nsdap_relation;
Q.party_relations.SPD.KVP  = Q.kvp_relation;
Q.party_relations.SPD.DHP  = Q.dhp_relation;
Q.party_relations.SPD.BB   = Q.bb_relation;
Q.party_relations.SPD.DVFP = Q.dvfp_relation;

// SRPD
Q.party_relations.SRPD.KPD  = Q.kpd_relation - 10;
Q.party_relations.SRPD.DDP  = Q.ddp_relation + 10;
Q.party_relations.SRPD.Z    = Q.z_relation + 5;
Q.party_relations.SRPD.BVP  = (Q.bvp_relation  ?? 35) + 5;
Q.party_relations.SRPD.DVP  = Q.dvp_relation - 5;
Q.party_relations.SRPD.CSRP = Q.csrp_relation + 5;
Q.party_relations.SRPD.WP   = (Q.wp_relation   ?? 25) - 5;
Q.party_relations.SRPD.CNBL = (Q.cnbl_relation  ?? 20) + 5;
Q.party_relations.SRPD.CSVD = (Q.csvd_relation  ?? 35) + 5;
Q.party_relations.SRPD.DNVP = Q.dnvp_line === 3 ? 0 : Q.dnvp_relation - 10;

// DDP
Q.party_relations.DDP.SPD  = Q.ddp_relation;
Q.party_relations.DDP.SRPD = Q.ddp_relation + 10;
Q.party_relations.DDP.DVP  = 65 - (Q.dvp_right_shift ?? 0) * 10;

// Z
Q.party_relations.Z.SPD    = Q.z_relation;
Q.party_relations.Z.SRPD   = Q.z_relation + 5;
Q.party_relations.Z.DVP    = 60 + (Q.z_party_leader === "Kaas" ? 10 : 0);
Q.party_relations.Z.DNVP   = (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10);
Q.party_relations.Z.NSDAP  = Q.nazi_urgency >= 7 ? 0 : Math.max(0, 25 - Q.nazi_urgency * 5);

// BVP
Q.party_relations.BVP.SPD   = Q.bvp_relation ?? 35;
Q.party_relations.BVP.SRPD  = (Q.bvp_relation ?? 35) + 5;
Q.party_relations.BVP.NSDAP = Math.max(0, 15 - Q.nazi_urgency * 3);

// DVP
Q.party_relations.DVP.SPD   = Q.dvp_relation;
Q.party_relations.DVP.SRPD  = Q.dvp_relation - 5;
Q.party_relations.DVP.DDP   = 65 - (Q.dvp_right_shift ?? 0) * 10;
Q.party_relations.DVP.Z     = 60 + (Q.z_party_leader === "Kaas" ? 10 : 0);
Q.party_relations.DVP.DNVP  = 50 + (Q.dvp_right_shift ?? 0) * 15;
Q.party_relations.DVP.NSDAP = 20 + (Q.capital_strike_progress * 6) + (Q.dvp_right_shift ?? 0) * 12;

// WP
Q.party_relations.WP.SPD   = Q.wp_relation ?? 25;
Q.party_relations.WP.SRPD  = (Q.wp_relation ?? 25) - 5;
Q.party_relations.WP.NSDAP = 35 + (Q.capital_strike_progress * 4);

// CNBL
Q.party_relations.CNBL.SPD   = Q.cnbl_relation ?? 20;
Q.party_relations.CNBL.SRPD  = (Q.cnbl_relation ?? 20) + 5;
Q.party_relations.CNBL.NSDAP = 30 + (Q.capital_strike_progress * 4) + (Q.year >= 1930 ? 10 : 0);

// CSVD
Q.party_relations.CSVD.SPD  = Q.csvd_relation ?? 40;
Q.party_relations.CSVD.SRPD = (Q.csvd_relation ?? 40) + 5;
Q.party_relations.CSVD.DNVP = Q.dnvp_line === 3 ? 5 : 55;

// DNVP
Q.party_relations.DNVP.SPD  = Q.dnvp_relation;
Q.party_relations.DNVP.SRPD = Q.dnvp_relation - 5;
Q.party_relations.DNVP.DDP  = Q.dnvp_line === 3 ? 5 : 30;
Q.party_relations.DNVP.Z    = (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10);
Q.party_relations.DNVP.CSVD = Q.dnvp_line === 3 ? 5 : 55;
Q.party_relations.DNVP.NSDAP= Q.dnvp_line === 3 ? 70 : 40;
Q.party_relations.DNVP.KVP  = Q.dnvp_line === 3 ? 5 : 60;
Q.party_relations.DNVP.DHP  = Q.dnvp_line === 3 ? 15 : 55;

// NSDAP
Q.party_relations.NSDAP.Z    = Q.nazi_urgency >= 7 ? 0 : Math.max(0, 20 - Q.nazi_urgency * 4);
Q.party_relations.NSDAP.BVP  = Math.max(0, 15 - Q.nazi_urgency * 3);
Q.party_relations.NSDAP.DVP  = 20 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift ?? 0) * 10;
Q.party_relations.NSDAP.WP   = 30 + (Q.capital_strike_progress * 3);
Q.party_relations.NSDAP.DNVP = Q.dnvp_line === 3 ? 70 : 40;
Q.party_relations.NSDAP.VRP  = 25 + (Q.capital_strike_progress * 3);

// VRP
Q.party_relations.VRP.SPD  = Q.vrp_relation;
Q.party_relations.VRP.DNVP = Q.dnvp_line === 3 ? 10 : 35;




// === COALITION BLOCKS DYNAMIC PATCH (runs every tick) ===

if (!Q.coalition_blocks) {
    // Blocks not initialized yet — skip patch this tick
} else {

Q.coalition_blocks.KPD_Z     = Q.z_relation < 65 || Q.kpd_relation < 65;
Q.coalition_blocks.KPD_DDP   = Q.kpd_relation < 65;
Q.coalition_blocks.KPD_SPD   = Q.communist_coalition < 3;

Q.coalition_blocks.SPD_DNVP  = Q.dnvp_relation < 60 || Q.dnvp_line === 3;
Q.coalition_blocks.SPD_KPD   = Q.communist_coalition < 3;
Q.coalition_blocks.SPD_VRP   = Q.vrp_relation < 35;

Q.coalition_blocks.SRPD_KPD  = Q.kpd_relation < 40;
Q.coalition_blocks.SRPD_DNVP = Q.dnvp_line === 3;
Q.coalition_blocks.SRPD_VRP  = Q.vrp_relation < 30;

Q.coalition_blocks.DDP_DNVP  = Q.dnvp_line === 3;

Q.coalition_blocks.Z_KPD     = Q.kpd_relation < 65 || Q.z_relation < 45;
Q.coalition_blocks.Z_NSDAP   = Q.nazi_urgency >= 6;
Q.coalition_blocks.Z_DNVP    = Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas";

Q.coalition_blocks.BVP_NSDAP = Q.nazi_urgency >= 6;

Q.coalition_blocks.DVP_NSDAP = Q.nazi_urgency >= 7 && Q.capital_strike_progress < 4;
Q.coalition_blocks.DVP_VRP   = Q.dvp_right_shift >= 2;

Q.coalition_blocks.WP_NSDAP  = Q.capital_strike_progress < 5;

Q.coalition_blocks.CNBL_SPD  = Q.cnbl_relation < 30;

Q.coalition_blocks.DNVP_SPD  = Q.dnvp_line === 3 || Q.dnvp_relation < 40;
Q.coalition_blocks.DNVP_DDP  = Q.dnvp_line === 3;
Q.coalition_blocks.DNVP_Z    = Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas";
Q.coalition_blocks.DNVP_VRP  = Q.dnvp_line === 3;

Q.coalition_blocks.NSDAP_BVP = Q.nazi_urgency >= 6;
Q.coalition_blocks.NSDAP_Z   = Q.nazi_urgency >= 6;
Q.coalition_blocks.NSDAP_COALITIONS_GENERALLY = Q.nsdap_r < 35 || Q.year < 1932;

Q.coalition_blocks.VRP_DNVP  = Q.dnvp_line === 3;
Q.coalition_blocks.VRP_DVP   = Q.dvp_right_shift >= 1;
Q.coalition_blocks.VRP_SPD   = Q.vrp_relation < 35;

Q.coalition_blocks.KVP_DNVP  = Q.dnvp_line === 3;

Q.coalition_blocks.DHP_NSDAP = Q.nazi_urgency >= 5;

Q.coalition_blocks.BB_NSDAP  = Q.nazi_urgency >= 7;

}





// ============================================================
// QOL GRIEVANCE SYSTEM
// ============================================================

// ============================================================
// SECTION 2A — TARGET COMPUTATION PER DIMENSION PER CLASS
// Each target is 0–100. 50 = neutral (1928 baseline).
// Above 50 = satisfied, below 50 = aggrieved.
// ============================================================

// ---- SHARED SIGNALS ----
// Pre-compute signals used across multiple classes to avoid repetition.

// Economic signals
const _qol_unemp_stress  = Math.max(0, Q.unemployed - 8);       // 0 at baseline
const _qol_infl_stress   = Math.abs(Q.inflation - 2);            // 0 at stable 2%
const _qol_defl_stress   = Math.max(0, -Q.inflation);            // deflation hits debtors
const _qol_growth_bonus  = Math.max(0, Q.economic_growth - 1);   // positive growth signal
const _qol_growth_stress = Math.max(0, -Q.economic_growth);      // contraction signal

// Security signals
const _qol_sa_threat  = (Q.sa_strength  * Q.sa_militancy)  / 500;
const _qol_rfb_threat = (Q.rfb_strength * Q.rfb_militancy) / 400;
const _qol_sh_threat  = (Q.sh_strength  * Q.sh_militancy)  / 600;
const _qol_rb_shield  = Math.min(1.5, (Q.rb_strength * Q.rb_militancy) / 3000);
const _qol_pol_loyal  = ((Q.prussian_police_loyalty || 0.5) + (Q.interior_police_loyalty || 0.45)) / 2;

// Political signals
const _qol_spd_in_govt  = Q.spd_in_government  ? 1 : 0;
const _qol_left_in_govt = (Q.spd_in_government || Q.kpd_in_government || Q.sapd_in_government) ? 1 : 0;
const _qol_right_in_govt= (Q.dnvp_in_government || Q.nsdap_in_government) ? 1 : 0;
const _qol_con_reform   = Q.constitutional_reform || 0;
const _qol_pres_rel     = (Q.hindenburg_patience  || 50) / 100;

// Cultural signals
const _qol_edu          = Q.education_science || 0;
const _qol_sci          = Q.science           || 0;
const _qol_womens       = Q.womens_rights      || 0;
const _qol_secular      = Q.secularized        || 0;
const _qol_curriculum_d = (Q.major_curriculum === 'democratic'  || Q.minor_curriculum === 'democratic')  ? 1 : 0;
const _qol_curriculum_t = (Q.major_curriculum === 'traditional' || Q.minor_curriculum === 'traditional') ? 1 : 0;
const _qol_concordat    = (Q.prussian_concordate || Q.reichskonkordat) ? 1 : 0;
const _qol_youth_orgs   = Q.youth_organizations || 0;


// ============================================================
// WORKERS
// ============================================================

{
    // --- Economic ---
    let _t = 50;
    _t += (Q.welfare          || 0) * 7;
    _t += (Q.working_hours    || 0) * 5;
    _t += (Q.workers_safety   || 0) * 4;
    _t += (Q.works_councils   || 0) * 4;
    _t += (Q.works_program    || 0) * 6;
    _t += (Q.wtb_implemented  || 0) * 5;
    _t += (Q.cooperatives     || 0) * 3;
    _t += _qol_growth_bonus        * 1.5;
    _t -= _qol_unemp_stress        * 2.5;
    _t -= _qol_growth_stress       * 2.0;
    _t -= (Q.dues_workers     || 0) * 4;     // dues are a burden on workers
    _t -= _qol_infl_stress         * 0.8;   // workers hurt by inflation but less than middle
    if (Q.unions_independent === 1) _t -= 10; // alienated from SPD
    _t = Math.max(0, Math.min(100, _t));
    Q.workers_grievance_economic += ((_t - Q.workers_grievance_economic) * Q.grievance_decay.economic);

    // --- Security ---
    _t = 50;
    _t -= _qol_sa_threat  * 18;   // SA is the primary threat to workers
    _t -= _qol_rfb_threat * 6;    // RFB crossfire also hurts workers
    _t += _qol_rb_shield  * 12;   // Reichsbanner protects
    _t += _qol_pol_loyal  * 10;   // loyal police helps
    _t -= (Q.blutmai ? 8 : 0);    // Blutmai permanently scars worker trust in state
    _t -= (Q.rb_banned  ? 12 : 0);
    _t -= (Q.rfb_banned ? 3  : 0); // RFB ban removes crossfire but also solidarity org
    _t = Math.max(0, Math.min(100, _t));
    Q.workers_grievance_security += ((_t - Q.workers_grievance_security) * Q.grievance_decay.security);

    // --- Political ---
    _t = 50;
    _t += _qol_spd_in_govt      * 15;
    _t += (Q.labor_rights    || 0) * 8;
    _t += (Q.works_councils  || 0) * 5;
    _t += (Q.economic_democracy || 0) * 6;
    _t += _qol_con_reform       * 4;
    _t -= _qol_right_in_govt    * 12;
    _t -= (Q.presidential_cabinet ? 8 : 0);
    _t -= (Q.emergency_rule   ? 10 : 0);
    _t -= (Q.rfb_banned && !Q.kpd_banned ? 6 : 0); // banning their orgs feels political
    _t = Math.max(0, Math.min(100, _t));
    Q.workers_grievance_political += ((_t - Q.workers_grievance_political) * Q.grievance_decay.political);

    // --- Cultural ---
    _t = 50;
    _t += _qol_edu              * 4;
    _t += _qol_womens           * 3;
    _t += (Q.commonwealth_cooperation || 0) * 5;
    _t += _qol_curriculum_d     * 5;
    _t -= _qol_curriculum_t     * 4;
    _t += _qol_youth_orgs       * 3;
    _t = Math.max(0, Math.min(100, _t));
    Q.workers_grievance_cultural += ((_t - Q.workers_grievance_cultural) * Q.grievance_decay.cultural);
}


// ============================================================
// UNEMPLOYED
// ============================================================

{
    // --- Economic ---
    let _t = 50;
    _t += (Q.welfare        || 0) * 8;
    _t += (Q.works_program  || 0) * 10;   // works programs are their direct lifeline
    _t += (Q.wtb_implemented|| 0) * 8;
    _t += (Q.state_buyer    || 0) * 5;
    _t -= _qol_unemp_stress       * 3.5;  // they feel this most acutely
    _t -= _qol_growth_stress      * 2.5;
    _t -= _qol_defl_stress        * 1.5;  // deflation = no jobs being created
    _t -= (Q.dues_unemployedc > 0 ? (Q.dues_unemployedc * 6) : -8); // waived dues = relief
    _t = Math.max(0, Math.min(100, _t));
    Q.unemployedc_grievance_economic += ((_t - Q.unemployedc_grievance_economic) * Q.grievance_decay.economic);

    // --- Security ---
    _t = 50;
    _t -= _qol_sa_threat  * 20;   // SA recruits and terrorizes the unemployed simultaneously
    _t -= _qol_rfb_threat * 8;
    _t += _qol_rb_shield  * 10;
    _t += _qol_pol_loyal  * 8;
    _t -= (Q.blutmai ? 10 : 0);
    _t -= (Q.rb_banned  ? 14 : 0);
    _t = Math.max(0, Math.min(100, _t));
    Q.unemployedc_grievance_security += ((_t - Q.unemployedc_grievance_security) * Q.grievance_decay.security);

    // --- Political ---
    _t = 50;
    _t += _qol_left_in_govt     * 12;
    _t += (Q.labor_rights    || 0) * 5;
    _t += _qol_con_reform       * 3;
    _t -= _qol_right_in_govt    * 15;   // right govt = austerity = their destruction
    _t -= (Q.presidential_cabinet ? 12 : 0);
    _t -= (Q.emergency_rule   ? 12 : 0);
    _t -= (Q.austerity_cuts   ? 15 : 0); // emergency cuts devastate them
    _t = Math.max(0, Math.min(100, _t));
    Q.unemployedc_grievance_political += ((_t - Q.unemployedc_grievance_political) * Q.grievance_decay.political);

    // --- Cultural ---
    _t = 50;
    _t += _qol_edu              * 3;
    _t += _qol_youth_orgs       * 4;   // youth orgs matter more — they skew young
    _t += _qol_curriculum_d     * 4;
    _t -= _qol_curriculum_t     * 3;
    _t = Math.max(0, Math.min(100, _t));
    Q.unemployedc_grievance_cultural += ((_t - Q.unemployedc_grievance_cultural) * Q.grievance_decay.cultural);
}


// ============================================================
// OLD MIDDLE (Mittelstand — artisans, small shopkeepers, rentiers)
// ============================================================

{
    // --- Economic ---
    let _t = 50;
    // Old middle was destroyed by 1923 — inflation is their deepest fear
    _t -= _qol_infl_stress        * 4.0;   // strongest inflation sensitivity of any class
    _t -= _qol_defl_stress        * 2.0;   // deflation kills their businesses too
    _t -= _qol_unemp_stress       * 1.5;   // less direct than workers
    _t += _qol_growth_bonus       * 2.0;
    _t -= _qol_growth_stress      * 2.5;
    _t += (Q.pro_consumer      || 0) * 5;  // pro-consumer policy helps shopkeepers
    _t -= (Q.dues_old_middle   || 0) * 5;
    _t += (Q.nationalization_progress > 0 ? -8 : 0); // nationalization threatens them
    _t = Math.max(0, Math.min(100, _t));
    Q.old_middle_grievance_economic += ((_t - Q.old_middle_grievance_economic) * Q.grievance_decay.economic);

    // --- Security ---
    _t = 50;
    _t -= _qol_sa_threat  * 8;    // SA is disruptive to their businesses
    _t -= _qol_rfb_threat * 10;   // RFB street fighting scares shopkeepers more
    _t += _qol_pol_loyal  * 12;
    _t -= (Q.general_strike_progress > 3 ? 10 : 0); // general strike = closed shops
    _t -= (Q.rb_banned  ? 5  : 0);
    _t -= (Q.emergency_rule ? -5 : 0); // emergency rule = order, they may prefer it
    _t = Math.max(0, Math.min(100, _t));
    Q.old_middle_grievance_security += ((_t - Q.old_middle_grievance_security) * Q.grievance_decay.security);

    // --- Political ---
    _t = 50;
    _t -= _qol_spd_in_govt      * 8;    // SPD = socialism = threat to property
    _t -= _qol_left_in_govt     * 10;
    _t += _qol_right_in_govt    * 6;
    _t += _qol_con_reform       * 3;
    _t += (Q.judicial_reform   || 0) * 5; // rule of law protects their contracts
    _t -= (Q.presidential_cabinet ? 3 : 0); // ambiguous — order but uncertainty
    _t -= (Q.emergency_rule   ? -4 : 0);   // they often prefer strong order
    _t = Math.max(0, Math.min(100, _t));
    Q.old_middle_grievance_political += ((_t - Q.old_middle_grievance_political) * Q.grievance_decay.political);

    // --- Cultural ---
    // Old middle is the most culturally conservative class
    _t = 50;
    _t += _qol_concordat        * 8;    // church-state relations matter deeply
    _t += _qol_curriculum_t     * 8;    // traditional curriculum = their values
    _t -= _qol_curriculum_d     * 6;
    _t -= _qol_secular          * 5;
    _t -= _qol_womens           * 3;    // women's rights challenge their worldview
    _t += (Q.judicial_reform   || 0) * 3;
    _t = Math.max(0, Math.min(100, _t));
    Q.old_middle_grievance_cultural += ((_t - Q.old_middle_grievance_cultural) * Q.grievance_decay.cultural);
}


// ============================================================
// NEW MIDDLE (White-collar workers, civil servants, professionals)
// ============================================================

{
    // --- Economic ---
    let _t = 50;
    _t += _qol_growth_bonus       * 3.0;   // growth = promotions, security
    _t -= _qol_growth_stress      * 3.0;
    _t -= _qol_infl_stress        * 2.5;   // salaries don't keep up with inflation
    _t -= _qol_defl_stress        * 1.5;
    _t -= _qol_unemp_stress       * 1.5;
    _t += (Q.education_science || 0) * 5;  // education = their career prospects
    _t += (Q.science           || 0) * 4;
    _t -= (Q.dues_new_middle   || 0) * 4;
    _t += (Q.wtb_implemented   || 0) * 3;  // WTB stabilizes the economy they depend on
    _t = Math.max(0, Math.min(100, _t));
    Q.new_middle_grievance_economic += ((_t - Q.new_middle_grievance_economic) * Q.grievance_decay.economic);

    // --- Security ---
    _t = 50;
    _t -= _qol_sa_threat  * 10;
    _t -= _qol_rfb_threat * 10;   // equally threatened by both extremes
    _t += _qol_pol_loyal  * 14;   // care most about state order
    _t -= (Q.general_strike_progress > 3 ? 8 : 0);
    _t += (Q.emergency_rule ? 5 : 0); // new middle often prefers order over freedom
    _t -= (Q.rb_banned  ? 6  : 0);
    _t = Math.max(0, Math.min(100, _t));
    Q.new_middle_grievance_security += ((_t - Q.new_middle_grievance_security) * Q.grievance_decay.security);

    // --- Political ---
    _t = 50;
    // New middle wants competent, stable government more than ideology
    _t += _qol_con_reform       * 6;
    _t += (Q.bureaucratic_reform || 0) * 8;  // direct interest in civil service reform
    _t += (Q.judicial_reform    || 0) * 5;
    _t -= (Q.presidential_cabinet ? 4 : 0);
    _t -= _qol_left_in_govt     * 6;    // SPD threatens their civil service positions
    _t -= _qol_right_in_govt    * 4;    // DNVP purges them too
    _t += _qol_pres_rel         * 5;    // presidential legitimacy matters
    _t = Math.max(0, Math.min(100, _t));
    Q.new_middle_grievance_political += ((_t - Q.new_middle_grievance_political) * Q.grievance_decay.political);

    // --- Cultural ---
    // New middle is split — educated but often nationalist
    _t = 50;
    _t += _qol_edu              * 6;
    _t += _qol_sci              * 5;
    _t += _qol_womens           * 4;   // more open to women's rights than old middle
    _t += _qol_curriculum_d     * 4;
    _t -= _qol_curriculum_t     * 3;
    _t += _qol_youth_orgs       * 3;
    _t = Math.max(0, Math.min(100, _t));
    Q.new_middle_grievance_cultural += ((_t - Q.new_middle_grievance_cultural) * Q.grievance_decay.cultural);
}


// ============================================================
// RURAL
// ============================================================

{
    // --- Economic ---
    let _t = 50;
    _t += (Q.agricultural_policy  || 0) * 8;
    _t += (Q.agricultural_finance || 0) * 7;
    _t += (Q.land_reform          || 0) * 6;   // land reform helps poor farmers
    _t += (Q.state_buyer          || 0) * 6;   // state grain purchases = price floor
    _t -= _qol_defl_stress              * 3.5; // deflation crushes farm prices hardest
    _t -= _qol_infl_stress              * 1.5; // input cost inflation hurts
    _t -= _qol_unemp_stress             * 1.0;
    _t += _qol_growth_bonus             * 1.5;
    _t -= (Q.tariffs < 0 ? Math.abs(Q.tariffs) * 5 : 0); // low tariffs = foreign competition
    _t -= (Q.dues_rural           || 0) * 4;
    _t = Math.max(0, Math.min(100, _t));
    Q.rural_grievance_economic += ((_t - Q.rural_grievance_economic) * Q.grievance_decay.economic);

    // --- Security ---
    // Rural areas experience less direct street violence but fear disorder
    _t = 50;
    _t -= _qol_sa_threat  * 6;
    _t -= _qol_rfb_threat * 6;
    _t += _qol_pol_loyal  * 8;
    _t -= (Q.emergency_rule ? -6 : 0); // rural often welcomes strong order
    _t -= (Q.general_strike_progress > 5 ? 8 : 0); // strikes cut off supply chains
    _t = Math.max(0, Math.min(100, _t));
    Q.rural_grievance_security += ((_t - Q.rural_grievance_security) * Q.grievance_decay.security);

    // --- Political ---
    _t = 50;
    _t += (Q.agricultural_policy  || 0) * 6;  // direct representation of rural interests
    _t += (Q.land_reform          || 0) * 5;
    _t -= _qol_spd_in_govt              * 5;   // SPD is an urban party
    _t -= _qol_left_in_govt             * 8;
    _t += _qol_right_in_govt            * 4;   // DNVP claims to represent agrarian interests
    _t += (Q.cnbl_in_government ? 8 : 0);      // explicit rural party in govt
    _t += (Q.bb_in_government   ? 6 : 0);
    _t -= (Q.presidential_cabinet ? 2 : 0);
    _t = Math.max(0, Math.min(100, _t));
    Q.rural_grievance_political += ((_t - Q.rural_grievance_political) * Q.grievance_decay.political);

    // --- Cultural ---
    // Rural is the most church-dependent and tradition-bound class
    _t = 50;
    _t += _qol_concordat        * 12;   // church-state agreement is central to rural life
    _t += _qol_curriculum_t     * 10;
    _t -= _qol_curriculum_d     * 8;
    _t -= _qol_secular          * 8;
    _t -= _qol_womens           * 4;
    _t += (Q.catholics > 35 ? 4 : 0);  // high catholic share = concordat matters more
    _t += _qol_youth_orgs       * 2;
    _t = Math.max(0, Math.min(100, _t));
    Q.rural_grievance_cultural += ((_t - Q.rural_grievance_cultural) * Q.grievance_decay.cultural);
}


// ============================================================
// SECTION 2B — COMPOSITE QOL CALCULATION
// Weighted sum of 4 dimensions per class → Q.[class]_qol (0–150)
// ============================================================

const _CLASSES_QOL_TICK    = ['workers', 'unemployedc', 'old_middle', 'new_middle', 'rural'];
const _DIMENSIONS_QOL_TICK = ['economic', 'security', 'political', 'cultural'];

for (const _c of _CLASSES_QOL_TICK) {
    const _w  = Q.grievance_weights[_c];
    let _composite = 0;

    for (const _d of _DIMENSIONS_QOL_TICK) {
        // grievance dimension is 0-100, 50=neutral
        // remap to -50/+50 relative to neutral, then weight
        _composite += (_w[_d] * Q[_c + '_grievance_' + _d]);
    }
    // _composite is now 0-100 (50 = perfectly neutral across all dimensions)
    // Remap to 0-150 scale where 100 = 1928 baseline
    // Formula: 100 + (_composite - 50) * 1.0
    // So 50 composite → QOL 100, 100 composite → QOL 150, 0 composite → QOL 50

    Q[_c + '_qol_last'] = Q[_c + '_qol'];
    Q[_c + '_qol']      = Math.max(50, Math.min(150,
        100 + (_composite - 50)
    ));
    Q[_c + '_qol_vel']  = Q[_c + '_qol'] - Q[_c + '_qol_last'];
}

// Convenience aliases for display
Q.workers_qol_display    = Q.workers_qol.toFixed(1);
Q.unemployed_qol_display = Q.unemployedc_qol.toFixed(1);
Q.old_middle_qol_display = Q.old_middle_qol.toFixed(1);
Q.new_middle_qol_display = Q.new_middle_qol.toFixed(1);
Q.rural_qol_display      = Q.rural_qol.toFixed(1);

// Overall population QOL (class-size weighted)
Q.population_qol = (
    (Q.workers    / 100) * Q.workers_qol    +
    (Q.unemployedc/ 100) * Q.unemployedc_qol+
    (Q.old_middle / 100) * Q.old_middle_qol +
    (Q.new_middle / 100) * Q.new_middle_qol +
    (Q.rural      / 100) * Q.rural_qol
);
Q.population_qol = Math.round(Q.population_qol * 10) / 10;


// ============================================================
// SECTION 3D — MATH BROKEN COMPATIBILITY
// If Q.math_broken is active, QOL becomes chaotic.
// ============================================================

if (Q.math_broken) {
    for (const _c of ['workers', 'unemployedc', 'old_middle', 'new_middle', 'rural']) {
        Q[_c + '_qol'] = Q.impossible_percentage(Q[_c + '_qol']);
        for (const _d of ['economic', 'security', 'political', 'cultural']) {
            Q[_c + '_grievance_' + _d] = Q.impossible_add(Q[_c + '_grievance_' + _d], 0);
        }
    }
    Q.population_qol = Q.impossible_percentage(Q.population_qol);
    console.log('QOL CHAOS: population_qol=' + Q.population_qol);
}


// ============================================================
// SECTION 3C — QOL DISPLAY STRING
// ============================================================

{
    const _QOL_CLASSES = [
        ['workers',    'Workers'],
        ['unemployedc','Unemployed'],
        ['old_middle', 'Old Middle'],
        ['new_middle', 'New Middle'],
        ['rural',      'Rural'],
    ];
    const _QOL_DIMS = ['economic', 'security', 'political', 'cultural'];

    function _qol_bar(val) {
        // val is 0-100 grievance dimension. 50=neutral.
        // Returns a simple text indicator.
        if (val >= 75) return '+++';
        if (val >= 60) return '++ ';
        if (val >= 50) return '+  ';
        if (val >= 40) return '-  ';
        if (val >= 25) return '-- ';
        return                     '---';
    }

    let _report = '';
    for (const [_ck, _label] of _QOL_CLASSES) {
        const _qol = Q[_ck + '_qol'] || 100;
        const _vel = Q[_ck + '_qol_vel'] || 0;
        const _trend = _vel > 0.3 ? '↑' : _vel < -0.3 ? '↓' : '→';
        _report += `**${_label}** QOL: ${_qol.toFixed(0)} ${_trend}\n`;
        for (const _d of _QOL_DIMS) {
            const _dval = Q[_ck + '_grievance_' + _d] || 50;
            _report += `  ${_d}: ${_qol_bar(_dval)} (${_dval.toFixed(0)})\n`;
        }
        _report += '\n';
    }
    _report += `**Population QOL:** ${(Q.population_qol || 100).toFixed(1)}\n`;
    Q.qol_report = _report;
}


// ============================================================
// IDENTITY POPULATION DRIFT
// These are overlapping shares, not a normalized pool.
// ============================================================

// --- SECULARS ---
// Grows slowly with education and science policy
// Shrinks if traditional curriculum dominates
Q.secular_growth = 0;
if (Q.education_science >= 2)   Q.secular_growth += 0.08;
if (Q.education_science >= 4)   Q.secular_growth += 0.06;
if (Q.secularized >= 1)         Q.secular_growth += 0.10;
if (Q.major_curriculum === 'traditional') Q.secular_growth -= 0.10;
if (Q.minor_curriculum === 'traditional') Q.secular_growth -= 0.05;
// Baseline slow drift upward — modernization is a tide
Q.secular_growth += 0.02;
Q.seculars = Math.max(3, Math.min(40, Q.seculars + Q.secular_growth));

// --- CATHOLICS ---
// Mostly stable — shifts only from major events
// Slow natural decline as seculars grow, mostly from Protestant pool
Q.catholics = Math.max(20, Math.min(40, Q.catholics - Q.secular_growth * 0.3));

// --- PROTESTANTS ---
// Derived residual — takes the bulk of secular drift loss
Q.protestants = Math.max(30, Math.min(75, 100 - Q.catholics - Q.seculars));

// --- YOUTH ---
// 18-30 cohort radicalization level, not raw population share
// Rises with economic crisis, street violence, unemployment
// Falls with stability, successful youth policy
Q.youth_crisis_pressure = 0;
Q.youth_crisis_pressure += Math.max(0, Q.unemployed - 8) * 0.15;
Q.youth_crisis_pressure += Math.max(0, -Q.economic_growth) * 0.10;
Q.youth_crisis_pressure += ((Q.sa_strength * Q.sa_militancy) + 
                            (Q.rfb_strength * Q.rfb_militancy)) / 8000;
// Normalization pressure — always pulls back toward baseline over time
Q.youth_normalization = (Q.youth - 18) * 0.05;
// Policy counters
Q.youth_policy_effect = 0;
if (Q.youth_organizations >= 1) Q.youth_policy_effect -= 0.15 * Q.youth_organizations;
if (Q.education_science >= 2)   Q.youth_policy_effect -= 0.08;
if (Q.womens_rights >= 2)       Q.youth_policy_effect -= 0.04;

Q.youth = Math.max(10, Math.min(55, 
    Q.youth + Q.youth_crisis_pressure - Q.youth_normalization + Q.youth_policy_effect
));


// ============================================================
// IDENTITY MODIFIERS
// Applied to ideology_caps.base as multipliers.
// Each variable is a population share 0-100.
// Normalized to 0-1 for multiplication.
// ============================================================

var cath_share  = Q.catholics  / 100;
var prot_share  = Q.protestants / 100;
var sec_share   = Q.seculars   / 100;
var youth_share = Q.youth      / 100;

// Pre-compute identity bonuses/penalties per party
// Format: base multiplier applied after all other cap calculations
Q.identity_modifier = {
    // SPD: secular and youth friendly, loses ground with catholics
    spd:   1 + (sec_share * 0.20) + (youth_share * 0.08) - (cath_share * 0.10),

    // SRPD: similar to SPD
    srpd:  1 + (sec_share * 0.15) + (youth_share * 0.06) - (cath_share * 0.08),

    // KPD: strongly secular, youth volatile — gains youth in crisis
    kpd:   1 + (sec_share * 0.30) + (youth_share * 0.15) - (cath_share * 0.15),

    // SAPD: similar to KPD but weaker
    sapd:  1 + (sec_share * 0.20) + (youth_share * 0.10) - (cath_share * 0.10),

    // NSDAP: Protestant and youth are its hunting ground
    // Catholics resist strongly, seculars partially resist
    nsdap: 1 + (prot_share * 0.34) + (youth_share * 0.45) 
             - (cath_share * 0.40) - (sec_share * 0.10),

    // DNVP: Protestant conservative base, loses youth
    dnvp:  1 + (prot_share * 0.45) - (youth_share * 0.15) - (cath_share * 0.10),

    //DVFP
    dvfp:  1 + (prot_share * 0.25) - (youth_share * 0.25) - (cath_share * 0.10),

    // DVP: secular liberal business, loses catholics and youth extremes
    dvp:   1 + (sec_share * 0.15) + (prot_share * 0.10) - (youth_share * 0.12),

    // DDP: strongly secular, loses heavily in crisis youth environment
    ddp:   1 + (sec_share * 0.25) + (prot_share * 0.05) - (youth_share * 0.20),

    // Z: Catholic party — catholic share is its lifeline
    z:     1 + (cath_share * 0.60) - (sec_share * 0.30) - (youth_share * 0.10),

    // BVP: same as Z, even more catholic-dependent
    bvp:   1 + (cath_share * 0.70) - (sec_share * 0.35) - (youth_share * 0.08),

    // CNBL: rural Protestant, weak youth appeal
    cnbl:  1 + (prot_share * 0.15) - (youth_share * 0.10),

    // WP: middle class secular-ish, neutral on religion
    wp:    1 + (sec_share * 0.10) - (youth_share * 0.18),

    // CSVD: Protestant conservative, anti-Nazi but still nationalist
    csvd:  1 + (prot_share * 0.20) - (youth_share * 0.12) - (cath_share * 0.08),

    // CSRP: small, secular-left
    csrp:  1 + (sec_share * 0.15) - (cath_share * 0.10),

    // VRP: secular, youth hostile
    vrp:   1 + (sec_share * 0.10) - (youth_share * 0.25),

    // BB: rural Protestant agrarian
    bb:    1 + (prot_share * 0.12) - (youth_share * 0.08),

    // DHB: Protestant conservative regional
    dhp:   1 + (prot_share * 0.15) - (youth_share * 0.10),

    // KVP: Protestant moderate conservative
    kvp:   1 + (prot_share * 0.12) - (youth_share * 0.15),

dtsp:  1 + (prot_share * 0.28) + (youth_share * 0.20) - (cath_share * 0.35) - (sec_share * 0.08),

sls:   1 + (sec_share * 0.08) - (cath_share * 0.05),

rdp:   1 + (sec_share * 0.30) + (prot_share * 0.05) - (cath_share * 0.20) - (youth_share * 0.18),

cvp:   1 + (cath_share * 0.55) - (sec_share * 0.28) - (youth_share * 0.12),

lb:    1 + (sec_share * 0.25) + (youth_share * 0.18) - (cath_share * 0.18),

    // OTHER: catch-all, slight youth boost (protest votes)
    other: 1 + (youth_share * 0.10)
};


// === PARTY DRIFT OVERHAUL ===
// Architecture: thermostat model
// Each tick: target = f(conditions), support moves toward target at speed s
// No caps, no soft cap function, no delta accumulation
// Target IS the ceiling/floor — self-correcting by design

// ─────────────────────────────────────────
// SHARED FACTORS (unchanged from original)
// ─────────────────────────────────────────

Q.unemployment_threshold = 7.5;
Q.inflation_threshold    = 3.0;

Q.unemployment_excess = Math.max(0, Q.unemployed - Q.unemployment_threshold);

if (Q.inflation >= 0) {
    Q.inflation_excess = Math.max(0, Q.inflation - Q.inflation_threshold);
} else {
    Q.inflation_excess = Math.abs(Q.inflation) * 1.5;
}

Q.unrest_factor = Q.random_factor(
    0.3 +
    Math.pow(Q.unemployment_excess / 8,  2.2) +
    Math.pow(Q.inflation_excess   / 6,  1.8),
    0.35
);
Q.unrest_factor = Math.min(Q.unrest_factor, 12.0);

if (Q.inflation >= 0) {
    Q.inflation_component = Q.inflation / 5;
} else {
    Q.inflation_component = Math.abs(Q.inflation) / 3;
}

Q.pro_republic_factor = Q.random_factor(
    Math.min(Math.max(Q.pro_republic / 33, 0.5), 1.5), 0.15
);
Q.nationalism_factor = Q.random_factor(
    Math.min(Math.max(Q.nationalism / 33, 0.5), 1.5), 0.20
);
Q.socialism_factor = Q.random_factor(
    Math.min(Math.max(Q.socialism / 33, 0.5), 1.5), 0.20
);
Q.street_pressure_factor = Q.random_factor(
    Math.min(Math.max(
        (Q.sa_strength * Q.sa_militancy + Q.rfb_strength * Q.rfb_militancy + Q.sh_strength * Q.sh_militancy) / 3500,
        0.7), 1.8),
    0.25
);

Q.sa_influence  = Q.nsdap_banned ? 0 : Q.random_factor((Q.sa_strength/100  + Q.sa_militancy)  * 0.25, 0.3);
Q.sh_influence  = (Q.dnvp_banned || Q.sh_banned) ? 0 : Q.random_factor((Q.sh_strength/100  + Q.sh_militancy)  * 0.2,  0.25);
Q.rfb_influence = Q.kpd_banned  ? 0 : Q.random_factor((Q.rfb_strength/100 + Q.rfb_militancy) * 0.2,  0.25);
Q.rb_influence  = Q.random_factor((Q.rb_strength/100 + Q.rb_militancy) * 0.15, 0.25);

// Class amplifiers — survive unchanged
Q.class_influences = {
    workers:     1.3 + Q.rfb_influence,
    old_middle:  1.0 + Q.sh_influence,
    new_middle:  1.0 + Q.sh_influence,
    rural:       1.0 + Q.sh_influence,
    unemployedc: 1.3 + Q.sa_influence,
};

// Campaign intensity decay
if (Q.campaign_intensity > 0) Q.campaign_intensity -= 0.08;
Q.campaign_intensity = Math.max(0, Q.campaign_intensity);
const ci = Q.campaign_intensity;


// ─────────────────────────────────────────
// BANNED REDISTRIBUTION MAP (unchanged)
// ─────────────────────────────────────────

const BANNED_REDISTRIBUTION = {
    nsdap: [
        ['dnvp',  0.50, () => !Q.dnvp_banned],
        ['dvp',   0.25, () => Q.dvp_right_shift && !Q.dvp_banned],
        ['other', 0.25, () => true]
    ],
    dnvp: [
        ['nsdap', 0.60, () => !Q.nsdap_banned && Q.dnvp_line === 3],
        ['nsdap', 0.30, () => !Q.nsdap_banned && Q.dnvp_line !== 3],
        ['dvp',   0.20, () => !Q.dvp_banned],
        ['other', 0.20, () => true]
    ],
    dvp: [
        ['dnvp',  0.35, () => !Q.dnvp_banned],
        ['nsdap', 0.25, () => !Q.nsdap_banned && Q.dvp_right_shift],
        ['wp',    0.20, () => !Q.wp_banned && !Q.dvp_right_shift],
        ['other', 0.20, () => true]
    ],
    wp: [
        ['spd',   0.30, () => !Q.spd_banned],
        ['ddp',   0.25, () => !Q.ddp_banned],
        ['srpd',  0.20, () => !Q.srpd_banned],
        ['other', 0.25, () => true]
    ],
    cnbl: [
        ['z',     0.35, () => !Q.z_banned],
        ['bvp',   0.20, () => !Q.bvp_banned],
        ['dnvp',  0.20, () => !Q.dnvp_banned],
        ['other', 0.25, () => true]
    ],
    kpd: [
        ['sapd',  0.40, () => Q.sapd_formed && !Q.sapd_banned],
        ['spd',   0.35, () => !Q.spd_banned && (Q.ideology === 'left' || Q.ideology === 'neorev')],
        ['spd',   0.20, () => !Q.spd_banned && Q.ideology !== 'left' && Q.ideology !== 'neorev'],
        ['other', 0.25, () => true]
    ],
    sapd: [
        ['kpd',   0.40, () => !Q.kpd_banned],
        ['spd',   0.30, () => !Q.spd_banned],
        ['srpd',  0.15, () => !Q.srpd_banned],
        ['other', 0.15, () => true]
    ],
    csvd: [
        ['dnvp',  0.30, () => !Q.dnvp_banned],
        ['nsdap', 0.25, () => !Q.nsdap_banned],
        ['other', 0.45, () => true]
    ],
    srpd: [
        ['spd',   0.45, () => !Q.spd_banned],
        ['sapd',  0.25, () => Q.sapd_formed && !Q.sapd_banned],
        ['kpd',   0.15, () => !Q.kpd_banned],
        ['other', 0.15, () => true]
    ],
    spd: [
        ['srpd',  0.35, () => !Q.srpd_banned],
        ['sapd',  0.25, () => Q.sapd_formed && !Q.sapd_banned],
        ['ddp',   0.20, () => !Q.ddp_banned],
        ['other', 0.20, () => true]
    ],
    ddp: [
        ['spd',   0.30, () => !Q.spd_banned],
        ['wp',    0.25, () => !Q.wp_banned],
        ['z',     0.20, () => !Q.z_banned],
        ['other', 0.25, () => true]
    ],
    z: [
        ['bvp',   0.40, () => !Q.bvp_banned],
        ['cnbl',  0.25, () => !Q.cnbl_banned],
        ['ddp',   0.15, () => !Q.ddp_banned],
        ['other', 0.20, () => true]
    ],
    bvp: [
        ['z',     0.45, () => !Q.z_banned],
        ['cnbl',  0.25, () => !Q.cnbl_banned],
        ['other', 0.30, () => true]
    ],
    other: [
        ['dnvp',  0.20, () => !Q.dnvp_banned],
        ['spd',   0.20, () => !Q.spd_banned],
        ['z',     0.20, () => !Q.z_banned],
        ['other', 0.40, () => true]
    ],
    kvp: [
        ['dnvp',  0.45, () => !Q.dnvp_banned],
        ['csvd',  0.30, () => !Q.csvd_banned],
        ['other', 0.25, () => true]
    ],
    dhp: [
        ['cnbl',  0.40, () => !Q.cnbl_banned],
        ['dnvp',  0.30, () => !Q.dnvp_banned],
        ['other', 0.30, () => true]
    ],
    bb: [
        ['cnbl',  0.35, () => !Q.cnbl_banned],
        ['bvp',   0.30, () => !Q.bvp_banned],
        ['nsdap', 0.20, () => !Q.nsdap_banned],
        ['other', 0.15, () => true]
    ]
};

// Crisis party definitions — mirrors Q.crisis_parties_by_class

const _CRISIS_PARTIES = {
    workers:     ['kpd', 'sapd', 'nsdap'],
    unemployedc: ['kpd', 'sapd', 'nsdap'],
    old_middle:  ['nsdap', 'dvfp', 'dnvp'],
    new_middle:  ['nsdap', 'dvfp', 'dnvp'],
    rural:       ['nsdap', 'cnbl', 'dnvp'],
};


// ─────────────────────────────────────────
// SECTION 3A — QOL HELPER
// ─────────────────────────────────────────

// _applyQOL — applies the asymmetric QOL multiplier to a computed base.
//
// For crisis parties: bad QOL amplifies appeal (2.0 - qol_ratio)
//   qol=50  (ratio 0.50) → ×1.50  strong amplification
//   qol=100 (ratio 1.00) → ×1.00  neutral
//   qol=150 (ratio 1.50) → ×0.50  suppressed even at baseline
//
// For moderate parties: good QOL gives gentle boost (0.85 + ratio*0.15)
//   qol=50  (ratio 0.50) → ×0.925  mild suppression
//   qol=100 (ratio 1.00) → ×1.000  neutral
//   qol=150 (ratio 1.50) → ×1.075  mild bonus
//
// The asymmetry is intentional:
//   crisis party penalty from high QOL (×0.50) >> moderate party bonus from high QOL (×1.075)
//   This means QOL erosion is always more dangerous than QOL improvement is helpful.

function _applyQOL(base, party, c) {
    const _qol    = Q[c + '_qol'] || 100;
    const _ratio  = _qol / 100;                     // 0.5 to 1.5
    const _crisis = (_CRISIS_PARTIES[c] || []).includes(party);

    if (_crisis) {
        // Amplify crisis party appeal when QOL is bad
        return base * (2.0 - _ratio);
    } else {
        // Gently modulate moderate party appeal with QOL
        return base * (0.85 + _ratio * 0.15);
    }
}


// ─────────────────────────────────────────
// TARGET COMPUTATION
// Returns: the support level conditions currently warrant for this party/class
// This replaces ideology_caps.base × class_multiplier
// ─────────────────────────────────────────

function computeTarget(party, c) {
    const nat  = Q.nationalism_factor;
    const rep  = Q.pro_republic_factor;
    const soc  = Q.socialism_factor;
    const unr  = Q.unrest_factor;
    const im   = Q.identity_modifier;

    let base = 0;

    switch (party) {

        case 'nsdap': {
            if (Q.nsdap_banned) return 0;
            
            // Misery Index: Unemployment + Deflation + Growth Collapse
            let misery = (Q.unemployment_excess * 2.0) + (Q.inflation_excess * 1.5);
            if (Q.economic_growth < 0) misery += Math.abs(Q.economic_growth) * 3.0;

            let soft = 40, hard = 120; 
            let raw = (nat * 8.559) + (misery * 1.1);
            
            let final_raw = raw <= soft ? raw
                : soft + (hard - soft) * (1 - Math.exp(-(raw - soft) / 45));

            // CRITICAL: Check if Q.identity_modifier.nsdap is killing your growth.
            // We force a floor of 1.0 during a high-misery crisis.
            let identity = im.nsdap;
            if (misery > 15) identity = Math.max(identity, 1.0);

            base = final_raw * identity;

            const class_mods = {
                workers:     0.85 * (Q.peoples_party === 1 ? 1.1 : 1),
                old_middle:  2.20 * (1 + (Q.nationalism/100) * 0.5), 
                new_middle:  1.90 * (1 + (Q.nationalism/100) * 0.4),
                rural:       2.50 * (1 + (Q.nationalism/100) * 0.6), // Rural core
                unemployedc: 2.10 * (1 + Math.min(Q.unemployed/10, 1.0)),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'dvfp': {
            if (Q.dvfp_banned || !Q.dvfp_formed) return 0;
            let nat_floor   = nat * 25;
            let u           = Math.max(0, unr - 0.6);
            let crisis_ramp = 90 / (1 + Math.exp(-1.4 * (u - 1.8)));
            base = (nat_floor + crisis_ramp) * im.dvfp;

            const class_mods = {
                workers:     0.20 * (Q.peoples_party === 1 ? 1.02 : 1),
                old_middle:  1.74 * (1 + Math.min(Q.nationalism/100,1)*0.25) * (Q.peoples_party === 1 ? 0.95 : 1),
                new_middle:  0.77 * (Q.peoples_party === 1 ? 0.95 : 1),
                rural:       1.79 * (1 + Math.min(Q.nationalism/100,1)*0.22) * (Q.peoples_party === 1 ? 0.95 : 1),
                unemployedc: 0.77 * (Q.peoples_party === 1 ? 1.03 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'dnvp': {
            if (Q.dnvp_banned) return 0;
            if (Q.dnvp_line === 1) {
                let stability_bonus = Math.max(0, (1.5 - unr) * 12);
                base = ((nat * 25) + (rep * 35) + stability_bonus) * im.dnvp;
            } else if (Q.dnvp_line === 3) {
                let polarization = (1 - rep) * 45;
                let crisis_bonus = Q.unemployment * 55;
                base = ((nat * 40) + polarization + crisis_bonus) * im.dnvp;
            } else {
                let chaos_penalty = unr > 0.7 ? (unr * 1) : 0;
                base = ((nat * 60) + (rep * 36) - chaos_penalty) * im.dnvp;
            }

            let workers_m     = 0.60
                * (Q.peoples_party    === 1                              ? 1.05 : 1)
                * (Q.lambach_reinstated && Q.year < 1929                 ? 1.15 : 1)
                * (Q.lambach_momentum  && Q.year < 1929                  ? 1.55 : 1)
                * (Q.dnvp_party_leader == "Walther Lambach" ? 1.25 : 1.00);
            let old_middle_m  = 1.52 * (1 + Math.min(Q.nationalism/100,1)*0.28) * (Q.peoples_party === 1 ? 0.95 : 1);
            let new_middle_m  = 0.98 * (1 + Math.min(Q.nationalism/100,1)*0.18)
                * (Q.peoples_party    === 1                              ? 0.95 : 1)
                * (Q.lambach_reinstated && Q.year < 1929                 ? 1.15 : 1)
                * (Q.lambach_momentum  && Q.year < 1929                  ? 2.45 : 1)
                * (Q.dnvp_party_leader == "Walther Lambach" ? 1.45 : 1.00);
            let rural_m       = 1.72 * (1 + Math.min(Q.nationalism/100,1)*0.30)
                * (Q.peoples_party === 1 ? 0.95 : 1)
                * (Q.parties.includes('cnbl') ? 0.7953 : 1);
            let unemployedc_m = 0.57 * (Q.peoples_party === 1 ? 1.02 : 1);

            const class_mods = { workers: workers_m, old_middle: old_middle_m, new_middle: new_middle_m, rural: rural_m, unemployedc: unemployedc_m };
            if (Q.dem_challenge === 1) base *= 0.80;
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'dvp': {
            if (Q.dvp_banned) return 0;
            let factor      = Q.dvp_right_shift ? nat * 0.95 : rep * 1.0;
            let infl_pen    = Math.pow(Math.abs(Q.inflation - 1.5) / 12, 1.2);
            let unemp_pen   = Math.pow(Math.max(0, Q.unemployed - 5) / 25, 1.1);
            let econ_conf   = Math.max(0.35, 1 - (infl_pen * 0.7) - (unemp_pen * 0.7));
            let scale       = Q.dvp_right_shift ? 2.2 : 1.8;
            base = factor * 60 * scale * econ_conf * (im.dvp || 1);

            const class_mods = {
                workers:     0.40 * (Q.peoples_party === 1 ? 0.92 : 1),
                old_middle:  1.30 * (Q.dvp_right_shift ? (1 + Math.min(Q.nationalism/100,1)*0.22) : 1) * (Q.peoples_party === 1 ? 0.96 : 1),
                new_middle:  1.40 * (Q.dvp_right_shift ? (1 + Math.min(Q.nationalism/100,1)*0.18) : 1) * (Q.peoples_party === 1 ? 0.96 : 1),
                rural:       0.70 * (Q.peoples_party === 1 ? 0.96 : 1),
                unemployedc: 0.35 * (Q.peoples_party === 1 ? 0.92 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'wp': {
            if (Q.wp_banned) return 0;
            let middle_norm  = (Q.old_middle + Q.new_middle) / 99;
            let crisis       = 1 + (Q.inflation * 0.23) - (Q.unemployed * 0.15);
            base = rep * 19 * nat * 17 * middle_norm * Math.max(0.3, crisis) * im.wp;

            let old_middle_m = 1.50 * (1 + Math.max(0, Q.inflation * 0.008)) * (Q.peoples_party === 1 ? 0.96 : 1);
            let new_middle_m = 1.30 * (Q.peoples_party === 1 ? 0.96 : 1);
            const class_mods = { workers: 0.50, old_middle: old_middle_m, new_middle: new_middle_m, rural: 0.70, unemployedc: 0.50 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'cnbl': {
            if (Q.cnbl_banned) return 0;
            base = (rep * 11 + nat * 19) * (1 + Q.rural * 0.009) * im.cnbl;
            let rural_m = 1.80 * (1 + Math.min(Q.rural / 100, 0.4));
            const class_mods = { workers: 0.25, old_middle: 0.60, new_middle: 0.40, rural: rural_m, unemployedc: 0.30 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'kpd': {
            if (Q.kpd_banned) return 0;
            let buff = Q.april_challenge === 1 ? 1.35 : 1;
            base = soc * 45 * 2.0 * (1 + unr * 0.13) * buff * im.kpd;

            let workers_m     = 1.50 * (Q.peoples_party === 1 ? 1.08 : 1);
            let old_middle_m  = 0.20 * (Q.peoples_party === 1 ? 0.92 : 1);
            let new_middle_m  = 0.35 * (Q.peoples_party === 1 ? 0.92 : 1);
            let rural_m       = 0.15 * (Q.peoples_party === 1 ? 0.92 : 1);
            let unemployedc_m = 1.40 * (Q.peoples_party === 1 ? 1.08 : 1);
            const class_mods  = { workers: workers_m, old_middle: old_middle_m, new_middle: new_middle_m, rural: rural_m, unemployedc: unemployedc_m };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'sapd': {
            if (Q.sapd_banned || !Q.sapd_formed) return 0;
            let buff = Q.april_challenge === 1 ? 1.25 : 0.90;
            base = soc * 19 * 2.0 * (1 + unr * 0.12) * buff * im.sapd;

            const class_mods = {
                workers:     1.30 * (Q.peoples_party === 1 ? 1.07 : 1),
                old_middle:  0.25 * (Q.peoples_party === 1 ? 0.93 : 1),
                new_middle:  0.40 * (Q.peoples_party === 1 ? 0.93 : 1),
                rural:       0.20 * (Q.peoples_party === 1 ? 0.93 : 1),
                unemployedc: 1.20 * (Q.peoples_party === 1 ? 1.07 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'srpd': {
            if (Q.srpd_banned || !Q.srpd_formed) return 0;
            let rb = Q.rb_strength * 0.00011;
            base = (soc * 5 * 1.9 + rep * 41 * 1.75 + rb) * im.srpd;

            const class_mods = {
                workers:     1.21 * (Q.peoples_party === 1 ? 1.06 : 1),
                old_middle:  0.83 * (Q.peoples_party === 1 ? 0.94 : 1),
                new_middle:  0.97 * (Q.peoples_party === 1 ? 0.94 : 1),
                rural:       0.73 * (Q.peoples_party === 1 ? 0.94 : 1),
                unemployedc: 1.02 * (Q.peoples_party === 1 ? 1.06 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'spd': {
            if (Q.spd_banned) return 0;
            let s = soc, r = rep;
            if (Q.peoples_party === 1)      { s *= 0.80; r *= 1.20; }
            if (Q.ideology === 'left')       { s *= 1.15; r *= 0.90; }
            else if (Q.ideology === 'reformist') { r *= 1.10; s *= 0.90; }
            else if (Q.ideology === 'neorev')    { s *= 1.05; r *= 1.05; }

            if (Q.social_fascism_adopted == 1) {r *= 1.31; s *= 0.79}

            let campaign_boost = 1.1;
            if (Q.campaign_focus === 'workers'    && ci > 0) campaign_boost += ci * 0.75;
            if (Q.campaign_focus === 'new_middle' && ci > 0) campaign_boost += ci * 0.65;
            if (Q.campaign_focus === 'old_middle' && ci > 0) campaign_boost += ci * 0.55;
            if (Q.campaign_focus === 'rural'      && ci > 0) campaign_boost += ci * 0.55;
            if (Q.campaign_focus === 'unemployed' && ci > 0) campaign_boost += ci * 0.65;
            if (Q.campaign_focus === 'women'      && ci > 0) campaign_boost += ci * 0.45;
            if (Q.campaign_focus === 'middle'     && ci > 0) campaign_boost += ci * 0.45;
            base = (r * 105 + s * 54) * im.spd * campaign_boost;

            // Per-class multiplier (inline, keeps all policy bonuses)
            let m;
            if (c === 'workers') {
                m = 1.15;
                if (Q.peoples_party === 1)  m *= 0.82;
                if (Q.ideology === 'left')      m *= 1.12;
                if (Q.ideology === 'reformist') m *= 0.92;
                if (Q.campaign_focus === 'workers'    && ci > 0) m += ci * 0.45;
                if (Q.campaign_focus === 'unemployed' && ci > 0) m += ci * 0.12;
                if (Q.dues_workers > 0)          m -= Q.dues_workers   * 0.086;
                if (Q.wtb_timer > 0)             m += (Q.workers / 100) * 0.75;
                if (Q.unions_independent === 1)  m *= 0.50;
                if (Q.pro_consumer > 0)          m += Q.land_reform     * 0.23;
                if (Q.state_buyer > 0)           m += Q.state_buyer     * 0.25;
                if (Q.welfare > 0)               m += Q.welfare         * 0.11;
                if (Q.working_hours > 0)         m += Q.working_hours   * 0.08;
                if (Q.workers_safety > 0)        m += Q.workers_safety  * 0.05;
                if (Q.commonwealth_cooperation > 0) m += Q.commonwealth_cooperation * 0.55;
                if (Q.works_councils > 0)        m += Q.works_councils  * 0.05;
                if (Q.economic_democracy > 0)    m += Q.economic_democracy * 0.02;
                if (Q.cooperatives > 0)          m += Q.cooperatives    * 0.10;
                if (Q.lower_tax_rates > 0)       m -= Q.lower_tax_rates * 0.25;
            } else if (c === 'old_middle') {
                m = 0.65;
                if (Q.peoples_party === 1)   m *= 1.15;
                if (Q.ideology === 'left')       m *= 0.88;
                if (Q.ideology === 'reformist')  m *= 1.10;
                if (Q.ideology === 'neorev')     m *= 1.05;
                if (Q.campaign_focus === 'old_middle' && ci > 0) m += ci * 0.16;
                if (Q.campaign_focus === 'middle'     && ci > 0) m += ci * 0.12;
                if (Q.campaign_focus === 'women'      && ci > 0) m += ci * 0.07;
                if (Q.campaign_focus === 'catholics'  && ci > 0) m += ci * 0.12 * (Q.catholics / 35);
                if (Q.dues_old_middle > 0)  m -= Q.dues_old_middle * 0.12;
                if (Q.land_reform > 0)      m -= Q.land_reform     * 0.15;
            } else if (c === 'new_middle') {
                m = 0.80;
                if (Q.peoples_party === 1)   m *= 1.15;
                if (Q.ideology === 'left')       m *= 0.88;
                if (Q.ideology === 'reformist')  m *= 1.10;
                if (Q.ideology === 'neorev')     m *= 1.05;
                if (Q.campaign_focus === 'new_middle' && ci > 0) m += ci * 0.18;
                if (Q.campaign_focus === 'women'      && ci > 0) m += ci * 0.10;
                if (Q.campaign_focus === 'middle'     && ci > 0) m += ci * 0.12;
                if (Q.campaign_focus === 'catholics'  && ci > 0) m += ci * 0.07 * (Q.catholics / 35);
                if (Q.dues_new_middle > 0)  m -= Q.dues_new_middle * 0.094;
                if (Q.wtb_timer > 0)        m += (Q.new_middle / 100) * 0.27;
                if (Q.reformists_resign === 1) m *= 0.50;
            } else if (c === 'rural') {
                m = 0.76;
                if (Q.peoples_party === 1)   m *= 1.12;
                if (Q.campaign_focus === 'rural'     && ci > 0) m += ci * 0.20;
                if (Q.campaign_focus === 'catholics' && ci > 0) m += ci * 0.13 * (Q.catholics / 35);
                if (Q.dues_rural > 0)       m -= Q.dues_rural           * 0.11;
                if (Q.land_reform > 0)      m += Q.land_reform          * 0.32;
                if (Q.agricultural_finance > 0) m += Q.agricultural_finance * 0.22;
                if (Q.pro_consumer > 0)     m += Q.land_reform          * 0.03;
                if (Q.state_buyer > 0)      m += Q.state_buyer          * 0.45;
            } else if (c === 'unemployedc') {
                m = 1.05;
                if (Q.peoples_party === 1)   m *= 0.88;
                if (Q.ideology === 'left')   m *= 1.10;
                if (Q.campaign_focus === 'unemployed' && ci > 0) m += ci * 0.22;
                if (Q.campaign_focus === 'workers'    && ci > 0) m += ci * 0.08;
                if (Q.dues_unemployedc > 0)  m -= Q.dues_unemployedc * 0.086;
                if (Q.dues_unemployedc === 0) m *= 1.17;
                if (Q.wtb_timer > 0)         m += (Q.unemployedc / 100) * 1.03;
                if (Q.left_split === 1)      m *= 0.50;
                if (Q.pro_consumer > 0)      m += Q.land_reform         * 0.13;
                if (Q.state_buyer > 0)       m += Q.state_buyer         * 0.15;
                if (Q.welfare > 0)           m += Q.welfare             * 0.06;
            } else {
                m = 1.0;
            }

            if (Q.dem_challenge === 1) base *= 0.80;
            if (Q.new_partei_challenge) {
                const START_YEAR = 1928;
                const END_YEAR = 1935;
                const totalWeeks = (END_YEAR - START_YEAR) * 26;
                const elapsedWeeks = (Q.year - START_YEAR) * 26 + Q.month * 2 + (Q.weeks / 2);
                const debuffPercent = Math.max(0, 99 * (1 - elapsedWeeks / totalWeeks));
                base *= (1 - debuffPercent / 100);
            }

            return _applyQOL(base * m * 0.93, party, c);
        }

        case 'ddp': {
            if (Q.ddp_banned) return 0;
            let edu_bonus = (Q.education_science || 0) * 0.03
                          + (Q.secularized       || 0) * 0.05
                          + (Q.science           || 0) * 0.10
                          + (Q.womens_rights     || 0) * 0.05;
            if (!Q.ddp_name || Q.ddp_name === 'DDP') {
                let sec_bonus = (100 - Q.catholics) / 100 * 0.10;
                let nat_pen   = (Q.nationalism / 100) * 0.15;
                base = (rep * 53 * (1.1 + sec_bonus - nat_pen + edu_bonus)) * im.ddp;

                const class_mods = {
                    workers:     (0.60) * (Q.peoples_party === 1 ? 0.93 : 1),
                    old_middle:  (0.85) * (Q.peoples_party === 1 ? 1.08 : 1),
                    new_middle:  (1.40 * ((Q.education_science >= 2 || Q.womens_rights >= 3) ? 1.05 : 1)) * (Q.peoples_party === 1 ? 1.08 : 1),
                    rural:       (0.50) * (Q.peoples_party === 1 ? 1.05 : 1),
                    unemployedc: (0.55) * (Q.peoples_party === 1 ? 0.93 : 1),
                };
                return _applyQOL(base * (class_mods[c] || 1.0), party, c);
            } else {
                // DStP
                let jungdo  = (Q.jungdo_strength || 0) * 0.0003;
                let edu_pen = (Q.education_science || 0) * 0.01
                            + (Q.secularized       || 0) * 0.05
                            + (Q.science           || 0) * 0.10
                            + (Q.womens_rights     || 0) * 0.05;
                base = (rep * 0.39 + nat * 0.29 + jungdo - edu_pen) * 59 * im.ddp;

                const class_mods = {
                    workers:     0.50 * (Q.peoples_party === 1 ? 0.93 : 1),
                    old_middle:  1.05 * (Q.peoples_party === 1 ? 1.08 : 1),
                    new_middle:  1.10 * (Q.peoples_party === 1 ? 1.08 : 1),
                    rural:       1.15 * (Q.peoples_party === 1 ? 1.05 : 1),
                    unemployedc: 0.55 * (Q.peoples_party === 1 ? 0.93 : 1),
                };
                return _applyQOL(base * (class_mods[c] || 1.0), party, c);
            }
        }

        case 'z': {
            if (Q.z_banned) return 0;
            let cath_bonus  = Q.catholics / 12;
            let leader_mod  = Q.z_party_leader === 'Kaas' ? 0.94 : Q.z_party_leader === 'Joos' ? 1.06 : 1.0;
            let gov_mod     = Q.z_in_government ? 1.12 : 0.93;
            base = (rep * 85 + cath_bonus) * leader_mod * gov_mod * im.z;

            const class_mods = {
                workers:     0.80 * (Q.z_party_leader !== 'Kaas' ? 1.03 : 1) * (Q.peoples_party === 1 ? 0.94 : 1),
                old_middle:  1.10 * (Q.peoples_party === 1 ? 0.96 : 1),
                new_middle:  0.90 * (Q.peoples_party === 1 ? 0.96 : 1),
                rural:       1.05 * (Q.peoples_party === 1 ? 0.96 : 1),
                unemployedc: 0.70 * (Q.peoples_party === 1 ? 0.94 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'bvp': {
            if (Q.bvp_banned) return 0;
            let cath = Q.catholics * 0.10;
            let rur  = Q.rural    * 0.05;
            base = Math.min(4.5, rep * 42 * im.bvp + cath + rur);

            let rural_m = 1.25 * (1 + Math.min(Q.rural / 100, 0.25)) * (Q.peoples_party === 1 ? 0.96 : 1);
            const class_mods = {
                workers:     0.70 * (Q.peoples_party === 1 ? 0.94 : 1),
                old_middle:  1.25 * (Q.peoples_party === 1 ? 0.96 : 1),
                new_middle:  0.88 * (Q.peoples_party === 1 ? 0.96 : 1),
                rural:       rural_m,
                unemployedc: 0.70 * (Q.peoples_party === 1 ? 0.94 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'csvd': {
            if (Q.csvd_banned || !Q.csvd_flee) return 0;
            let dnvp_split_bonus = 0;
            if (Q.dnvp_line === 3)                              dnvp_split_bonus = 0.5 + (Q.dnvp_r * 0.03);
            else if (Q.dnvp_line === 1 && Q.year >= 1930)      dnvp_split_bonus = 0.2;

            let anti_nazi_appeal = 0;
            if (Q.nsdap_r >= 15 && Q.nsdap_r < 30)             anti_nazi_appeal = 0.3 + (Q.church_resist_nazis ? 0.15 : 0);
            else if (Q.nsdap_r >= 30)                           anti_nazi_appeal = -0.2;

            let coalition_stability = 0;

            let crisis_factor = Q.unemployed >= 20 ? 0.6 : Q.unemployed >= 12 ? 0.8 : Q.unemployed >= 8 ? 0.85 : 1.0;

            base = (rep * 0.5 + dnvp_split_bonus + anti_nazi_appeal + coalition_stability) * crisis_factor * im.csvd;

            const class_mods = {
                workers:     0.50 * (Q.peoples_party === 1 ? 0.93 : 1),
                old_middle:  1.20 * (1 + Math.min(Q.nationalism/100,1)*0.22) * (Q.peoples_party === 1 ? 0.96 : 1),
                new_middle:  1.10 * (1 + Math.min(Q.nationalism/100,1)*0.18) * (Q.peoples_party === 1 ? 0.96 : 1),
                rural:       1.30 * (1 + Math.min(Q.nationalism/100,1)*0.25) * (Q.peoples_party === 1 ? 0.96 : 1),
                unemployedc: 0.60 * (Q.peoples_party === 1 ? 0.93 : 1),
            };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'csrp': {
            if (Q.csrp_banned) return 0;
            let april = Q.april_challenge && Q.year >= 1933 ? 20 : 1;
            base = rep * 16 * im.csrp * april;
            const class_mods = { workers: 0.20, old_middle: 0.05, new_middle: 0.15, rural: 0.10, unemployedc: 0.30 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'vrp': {
            if (Q.vrp_banned) return 0;
            base = rep * 10 + Math.max(0, Q.inflation) * 0.05 * im.vrp;
            const class_mods = { workers: 0.25, old_middle: 0.01, new_middle: 0.10, rural: 0.04, unemployedc: 0.40 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'other': {
            if (Q.other_banned) return 0;
            base = (nat + rep) * 7 * im.other;
            const class_mods = { 
        workers: 0.30, 
        old_middle: 0.85, 
        new_middle: 0.80, 
        rural: 1.15 * (Q.landvolk_fury > 0 ? Q.landvolk_fury / 1.05 : 1) * (Q.parties.includes('cnbl') ? 1.5953 : 1), 
        unemployedc: 0.30 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'kvp': {
            if (Q.kvp_banned || !Q.kvp_flee) return 0;
            let split_bonus = Q.dnvp_line === 3 ? 2.2 : 0.8;
            base = (rep * 18 + nat * 14) * split_bonus * im.kvp;
            const class_mods = { workers: 0.25, old_middle: 1.45, new_middle: 1.20, rural: 0.90, unemployedc: 0.30 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'dhp': {
            if (Q.dhp_banned) return 0;
            base = Math.min(3.5, (rep * 30 + nat * 10) * 0.8 * im.dhp);
            const class_mods = { workers: 0.20, old_middle: 1.35, new_middle: 0.60, rural: 1.70, unemployedc: 0.25 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'bb': {
            if (Q.bb_banned) return 0;
            let rural_weight    = Q.rural / 60;
            let deflation_bonus = Q.inflation < 0 ? (1 + Math.abs(Q.inflation) * 0.08) : 1.0;
            base = (rep * 10 + nat * 12) * rural_weight * deflation_bonus * im.bb;
            const class_mods = { workers: 0.10, old_middle: 0.40, new_middle: 0.20, rural: 2.10, unemployedc: 0.35 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'aspd': {
            if (Q.aspd_banned) return 0;
            base = (rep * 3 + nat * 5 + soc * 10) * im.bb;
            const class_mods = { workers: 0.50, old_middle: 0.50, new_middle: 0.20, rural: 0.55, unemployedc: 0.25 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'hl': {
            if (Q.hl_banned) return 0;
            base = (rep * 3 + nat * 5 + soc * 10) * im.bb;
            const class_mods = { workers: 0.50, old_middle: 0.50, new_middle: 0.20, rural: 0.55, unemployedc: 0.25 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'sl': {
            if (Q.sl_banned) return 0;
            let sl_buff = Q.april_challenge === 1 ? 4.50 : 1;
            base = (rep * 3 + nat * 5 + soc * 10) * sl_buff * im.bb;
            const class_mods = { workers: 0.50, old_middle: 0.50, new_middle: 0.20, rural: 0.55, unemployedc: 0.25 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'kpo': {
            if (Q.kpo_banned) return 0;
            base = (rep * 3 + nat * 5 + soc * 20) * im.bb;
            const class_mods = { workers: 0.50, old_middle: 0.50, new_middle: 0.20, rural: 0.55, unemployedc: 0.25 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'vnr': {
            if (Q.vnr_banned) return 0;
            base = (rep * 10 + nat * 8 + soc * 1) * im.bb;
            const class_mods = { 
            workers: 0.10, 
            old_middle: 0.35 * (Q.vnr_momentum >= 1 ? 3.11 : 1), 
            new_middle: 0.30 * (Q.vnr_momentum >= 1 ? 3.11 : 1), 
            rural: 0.20, 
            unemployedc: 0.10 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'dtsp': {
            if (Q.dtsp_banned) return 0;
            base = nat * 8 * (1 + unr * 0.10) * im.dtsp;
            const class_mods = { workers: 0.15, old_middle: 0.90, new_middle: 0.70, rural: 0.80, unemployedc: 0.20 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'sls': {
            if (Q.sls_banned) return 0;
            base = rep * 4 * im.sls;
            const class_mods = { workers: 0.30, old_middle: 0.40, new_middle: 0.25, rural: 0.60, unemployedc: 0.20 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'rdp': {
            if (Q.rdp_banned) return 0;
            let nat_pen = (Q.nationalism / 100) * 0.20;
            base = rep * 6 * (1.0 - nat_pen) * im.rdp;
            const class_mods = { workers: 0.25, old_middle: 0.30, new_middle: 0.85, rural: 0.15, unemployedc: 0.20 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'cvp': {
            if (Q.cvp_banned) return 0;
            let cath_bonus = Q.catholics / 18;
            base = (rep * 5 + cath_bonus) * im.cvp;
            const class_mods = { workers: 0.40, old_middle: 0.80, new_middle: 0.50, rural: 0.70, unemployedc: 0.30 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        case 'lb': {
            if (Q.lb_banned) return 0;
            base = soc * 7 * (1 + unr * 0.08) * im.lb;
            const class_mods = { workers: 0.55, old_middle: 0.10, new_middle: 0.20, rural: 0.10, unemployedc: 0.45 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }

        default: {
            if (Q.other_banned) return 0;
            base = (nat + rep) * 6 * im.other;
            const class_mods = { workers: 0.30, old_middle: 1.00, new_middle: 1.00, rural: 1.00, unemployedc: 0.30 };
            return _applyQOL(base * (class_mods[c] || 1.0), party, c);
        }
    }
}


// ─────────────────────────────────────────
// SPEED COMPUTATION
// Returns: fraction of (target - current) closed per tick
// Crisis parties fast, stable parties slow
// ─────────────────────────────────────────

function computeSpeed(party, c) {
    const unr = Q.unrest_factor;

    // Base speed per party archetype
    const base_speeds = {
        // Crisis-reactive — fast
        nsdap:  0.18,
        kpd:    0.17,
        sapd:   0.14,
        dvfp:   0.13,

        // Moderate reactive
        spd:    0.11,
        dnvp:   0.12,
        srpd:   0.10,
        csvd:   0.09,
        dvp:    0.09,
        ddp:    0.09,

        // Stable/structural
        z:      0.06,
        bvp:    0.06,
        cnbl:   0.07,
        wp:     0.07,
        kvp:    0.08,

        // Very stable / niche
        bb:     0.05,
        dhp:    0.05,
        sls:    0.04,
        csrp:   0.05,
        vrp:    0.06,
        dtsp:   0.10,
        rdp:    0.06,
        cvp:    0.06,
        lb:     0.07,
        aspd:   0.06,
        hl:     0.06,
        sl:     0.08,
        kpo:    0.08,
        vnr:    0.07,
        srpd:   0.09,
        other:  0.08,
        default: 0.07,
    };

    let speed = base_speeds[party] || base_speeds.default;

    // Crisis bonus: reactive parties get faster when conditions are extreme
    const crisis_parties = ['nsdap', 'kpd', 'sapd', 'dvfp', 'dnvp', 'srpd'];
    if (crisis_parties.includes(party)) {
        speed *= (1 + Math.min(unr * 0.12, 0.50));  // up to +50% faster in deep crisis
    }

    // Stable parties slow down further under crisis (confusion, fragmentation)
    const stable_parties = ['z', 'bvp', 'cnbl', 'wp', 'bb'];
    if (stable_parties.includes(party) && unr > 1.5) {
        speed *= Math.max(0.60, 1 - (unr - 1.5) * 0.08);
    }

    // SPD: campaign gives speed boost toward focused class
    if (party === 'spd' && Q.campaign_focus && ci > 0) {
        const focus_map = {
            workers:    'workers',
            unemployed: 'unemployedc',
            new_middle: 'new_middle',
            old_middle: 'old_middle',
            rural:      'rural',
        };
        if (focus_map[Q.campaign_focus] === c) {
            speed += ci * 0.04;
        }
        // women / middle spread a little across all
        if (Q.campaign_focus === 'women' || Q.campaign_focus === 'middle') {
            speed += ci * 0.02;
        }
    }

    // Enemies modifier: suppressed parties move slower toward targeted classes
    if (Q.enemies) {
        const target_map = {
            'NSDAP':                   ['nsdap'],
            'KPD':                     ['kpd'],
            'far right':               ['nsdap', 'dnvp', 'dvfp'],
            'DNVP':                    ['dnvp'],
            'anti-democratic parties': ['nsdap', 'dnvp', 'kpd'],
            'bourgeois parties':       ['dvp', 'wp', 'z'],
            'DVP':                     ['dvp'],
            'Z':                       ['z'],
            'BVP':                     ['bvp'],
            'WP':                      ['wp'],
            'DDP':                     ['ddp'],
        };
        const targets = target_map[Q.enemies] || [];
        const worker_classes = ['workers', 'unemployedc'];
        if (targets.includes(party) && worker_classes.includes(c)) {
            speed *= 0.80;  // negative campaigning slows drift toward that party
        }
        if (party === 'spd' && targets.length > 0 && worker_classes.includes(c)) {
            speed *= 1.08;  // SPD benefits from attacking enemies
        }
    }

    return Math.min(speed, 0.40);  // hard cap — never jump more than 40% in one tick
}


// ─────────────────────────────────────────
// MAIN DRIFT LOOP
// ─────────────────────────────────────────

for (Q.c of Q.classes) {
    for (Q.party of Q.parties) {
        Q.base = Q[Q.c + '_' + Q.party] || 0;

        // === BANNED PARTY HANDLING ===
        const banned_flag = Q.party + '_banned';
        if (Q[banned_flag] && BANNED_REDISTRIBUTION[Q.party]) {
            if (Q.base > 0) {
                const routes = BANNED_REDISTRIBUTION[Q.party];
                for (let i = 0; i < routes.length; i++) {
                    const [target, share, condition] = routes[i];
                    if (condition()) {
                        Q[Q.c + '_' + target] += Q.base * share;
                    }
                }
            }
            Q[Q.c + '_' + Q.party] = 0;
            continue;
        }

        // === THERMOSTAT MOVE ===
        const target = computeTarget(Q.party, Q.c);
        const speed  = computeSpeed(Q.party, Q.c);

        // Noise on the move itself, not the target
        // Slightly asymmetric: gains are noisier than losses (political momentum)
        const moving_up   = target > Q.base;
        const noise       = moving_up
            ? (0.80 + _r() * 0.45)   // 0.80–1.25 when gaining
            : (0.88 + _r() * 0.28);  // 0.88–1.16 when losing (stickier)

        Q[Q.c + '_' + Q.party] = Math.max(0,
            Q.base + (target - Q.base) * speed * noise
        );
    }
}


// ─────────────────────────────────────────
// NORMALIZATION
// ─────────────────────────────────────────

if (!Q.math_broken) {
    for (var c of Q.classes) {
        var class_votes = 0;
        for (var party of Q.parties) {
            class_votes += Q[c + '_' + party];
        }
        for (var party of Q.parties) {
            Q[c + '_' + party + '_normalized'] = class_votes > 0 ? Q[c + '_' + party] / class_votes : 0;
            Q[c + '_' + party + '_display']    = (Q[c + '_' + party + '_normalized'] * 100).toFixed(1);
        }
    }
} else {
    for (var c of Q.classes) {
        var class_votes = Q.impossible_add(0, 0);
        for (var party of Q.parties) {
            class_votes = Q.impossible_add(class_votes, Q[c + '_' + party]);
        }
        for (var party of Q.parties) {
            Q[c + '_' + party + '_normalized'] = Q.impossible_multiply(Q[c + '_' + party], 1 / class_votes);
            Q[c + '_' + party + '_display']    = Q.impossible_percentage(Q[c + '_' + party + '_normalized'] * 100).toFixed(1);
        }
    }
}












// ========================================
// PRESIDENTIAL INNER CIRCLE SYSTEM
// ========================================

// === PRESIDENT PROFILE DEFINITIONS ===
// Each president gets: inner circle members, ideological comfort, goals weights
// Members: { name, influence_base, growth_rate, condition, counter }

const PRESIDENT_PROFILES = {

