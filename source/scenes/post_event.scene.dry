        DNVP: 'Schiele',
        NSDAP:'Seldte',
    },
    economic: {
        KPD:  'Remmele',
        SAPD: 'Rosenfeld',
        SPD:  'Hilferding',
        SRPD: 'Schmidt',
        DDP:  'Dietrich',
        Z:    'Bredt',
        BVP:  'Held',
        DVP:  'Curtius',
        WP:   'Lambach',
        CNBL: 'Heim',
        DNVP: 'Hugenberg',
        NSDAP:'Hugenberg',
    },
    finance: {
        KPD:  'Neumann',
        SAPD: 'Rosenfeld',
        SPD:  'Hilferding',
        SRPD: 'Hilferding',
        DDP:  'Dietrich',
        Z:    'Köhler',
        BVP:  'Krausneck',
        DVP:  'Moldenhauer',
        WP:   'Drewitz',
