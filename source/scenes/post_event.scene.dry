    { id: 'middle_class_credit',name: 'Middle Class Credit Relief',
      type: 'economic', base_ideo: 7, affinity: ['bourgeois','reform'],
      timer: 30, push_weight: 0.14, ministry: 'finance',     cooldown: 40,
