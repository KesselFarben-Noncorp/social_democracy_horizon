      on_pass: function() { Q.socialization=(Q.socialization||0)+1; } },

    { id: 'works_councils',     name: 'Revolutionary Works Councils Act',
      type: 'labor',    base_ideo: 1, affinity: ['labor','socialist'],
      timer: 30, push_weight: 0.14, ministry: 'labor',       cooldown: 40,
