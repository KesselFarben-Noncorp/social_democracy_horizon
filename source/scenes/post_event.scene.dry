    { id: 'labour_front',       name: 'National Labour Front Act',
      type: 'labor',    base_ideo: 10, affinity: ['nationalist','volkisch'],
      timer: 25, push_weight: 0.18, ministry: 'labor',       cooldown: 40,
      on_pass: function() { Q.works_councils=Math.max(0,(Q.works_councils||0)-2); Q.cooperatives=Math.max(0,(Q.cooperatives||0)-1); } },

    { id: 'hereditary_farm',    name: 'Hereditary Farm Law',
      type: 'economic', base_ideo: 10, affinity: ['agrarian','volkisch'],
      timer: 30, push_weight: 0.16, ministry: 'agriculture', cooldown: 40,
      on_pass: function() { Q.land_reform=Math.max(0,(Q.land_reform||0)-1); Q.agricultural_finance=(Q.agricultural_finance||0)+1; } },

    { id: 'volkisch_protection',name: 'Völkisch Community Protection Act',
      type: 'civil',    base_ideo: 10, affinity: ['volkisch','nationalist'],
      timer: 30, push_weight: 0.14, ministry: 'interior',    cooldown: 40,
      on_pass: function() { Q.homosexual_rights=Math.max(0,(Q.homosexual_rights||0)-1); Q.womens_rights=Math.max(0,(Q.womens_rights||0)-1); } },

    { id: 'racial_welfare_cut', name: 'Racial Welfare Restriction Act',
      type: 'welfare',  base_ideo: 10, affinity: ['volkisch','nationalist'],
      timer: 28, push_weight: 0.13, ministry: 'interior',    cooldown: 40,
      on_pass: function() { Q.welfare=Math.max(-2,(Q.welfare||0)-1); Q.workers_aid=Math.max(0,(Q.workers_aid||0)-1); } },
];

// Build a lookup map for O(1) resolution
var BILL_MAP = {};
for (var _bi = 0; _bi < BILLS.length; _bi++) {
    BILL_MAP[BILLS[_bi].id] = BILLS[_bi];
}

window.BILL_MAP = BILL_MAP;


// ============================================================
// SECTION B: PARTY IDEOLOGY & AFFINITY
//
// Each party has:
//   base_ideo : their natural ideological position (1–10)
//   affinities: tag weights (0–1) for bill scoring
//
// Both are overridable at runtime via Q vars:
//   Q.<party>_ideo_drift   — float offset from base_ideo
//   Q.<party>_aff_<tag>    — override affinity weight for tag
// ============================================================

var PARTIES = {
    KPD:   { base_ideo: 1,  affinities: { labor:1.0, socialist:1.0, welfare:0.8, civil:0.3, agrarian:0.1, bourgeois:0,   industry:0,   conservative:0,   nationalist:0,   volkisch:0,   catholic:0,   secular:0.4, reform:0.3 } },
    SAPD:  { base_ideo: 2,  affinities: { labor:0.9, socialist:1.0, welfare:0.7, civil:0.3, agrarian:0.5, bourgeois:0,   industry:0,   conservative:0,   nationalist:0,   volkisch:0,   catholic:0,   secular:0.3, reform:0.4 } },
    SPD:   { base_ideo: 3,  affinities: { labor:0.8, socialist:0.5, welfare:0.9, civil:0.6, agrarian:0.2, bourgeois:0.2, industry:0,   conservative:0,   nationalist:0,   volkisch:0,   catholic:0,   secular:0.5, reform:0.7 } },
    DDP:   { base_ideo: 5,  affinities: { labor:0.3, socialist:0,   welfare:0.3, civil:0.9, agrarian:0.1, bourgeois:0.6, industry:0.3, conservative:0.2, nationalist:0,   volkisch:0,   catholic:0,   secular:0.9, reform:0.8 } },
    Z:     { base_ideo: 5,  affinities: { labor:0.4, socialist:0,   welfare:0.5, civil:0.3, agrarian:0.4, bourgeois:0.4, industry:0.2, conservative:0.8, nationalist:0.2, volkisch:0,   catholic:1.0, secular:0,   reform:0.2 } },
    BVP:   { base_ideo: 6,  affinities: { labor:0.3, socialist:0,   welfare:0.4, civil:0.2, agrarian:0.7, bourgeois:0.3, industry:0.1, conservative:0.9, nationalist:0.1, volkisch:0,   catholic:1.0, secular:0,   reform:0.1 } },
    DVP:   { base_ideo: 7,  affinities: { labor:0.1, socialist:0,   welfare:0.2, civil:0.3, agrarian:0.2, bourgeois:0.9, industry:1.0, conservative:0.6, nationalist:0.3, volkisch:0,   catholic:0,   secular:0.3, reform:0.3 } },
    WP:    { base_ideo: 7,  affinities: { labor:0.2, socialist:0,   welfare:0.3, civil:0.2, agrarian:0.4, bourgeois:1.0, industry:0.4, conservative:0.4, nationalist:0.2, volkisch:0,   catholic:0,   secular:0.2, reform:0.5 } },
    CNBL:  { base_ideo: 7,  affinities: { labor:0.2, socialist:0,   welfare:0.3, civil:0.1, agrarian:1.0, bourgeois:0.3, industry:0.1, conservative:0.7, nationalist:0.3, volkisch:0,   catholic:0.2, secular:0.1, reform:0.2 } },
    DNVP:  { base_ideo: 9,  affinities: { labor:0.1, socialist:0,   welfare:0.1, civil:0,   agrarian:0.5, bourgeois:0.5, industry:0.6, conservative:1.0, nationalist:0.8, volkisch:0.3, catholic:0.2, secular:0.1, reform:0   } },
    NSDAP: { base_ideo: 10, affinities: { labor:0.2, socialist:0,   welfare:0,   civil:0,   agrarian:0.5, bourgeois:0.2, industry:0.3, conservative:0.4, nationalist:1.0, volkisch:1.0, catholic:0,   secular:0,   reform:0   } },
    DVFP:  { base_ideo: 10, affinities: { labor:0,   socialist:0,   welfare:0,   civil:0,   agrarian:0.3, bourgeois:0.2, industry:0.3, conservative:0.5, nationalist:1.0, volkisch:1.0, catholic:0,   secular:0,   reform:0   } },
};


// ============================================================
// SECTION C: PARTY STATE HELPERS
// ============================================================

function get_effective_ideo(party) {
    var base  = (PARTIES[party] || {}).base_ideo || 5;
    var drift = Q[party.toLowerCase() + '_ideo_drift'] || 0;
    return Math.min(10, Math.max(1, base + drift));
}

// Tolerance: base ±2, widens by 1 per 3 points of drift
function get_ideo_tolerance(party) {
    var drift = Math.abs(Q[party.toLowerCase() + '_ideo_drift'] || 0);
    return 2 + Math.floor(drift / 3);
}

function get_affinity(party, tag) {
    var base = ((PARTIES[party] || {}).affinities || {})[tag] || 0;
    var key  = party.toLowerCase() + '_aff_' + tag;
    return (Q[key] !== undefined) ? Q[key] : base;
}

function affinity_score(party, bill) {
    if (!bill.affinity || bill.affinity.length === 0) return 1.0;
    var total = 0;
    for (var ai = 0; ai < bill.affinity.length; ai++) {
        total += get_affinity(party, bill.affinity[ai]);
    }
    return total / bill.affinity.length;
}

// Pick-count fatigue and block pressure
function pick_count_multiplier(bill_id) {
    var picks  = Q['bill_picks_'  + bill_id] || 0;
    var blocks = Q['bill_blocks_' + bill_id] || 0;
    var fatigue  = Math.max(0.30, 1.0 - (picks  * 0.10));
    var pressure = Math.min(2.50, 1.0 + (blocks * 0.20));
    return fatigue * pressure;
}

// Per-party political viability multiplier
function get_push_multiplier(party) {
    var m = 1.0;
    switch (party) {
        case 'KPD':
            if (Q.workers < 35)         m += 0.4;
            if (Q.unemployed > 20)      m += 0.3;
            if (Q.kpd_banned)           m  = 0;
            break;
        case 'SAPD':
            if (!Q.sapd_formed)         m  = 0;
            if (Q.sapd_banned)          m  = 0;
            break;
        case 'SPD':
            if (Q.spd_in_government)    m -= 0.3;
            if (Q.unemployed > 18)      m -= 0.3;
            if (Q.spd_banned)           m  = 0;
            break;
        case 'DDP':
            if (Q.ddp_banned)           m  = 0;
            if (Q.pro_republic > 60)    m += 0.2;
            break;
        case 'Z':
            if (Q.z_in_government)      m -= 0.2;
            if (Q.catholics > 30)       m += 0.2;
            if (Q.z_banned)             m  = 0;
            break;
        case 'BVP':
            if (Q.bvp_banned)           m  = 0;
            break;
        case 'DVP':
            if (Q.dvp_in_government)    m -= 0.3;
            if (Q.economic_growth < -1) m += 0.3;
            if (Q.dvp_banned)           m  = 0;
            break;
        case 'WP':
            if (Q.wp_banned)            m  = 0;
            if (Q.inflation > 4)        m += 0.3;
            break;
        case 'CNBL':
            if (Q.cnbl_banned)          m  = 0;
            if (Q.rural > 35)           m += 0.2;
            break;
        case 'DNVP':
            if (Q.dnvp_banned)          m  = 0;
            if (Q.dnvp_line === 3)      m += 0.4;
            if (Q.dnvp_in_government)   m -= 0.3;
            break;
        case 'NSDAP':
            if (Q.nsdap_banned)         m  = 0;
            if (Q.nsdap_r > 20)         m += 0.5;
            if (Q.nsdap_r > 35)         m += 0.5;
            break;
        case 'DVFP':
            if (!Q.dvfp_formed)         m  = 0;
            if (Q.dvfp_banned)          m  = 0;
            if (Q.nationalism > 50)     m += 0.2;
            break;
    }
    return Math.max(0, m);
}


// ============================================================
// SECTION D: PHASE 1A — COOLDOWN TICK
// ============================================================

for (var _bi = 0; _bi < BILLS.length; _bi++) {
    var _id = BILLS[_bi].id;
    if ((Q['bill_cd_' + _id] || 0) > 0) {
        Q['bill_cd_' + _id]--;
    }
}


// ============================================================
// SECTION E: PHASE 1B — TIMER DECAY
// ============================================================

for (var i = 0; i < 10; i++) {
    if (!Q['bill_' + i + '_id'])    continue;
    if (Q['bill_' + i + '_frozen']) continue;

    Q['bill_' + i + '_timer']--;

    if (Q['bill_' + i + '_timer'] <= 0) {
        Q['bill_' + i + '_timer']  = 0;
        Q['bill_' + i + '_frozen'] = 1;
    }
}


// ============================================================
// SECTION F: PHASE 1C — CRISIS STAGING
// ============================================================

if (!Q.bill_crisis_in_progress) {
    Q.any_bill_crisis = 0;

    for (var i = 0; i < 10; i++) {
        if (!Q['bill_' + i + '_id'])     continue;
        if (!Q['bill_' + i + '_frozen']) continue;

        Q.crisis_slot     = i;
        Q.crisis_id       = Q['bill_' + i + '_id'];
        Q.crisis_name     = Q['bill_' + i + '_name'];
        Q.crisis_party    = Q['bill_' + i + '_party'];
        Q.crisis_type     = Q['bill_' + i + '_type'];
        Q.crisis_ideo     = Q['bill_' + i + '_ideo'];
        Q.crisis_ministry = Q['bill_' + i + '_ministry'];

        Q.any_bill_crisis         = 1;
        Q.bill_crisis_in_progress = 1;
        break;
    }
}


// ============================================================
// SECTION G: PHASE 1D — PUSH LOOP
//
// Each party independently scores all eligible bills from
// the shared pool. Eligible = not on cooldown, not in queue,
// within ideology window, affinity > 0.
//
// Composite score: push_weight × party_mult × affinity × pick_curve
// Party with highest per-bill score wins that bill's slot.
// One bill pushed per party per tick (queue cap: 10).
// ============================================================

var _party_list = Object.keys(PARTIES);

for (var pi = 0; pi < _party_list.length; pi++) {
    var _party = _party_list[pi];
    var _mult  = get_push_multiplier(_party);
    if (_mult <= 0) continue;

    // Find a free slot
    var _slot = -1;
    for (var si = 0; si < 10; si++) {
        if (!Q['bill_' + si + '_id']) { _slot = si; break; }
    }
    if (_slot === -1) break; // queue full

    var _eff_ideo   = get_effective_ideo(_party);
    var _tolerance  = get_ideo_tolerance(_party);

    var _candidates = [];

    for (var bi = 0; bi < BILLS.length; bi++) {
        var _bill = BILLS[bi];

        // Hard exclusions
        if ((Q['bill_cd_' + _bill.id] || 0) > 0) continue;
        if (Q.crisis_id === _bill.id)             continue;
        if (Q['bill_stall_id'] === _bill.id)      continue;

        // Already in queue?
        var _in_queue = false;
        for (var qi = 0; qi < 10; qi++) {
            if (Q['bill_' + qi + '_id'] === _bill.id) { _in_queue = true; break; }
        }
        if (_in_queue) continue;

        // Ideology window
        if (Math.abs(_eff_ideo - _bill.base_ideo) > _tolerance) continue;

        // Affinity
        var _aff = affinity_score(_party, _bill);
        if (_aff <= 0) continue;

        var _score = _bill.push_weight * _mult * _aff * pick_count_multiplier(_bill.id);
        _candidates.push({ bill: _bill, score: _score });
    }

    if (_candidates.length === 0) continue;

    // Sort descending by score
    _candidates.sort(function(a, b) { return b.score - a.score; });

    // Weighted selection with fallback
    var _winner = null;
    for (var _ci = 0; _ci < _candidates.length; _ci++) {
    if (_r() < _candidates[_ci].score) {
        _winner = _candidates[_ci].bill;
        break;
        }
    }
    if (!_winner && _r() < 0.25) _winner = _candidates[0].bill;

    if (_winner) {
        Q['bill_' + _slot + '_id']       = _winner.id;
        Q['bill_' + _slot + '_name']     = _winner.name;
        Q['bill_' + _slot + '_party']    = _party;
        Q['bill_' + _slot + '_type']     = _winner.type;
        Q['bill_' + _slot + '_ideo']     = _winner.base_ideo;
        Q['bill_' + _slot + '_timer']    = _winner.timer;
        Q['bill_' + _slot + '_frozen']   = 0;
        Q['bill_' + _slot + '_ministry'] = _winner.ministry;

        Q['bill_cd_'    + _winner.id] = _winner.cooldown;
        Q['bill_picks_' + _winner.id] = (Q['bill_picks_' + _winner.id] || 0) + 1;
    }
}


// ============================================================
// SECTION H: STALL TIMER TICK
// ============================================================

if (Q.bill_stall_timer > 0) {
    Q.bill_stall_timer--;

    var _sp     = Q.bill_stall_party || '';
    var _diss_k = _sp.toLowerCase() + '_dissent';

    // Incremental dissent bleed
    Q.bill_stall_dissent_acc = (Q.bill_stall_dissent_acc || 0) + 0.2;
    if (Q.bill_stall_dissent_acc >= 1) {
        Q[_diss_k] = Math.min(99, (Q[_diss_k] || 0) + 1);
        Q.bill_stall_dissent_acc -= 1;
    }

    if (Q.bill_stall_timer <= 0) {

        if ((Q.bill_stall_attempt || 0) >= 2) {
            var _rel_k = _sp.toLowerCase() + '_relation';
            Q[_diss_k] = Math.min(99,   (Q[_diss_k] || 0)  + 3);
            Q[_rel_k]  = Math.max(-100, (Q[_rel_k]  || 50) - 4);

            Q['bill_blocks_' + Q.bill_stall_id] = (Q['bill_blocks_' + Q.bill_stall_id] || 0) + 1;
            Q['bill_cd_'     + Q.bill_stall_id] = 40;

            Q.bill_stall_id          = '';
            Q.bill_stall_name        = '';
            Q.bill_stall_party       = '';
            Q.bill_stall_type        = '';
            Q.bill_stall_ideo        = 0;
            Q.bill_stall_ministry    = '';
            Q.bill_stall_timer       = 0;
            Q.bill_stall_attempt     = 0;
            Q.bill_stall_dissent_acc = 0;

        } else if (!Q.bill_crisis_in_progress) {
            Q.crisis_slot     = -1;
            Q.crisis_id       = Q.bill_stall_id;
            Q.crisis_name     = Q.bill_stall_name;
            Q.crisis_party    = Q.bill_stall_party;
            Q.crisis_type     = Q.bill_stall_type;
            Q.crisis_ideo     = Q.bill_stall_ideo;
            Q.crisis_ministry = Q.bill_stall_ministry;

            Q.any_bill_crisis         = 1;
            Q.bill_crisis_in_progress = 1;

            Q.bill_stall_id       = '';
            Q.bill_stall_name     = '';
            Q.bill_stall_party    = '';
            Q.bill_stall_type     = '';
            Q.bill_stall_ideo     = 0;
            Q.bill_stall_ministry = '';
            Q.bill_stall_timer    = 0;
        }
    }
}


// ============================================================
// SECTION I: ON_PASS HOOK
// Usage: bill_resolve(Q.crisis_id)
// ============================================================

function bill_resolve(bill_id) {
    var _bill = BILL_MAP[bill_id];
    if (!_bill) return;
    _bill.on_pass();
    Q['bill_cd_'     + bill_id] = _bill.cooldown;
    Q['bill_picks_'  + bill_id] = Math.floor((Q['bill_picks_'  + bill_id] || 0) * 0.5);
    Q['bill_blocks_' + bill_id] = 0;
}


// ============================================================
// SECTION J: DRIFT & AFFINITY HELPERS
// ============================================================

function shift_party_ideo(party, delta) {
    var key  = party.toLowerCase() + '_ideo_drift';
    var base = (PARTIES[party] || {}).base_ideo || 5;
    var d    = (Q[key] || 0) + delta;
    Q[key]   = Math.min(10 - base, Math.max(1 - base, d));
}

function shift_party_affinity(party, tag, value) {
    var key = party.toLowerCase() + '_aff_' + tag;
    if (value === null) { delete Q[key]; }
    else                { Q[key] = Math.min(1.0, Math.max(0.0, value)); }
}


// ============================================================
// SECTION K: BUILD DISPLAY VARS
// ============================================================

var _text = '';
var _html = '<table style="width:100%;border-collapse:collapse;font-size:0.93em;">';
_html += '<tr style="border-bottom:1px solid #555;">'
       + '<th style="text-align:left;padding:3px 6px;">Bill</th>'
       + '<th style="padding:3px 6px;">Sponsor</th>'
       + '<th style="padding:3px 6px;">Type</th>'
       + '<th style="padding:3px 6px;">Timer</th>'
       + '<th style="padding:3px 6px;">Status</th>'
       + '</tr>';

var TYPE_COLORS = {
    economic: '#c8a84b', labor: '#e3000f', social: '#a0c4a0',
    civil:    '#7eb8d4', foreign: '#9b8ec4', welfare: '#c47fd4',
};

var _filled = 0;
for (var i = 0; i < 10; i++) {
    if (!Q['bill_' + i + '_id']) continue;
    _filled++;

    var _bid    = Q['bill_' + i + '_id'];
    var _name   = Q['bill_' + i + '_name'];
    var _party  = Q['bill_' + i + '_party'];
    var _type   = Q['bill_' + i + '_type'];
    var _timer  = Q['bill_' + i + '_timer'];
    var _frozen = Q['bill_' + i + '_frozen'];
    var _status = _frozen     ? '⚠ Crisis' :
                  _timer <= 1 ? '🔴 Urgent' :
                  _timer <= 5 ? '🟡 Soon'   : '🟢 Active';
    var _color  = TYPE_COLORS[_type] || '#888';

    _text += (i+1) + '. ' + _name + ' (' + _party + ') — '
           + _type + ' — ' + (_frozen ? 'CRISIS' : 'T-' + _timer) + '\n';

    _html += '<tr style="border-bottom:1px solid #333;">'
           + '<td style="padding:3px 6px;">' + _name + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">' + _party + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">'
           + '<span style="background:' + _color + ';color:#111;border-radius:3px;padding:1px 5px;font-size:0.85em;">' + _type + '</span>'
           + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">' + (_frozen ? '—' : _timer) + '</td>'
           + '<td style="padding:3px 6px;text-align:center;">' + _status + '</td>'
           + '</tr>';
}

if (_filled === 0) {
    _text = 'No bills currently in queue.';
    _html += '<tr><td colspan="5" style="padding:6px;text-align:center;color:#888;">No bills in queue</td></tr>';
}

_html += '</table>';

Q.bill_list_text   = _text;
Q.bill_list_html   = _html;
Q.bill_queue_count = _filled;
Q.bill_queue_full  = (_filled >= 10) ? 1 : 0;

Q.bill_proposed_this_month = 0;






















// === PARAMILITARY STRENGTH UPDATES ===

if (Q.nsdap_banned) {
    Q.sa_strength *= 0.90;
    Q.sa_militancy = Math.max(0, Q.sa_militancy - 0.1);
} else {
    Q.sa_strength += Q.random_factor(Q.unrest_factor / 3, 0.3);
}

if (Q.dnvp_banned || Q.sh_banned) {
    Q.sh_strength *= 0.95;
    Q.sh_militancy = Math.max(0, Q.sh_militancy - 0.3);
} else {
    Q.sh_strength += Q.random_factor(Q.unrest_factor / 6, 0.3);
}

if (Q.rfb_banned && !Q.april_challenge) {
    Q.rfb_strength *= 0.95;
    Q.rfb_militancy = Math.max(0, Q.rfb_militancy - 0.6);
} else if (Q.rfb_true_ban && Q.april_challenge) {
    Q.rfb_strength *= 0.95;
    Q.rfb_militancy = Math.max(0, Q.rfb_militancy - 0.01);
} else {
    Q.rfb_strength += Q.random_factor(Q.unrest_factor / 5, 0.3);
}

if (Q.rb_banned) {
    Q.rb_strength *= 0.90;
    Q.rb_militancy = Math.max(0, Q.rfb_militancy - 0.6);
} else {
    Q.rb_strength += Q.random_factor(Q.unrest_factor / 20, 0.3);
}

if (Q.jungdo_banned) {
    Q.jungdo_strength *= 0.90;
    Q.jungdo_militancy = Math.max(0, Q.rfb_militancy - 0.6);
} else {
    Q.jungdo_strength += Q.random_factor(Q.new_middle/50 + Q.old_middle/100 + Q.nationalism/100, 0.3);
}


// Decay factors — FIXED
// stability_decay: only applies when things are genuinely calm (low unrest)
// Multiplier reduced from 10 → 2 so it doesn't obliterate growth
Q.stability_decay = Math.max(0, (0.4 - Q.unrest_factor)) * 2;

// prosperity_factor: INVERTED so economic collapse REDUCES decay instead of adding to it
// Previously this was always ~3-4 even in crisis — now crisis = near zero decay from this term
// Formula: high unemployment and inflation push this toward 0, stable economy pushes toward 1
Q.prosperity_factor = Math.max(0, Q.inflation / 100 + Q.unemployed / 50) * 1.5;
// This now reads: the worse the economy, the MORE this subtracts from decay pressure

// Combined decay = calm conditions + good economy both reduce paramilitaries
// Crisis conditions = both terms shrink toward 0, so decay is minimal
Q.combined_decay = Math.max(0, Q.stability_decay - Q.prosperity_factor);

// Apply natural decay
Q.sa_strength     -= Q.random_factor(Q.combined_decay, 0.25);
Q.sh_strength     -= Q.random_factor(Q.combined_decay, 0.25);
Q.rfb_strength    -= Q.random_factor(Q.combined_decay, 0.25);
Q.rb_strength     -= Q.random_factor(Q.combined_decay, 0.25);
Q.jungdo_strength -= Q.random_factor(Q.combined_decay, 0.25);

// Caps for banned orgs
if (Q.nsdap_banned) Q.sa_strength     = Math.min(Q.sa_strength, 10);
if (Q.dnvp_banned || Q.sh_banned) Q.sh_strength = Math.min(Q.sh_strength, 15);
if (Q.rfb_banned && !Q.april_challenge) Q.rfb_strength = Math.min(Q.rfb_strength, 10);
if (Q.rfb_true_ban && Q.april_challenge) Q.rfb_strength = Math.min(Q.rfb_strength, 3);


// Caps for RB.

if (Q.prussian_police_training < 1) {
    Q.rb_militancy = Math.min(Q.rb_militancy, 0.20); 
    }


        // === PARAMILITARY CONSTRAINTS (SKIP IN CHAOS MODE) ===
    if (!Q.math_broken) {
        // NORMAL: Constrain paramilitary strength
        Q.sa_strength  = Math.min(Math.max(Q.sa_strength, 0), 10000);
        Q.sh_strength  = Math.min(Math.max(Q.sh_strength, 0), 10000);
        Q.rfb_strength = Math.min(Math.max(Q.rfb_strength, 0), 10000);
        Q.rb_strength  = Math.min(Math.max(Q.rb_strength, 0), 10000);
        Q.jungdo_strength  = Math.min(Math.max(Q.jungdo_strength, 0), 10000);
    } else {
        // MATH BROKEN: Paramilitary numbers can be anything
        Q.sa_strength = Q.impossible_add(Q.sa_strength, 0);
        Q.sh_strength = Q.impossible_multiply(Q.sh_strength, 1);
        Q.rfb_strength = Q.impossible_subtract(Q.rfb_strength, 0);
        Q.rb_strength = Q.impossible_percentage(Q.rb_strength / 100) * 100;
        Q.jungdo_strength = Q.impossible_add(Q.jungdo_strength, 0);
    }






}












// === PARAMILITARY BALANCE OF POWER ===

// Gather all force strengths
const forces = {
    prussian_police:       Q.prussian_police_strength || 0,
    interior_police:       Q.interior_police_strength || 0,
    reichswehr:            Q.reichswehr_strength || 0,
    reichsbanner:          Q.rb_strength || 0,
    rpb:                   (Q.rpb_formed ? Q.rpb_strength || 0 : 0),
    jungdo:                Q.jungdo_strength || 0,
    rfb:                   Q.rfb_strength || 0,
    stahlhelm:             Q.sh_strength || 0,
    sa:                    Q.sa_strength || 0,
};

// Militancy weights — raw strength alone isn't threat; multiply by militancy
const militancy_weights = {
    prussian_police:  (Q.prussian_police_loyalty || 50) / 100,
    interior_police:  (Q.interior_police_loyalty || 50) / 100,
    reichswehr:       (Q.reichswehr_militancy || 1) / 5,
    reichsbanner:     (Q.rb_militancy || 1) / 5,
    rpb:              (Q.rpb_militancy || 1) / 5,
    jungdo:           (Q.jungdo_militancy || 1) / 5,
    rfb:              (Q.rfb_militancy || 1) / 5,
    stahlhelm:        (Q.sh_militancy || 1) / 5,
    sa:               (Q.sa_militancy || 1) / 5,
};

// Effective strength = raw * militancy weight
let total_effective = 0;
const effective = {};
for (const [key, raw] of Object.entries(forces)) {
    effective[key] = raw * (militancy_weights[key] || 1);
    total_effective += effective[key];
}

// Normalize to percentages
const para_share = {};
if (!Q.math_broken) {
    for (const [key, eff] of Object.entries(effective)) {
        para_share[key] = total_effective > 0
            ? Math.round((eff / total_effective) * 1000) / 10
            : 0;
    }
} else {
    for (const [key, eff] of Object.entries(effective)) {
        para_share[key] = total_effective > 0
            ? Q.impossible_percentage(Math.round((eff / total_effective) * 1000) / 10)
            : Q.impossible_add(0, 0);
    }
    console.log("PARA CHAOS: SA=" + para_share.sa + "% RFB=" + para_share.rfb + "% Total=" +
        Object.values(para_share).reduce((a, b) => a + b, 0) + "%");
}

// Write back to Q
Q.para_share_prussian_police  = para_share.prussian_police;
Q.para_share_interior_police  = para_share.interior_police;
Q.para_share_reichswehr       = para_share.reichswehr;
Q.para_share_reichsbanner     = para_share.reichsbanner;
Q.para_share_rpb              = para_share.rpb;
Q.para_share_jungdo           = para_share.jungdo;
Q.para_share_rfb              = para_share.rfb;
Q.para_share_stahlhelm        = para_share.stahlhelm;
Q.para_share_sa               = para_share.sa;

//// Faction blocs
if (Q.april_challenge === 1 && Q.year >= 1933 && Q.month >= 10) {
    Q.para_bloc_pro_republic =
        para_share.prussian_police +
        para_share.interior_police +
        para_share.rpb +
        para_share.jungdo +
        para_share.stahlhelm;

    Q.para_bloc_left =
        para_share.rfb +
        para_share.reichsbanner;

    Q.para_bloc_right    = para_share.sa;
    Q.para_bloc_military = para_share.reichswehr;
} else {
    Q.para_bloc_pro_republic =
        para_share.prussian_police +
        para_share.interior_police +
        para_share.reichsbanner +
        para_share.rpb +
        para_share.jungdo;

    Q.para_bloc_left     = para_share.rfb;
    Q.para_bloc_right    = para_share.stahlhelm + para_share.sa;
    Q.para_bloc_military = para_share.reichswehr;
}















Q.has_event = 0;
// check if there are any cards in #event, and then go to main if not.
var scene = this.game.scenes['post_event.events_choice'];
var choices = this._compileChoices(scene);
if (choices && choices[0].title != "Continue...") {
    Q.has_event = 1;
} else {
    Q.has_event = 0;
}
// pre-load all of the event images
if (this.ui && this.ui.show_portraits) {
    for (var choice of choices) {
        var cc = this.game.scenes[choice.id];
        if (cc.faceImage) {
            var im = new Image();
            im.onload = function(){};
            im.src = cc.faceImage;
        }
    }
}



var parties = ['z','srpd','ddp','dvp','csrp','sapd','kpd','bvp','wp','cnbl','dhp','bb','vrp','kvp','csvd','dnvp','nsdap'];

if (!Q.math_broken) {
    // NORMAL: Coalition dissent is a straightforward sum
    var total = 0;
    for (var i = 0; i < parties.length; i++) {
        var p = parties[i];
        if (Q[p + '_in_government']) {
            total += Q[p + '_dissent'] || 0;
        } else {
            Q[p + '_dissent'] = 0;
        }
    }
    Q.coalition_dissent = total;
} else {
    // MATH BROKEN: Dissent arithmetic is unreliable
    var total = Q.impossible_add(0, 0); // "Zero" that may not be zero
    for (var i = 0; i < parties.length; i++) {
        var p = parties[i];
        if (Q[p + '_in_government']) {
            total = Q.impossible_add(total, Q[p + '_dissent'] || 0);
        } else {
            // MATH BROKEN: Setting to zero may produce non-zero
            Q[p + '_dissent'] = Q.impossible_multiply(0, 1);
        }
    }
    Q.coalition_dissent = total;
    console.log("DISSENT CHAOS: Coalition dissent = " + Q.coalition_dissent);
}









 
// === EARLY BOUNDS CHECKING (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    Q.pro_republic = Math.round(Q.pro_republic * 10) / 10;
    Q.nationalism  = Math.round(Q.nationalism  * 10) / 10;
    Q.socialism    = Math.round(Q.socialism    * 10) / 10;

    Q.pro_republic = Math.max(0.1, Math.min(99.9, Q.pro_republic));
    Q.nationalism  = Math.max(0.1, Math.min(99.9, Q.nationalism));
    Q.socialism    = Math.max(0.1, Math.min(99.9, Q.socialism));
} else {
    // MATH BROKEN: Political values can be anything
    Q.pro_republic = Q.impossible_add(Q.pro_republic, 0);
    Q.nationalism  = Q.impossible_multiply(Q.nationalism, 1);
    Q.socialism    = Q.impossible_subtract(Q.socialism, 0);
}

// === IDEOLOGICAL NORMALIZATION (SKIP IN CHAOS MODE) ===
let ideologies = ['pro_republic', 'socialism', 'nationalism'];

if (!Q.math_broken) {
    // NORMAL: Ideologies sum to 200
    let total = 0;
    for (let ideology of ideologies) {
        total += Q[ideology];
    }
    let factor = 100 / total;
    for (let ideology of ideologies) {
        Q[ideology] = Math.round(Q[ideology] * factor * 10) / 10;
    }
} else {
    // MATH BROKEN: Ideologies don't normalize
    for (let ideology of ideologies) {
        Q[ideology] = Q.impossible_percentage(Q[ideology]);
    }
    console.log("IDEOLOGY CHAOS: Total = " + (Q.pro_republic + Q.socialism + Q.nationalism));
}

// === FACTION BOUNDS (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    for (var c of Q.factions) {
        if (Q[c+'_dissent'] < 0) {
            Q[c+'_dissent'] = 0;
        } else if (Q[c+'_dissent'] >= 100) {
            Q[c+'_dissent'] = 99;
        }
        if (Q[c+'_strength'] < 0) {
            Q[c+'_strength'] = 0;
        }
    }
} else {
    // MATH BROKEN: Factions can have impossible values
    for (var c of Q.factions) {
        Q[c+'_dissent'] = Q.impossible_percentage(Q[c+'_dissent']);
        Q[c+'_strength'] = Q.impossible_add(Q[c+'_strength'], 0);
    }
}

// === UNEMPLOYMENT FLOOR (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    if (Q.unemployed <= 1) {
        Q.unemployed = 1;
    }
    Q.unemployedc = Math.max(2, 10 + (Q.unemployed - 8) * 0.55);
} else {
    Q.unemployed = Q.impossible_add(Q.unemployed, 0);
}

// === CLASS NORMALIZATION (SKIP IN CHAOS MODE) ===
let classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployedc'];

if (!Q.math_broken) {
    // NORMAL: Classes sum to 100%
    let total = 0;
    for (let c of classes) {
        total += Q[c];
    }
    let factor = 100 / total;
    for (let c of classes) {
        Q[c] = +(Q[c] * factor).toFixed(2);
    }
} else {
    // MATH BROKEN: Classes don't normalize
    // Apply impossible math to each class
    for (let c of classes) {
        Q[c] = Q.impossible_percentage(Q[c]);
    }
    // Total will NOT equal 100
    console.log("CLASS CHAOS: Total = " + (Q.workers + Q.old_middle + Q.new_middle + Q.rural + Q.unemployedc) + "%");
}

// After this, sum of Q.workers + Q.old_middle + ... + Q.catholics === 100




// === IDENTITY CLASS NORMALIZATION (SKIP IN CHAOS MODE) ===
let classesI = ['protestants', 'catholics', 'seculars', 'youth'];

if (!Q.math_broken) {
    // NORMAL: ClassesI sum to 100%
    let totalI = 0;
    for (let c of classesI) {
        totalI += Q[c];
    }
    let factor = 100 / totalI;
    for (let c of classesI) {
        Q[c] = +(Q[c] * factor).toFixed(2);
    }
} else {
    // MATH BROKEN: Classes don't normalize
    // Apply impossible math to each class
    for (let c of classesI) {
        Q[c] = Q.impossible_percentage(Q[c]);
    }
    }




// === CLASS VOTE NORMALIZATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Class votes normalize to 100%
    for (var c of Q.classes) {
        let class_votes = 0;

        for (var party of Q.parties) {
            Q[c + '_' + party] = Math.max(0, Q[c + '_' + party]);
            class_votes += Q[c + '_' + party];
        }

        for (var party of Q.parties) {
            Q[c + '_' + party + '_normalized'] = class_votes > 0 ? Q[c + '_' + party] / class_votes : 0;
            Q[c + '_' + party + '_display'] = (Q[c + '_' + party + '_normalized'] * 100).toFixed(1);
        }
    }
} else {
    // MATH BROKEN: Class votes don't normalize
    for (var c of Q.classes) {
        let class_votes = Q.impossible_add(0, 0); // "Zero" that isn't zero

        for (var party of Q.parties) {
            Q[c + '_' + party] = Q.impossible_add(Q[c + '_' + party], 0); // Can go negative
            class_votes = Q.impossible_add(class_votes, Q[c + '_' + party]);
        }

        for (var party of Q.parties) {
            // Division that doesn't work properly
            if (Math.random() < 0.5) {
                Q[c + '_' + party + '_normalized'] = Q.impossible_multiply(Q[c + '_' + party], 1/class_votes);
            } else {
                Q[c + '_' + party + '_normalized'] = Q.impossible_subtract(Q[c + '_' + party], -class_votes);
            }
            Q[c + '_' + party + '_display'] = Q.impossible_percentage(Q[c + '_' + party + '_normalized'] * 100).toFixed(1);
        }
    }
}


// === PARTY SUPPORT CALCULATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Party support calculated correctly
    var total_support = 0;
    for (var party of Q.parties) {
        let party_support = 0;
        for (var c of Q.classes) {
            if (Q.old_demographics) {
                party_support += Q[c] * Q[c + '_' + party];
            } else {
                party_support += Q[c] * Q[c + '_' + party + '_normalized'];
            }
        }
        Q[party + '_support'] = party_support;
        total_support += party_support;
    }
} else {
    // MATH BROKEN: Party support calculation is nonsense
    var total_support = Q.impossible_add(0, 0);
    for (var party of Q.parties) {
        let party_support = Q.impossible_multiply(0, 1);
        for (var c of Q.classes) {
            if (Q.old_demographics) {
                party_support = Q.impossible_add(party_support, Q.impossible_multiply(Q[c], Q[c + '_' + party]));
            } else {
                party_support = Q.impossible_add(party_support, Q.impossible_multiply(Q[c], Q[c + '_' + party + '_normalized']));
            }
        }
        Q[party + '_support'] = party_support;
        total_support = Q.impossible_add(total_support, party_support);
    }
    console.log("PARTY CHAOS: Total support = " + total_support);
}




// === PARTY VOTE NORMALIZATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Parties normalize to 100%
    for (var party of Q.parties) {
        Q[party + '_normalized'] = total_support > 0 ? Q[party + '_support'] / total_support : 0;
        Q[party + '_votes'] = Math.round(Q[party + '_normalized'] * 1000) / 10;
    }
} else {
    // MATH BROKEN: Parties don't normalize
    for (var party of Q.parties) {
        Q[party + '_normalized'] = Q.impossible_multiply(Q[party + '_support'], 1/total_support);
        Q[party + '_votes'] = Q.impossible_percentage(Q[party + '_normalized'] * 100);
    }
    console.log("VOTE CHAOS: SPD = " + Q.spd_votes + "%, NSDAP = " + Q.nsdap_votes + "%");
}

// tried merging this and draft party support changer code, went horrible for one hour... Fuck this, I tried to rewrite the code with both AI and without trying to invent some random bullshit fractions, fuck this now, im stealing code from Originn0.

// === FACTION STRENGTH NORMALIZATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Faction strength normalizes to 100%
    var total_strength = Q.left_strength + Q.center_strength + Q.labor_strength + Q.reformist_strength + Q.neorevisionist_strength;

    Q.left_strength = 100*Q.left_strength/total_strength;
    Q.center_strength = 100*Q.center_strength/total_strength;
    Q.labor_strength = 100*Q.labor_strength/total_strength;
    Q.reformist_strength = 100*Q.reformist_strength/total_strength;
    Q.neorevisionist_strength = 100*Q.neorevisionist_strength/total_strength;
} else {
    // MATH BROKEN: Faction strength doesn't normalize
    var total_strength = Q.impossible_add(Q.left_strength, Q.center_strength);
    total_strength = Q.impossible_add(total_strength, Q.labor_strength);
    total_strength = Q.impossible_add(total_strength, Q.reformist_strength);
    total_strength = Q.impossible_add(total_strength, Q.neorevisionist_strength);

    Q.left_strength = Q.impossible_multiply(Q.left_strength, 100/total_strength);
    Q.center_strength = Q.impossible_multiply(Q.center_strength, 100/total_strength);
    Q.labor_strength = Q.impossible_multiply(Q.labor_strength, 100/total_strength);
    Q.reformist_strength = Q.impossible_multiply(Q.reformist_strength, 100/total_strength);
    Q.neorevisionist_strength = Q.impossible_multiply(Q.neorevisionist_strength, 100/total_strength);
    
    console.log("FACTION CHAOS: Total = " + (Q.left_strength + Q.center_strength + Q.labor_strength + Q.reformist_strength + Q.neorevisionist_strength) + "%");
}

// === DISSENT CALCULATION (SKIP IN CHAOS MODE) ===
if (!Q.math_broken) {
    // NORMAL: Dissent calculated correctly
    var total_dissent = Q.left_strength*Q.left_dissent + Q.center_strength*Q.center_dissent + Q.labor_strength*Q.labor_dissent + Q.reformist_strength*Q.reformist_dissent + Q.neorevisionist_strength*Q.neorevisionist_dissent;

    Q.dissent = 0.01*total_dissent/total_strength;
    Q.dissent_percent = Q.dissent*100;

    if (Q.dissent < 0) {
        Q.dissent = 0;
    } else if (Q.dissent > 0.95) {
        Q.dissent = 0.95;
    }
} else {
    // MATH BROKEN: Dissent calculation is chaos
    var total_dissent = Q.impossible_multiply(Q.left_strength, Q.left_dissent);
    total_dissent = Q.impossible_add(total_dissent, Q.impossible_multiply(Q.center_strength, Q.center_dissent));
    total_dissent = Q.impossible_add(total_dissent, Q.impossible_multiply(Q.labor_strength, Q.labor_dissent));
    total_dissent = Q.impossible_add(total_dissent, Q.impossible_multiply(Q.reformist_strength, Q.reformist_dissent));
    total_dissent = Q.impossible_add(total_dissent, Q.impossible_multiply(Q.neorevisionist_strength, Q.neorevisionist_dissent));

    Q.dissent = Q.impossible_multiply(0.01, total_dissent/total_strength);
    Q.dissent_percent = Q.impossible_percentage(Q.dissent*100);
    
    console.log("DISSENT CHAOS: " + Q.dissent_percent + "%");
}




if (Q.ma >= 1) {
    Q.ma = 0;
    // append to historical party support records
    var party_support_results = {'date': new Date(Q.year, Q.month - 1)};
    for (var party of Q.parties) {
        party_support_results[party] = Q[party + '_normalized']*100;
    }
    Q.party_support_records.push(party_support_results);
    Q.economic_records.push({'date': new Date(Q.year, Q.month - 1),
                             'economic_growth': Q.economic_growth,
                             'inflation': Q.inflation,
                             'unemployment': Q.unemployed});
}


Q.capital_strike_progress = Math.max(0, Math.min(15, Q.capital_strike_progress || 0));
Q.coup_progress           = Math.max(0, Math.min(15, Q.coup_progress           || 0));
Q.general_strike_progress = Math.max(0, Math.min(15, Q.general_strike_progress || 0));

