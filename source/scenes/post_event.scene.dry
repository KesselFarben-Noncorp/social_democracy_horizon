// === RESOLVE ACTIVE PROFILE ===
// Map president variable to profile key
const PRESIDENT_KEY_MAP = {
    "Hindenburg":  "Hindenburg",
    "Westarp":     "Westarp",
    "Marx":        "Marx",
    "Thalmann":    "Thalmann",
    "Thälmann":    "Thalmann",
    "Seeckt":      "Seeckt",
    "Braun":       "SPD_President",
    "Wels":        "SPD_President",
    "Breitscheid": "SPD_President"
};

const _pres_key = PRESIDENT_KEY_MAP[Q.president] || "_default";
const _profile  = PRESIDENT_PROFILES[_pres_key];

// === DYNAMIC CEILING (non-Hindenburg) ===
// Base 60, offset by seeded prng so each run feels slightly different
// Hindenburg keeps hardcoded 120
if (!Q.camarilla_ceiling_set) {
    if (_pres_key === "Hindenburg") {
        Q.camarilla_ceiling = 120;
    } else {
        const _ceil_rng = _mkrng((Q.rng_seed + 0xCAFE) >>> 0);
        Q.camarilla_ceiling = 45 + Math.floor(_ceil_rng() * 31); // 45–75
    }
    Q.camarilla_ceiling_set = 1;
}

// Reset ceiling if president changes
if (Q._last_president !== Q.president) {
    Q.camarilla_ceiling_set = 0;
    Q._last_president = Q.president;
    // Reset member influences for new president
    Q.camarilla_member_influences = {};
    Q.camarilla_goals = {};
    Q.camarilla_strength = _pres_key === "Hindenburg" ? 35 : 20;
}

// === INITIALIZE MEMBER INFLUENCES ===
if (!Q.camarilla_member_influences) Q.camarilla_member_influences = {};
if (!Q.camarilla_goals)             Q.camarilla_goals = {};

// === HINDENBURG HEALTH MODEL ===
if (_pres_key === "Hindenburg") {

    Q.hindenburg_age = 78 + (Q.year - 1925) + (Q.month / 12);
    Q.age_factor     = Math.pow((Q.hindenburg_age - 75) / 9, 2);

    // Health decline
    Q.base_health_decline = 0.08 + (Q.age_factor * 0.25);

    Q.unemployment_stress = Math.pow(Math.max(0, Q.unemployed - 8) / 12, 2.1) * 0.25;
    Q.inflation_stress    = Math.pow(Math.abs(Q.inflation - 2) / 8, 1.5) * 0.12;
    Q.growth_stress       = Math.pow(Math.max(0, -Q.economic_growth) / 10, 1.6) * 0.10;
    Q.economic_health_drain = Q.unemployment_stress + Q.inflation_stress + Q.growth_stress;

    Q.left_bloc   = Q.math_broken
        ? Q.impossible_add(Q.impossible_add(Q.spd_r || 0, Q.kpd_r || 0), Q.sapd_r || 0)
        : (Q.spd_r || 0) + (Q.kpd_r || 0) + (Q.sapd_r || 0);
    Q.left_stress = Math.pow(Math.max(0, Q.left_bloc - 35) / 25, 1.4) * 0.08;
    Q.nazi_stress = Math.pow(Math.max(0, Q.nsdap_r - 10) / 30, 2.0) * 0.12;

    Q.coalition_chaos = (
        (Q.coalition_dissent || 0) * 0.08 +
        (Q.no_majority_elections || 0) * 0.05 +
        (Q.grand_coalition_failed ? 0.15 : 0) +
        (Q.minority_government ? 0.10 : 0)
    );

    Q.street_violence_index = (
        ((Q.sa_strength || 0)  * (Q.sa_militancy  || 0) / 500) +
        ((Q.rfb_strength || 0) * (Q.rfb_militancy || 0) / 200)
    );
    Q.street_stress = Math.min(Q.street_violence_index * 0.09, 0.20);

    Q.emergency_stress = (
        (Q.emergency_rule ? 0.05 : 0) +
        (Q.hindenburg_interventions || 0) * 0.02 +
        (Q.article_48_permanent ? 0.15 : 0)
    );

    Q.political_health_drain = Q.left_stress + Q.nazi_stress + Q.coalition_chaos +
                               Q.street_stress + Q.emergency_stress;

    Q.total_health_decline   = Q.base_health_decline + Q.economic_health_drain + Q.political_health_drain;
    Q.hindenburg_health      = Math.max(0, (Q.hindenburg_health || 100) - Q.total_health_decline);

    // Senility
    Q.base_senility_rate           = Q.age_factor * 0.10;
    Q.health_senility_multiplier   = Q.hindenburg_health < 50 ?
        (1 + (50 - Q.hindenburg_health) / 30) : 1;
    Q.senility_increase            = Q.base_senility_rate * Q.health_senility_multiplier;
    Q.hindenburg_senility          = Math.min(100, (Q.hindenburg_senility || 0) + Q.senility_increase);

    // Death check
    if ((Q.year >= 1934 && Q.month >= 8) || Q.hindenburg_health <= 0) {
        Q.hindenburg_dead       = 1;
        Q.hindenburg_death_year = Q.year;
    }

    // Reichstag trust (Hindenburg-specific)
    Q.extremism_index    = (Q.nsdap_r + Q.kpd_r) / 100;
    Q.base_trust_decay   = Q.extremism_index * 0.08;

    Q.govt_trust_modifier = 0;
    if (Q.spd_in_government)  Q.govt_trust_modifier -= 0.12;
    if (Q.kpd_in_government)  Q.govt_trust_modifier -= 0.25;
    if (Q.sapd_in_government) Q.govt_trust_modifier -= 0.20;
    if (Q.z_in_government || Q.bvp_in_government) Q.govt_trust_modifier += 0.05;
    if (Q.dnvp_in_government) Q.govt_trust_modifier += 0.08;
    if (Q.dvp_in_government)  Q.govt_trust_modifier += 0.06;
    if (Q.presidential_cabinet) Q.govt_trust_modifier -= 0.10;
    if (Q.nsdap_in_government) {
        Q.govt_trust_modifier += (Q.camarilla_strength || 0) > 70 ? 0.05 : -0.15;
    }

    Q.trust_reichstag_change      = Q.base_trust_decay + Q.govt_trust_modifier + (Q.coalition_chaos * 0.05);
    Q.hindenburg_trust_reichstag  = Math.max(0, (Q.hindenburg_trust_reichstag || 50) - Q.trust_reichstag_change);

    // Party trusts
    Q.economy_score = (5 - Q.unemployed / 5) + (Q.economic_growth / 3) - (Math.abs(Q.inflation - 2) / 4);

    Q.spd_trust_change = -0.026;
    if (Q.spd_in_government) Q.spd_trust_change += Q.economy_score * 0.01;
    if (Q.spd_in_government) Q.spd_trust_change + Q.welfare / 10;
    if (Q.hindenburg_relationship_efforts > 0) Q.spd_trust_change += 0.08;
    Q.hindenburg_trust_spd  = Math.max(0, Math.min(100, (Q.hindenburg_trust_spd  || 50) + Q.spd_trust_change));

    Q.z_trust_change = 0.01;
    if (Q.z_in_government && Q.economy_score > 3) Q.z_trust_change += 0.03;
    Q.hindenburg_trust_z    = Math.max(0, Math.min(100, (Q.hindenburg_trust_z    || 60) + Q.z_trust_change));

    Q.dnvp_trust_change = 0.02;
    if (Q.dnvp_leader === "Hugenberg" || Q.dnvp_party_leader === "Hugenberg") Q.dnvp_trust_change -= 0.08;
    Q.hindenburg_trust_dnvp = Math.max(0, Math.min(100, (Q.hindenburg_trust_dnvp || 70) + Q.dnvp_trust_change));

} else {
    // === SIMPLE HEALTH MODEL (all other presidents) ===
    // Political stress only — no aging curve
    Q.left_bloc   = Q.math_broken
        ? Q.impossible_add(Q.impossible_add(Q.spd_r || 0, Q.kpd_r || 0), Q.sapd_r || 0)
        : (Q.spd_r  || 0) + (Q.kpd_r  || 0) + (Q.sapd_r || 0);
    Q.right_bloc  = Q.math_broken
        ? Q.impossible_add(Q.nsdap_r || 0, Q.dnvp_r || 0)
        : (Q.nsdap_r || 0) + (Q.dnvp_r || 0);
    Q.economy_score = (5 - Q.unemployed / 5) + (Q.economic_growth / 3) - (Math.abs(Q.inflation - 2) / 4);
    Q.coalition_chaos = (
        (Q.coalition_dissent || 0) * 0.08 +
        (Q.no_majority_elections || 0) * 0.05 +
        (Q.grand_coalition_failed ? 0.15 : 0) +
        (Q.minority_government ? 0.10 : 0)
    );
    Q.extremism_index = (Q.nsdap_r + Q.kpd_r) / 100;
}

// === MEMBER INFLUENCE UPDATE ===
for (const [key, member] of Object.entries(_profile.members)) {

    // Condition check — skip member if condition not met
    if (member.condition_var) {
        if (member.condition_min !== undefined && Q[member.condition_var] < member.condition_min) {
            Q.camarilla_member_influences[key] = 0;
            continue;
        }
        if (member.condition_val !== undefined && Q[member.condition_var] !== member.condition_val) {
            // Special case: Seeckt in Hindenburg profile only active if Seeckt is actually president
            Q.camarilla_member_influences[key] = 0;
            continue;
        }
    }

    // Initialize
    if (Q.camarilla_member_influences[key] === undefined) {
        Q.camarilla_member_influences[key] = member.influence_base;
    }

    let growth = member.growth_rate;

    // Hindenburg-specific member growth modifiers
    if (_pres_key === "Hindenburg") {
        if (key === "schleicher") {
            growth = (Q.year >= 1930 && Q.year <= 1932) ? 0.5 : 0.2;
            if (Q.year >= 1933) growth = -0.3;
        }
        if (key === "oskar") {
            growth = 0.15 + ((Q.hindenburg_senility || 0) / 100) * 0.4;
        }
        if (key === "oldenburg") {
            growth += Math.max(0, -(Q.agricultural_policy || 0)) * 0.3;
        }
        if (key === "papen") {
            growth += (Q.papen_cabinet ? 0.8 : 0) + (Q.chancellor === "Papen" ? 1.0 : 0);
        }
        if (key === "hugenberg") {
            // Only grows if Hugenberg DNVP line is active
            if (Q.dnvp_line !== 3) { growth = 0; }
        }
    }

    // Apply counter (exposure/scandal reduces influence)
    if (member.counter_var && Q[member.counter_var]) {
        growth -= (member.counter_penalty || 0.5);
    }

    // Economy modifier: bad economy grows most inner circles
    const econ_mod = Math.max(0, -Q.economy_score) * 0.05;
    growth += econ_mod;

    // Small prng jitter per member per tick
    growth += (_r() - 0.5) * 0.08;

    Q.camarilla_member_influences[key] = Math.max(0, Math.min(100,
        Q.camarilla_member_influences[key] + growth
    ));
}

// === CAMARILLA STRENGTH UPDATE ===
{
    const _is_hindenburg = (_pres_key === "Hindenburg");

    let _base_growth = _is_hindenburg ? 0.15 : 0.08;

    // Weakness multiplier (Hindenburg: health+senility; others: economy+chaos only)
    let _weakness_mult = 1.0;
    if (_is_hindenburg) {
        _weakness_mult = 1
            + ((100 - (Q.hindenburg_health || 100)) / 100)
            + ((Q.hindenburg_senility || 0) / 100);
    } else {
        _weakness_mult = 1 + Math.max(0, -Q.economy_score) * 0.15;
    }

    const _instability_mult = 1 + (Q.coalition_chaos * 0.5) + (Q.presidential_cabinet ? 0.3 : 0);
    const _crisis_mult      = 1
        + (Q.unemployment_stress || 0) * 2
        + (Q.inflation_stress    || 0) * 1.5
        + (Q.growth_stress       || 0) * 1.8;
    const _extremism_mult   = 1 + (Q.extremism_index || 0) * 0.8;
    const _year_mult        = _is_hindenburg
        ? 1 + Math.max(0, (Q.year - 1928) * 0.25)
        : 1 + Math.max(0, (Q.year - 1928) * 0.10); // slower for others

    let _cam_growth = _base_growth
        * _weakness_mult
        * _instability_mult
        * _crisis_mult
        * _extremism_mult
        * _year_mult;

    // Counters
    if (Q.president_relation >= 20)           _cam_growth *= 0.70;
    if (Q.in_grand_coalition || Q.in_weimar_coalition) _cam_growth *= 0.85;
    if (Q.constitutional_reform >= 2)         _cam_growth *= 0.80;
    if (_is_hindenburg && Q.osthilfe_exposed) _cam_growth *= 0.60;

    // prng jitter on growth
    _cam_growth *= (0.85 + _r() * 0.30);

    Q.camarilla_strength = Math.min(
        Q.camarilla_ceiling,
        (Q.camarilla_strength || (_is_hindenburg ? 35 : 20)) + _cam_growth
    );
}

// === GOAL SCORES ===
// Each goal accumulates from weighted member influences
{
    const _goals_template = _profile.goals;

    // Initialize goals from template if missing
    for (const [gkey, gdata] of Object.entries(_goals_template)) {
        if (Q.camarilla_goals[gkey] === undefined) {
            Q.camarilla_goals[gkey] = gdata.base;
        }
    }

    // Accumulate from member influences
    for (const [mkey, member] of Object.entries(_profile.members)) {
        const _minf = Q.camarilla_member_influences[mkey] || 0;
        if (_minf <= 0) continue;
        for (const [gkey, weight] of Object.entries(member.goal_weights || {})) {
            if (Q.camarilla_goals[gkey] !== undefined) {
                Q.camarilla_goals[gkey] = Math.min(100,
                    Q.camarilla_goals[gkey] + (_minf * weight * 0.005)
                );
            }
        }
    }

    // Hindenburg-specific goal modifiers
    if (_pres_key === "Hindenburg") {
        Q.camarilla_goals.destroy_parliament = Math.min(100,
            (Q.camarilla_goals.destroy_parliament || 15)
            + (100 - Q.hindenburg_trust_reichstag) * 0.02
            + (Q.emergency_stress || 0) * 5
        );
        Q.camarilla_goals.crush_left = Math.min(100,
            (Q.camarilla_goals.crush_left || 50)
            + ((Q.left_bloc || 0) / 100) * 0.5
            + (Q.spd_in_government ? 0.5 : 0)
        );
        Q.camarilla_goals.protect_junkers = Math.min(100,
            (Q.camarilla_goals.protect_junkers || 70)
            + 0.2
            + (Q.land_reform > 0 ? 0.5 : 0)
        );
        Q.camarilla_goals.install_hitler = Math.min(100,
            (Q.camarilla_goals.install_hitler || 0)
            + (Q.year >= 1930
                ? Math.pow((Q.nsdap_r || 0) / 40, 1.5) * 0.3
                : 0)
        );
    }
}

// === DECREE PRESSURE ===
// Aggregated score per target category.
// Fires as an event when threshold crossed — event system reads Q.decree_pressure_target.
{
    Q.decree_pressure = Q.decree_pressure || {};

    const _decree_targets = _profile.decree_targets || [];
    const _base_pressure  = Q.camarilla_strength / Q.camarilla_ceiling;

    for (const target of _decree_targets) {
        if (Q.decree_pressure[target] === undefined) Q.decree_pressure[target] = 0;

        let _target_growth = _base_pressure * 0.4;

        // Goal-specific amplifiers
        if (target === "land_reform" && (Q.camarilla_goals.protect_junkers || 0) > 60) {
            _target_growth += (Q.camarilla_goals.protect_junkers - 60) * 0.008;
        }
        if (target === "left_coalition" && (Q.camarilla_goals.crush_left || 0) > 50) {
            _target_growth += (Q.camarilla_goals.crush_left - 50) * 0.010;
        }
        if (target === "constitutional_reform" && (Q.camarilla_goals.destroy_parliament || 0) > 40) {
            _target_growth += (Q.camarilla_goals.destroy_parliament - 40) * 0.008;
        }
        if (target === "paramilitary_ban") {
            // Grows when SA/RFB bans threatened and camarilla strong
            _target_growth += _base_pressure * 0.2;
        }
        if (target === "budget_spending") {
            // Grows with deficit
            _target_growth += Math.max(0, -(Q.budget || 0)) * 0.005;
        }

        // prng jitter
        _target_growth *= (0.8 + _r() * 0.4);

        // Natural decay — pressure dissipates if not reinforced
        Q.decree_pressure[target] = Math.max(0, Math.min(100,
            Q.decree_pressure[target] * 0.92 + _target_growth
        ));
    }

    // === FIRE DECREE ===
    // Pick highest-pressure target above threshold (75)
    // Set Q.decree_pressure_target for event system to read
    // Only fire one decree per tick, clear after firing
    if (!Q.decree_fired_this_tick) {
        let _highest = 0;
        let _target_key = null;
        for (const target of _decree_targets) {
            if ((Q.decree_pressure[target] || 0) > 75 && Q.decree_pressure[target] > _highest) {
                _highest    = Q.decree_pressure[target];
                _target_key = target;
            }
        }
        if (_target_key) {
            Q.decree_pressure_target  = _target_key;
            Q.decree_pressure_active  = 1;
            Q.decree_pressure[_target_key] = 0; // reset after firing
            Q.decree_fired_this_tick  = 1;
        } else {
            Q.decree_pressure_active  = 0;
            Q.decree_pressure_target  = null;
        }
    }
    Q.decree_fired_this_tick = 0; // reset for next tick
}

// === CHANCELLOR PRESSURE ===
// Produces Q.camarilla_chancellor_scores — a map of chancellor names to pressure scores.
// Coalition formation reads this to determine if president will accept a candidate.
// Presidential cabinet is pushed when camarilla_strength > cabinet_threshold.
{
    Q.camarilla_chancellor_scores = {};

    const _preferred  = _profile.preferred_chancellors  || [];
    const _hostile    = _profile.hostile_chancellors    || [];
    const _comfort    = _profile.comfort_parties        || [];
    const _hostile_p  = _profile.hostile_parties        || [];

    // Score preferred chancellors positively
    for (const name of _preferred) {
        Q.camarilla_chancellor_scores[name] =
            (Q.camarilla_chancellor_scores[name] || 0) + Q.camarilla_strength * 0.4;
    }
    // Score hostile chancellors negatively
    for (const name of _hostile) {
        Q.camarilla_chancellor_scores[name] =
            (Q.camarilla_chancellor_scores[name] || 0) - Q.camarilla_strength * 0.5;
    }

    // Amplify install_hitler goal into Hitler score (Hindenburg only, late game)
    if (_pres_key === "Hindenburg" && (Q.camarilla_goals.install_hitler || 0) > 50) {
        Q.camarilla_chancellor_scores["Hitler"] =
            (Q.camarilla_chancellor_scores["Hitler"] || 0)
            + (Q.camarilla_goals.install_hitler - 50) * 0.8;
    }

    // Presidential cabinet threshold
    // Base: 80 for Hindenburg, scaled ceiling*0.75 for others
    const _cabinet_threshold = _pres_key === "Hindenburg"
        ? 80
        : Q.camarilla_ceiling * 0.75;

    Q.camarilla_pushes_presidential_cabinet = (Q.camarilla_strength >= _cabinet_threshold) ? 1 : 0;

    // Expose threshold to event system
    Q.camarilla_cabinet_threshold = _cabinet_threshold;
}

// === BUILD DISPLAY STRINGS ===
Q.camarilla_members_display = "";
for (const [key, member] of Object.entries(_profile.members)) {
    const inf = Math.round(Q.camarilla_member_influences[key] || 0);
    if (inf > 0) {
        Q.camarilla_members_display += member.label + ": " + inf + "\n";
    }
}

Q.camarilla_goals_display = "";
for (const [key, gdata] of Object.entries(_profile.goals)) {
    const score = Math.round(Q.camarilla_goals[key] || 0);
    Q.camarilla_goals_display += gdata.label + ": " + score + "\n";
}


// === LEGACY COMPATIBILITY ===
// Keep old variable names alive so existing events don't break
if (_pres_key === "Hindenburg") {
    Q.camarilla_exists        = 1;
    Q.hindenburg_president    = 1;
    Q.meissner_influence      = Q.camarilla_member_influences.meissner  || 0;
    Q.schleicher_influence    = Q.camarilla_member_influences.schleicher || 0;
    Q.oskar_influence         = Q.camarilla_member_influences.oskar     || 0;
    Q.oldenburg_influence     = Q.camarilla_member_influences.oldenburg || 0;
    Q.papen_influence         = Q.camarilla_member_influences.papen     || 0;
    Q.camarilla_goal_destroy_parliament = Q.camarilla_goals.destroy_parliament || 0;
    Q.camarilla_goal_crush_left         = Q.camarilla_goals.crush_left         || 0;
    Q.camarilla_goal_protect_junkers    = Q.camarilla_goals.protect_junkers    || 0;
    Q.camarilla_goal_install_hitler     = Q.camarilla_goals.install_hitler     || 0;
} else {
    Q.camarilla_exists     = Q.camarilla_strength > 20 ? 1 : 0;
    Q.hindenburg_president = 0;
  }

















// === HINDENBURG PATIENCE ENGINE ===
// Guard: Only runs for Hindenburg or Independent presidents, never party presidents
if (Q.president === "Hindenburg" || Q.president_party === "I") {

// === INITIALIZE MISSING VARIABLES ===
if (Q.hindenburg_dismissed_cooldown_turns > 0) {
    Q.hindenburg_dismissed_cooldown_turns -= 1;
    if (Q.hindenburg_dismissed_cooldown_turns === 0) {
        Q.hindenburg_dismissed_government_this_turn = 0;
    }
}
Q.article_48_uses           = Q.article_48_uses           || 0;
Q.z_left_wing               = Q.z_left_wing               || 0;
Q.chancellor_minority_ticks = Q.chancellor_minority_ticks || 0;
Q.hindenburg_trust_spd      = Q.hindenburg_trust_spd      || 30;
Q.hindenburg_trust_dnvp     = Q.hindenburg_trust_dnvp     || 70;
Q.hindenburg_trust_military = Q.hindenburg_trust_military || 85;
Q.hindenburg_trust_z        = Q.hindenburg_trust_z        || 60;
Q.hindenburg_trust_reichstag= Q.hindenburg_trust_reichstag|| 50;
Q.hindenburg_senility       = Q.hindenburg_senility       || 0;
Q.hindenburg_monarchist_sentiment = Q.hindenburg_monarchist_sentiment || 65;
Q.camarilla_strength        = Q.camarilla_strength        || 0;
Q.oskar_influence           = Q.oskar_influence           || 0;
Q.papen_influence           = Q.papen_influence           || 0;
Q.oldenburg_influence       = Q.oldenburg_influence       || 0;
Q.schleicher_influence      = Q.schleicher_influence      || 0;
Q.camarilla_goal_protect_junkers    = Q.camarilla_goal_protect_junkers    || 0;
Q.camarilla_goal_destroy_parliament = Q.camarilla_goal_destroy_parliament || 0;
Q.camarilla_goal_crush_left         = Q.camarilla_goal_crush_left         || 0;
Q.hindenburg_interventions          = Q.hindenburg_interventions           || 0;
Q.hindenburg_crisis_threshold       = Q.hindenburg_crisis_threshold        || 0;

// === DISMISSAL COOLDOWN GUARD ===
// Prevent any patience processing the same turn a dismissal fires
if (Q.hindenburg_dismissed_government_this_turn) return;

const hasChancellor = !!(
    Q.bruning_cabinet || Q.schleicher_cabinet ||
    Q.papen_cabinet   || Q.chancellor
);

if (!hasChancellor) {
    // No chancellor — reset trackers and clear flags, then stop
    Q.chancellor_minority_ticks    = 0;
    Q.hindenburg_patience_low      = 0;
    Q.hindenburg_patience_critical = 0;
    // Do NOT set hindenburg_ready_to_dismiss here — nothing to dismiss
    Q.hindenburg_ready_to_dismiss  = 0;
    return;
}

// === PATIENCE INITIALIZATION ON CHANCELLOR CHANGE ===
const PATIENCE_START = {
    "Müller":      55, "Wels":        40, "Braun":       45,
    "Breitscheid": 30, "Hilferding":  35,
    "Thälmann":    10, "Neumann":     15, "Rosenfeld":   20,
    "Koch-Weser":  60, "Dietrich":    62, "Mahraun":     58,
    "Wirth":       55, "Joos":        60, "Horsing":     58,
    "Held":        65, "Schäffer":    68, "Drewitz":     65,
    "Hepp":        68, "Heller":      52, "Brüning":    100,
    "Kaas":        85, "Stresemann":  75, "Curtius":     80,
    "Dingeldey":   82, "Westarp":     90, "Treviranus":  88,
    "Hugenberg":   85, "Lambach":     80,
    "Papen":       95, "Schleicher":  78, "Goerdeler":   72,
};

if (Q.last_chancellor !== Q.chancellor) {
    Q.hindenburg_patience       = PATIENCE_START[Q.chancellor] ?? 70;
    Q.last_chancellor           = Q.chancellor;
    Q.chancellor_minority_ticks = 0;
    // Also clear any stale dismissal flags on new appointment
    Q.hindenburg_ready_to_dismiss  = 0;
    Q.hindenburg_patience_low      = 0;
    Q.hindenburg_patience_critical = 0;
}

// Clamp patience to valid range before computing this turn's delta
Q.hindenburg_patience = Math.max(0, Math.min(100, Q.hindenburg_patience || 70));

let patience_delta = 0;

// === UNIVERSAL DRAINS & RECOVERIES ===

// Unemployment
if      (Q.unemployed >= 25) patience_delta -= 0.3 + (Q.unemployed - 25) * 0.05;
else if (Q.unemployed >= 20) patience_delta -= 0.20;
else if (Q.unemployed >= 15) patience_delta -= 0.10;
else if (Q.unemployed >= 12) patience_delta -= 0.05;
else if (Q.unemployed <   8) patience_delta += 0.08;
else if (Q.unemployed <  10) patience_delta += 0.04;

// Deflation
if (Q.inflation < -2) patience_delta -= 0.15 * Math.abs(Q.inflation + 2);

// Growth
if      (Q.economic_growth < -2) patience_delta -= 0.12 * Math.abs(Q.economic_growth + 2);
else if (Q.economic_growth <  0) patience_delta -= 0.06;
else if (Q.economic_growth >  4) patience_delta += 0.05;

// Budget
if      (Q.budget < -3) patience_delta -= 0.10;
else if (Q.budget < -1) patience_delta -= 0.05;
else if (Q.budget >= 2) patience_delta += 0.08;
else if (Q.budget >= 0) patience_delta += 0.03;

// NSDAP surge
if      (Q.nsdap_r >= 35) patience_delta -= 0.35 + (Q.nsdap_r - 35) * 0.02;
else if (Q.nsdap_r >= 25) patience_delta -= 0.18;
else if (Q.nsdap_r >= 15) patience_delta -= 0.08;

// Presidential cabinet count
if (Q.presidential_cabinet_count >= 3) patience_delta -= 0.08;
if (Q.article_48_permanent)            patience_delta -= 0.20;

// Reichstag dissolutions
if (Q.hindenburg_reichstag_dissolutions >= 2) patience_delta -= 0.10;
if (Q.hindenburg_reichstag_dissolutions >= 3) patience_delta -= 0.15;

// === HINDENBURG-SPECIFIC MODIFIERS ===

const trust_spd_drain    = (50 - Q.hindenburg_trust_spd)    / 100;
const trust_dnvp_bonus   = (Q.hindenburg_trust_dnvp - 50)   / 200;
const trust_z_modifier   = (Q.hindenburg_trust_z - 50)      / 300;
const trust_mil_modifier = (Q.hindenburg_trust_military - 50)/ 400;

// DNVP vs Z gap
const dnvp_z_gap = (Q.dnvp_r || 0) - (Q.z_r || 0);
if      (dnvp_z_gap > 10) patience_delta -= 0.12 + (dnvp_z_gap - 10) * 0.01;
else if (dnvp_z_gap >  5) patience_delta -= 0.06;
if (Q.dnvp_line === 3)    patience_delta -= 0.15;

patience_delta += trust_dnvp_bonus;
patience_delta += trust_z_modifier;
patience_delta += trust_mil_modifier;
if (Q.reichswehr_loyalty < 0.15) patience_delta -= 0.12;

// Camarilla pressure
const camarilla = Q.camarilla_strength;
if      (camarilla >= 90) patience_delta -= 0.40;
else if (camarilla >= 75) patience_delta -= 0.25;
else if (camarilla >= 60) patience_delta -= 0.12;
else if (camarilla >= 40) patience_delta -= 0.06;

if (Q.oskar_influence     >= 60) patience_delta -= 0.15;
if (Q.papen_influence     >= 40) patience_delta -= 0.20;
if (Q.oldenburg_influence >= 50) patience_delta -= 0.10;
if (Q.schleicher_influence>= 55) patience_delta -= 0.08;

if (Q.camarilla_goal_protect_junkers    >= 75) patience_delta -= 0.20;
if (Q.camarilla_goal_destroy_parliament >= 50) patience_delta -= 0.12;
if (Q.camarilla_goal_crush_left         >= 60) patience_delta -= 0.08;

if (Q.land_reform >= 1) patience_delta -= 1.50;

const monarch_drain = (Q.hindenburg_monarchist_sentiment - 50) / 500;
patience_delta -= monarch_drain;

if (Q.osthilfe_exposed)  patience_delta -= 0.40;
if (Q.osthilfe_cover_up) patience_delta += 0.10;

if (Q.hindenburg_estate_neudeck) {
    patience_delta -= 0.15;
    if (Q.land_reform >= 1) patience_delta -= 0.50;
}

// Street violence
const street_chaos = (
    (Q.sa_strength  * Q.sa_militancy)  +
    (Q.rfb_strength * Q.rfb_militancy) +
    (Q.sh_strength  * Q.sh_militancy)
) / 1000;
if      (street_chaos >= 6)   patience_delta -= 0.25 + (street_chaos - 6) * 0.05;
else if (street_chaos >= 3)   patience_delta -= 0.12;
else if (street_chaos >= 1.5) patience_delta -= 0.05;

// Minority government fatigue
if (Q.minority_government) {
    Q.chancellor_minority_ticks += 1;
    if (Q.chancellor_minority_ticks >= 6)
        patience_delta -= 0.10 + (Q.chancellor_minority_ticks - 6) * 0.02;
} else {
    Q.chancellor_minority_ticks = 0;
}

// Article 48 overuse
if      (Q.article_48_uses >= 15) patience_delta -= 0.20;
else if (Q.article_48_uses >= 10) patience_delta -= 0.12;
else if (Q.article_48_uses >=  5) patience_delta -= 0.06;

// Crisis threshold — ONLY increments interventions, does NOT touch patience flags
Q.hindenburg_crisis_threshold += Math.max(0, -patience_delta * 0.1);
if (Q.hindenburg_crisis_threshold >= 10) {
    Q.hindenburg_crisis_threshold = 0;
    Q.hindenburg_interventions += 1;
    // Do NOT set hindenburg_ready_to_dismiss here — let patience flags do it
}

// === CHANCELLOR-SPECIFIC MODIFIERS ===
const ch = Q.chancellor;

if (["Müller","Wels","Braun","Breitscheid","Hilferding"].includes(ch)) {
    patience_delta -= 0.20 + trust_spd_drain;
    if (Q.socialism >= 45) patience_delta -= 0.15;
    if (Q.spd_r    >= 30)  patience_delta -= 0.10;
    patience_delta -= camarilla * 0.004;
    if (Q.unemployed < 10 && Q.economic_growth > 2) patience_delta += 0.10;
}

if (["Thälmann","Neumann","Rosenfeld"].includes(ch)) {
    patience_delta -= 1.20;
    if (camarilla >= 50) patience_delta -= 0.50;
}

if (ch === "Brüning") {
    if (Q.spd_toleration && !Q.spd_in_government) {
        patience_delta -= 0.30;
        if (Q.spd_r >= 25) patience_delta -= 0.10;
        if (Q.spd_r >= 30) patience_delta -= 0.10;
    }
    if (Q.spd_in_government)            patience_delta -= 0.55;
    if (Q.hindenburg_patience > 60)     patience_delta += 0.04;
    if (Q.sa_banned && Q.nsdap_r >= 20) patience_delta -= 0.30;
    if (Q.camarilla_tired_of_bruning)   patience_delta -= 0.35;
    if (Q.bruning_saved_by_spd)         patience_delta -= 0.20;
}

if (ch === "Papen") {
    patience_delta += 0.15;
    if (Q.papen_cabinet)                  patience_delta += 0.05;
    if (Q.cabinet_of_barons)              patience_delta += 0.05;
    if (Q.schleicher_papen_rivalry >= 50) patience_delta -= 0.15;
    if (Q.papen_dictatorship_attempt)     patience_delta -= 0.30;
    if (Q.minority_government)            patience_delta -= 0.10;
}

if (ch === "Schleicher") {
    patience_delta += 0.05;
    if (Q.schleicher_querfront_attempt && !Q.schleicher_querfront_success)
        patience_delta -= 0.25;
    if (Q.schleicher_querfront_success)
        patience_delta += 0.15;
    if (Q.papen_influence >= 50) patience_delta -= 0.20;
    if (Q.schleicher_cabinet)    patience_delta -= 0.05;
}

if (ch === "Wirth") {
    patience_delta -= 0.20;
    if (Q.spd_toleration) patience_delta -= 0.20;
    if (Q.z_left_wing >= 1) patience_delta -= 0.10;
}

if (ch === "Kaas") {
    patience_delta += 0.05;
    if (Q.nsdap_r >= 30) patience_delta -= 0.10;
}

if (ch === "Stresemann") {
    if (Q.reparations <= 0)   patience_delta += 0.08;
    if (Q.pro_republic >= 60) patience_delta -= 0.08;
    if (Q.west_relation >= 1) patience_delta += 0.05;
}

if (ch === "Hugenberg") {
    if (Q.economic_growth < 0)   patience_delta -= 0.15;
    if (Q.nsdap_r >= 30)         patience_delta -= 0.12;
    if (Q.hugenberg_hitler_pact) patience_delta -= 0.20;
}

if (ch === "Goerdeler") {
    if (Q.economic_growth > 1)      patience_delta += 0.08;
    if (Q.unemployed < 15)          patience_delta += 0.05;
    if (Q.goerdeler_prominence < 5) patience_delta -= 0.05;
}

if (["Westarp","Treviranus"].includes(ch)) {
    patience_delta += 0.04;
    if (Q.unemployed >= 20) patience_delta -= 0.10;
}

// === SENILITY AMPLIFIER ===
if (Q.hindenburg_senility >= 50) {
    const senility_amp = 1 + ((Q.hindenburg_senility - 50) / 50) * 0.6;
    patience_delta *= senility_amp;
}

// Age-based health decline
Q.hindenburg_age = 78 + Math.max(0, Q.year - 1925);
if (Q.hindenburg_age >= 84) {
    Q.hindenburg_health = Math.max(0, (Q.hindenburg_health || 100) - 0.05);
}

// Universal recovery for non-SPD government
if (!Q.spd_in_government && !Q.spd_toleration &&
    (Q.z_in_government || Q.dvp_in_government || Q.dnvp_in_government)) {
    patience_delta += 0.10;
}
if (Q.dvp_in_government || Q.z_in_government) patience_delta += 0.05;

if (Q.wtb_timer > 0) patience_delta += 0.45;

// === APPLY & CLAMP ===
Q.hindenburg_patience = Math.max(0, Math.min(100,
    Q.hindenburg_patience + patience_delta
));

// === SET FLAGS ===
// Clamp patience to exactly 0 before flagging — prevents negative values
// triggering both "Presidential Intervention" (< 0) and "The Dismissal" (= 0)
Q.hindenburg_patience_low      = Q.hindenburg_patience <= 25 ? 1 : 0;
Q.hindenburg_patience_critical = Q.hindenburg_patience <= 10 ? 1 : 0;

// Only set ready_to_dismiss if patience is truly exhausted AND no cooldown active
Q.hindenburg_ready_to_dismiss = (
    Q.hindenburg_patience <= 0 ) ? 1 : 0;

}


























// ============================================================
// BILL SYSTEM — POST EVENT TICK (v3)
//
// Single flat bill pool ordered socialist → völkisch.
// Parties select from it based on ideology window + affinity.
// Bills are not owned by any party; any eligible party can
// push any bill that falls within their ideological range.
// ============================================================


// ============================================================
// SECTION A: GLOBAL BILL POOL
//
// base_ideo : 1 (communist) → 10 (völkisch)
// affinity  : thematic tags for party affinity scoring
// cooldown  : turns before bill can re-enter queue (25–60)
// push_weight: base probability weight before modifiers
// ============================================================

var BILLS = [

    // ── FAR LEFT (ideo 1) ────────────────────────────────────
    { id: 'socialisation',      name: 'Socialisation of Heavy Industry',
      type: 'economic', base_ideo: 1, affinity: ['labor','socialist'],
