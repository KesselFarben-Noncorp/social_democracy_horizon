      type: 'welfare',  base_ideo: 9, affinity: ['conservative','nationalist'],
      timer: 25, push_weight: 0.14, ministry: 'finance',     cooldown: 35,
      on_pass: function() { Q.welfare=Math.max(-2,(Q.welfare||0)-1); Q.workers_aid=Math.max(0,(Q.workers_aid||0)-1); } },

    { id: 'treaty_rejection',   name: 'Treaty Obligations Rejection Motion',
      type: 'foreign',  base_ideo: 9, affinity: ['nationalist','volkisch'],
