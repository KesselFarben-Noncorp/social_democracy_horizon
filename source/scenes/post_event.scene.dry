    { id: 'grain_tariff',       name: 'Emergency Grain Tariff',
      type: 'economic', base_ideo: 7, affinity: ['agrarian','conservative'],
      timer: 25, push_weight: 0.16, ministry: 'agriculture', cooldown: 30,
      on_pass: function() { Q.agricultural_finance=(Q.agricultural_finance||0)+1; } },

    { id: 'rural_debt',         name: 'Rural Debt Moratorium',
      type: 'economic', base_ideo: 7, affinity: ['agrarian','conservative'],
      timer: 35, push_weight: 0.14, ministry: 'agriculture', cooldown: 40,
      on_pass: function() { Q.land_reform=(Q.land_reform||0)+1; Q.agricultural_finance=(Q.agricultural_finance||0)+1; } },

    // ── NATIONALIST RIGHT (ideo 8–9) ─────────────────────────
    { id: 'eastern_settlement',  name: 'Eastern Settlement Programme',
      type: 'economic', base_ideo: 8, affinity: ['agrarian','nationalist'],
      timer: 40, push_weight: 0.10, ministry: 'agriculture', cooldown: 40,
      on_pass: function() { Q.land_reform=(Q.land_reform||0)+1; } },

    { id: 'anti_marxist_law',   name: 'Anti-Marxist Emergency Law',
      type: 'civil',    base_ideo: 9, affinity: ['nationalist','conservative'],
      timer: 30, push_weight: 0.16, ministry: 'interior',    cooldown: 40,
      on_pass: function() { Q.rfb_banned=1; Q.workers_aid=Math.max(0,(Q.workers_aid||0)-1); } },

    { id: 'industry_tariff',    name: 'Heavy Industry Tariff Wall',
