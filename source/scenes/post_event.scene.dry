    // ── VÖLKISCH FAR RIGHT (ideo 10) ─────────────────────────
    { id: 'civil_liberties_ban',name: 'Suppression of Civil Liberties Act',
      type: 'civil',    base_ideo: 10, affinity: ['nationalist','volkisch'],
      timer: 30, push_weight: 0.20, ministry: 'interior',    cooldown: 40,
