on-arrival: {!
// set up the infrastructure
Q.srpd_formed = 1;
Q.parties.push('srpd');

Q.workers_srpd = 8;
Q.workers_spd -= 2;
Q.new_middle_srpd = 4;
Q.old_middle_srpd = 3;
Q.rural_srpd = 0;
Q.unemployed_srpd = 1;
Q.catholics_srpd = 1;

Q.workers_other -= 5;

// update all records
Q.srpd_r = 0;
Q.old_srpd_r = 0;
for (var record of Q.election_records) {
    record['srpd'] = 0;
}
for (var record of Q.party_support_records) {
    record['srpd'] = 0;
}
!}
