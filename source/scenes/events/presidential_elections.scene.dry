title: Presidential Election
subtitle: The presidential term has ended
new-page: true
view-if: (year = next_presidential_election_year and month >= next_presidential_election_month) or (year > next_presidential_election_year)
on-arrival: presidential_election_active = 1; round = 0; last_presidential_election = year;
max-visits: 999
tags: event

= Presidential Election

[? if president : The term of President [+ president +] has ended. ?][? if not president : Germany requires a new president. ?]

Presidential elections will be held. If no candidate receives a majority in the first round, the top two candidates will advance to a runoff election.

All major parties are preparing their candidates for the race.

- @party_candidates: Who are the candidates?

@party_candidates
on-arrival: {!
    // === INITIALIZE VARIABLES ===
    Q.is_unity_candidate = 0;
    Q.is_cultural_candidate = 0;
    
    // Reset all candidate variables
    var all_candidates = ["Hitler", "Göring", "Goring", "Seldte", "Westarp", "Eckener", "Adenauer", 
                          "Kaas", "Gessler", "Stresemann", "Thälmann", "Thalmann", "Münzenberg", 
                          "Munzenberg", "Braun", "Schumacher", "Juchacz", "Einstein", "Mann", 
                          "Ossietzky", "Rosenfeld", "Schäffer", "Schaffer", "Drewitz", "Horsing", "Hamkens", "Behrens"];
    for (var i = 0; i < all_candidates.length; i++) {
        Q[all_candidates[i] + '_bonus'] = 0;
        Q[all_candidates[i] + '_running'] = 0;
    }
    
    // === NSDAP (NAZIS) ===
    if (Q.nsdap_banned) {
        // If NSDAP is banned, no candidate at all
        Q.nsdap_candidate = null;
    } else if (Q.hitler_dead) {
        Q.nsdap_candidate = "Goebbels";
    } else if (Q.hitler_deported) {
        Q.nsdap_candidate = "Göring";
    } else {
        Q.nsdap_candidate = "Hitler";
    }
    
    // === DNVP (NATIONALISTS) ===
    if (Q.dnvp_banned) {
        // If banned, no candidate
        Q.dnvp_candidate = null;
    } else if (Q.dnvp_line === 1) {
        // Moderate nationalist line
        Q.dnvp_candidate = "Westarp";
    } else if (Q.nsdap_banned) {
        // If NSDAP is banned, DNVP can't support them
        Q.dnvp_candidate = "Seldte";
    } else if (Q.dnvp_relation_nsdap >= 60) {
        // Strong Nazi alliance
        Q.dnvp_candidate = Q.nsdap_candidate;
    } else if (Q.dnvp_relation_nsdap >= 40 && Q.nsdap_r >= Q.dnvp_r) {
        // Moderate Nazi alliance, Nazis stronger
        Q.dnvp_candidate = Q.nsdap_candidate;
    } else {
        // Independent DNVP candidate
        Q.dnvp_candidate = "Seldte";
    }
    
    // === KPD (COMMUNISTS) ===
    if (Q.kpd_banned) {
        Q.kpd_candidate = null;
    } else if (Q.kpd_party_leader === "Conciliators") {
        Q.kpd_candidate = "Münzenberg";
    } else if (Q.kpd_party_leader === "Thälmann") {
        Q.kpd_candidate = "Thälmann";
    } else {
        Q.kpd_candidate = "Thälmann"; // Default
    }
    
    // === Z (CENTER PARTY) ===
    // Will be set after SPD chooses, as they might support unity candidate
    Q.z_candidate = null;
    if (Q.z_party_leader === "Kaas") {
        Q.z_default_candidate = "Kaas";
    } else if (Q.z_party_leader === "Joos") {
        Q.z_default_candidate = "Adenauer";
    } else if (Q.z_party_leader === "Brüning") {
        Q.z_default_candidate = "Brüning";
    } else {
        Q.z_default_candidate = "Adenauer";
    }
    
    // === BVP (BAVARIAN PEOPLE'S PARTY) ===
    // Will follow Z or go independent
    Q.bvp_candidate = null;
    Q.bvp_default_candidate = "Schäffer"; // Franz Schäffer, BVP leader
    
    // === DVP (PEOPLE'S PARTY) ===
    if (!Q.stresemann_dead && Q.year <= 1929) {
        Q.dvp_default_candidate = "Stresemann";
    } else if (Q.dvp_relation >= 45) {
        Q.dvp_default_candidate = null; // Will support unity/SPD
    } else {
        Q.dvp_default_candidate = "Gessler";
    }
    Q.dvp_candidate = null;

    // === CNBL (CHRISTLICH-NATIONALER BAUERN- UND LANDVOLKPARTEI) ===
    if (Q.cnbl_r && Q.cnbl_r > 1.5) { // Only if they have meaningful representation
        if (Q.agricultural_finance && Q.agricultural_finance < 2) {
            // Deep agricultural crisis - run own protest candidate
            Q.cnbl_candidate = "Hamkens"; // Wilhelm Hamkens, agricultural specialist
        } else if (Q.land_reform >= 2 || Q.pro_consumer >= 2) {
            // Hostile policies toward landowners - run own candidate in opposition
            Q.cnbl_candidate = "Hamkens";
        } else if (Q.state_buyer = 1 && Q.agricultural_finance >= 1) {
            // Government helping agriculture - might support establishment
            if (Q.dnvp_candidate && Q.dnvp_line !== 3 && !Q.dnvp_banned) {
                // Support moderate DNVP (traditional conservatives)
                Q.cnbl_candidate = Q.dnvp_candidate;
            } else if (Q.z_candidate && Q.bvp_candidate) {
                // Catholic agrarians acceptable
                Q.cnbl_candidate = Q.z_candidate;
            } else {
                // Still run own but weakly
                Q.cnbl_candidate = "Behrens"; // Wilhelm Behrens, Landvolk leader
            }
        } else if (Q.dnvp_line === 3 && Q.nsdap_r >= 12 && !Q.nsdap_banned) {
            // Hugenberg DNVP + strong Nazis = rural radicalization
            // Split between staying independent or going Nazi
            if (Q.year >= 1932) {
                Q.cnbl_candidate = Q.nsdap_candidate; // Absorbed into Nazi movement
            } else {
                Q.cnbl_candidate = "Behrens"; // Still independent protest
            }
        } else if (Q.dnvp_candidate && Q.dnvp_line !== 3 && !Q.dnvp_banned) {
            // Default: align with moderate conservative-nationalists
            Q.cnbl_candidate = Q.dnvp_candidate;
        } else {
            // Independent agrarian protest candidate
            Q.cnbl_candidate = "Hamkens";
        }
    } else {
        // Too small - fold into conservative camp (but check if those are banned)
        if (!Q.dnvp_banned) {
            Q.cnbl_candidate = Q.dnvp_candidate;
        } else {
            Q.cnbl_candidate = Q.bvp_candidate;
        }
    }

    // === WP (WIRTSCHAFTSPARTEI / ECONOMIC PARTY) ===
    if (Q.wp_r && Q.wp_r > 2) { // Only if they have meaningful representation
        if (Q.capital_strike_progress >= 5 || Q.inflation >= 6) {
            // During crisis, run own candidate
            Q.wp_candidate = "Drewitz"; // Max Drewitz, WP leader
        } else if (Q.dvp_candidate && Q.dvp_relation >= 40) {
            // Usually align with DVP (liberal economics)
            Q.wp_candidate = Q.dvp_candidate;
        } else if (Q.ddp_candidate === "Gessler") {
            // Support liberal centrists
            Q.wp_candidate = "Gessler";
        } else {
            // Independent middle-class candidate
            Q.wp_candidate = "Drewitz";
        }
    } else {
        Q.wp_candidate = Q.dvp_candidate || Q.ddp_candidate; // Fold into liberals
    }
    
    // === DDP/DStP (DEMOCRATS) ===
    if (Q.ddp_relation >= 40) {
        Q.ddp_default_candidate = null; // Will support unity/SPD
    } else {
        Q.ddp_default_candidate = "Gessler";
    }
    Q.ddp_candidate = null;
    
    // === SAPD (SOCIALIST WORKERS' PARTY) ===
    if (Q.sapd_formed) {
        if (Q.kpd_relation >= 60 && Q.spd_sapd_relation < 40 && !Q.kpd_banned) {
            Q.sapd_candidate = Q.kpd_candidate;
        } else {
            Q.sapd_candidate = "Rosenfeld"; // Default SAPD candidate
        }
    } else {
        Q.sapd_candidate = null;
    }

    // === SRPD (SOCIAL REPUBLICANS) ===
    if (Q.srpd_formed) {
        if (Q.ddp_relation >= 60 && Q.z_relation >= 60) {
            Q.srpd_candidate = Q.spd_candidate;
        } else {
            Q.srpd_candidate = "Horsing"; // Default SRPD candidate
        }
    } else {
        Q.srpd_candidate = null;
    }

    
    // === OTHER PARTIES ===
    // Other parties default to conservative, but not if conservatives are banned
    if (!Q.dnvp_banned) {
        Q.other_candidate = "Seldte";
    } else if (!Q.nsdap_banned) {
        Q.other_candidate = Q.nsdap_candidate;
    } else {
        Q.other_candidate = "Gessler"; // Liberal fallback
    }
!}

The parties are preparing their candidates:

