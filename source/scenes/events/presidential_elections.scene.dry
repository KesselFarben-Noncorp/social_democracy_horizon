[? if Horsing_running: "Otto Hörsing - [+ Horsing_votes_disp +]% ?]

[? if Hamkens_running: "Hamkens - [+ Hamkens_votes_disp +]% ?]

[? if Behrens_running: "Behrens - [+ Behrens_votes_disp +]% ?]

@r2_start
on-arrival: {!
    // === ROUND 2 CONSOLIDATION ===
    
    var finalists = [Q.round1_winner, Q.round1_runner_up];
    
    // Ideological blocks for consolidation logic
    var far_left = ["Thälmann", "Thalmann", "Münzenberg", "Munzenberg"];
    var left = ["Braun", "Schumacher", "Juchacz", "Rosenfeld"];
    var center_left = ["Eckener", "Gessler", "Stresemann", "Horsing"];
    var center = ["Adenauer", "Kaas", "Brüning", "Bruning"];
    var center_right = ["Schäffer", "Schaffer", "Westarp", "Drewitz", "Hamkens", "Behrens"];
    var far_right = ["Hitler", "Göring", "Goring", "Goebbels", "Seldte"];
    var cultural = ["Einstein", "Mann", "Ossietzky"];
    
    function isInBlock(candidate, block) {
        return block.indexOf(candidate) !== -1;
    }
    
    function getIdeologicalDistance(candidate1, candidate2) {
        var blocks = [far_left, left, cultural, center_left, center, center_right, far_right];
        var pos1 = -1, pos2 = -1;
        
        for (var i = 0; i < blocks.length; i++) {
            if (isInBlock(candidate1, blocks[i])) pos1 = i;
            if (isInBlock(candidate2, blocks[i])) pos2 = i;
        }
        
        return Math.abs(pos1 - pos2);
    }
    
    // === FAR-RIGHT CONSOLIDATION ===
    // NSDAP and DNVP always consolidate in round 2
    if (Q.nsdap_candidate !== Q.dnvp_candidate) {
        var nsdap_in_runoff = finalists.indexOf(Q.nsdap_candidate) !== -1;
        var dnvp_in_runoff = finalists.indexOf(Q.dnvp_candidate) !== -1;
        
        if (nsdap_in_runoff && !dnvp_in_runoff) {
            Q.dnvp_candidate = Q.nsdap_candidate;
            Q.other_candidate = Q.nsdap_candidate;
        } else if (dnvp_in_runoff && !nsdap_in_runoff) {
            Q.nsdap_candidate = Q.dnvp_candidate;
        } else if (!nsdap_in_runoff && !dnvp_in_runoff) {
            // Both eliminated, support whoever is closest ideologically
            var nsdap_votes = Q[Q.nsdap_candidate + '_votes'] || 0;
            var dnvp_votes = Q[Q.dnvp_candidate + '_votes'] || 0;
            
            if (nsdap_votes > dnvp_votes) {
                // NSDAP had more votes, they choose
                if (isInBlock(finalists[0], far_right) || isInBlock(finalists[0], center_right)) {
                    Q.nsdap_candidate = finalists[0];
                    Q.dnvp_candidate = finalists[0];
                } else if (isInBlock(finalists[1], far_right) || isInBlock(finalists[1], center_right)) {
                    Q.nsdap_candidate = finalists[1];
                    Q.dnvp_candidate = finalists[1];
                } else {
                    // Both finalists are left-wing, reluctantly pick less-left
                    Q.nsdap_candidate = finalists[0];
                    Q.dnvp_candidate = finalists[0];
                }
            } else {
                // DNVP chooses
                if (isInBlock(finalists[0], far_right) || isInBlock(finalists[0], center_right) || isInBlock(finalists[0], center)) {
                    Q.dnvp_candidate = finalists[0];
                    Q.nsdap_candidate = finalists[0];
                } else {
                    Q.dnvp_candidate = finalists[1];
                    Q.nsdap_candidate = finalists[1];
                }
            }
        }
    }
    
    // === OTHER PARTIES CONSOLIDATE ===
    
    // Function to pick closest finalist
    function pickClosestFinalist(current_candidate, party_ideology_priority) {
        if (finalists.indexOf(current_candidate) !== -1) {
            return current_candidate; // Already in runoff
        }
        
        // Pick based on ideological priority
        for (var i = 0; i < party_ideology_priority.length; i++) {
            var preferred_block = party_ideology_priority[i];
            
            for (var j = 0; j < finalists.length; j++) {
                if (isInBlock(finalists[j], preferred_block)) {
                    return finalists[j];
                }
            }
        }
        
        // Fallback: pick closest by distance
        var dist0 = getIdeologicalDistance(current_candidate, finalists[0]);
        var dist1 = getIdeologicalDistance(current_candidate, finalists[1]);
        
        return dist0 <= dist1 ? finalists[0] : finalists[1];
    }
    
    // === Z (CENTER) ===
    if (Q.z_party_leader === "Kaas") {
        // Right-wing Z
        Q.z_candidate = pickClosestFinalist(Q.z_candidate, [center, center_right, center_left, far_right]);
    } else {
        // Moderate Z
        Q.z_candidate = pickClosestFinalist(Q.z_candidate, [center, center_left, left, center_right]);
    }
    
    // === BVP ===
    Q.bvp_candidate = pickClosestFinalist(Q.bvp_candidate, [center_right, center, far_right, center_left]);
    
    // === DVP ===
    Q.dvp_candidate = pickClosestFinalist(Q.dvp_candidate, [center_left, center, center_right, left]);
    
    // === DDP ===
    Q.ddp_candidate = pickClosestFinalist(Q.ddp_candidate, [center_left, center, left, cultural]);
    
    // === KPD ===
    Q.kpd_candidate = pickClosestFinalist(Q.kpd_candidate, [far_left, left, cultural]);
    
    // === SAPD ===
    if (Q.sapd_formed) {
        Q.sapd_candidate = pickClosestFinalist(Q.sapd_candidate, [left, far_left, cultural, center_left]);
    }

    // SRPD

    if (Q.srpd_formed) {
        Q.srpd_candidate = pickClosestFinalist(Q.srpd_candidate, [center_left, center, center_right, left, far_left]);
    }

    // === WP (ECONOMIC PARTY) ===
    if (Q.wp_candidate) {
        Q.wp_candidate = pickClosestFinalist(Q.wp_candidate, [center_right, center, center_left, far_right, left]);
    }

    // === CNBL ===
    if (Q.cnbl_candidate) {
        Q.cnbl_candidate = pickClosestFinalist(Q.cnbl_candidate, [center_right, center, far_right, center_left, left]);
    }
    
    // === OTHER ===
    Q.other_candidate = pickClosestFinalist(Q.other_candidate, [far_right, center_right, center]);
!}

**Second Round Runoff**

No candidate achieved a majority in the first round. The top two candidates advance:

**[+ round1_winner +]** - [+ round1_winner_votes +]%
**[+ round1_runner_up +]** - [+ round1_runner_up_votes +]%

---

**All eliminated candidates' supporters must now choose:**

**Far Right:**
[? if nsdap_candidate != round1_winner and nsdap_candidate != round1_runner_up : - NSDAP (was: [+ nsdap_candidate +]) → Now supporting: **[+ nsdap_candidate +]** ?]
[? if nsdap_candidate = round1_winner or nsdap_candidate = round1_runner_up : - NSDAP: **[+ nsdap_candidate +]** (in runoff) ?]

[? if dnvp_candidate != round1_winner and dnvp_candidate != round1_runner_up and dnvp_candidate != nsdap_candidate : - DNVP (was: [+ dnvp_candidate +]) → Now supporting: **[+ dnvp_candidate +]** ?]
[? if dnvp_candidate = round1_winner or dnvp_candidate = round1_runner_up : - DNVP: **[+ dnvp_candidate +]** (in runoff) ?]
[? if dnvp_candidate = nsdap_candidate : - DNVP: Supporting **[+ nsdap_candidate +]** (far-right united) ?]

**Left:**
[? if kpd_candidate != round1_winner and kpd_candidate != round1_runner_up : - KPD (was: [+ kpd_candidate +]) → Now supporting: **[+ kpd_candidate +]** ?]
[? if kpd_candidate = round1_winner or kpd_candidate = round1_runner_up : - KPD: **[+ kpd_candidate +]** (in runoff) ?]

[? if sapd_formed and sapd_candidate != round1_winner and sapd_candidate != round1_runner_up : - SAPD (was: [+ sapd_candidate +]) → Now supporting: **[+ sapd_candidate +]** ?]
[? if sapd_formed and (sapd_candidate = round1_winner or sapd_candidate = round1_runner_up) : - SAPD: **[+ sapd_candidate +]** (in runoff) ?]

**SPD:**
[? if spd_candidate != round1_winner and spd_candidate != round1_runner_up : - **SPD (was: [+ spd_candidate +]) → Now supporting: [+ spd_candidate +]** ?]
[? if spd_candidate = round1_winner or spd_candidate = round1_runner_up : - **SPD: [+ spd_candidate +] (in runoff)** ?]

[? if srpd_formed and srpd_candidate != round1_winner and srpd_candidate != round1_runner_up : - SRPD (was: [+ srpd_candidate +]) → Now supporting: **[+ srpd_candidate +]** ?]

**Center/Liberal:**
[? if z_candidate != round1_winner and z_candidate != round1_runner_up : - Z (was: [+ z_candidate +]) → Now supporting: **[+ z_candidate +]** ?]
[? if z_candidate = round1_winner or z_candidate = round1_runner_up : - Z: **[+ z_candidate +]** (in runoff) ?]

[? if bvp_candidate != round1_winner and bvp_candidate != round1_runner_up : - BVP (was: [+ bvp_candidate +]) → Now supporting: **[+ bvp_candidate +]** ?]
[? if bvp_candidate = round1_winner or bvp_candidate = round1_runner_up : - BVP: **[+ bvp_candidate +]** (in runoff) ?]

[? if ddp_candidate != round1_winner and ddp_candidate != round1_runner_up : - [+ ddp_name +] (was: [+ ddp_candidate +]) → Now supporting: **[+ ddp_candidate +]** ?]
[? if ddp_candidate = round1_winner or ddp_candidate = round1_runner_up : - [+ ddp_name +]: **[+ ddp_candidate +]** (in runoff) ?]

[? if dvp_candidate != round1_winner and dvp_candidate != round1_runner_up : - DVP (was: [+ dvp_candidate +]) → Now supporting: **[+ dvp_candidate +]** ?]
[? if dvp_candidate = round1_winner or dvp_candidate = round1_runner_up : - DVP: **[+ dvp_candidate +]** (in runoff) ?]

[? if wp_candidate != round1_winner and wp_candidate != round1_runner_up : - WP (was: [+ wp_candidate +]) → Now supporting: **[+ wp_candidate +]** ?]
[? if wp_candidate = round1_winner or wp_candidate = round1_runner_up : - WP: **[+ wp_candidate +]** (in runoff) ?]

[? if cnbl_candidate != round1_winner and cnbl_candidate != round1_runner_up : - CNBL (was: [+ cnbl_candidate +]) → Now supporting: **[+ cnbl_candidate +]** ?]
[? if cnbl_candidate = round1_winner or cnbl_candidate = round1_runner_up : - CNBL: **[+ cnbl_candidate +]** (in runoff) ?]

---

**Current Projected Second Round:**

[? if spd_candidate = round1_winner or z_candidate = round1_winner or ddp_candidate = round1_winner or dvp_candidate = round1_winner or bvp_candidate = round1_winner : **[+ round1_winner +]** is projected to have: SPD [? if spd_candidate = round1_winner : ✓ ?], Z [? if z_candidate = round1_winner : ✓ ?], [+ ddp_name +] [? if ddp_candidate = round1_winner : ✓ ?], DVP [? if dvp_candidate = round1_winner : ✓ ?], BVP [? if bvp_candidate = round1_winner : ✓ ?], WP [? if wp_candidate = round1_winner : ✓ ?] ?]

[? if spd_candidate = round1_runner_up or z_candidate = round1_runner_up or ddp_candidate = round1_runner_up or dvp_candidate = round1_runner_up or bvp_candidate = round1_runner_up : **[+ round1_runner_up +]** is projected to have: SPD [? if spd_candidate = round1_runner_up : ✓ ?], Z [? if z_candidate = round1_runner_up : ✓ ?], [+ ddp_name +] [? if ddp_candidate = round1_runner_up : ✓ ?], DVP [? if dvp_candidate = round1_runner_up : ✓ ?], BVP [? if bvp_candidate = round1_runner_up : ✓ ?], WP [? if wp_candidate = round1_runner_up : ✓ ?] ?

