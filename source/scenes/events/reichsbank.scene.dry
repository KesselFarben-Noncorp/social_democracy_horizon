title: Schacht's Resignation
subtitle: The Reichsbank President Departs
new-page: true
view-if: year = 1930 and month = 3 and (schacht_exposed = 1 or (finance_minister = "Moldenhauer" and (unemployed >= 12 or inflation <= -3))) and schacht_plan_adopted != 1
