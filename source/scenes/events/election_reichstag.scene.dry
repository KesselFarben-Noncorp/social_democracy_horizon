title: Reichstag Elections
new-page: true
tags: event
priority: -2
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year)
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 4; n_elections += 1; next_election_time = time + 48; papen_chancellor_timer = 4;
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

= Elections, [+ month : month +] [+ year +]

The Reichstag elections are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-arrival: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; dvp_relation -= 8; z_relation -= 8; ddp_relation -= 10; kpd_relation -= 8; coup_progress += 2; workers_spd -= 4; new_middle_spd -= 5; old_middle_spd -= 5; rural_spd -= 5; catholics_spd -= 5; unemployed_spd -= 5; coup_progress += 2 if nsdap_normalized >= 0.3; coup_progress += 2 if nsdap_normalized + dnvp_normalized >= 0.5; sa_strength += 100 if coup_progress >= 7; sh_strength += 100 if coup_progress >= 7
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

@post_election_1928
on-arrival: {!
var new_party_sum = 0;

// Calculate election results
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'] ?? 0;
    
    // Handle banned parties - set support to 0
    if (Q[party + '_banned']) {
        Q[party + '_support'] = 0;
    }
    
    if (Q.constitutional_reform > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || 
            (Q.electoral_threshold > 1 && party === 'other') ||
            Q[party + '_banned']) {
            Q[party + '_support'] = 0;
        }
    }
    
    if (Q.math_broken) {
        // CHAOS MODE: Support values become nonsense
        Q[party + '_support'] = Q.impossible_add(Q[party + '_support'], 0);
    }
    
    new_party_sum += Q[party + '_support'];
}

// Apply chaos to the sum itself
if (Q.math_broken) {
    new_party_sum = Q.impossible_multiply(new_party_sum, 1);
}

for (var party of Q.parties) {
    // If party is banned, force everything to 0
    if (Q[party + '_banned'] && !Q.math_broken) {
        Q[party + '_r'] = 0;
        Q[party + '_votes'] = 0;
    } else if (!Q.math_broken) {
        // NORMAL: Votes sum to 100%
        if (new_party_sum > 0) {
            Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
        } else {
            Q[party + '_r'] = 0;
        }
        Q[party + '_votes'] = Math.round(Q[party + '_r'] * 10) / 10;
    } else {
        // CHAOS MODE: Division doesn't work properly
        if (new_party_sum > 0) {
            // Random choice of broken operations
            var roll = Math.random();
            if (roll < 0.3) {
                // Normal (rare)
                Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
            } else if (roll < 0.5) {
                // Multiplication instead of division
                Q[party + '_r'] = Q.impossible_multiply(Q[party + '_support'], new_party_sum / 100);
            } else if (roll < 0.7) {
                // Just add some chaos
                Q[party + '_r'] = Q.impossible_percentage(Q[party + '_support']);
            } else {
                // Complete nonsense
                Q[party + '_r'] = Q.impossible_add(Q[party + '_support'], new_party_sum);
            }
        } else {
            Q[party + '_r'] = Q.impossible_subtract(0, 0); // "Zero" that isn't zero
        }
        
        // Votes calculation also broken
        Q[party + '_votes'] = Q.impossible_multiply(Q[party + '_r'], 1);
        
        // Ensure no NaN
        if (isNaN(Q[party + '_r'])) Q[party + '_r'] = Math.random() * 50;
        if (isNaN(Q[party + '_votes'])) Q[party + '_votes'] = Math.random() * 50;
    }
}

for (var party of Q.parties) {
    if (!Q.math_broken) {
        // NORMAL: Display formatting
        if (Q.use_decimals) {
            Q[party + '_r_disp'] = (Math.ceil(Q[party + '_r'] * 10) / 10).toFixed(1);
        } else {
            Q[party + '_r_disp'] = Math.round(Q[party + '_r']).toString();
        }
        
        Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
        Q['str_change_' + party] = (Q['change_' + party + '_r'] >= 0 ? '+' : '') +
            (Math.ceil(Q['change_' + party + '_r'] * 10) / 10).toFixed(1);
    } else {
        // CHAOS MODE: Display formatting is also broken
        if (Q.use_decimals) {
            Q[party + '_r_disp'] = Q.impossible_add(Q[party + '_r'], 0).toFixed(1);
        } else {
            Q[party + '_r_disp'] = Math.round(Q.impossible_multiply(Q[party + '_r'], 1)).toString();
        }
        
        // Change calculation doesn't work right
        Q['change_' + party + '_r'] = Q.impossible_subtract(Q[party + '_r'], Q['old_' + party + '_r']);
        
        // Ensure no NaN in change
        if (isNaN(Q['change_' + party + '_r'])) Q['change_' + party + '_r'] = Math.random() * 20 - 10;
        
        // Sign might be wrong
        var broken_sign = Math.random() < 0.3 ? '-' : '+';
        if (Math.random() < 0.5) {
            // Sometimes use correct sign
            broken_sign = (Q['change_' + party + '_r'] >= 0 ? '+' : '');
        }
        
        Q['str_change_' + party] = broken_sign +
            Q.impossible_add(Q['change_' + party + '_r'], 0).toFixed(1);
    }
}

// Reset government flags
Q.coalition_dissent = 0;
Q.kpd_coalition_dissent = 0;
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.spd_toleration = 0;
Q.in_bourgeois_coalition = 0;
Q.in_right_coalition = 0;
Q.in_social_christian_coalition = 0;
Q.in_social_liberal_coalition = 0;

// Reset KPD goals
Q.kpd_goals_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labor_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.reichswehr_goal = 0;

// ============================================
// COMPREHENSIVE PARTY RELATIONSHIP MATRIX
// ============================================

Q.party_relations = {
    
    // === KPD (Communists) ===
    KPD: {
        SAPD: 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD: Q.kpd_relation,
        SRPD: Q.kpd_relation - 10,
        DDP: 15,
        Z: 10,
        BVP: 5,
        DVP: 5,
        WP: 5,
        CNBL: 0,
        CSVD: 0,  // Added
        DNVP: 0,
        NSDAP: 0
    },
    
    // === SAPD (Left Socialists) ===
    SAPD: {
        KPD: 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD: 50 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD: 55,
        DDP: 35,
        Z: 30,
        BVP: 25,
        DVP: 20,
        WP: 15,
        CNBL: 15,
        CSVD: 20,  // Added - some respect for Christian social values
        DNVP: 10,
        NSDAP: 0
    },
    
    // === SPD (Social Democrats) ===
    SPD: {
        KPD: Q.kpd_relation,
        SAPD: 50 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD: 65,
        DDP: Q.ddp_relation,
        Z: Q.z_relation,
        BVP: Q.bvp_relation || 40,
        DVP: Q.dvp_relation,
        WP: Q.wp_relation || 30,
        CNBL: Q.cnbl_relation || 25,
        CSVD: Q.csvd_relation || 35,  // Added - could work with moderate conservatives
        DNVP: Q.dnvp_relation,
        NSDAP: Q.nsdap_relation || 5
    },
    
    // === SRPD (Reformist Socialists - if formed) ===
    SRPD: {
        KPD: Q.kpd_relation - 10,
        SAPD: 55,
        SPD: 65,
        DDP: Q.ddp_relation + 10,
        Z: Q.z_relation + 5,
        BVP: (Q.bvp_relation || 40) + 5,
        DVP: Q.dvp_relation - 5,
        WP: (Q.wp_relation || 30) - 5,
        CNBL: (Q.cnbl_relation || 25) + 5,
        CSVD: (Q.csvd_relation || 35) + 5,  // Added - both are moderate splinter parties
        DNVP: Q.dnvp_relation - 10,
        NSDAP: 0
    },
    
    // === DDP (Liberals) ===
    DDP: {
        KPD: 15,
        SAPD: 35,
        SPD: Q.ddp_relation,
        SRPD: Q.ddp_relation + 10,
        Z: 70,
        BVP: 60,
        DVP: 65 - (Q.dvp_right_shift || 0) * 8,
        WP: 55,
        CNBL: 45,
        CSVD: 60,  // Added - both moderate, pro-constitutional, anti-extremist
        DNVP: Q.dnvp_line === 3 ? 15 : 35,
        NSDAP: 10
    },
    
    // === Z (Center Party) ===
    Z: {
        KPD: 10,
        SAPD: 30,
        SPD: Q.z_relation,
        SRPD: Q.z_relation + 5,
        DDP: 70,
        BVP: 80,
        DVP: 60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        WP: 50,
        CNBL: 30,
        CSVD: 55,  // Added - both Christian parties, but confessional divide (Catholic vs Protestant)
        DNVP: (Q.dnvp_line === 3 ? 25 : 50) + (Q.z_party_leader === "Kaas" ? 10 : -10),
        NSDAP: Math.max(5, 30 - Q.nazi_urgency * 4)
    },
    
    // === BVP (Bavarian People's Party) ===
    BVP: {
        KPD: 5,
        SAPD: 25,
        SPD: Q.bvp_relation || 40,
        SRPD: (Q.bvp_relation || 40) + 5,
        DDP: 60,
        Z: 80,
        DVP: 55,
        WP: 45,
        CNBL: 65,
        CSVD: 50,  // Added - both Christian conservatives, but Catholic-Protestant divide
        DNVP: 50,
        NSDAP: 25 - (Q.nazi_urgency * 2)
    },
    
    // === DVP (People's Party) ===
    DVP: {
        KPD: 5,
        SAPD: 20,
        SPD: Q.dvp_relation,
        SRPD: Q.dvp_relation - 5,
        DDP: 65 - (Q.dvp_right_shift || 0) * 8,
        Z: 60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        BVP: 55,
        WP: 70,
        CNBL: 30,
        CSVD: 55,  // Added - moderate bourgeois parties, potential coalition
        DNVP: 50 + (Q.dvp_right_shift || 0) * 15,
        NSDAP: 25 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift || 0) * 10
    },
    
    // === WP (Business Party) ===
    WP: {
        KPD: 5,
        SAPD: 15,
        SPD: Q.wp_relation || 30,
        SRPD: (Q.wp_relation || 30) - 5,
        DDP: 55,
        Z: 50,
        BVP: 45,
        DVP: 70,
        CNBL: 40,
        CSVD: 50,  // Added - both bourgeois parties
        DNVP: 45,
        NSDAP: 30 + (Q.capital_strike_progress * 3)
    },

    // === CNBL (Agrarian League) ===
    CNBL: {
        KPD: 5,
        SAPD: 15,
        SPD: Q.cnbl_relation || 25,
        SRPD: (Q.cnbl_relation || 25) + 5,
        DDP: 35,
        Z: 40,
        BVP: 55,
        DVP: 35,
        WP: 40,
        CSVD: 45,  // Added - both conservative, rural base overlap
        DNVP: 40,
        NSDAP: 20 + (Q.capital_strike_progress * 3)
    },
    
    // === CSVD (Christian-Social People's Service) ===
    CSVD: {
        KPD: 0,
        SAPD: 20,
        SPD: Q.csvd_relation || 35,  // Can work with SPD against extremism
        SRPD: (Q.csvd_relation || 35) + 5,
        DDP: 60,  // Good - both moderate, pro-constitutional
        Z: 55,  // Decent - both Christian parties, but Protestant vs Catholic
        BVP: 50,  // Same confessional divide as Z
        DVP: 55,  // Good - moderate bourgeois coalition potential
        WP: 50,  // Okay - both middle-class parties
        CNBL: 45,  // Some overlap in rural Protestant areas
        DNVP: Q.dnvp_line === 3 ? 10 : 65,  // Key: hostile to Hugenberg DNVP, friendly to moderate DNVP
        NSDAP: 15  // Anti-Nazi but some voters might defect
    },
    
    // === DNVP (Nationalists) ===
    DNVP: {
        KPD: 0,
        SAPD: 5,
        SPD: Q.dnvp_relation,
        SRPD: Q.dnvp_relation - 5,
        DDP: Q.dnvp_line === 3 ? 15 : 35,
        Z: (Q.dnvp_line === 3 ? 25 : 50) + (Q.z_party_leader === "Kaas" ? 10 : -10),
        BVP: 50,
        DVP: 50 + (Q.dvp_right_shift || 0) * 15,
        WP: 45,
        CNBL: 35,
        CSVD: Q.dnvp_line === 3 ? 10 : 65,  // Added - CSVD split FROM DNVP due to Hugenberg
        NSDAP: Q.dnvp_line === 3 ? 60 : 35
    },
    
    // === NSDAP (Nazis) ===
    NSDAP: {
        KPD: 0,
        SAPD: 0,
        SPD: Q.nsdap_relation || 5,
        SRPD: 0,
        DDP: 10,
        Z: Math.max(5, 30 - Q.nazi_urgency * 4),
        BVP: 25 - (Q.nazi_urgency * 2),
        DVP: 25 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift || 0) * 10,
        WP: 30 + (Q.capital_strike_progress * 3),
        CNBL: 25,
        CSVD: 15,  // Added - CSVD is anti-Nazi, but some voter crossover
        DNVP: Q.dnvp_line === 3 ? 60 : 35
    }
};

// ============================================
// COALITION IMPOSSIBILITIES (RED LINES)
// ============================================

Q.coalition_blocks = {
    // Communist red lines
    KPD_Z: Q.kpd_relation < 65 && Q.z_relation < 65,
    KPD_BVP: true,
    KPD_DVP: true,
    KPD_WP: true,
    KPD_DNVP: true,
    KPD_NSDAP: true,
    KPD_DDP: Q.kpd_relation < 60,
    KPD_SPD: Q.communist_coalition < 3,
    
    // SAPD red lines
    SAPD_DNVP: true,
    SAPD_NSDAP: true,
    SAPD_DVP: Q.dvp_right_shift >= 2,
    
    // SPD red lines
    SPD_NSDAP: true,
    SPD_DNVP: Q.dnvp_relation < 60 || Q.dnvp_line === 3,
    SPD_KPD: Q.communist_coalition < 3,
    
    // SRPD red lines (more moderate)
    SRPD_KPD: Q.kpd_relation < 40,
    SRPD_NSDAP: true,
    SRPD_DNVP: Q.dnvp_line === 3,
    
    // Liberal red lines
    DDP_KPD: Q.kpd_relation < 60,
    DDP_NSDAP: true,
    DDP_DNVP: Q.dnvp_line === 3,
    
    // Center red lines
    Z_KPD: Q.kpd_relation < 65 && Q.z_relation < 45,
    Z_NSDAP: Q.nazi_urgency >= 7,
    Z_DNVP: Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
    
    // BVP red lines
    BVP_KPD: true,
    BVP_SAPD: Q.sapd_r >= Q.spd_r,
    BVP_NSDAP: Q.nazi_urgency >= 8,
    
    // DVP red lines
    DVP_KPD: true,
    DVP_SAPD: true,
    DVP_NSDAP: Q.nazi_urgency >= 6 && Q.capital_strike_progress < 5,
    
    // WP red lines
    WP_KPD: true,
    WP_SAPD: true,
    WP_NSDAP: Q.capital_strike_progress < 6,
    
    // DNVP red lines
    DNVP_KPD: true,
    DNVP_SAPD: true,
    DNVP_SPD: Q.dnvp_line === 3 || Q.dnvp_relation < 40,
    DNVP_Z: Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
    
    // Nazi red lines (they don't join coalitions normally)
    NSDAP_ALL: Q.nsdap_r < 40 || Q.year < 1933
};

// ============================================
// SPECIAL COALITION CONDITIONS
// ============================================

Q.popular_front_possible = (Q.kpd_party_leader === "Conciliators" && Q.z_party_leader === "Joos") ? 1 : 0;
Q.left_front_possible = (Q.communist_coalition >= 3 && Q.kpd_relation >= 50) ? 1 : 0;
Q.unity_government_possible = (Q.nazi_urgency >= 6 || Q.pro_republic < 40) ? 1 : 0;
Q.bourgeois_only_possible = (Q.year >= 1929 || Q.spd_r < 25) ? 1 : 0;
Q.right_coalition_viable = (Q.dnvp_line !== 3 || Q.z_party_leader === "Kaas") ? 1 : 0;

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
on-display: {!
data = [
    {
        "id": "kpd",
        "legend": "KPD",
        "name": "KPD",
        "seats": Math.round(Q.kpd_r*6),
    }
];
if (Q.sapd_formed && Q.sapd_r) {
    data.push({
        "id": "sapd",
        "legend": "SAPD",
        "name": "SAPD",
        "seats": Math.round(Q.sapd_r*6),
    });
}
data = data.concat([
    {
        "id": "spd",
        "legend": "SPD",
        "name": "SPD",
        "seats": Math.round(Q.spd_r*6),
    }
]);
if (Q.srpd_formed && Q.srpd_r) {
    data.push({
        "id": "srpd",
        "legend": "SRPD",
        "name": "SRPD",
        "seats": Math.round(Q.srpd_r*6),
    });
}
data = data.concat([
    {
        "id": "ddp",
        "legend": Q.ddp_name,
        "name": Q.ddp_name,
        "seats": Math.round(Q.ddp_r*6),
    },
    {
        "id": "z",
        "legend": "Center",
        "name": "Center",
        "seats": Math.round(Q.z_r*6),
    },
    {
        "id": "bvp",
        "legend": "BVP",
        "name": "BVP",
        "seats": Math.round(Q.bvp_r*6),
    },
    {
        "id": "dvp",
        "legend": "DVP",
        "name": "DVP",
        "seats": Math.round(Q.dvp_r*6),
    },
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_r*6),
    },
]);
if (Q.wp_r && Q.wp_r > 0) {
    data.push({
        "id": "wp",
        "legend": "WP",
        "name": "WP",
        "seats": Math.round(Q.wp_r*6),
    });
}
if (Q.csvd_flee && Q.csvd_r) {
    data.push({
        "id": "csvd",
        "legend": "CSVD",
        "name": "CSVD",
        "seats": Math.round(Q.csvd_r*6),
    });
}
data = data.concat([
    {
        "id": "dnvp",
        "legend": "DNVP",
        "name": "DNVP",
        "seats": Math.round(Q.dnvp_r*6),
    }
]);
if (Q.cnbl_r && Q.cnbl_r > 0) {
    data.push({
        "id": "cnbl",
        "legend": "CNBL",
        "name": "CNBL",
        "seats": Math.round(Q.cnbl_r*6),
    });
}
data = data.concat([
    {
        "id": "nsdap",
        "legend": "NSDAP",
        "name": "NSDAP",
        "seats": Math.round(Q.nsdap_r*6),
    }
]);

if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}
go-to: coalition_formation_start

= Election results

{!<svg id="reichstag" style="width: 500px; height: 250px;"> </svg>!}

{!<table style="width:100%; border-collapse: collapse;">!}
<tr style="border-bottom: 2px solid #333;">
    <td style="padding: 8px; font-weight: bold;">Party</td>
    <td style="padding: 8px; font-weight: bold; text-align: right;">Vote Share</td>
    <td style="padding: 8px; font-weight: bold; text-align: right;">Change</td>
</tr>
<tr style="background-color: #ffebee;">
    <td style="padding: 8px;"><div class="box" style='background-color:#8B0000; display:inline-block; margin-right:8px;'> </div>KPD</td>
    <td style="padding: 8px; text-align: right; font-weight: bold;">[+ kpd_r_disp +]%</td>
    <td style="padding: 8px; text-align: right; [? if change_kpd_r > 0 : color: green; ?][? if change_kpd_r < 0 : color: red; ?]">[+ str_change_kpd +]</td>
</tr>
[? if sapd_formed = 1 : 
<tr style="background-color: #ffe8e8;">
    <td style="padding: 8px;"><div class="box" style='background-color:#C40000; display:inline-block; margin-right:8px;'> </div>SAPD</td>
    <td style="padding: 8px; text-align: right; font-weight: bold;">[+ sapd_r_disp +]%</td>
    <td style="padding: 8px; text-align: right; [? if change_sapd_r > 0 : color: green; ?][? if change_sapd_r < 0 : color: red; ?]">[+ str_change_sapd +]</td>
</tr>
?]
<tr style="background-color: #ffe0e0; border: 2px solid #E3000F;">
    <td style="padding: 8px;"><div class="box" style='background-color:#E3000F; display:inline-block; margin-right:8px;'> </div><strong>SPD</strong></td>
    <td style="padding: 8px; text-align: right; font-weight: bold;">[+ spd_r_disp +]%</td>
    <td style="padding: 8px; text-align: right; [? if change_spd_r > 0 : color: green; ?][? if change_spd_r < 0 : color: red; ?]"><strong>[+ str_change_spd +]</strong></td>
</tr>
[? if srpd_formed = 1 :
<tr style="background-color: #fff0f0;">
    <td style="padding: 8px;"><div class="box" style='background-color:#FF6B6B; display:inline-block; margin-right:8px;'> </div>SRPD</td>
    <td style="padding: 8px; text-align: right; font-weight: bold;">[+ srpd_r_disp +]%</td>
