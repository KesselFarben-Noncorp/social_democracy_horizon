title: Reichstag Elections
new-page: true
tags: event
priority: -1
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year) or month = 1
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 4; n_elections += 1; next_election_time = time + 48; papen_chancellor_timer = 4;
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

= Elections, [+ month : month +] [+ year +]

The Reichstag elections are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-arrival: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; dvp_relation -= 8; z_relation -= 8; ddp_relation -= 10; kpd_relation -= 8; coup_progress += 2; workers_spd -= 4; new_middle_spd -= 5; old_middle_spd -= 5; rural_spd -= 5; catholics_spd -= 5; unemployed_spd -= 5; coup_progress += 2 if nsdap_normalized >= 0.3; coup_progress += 2 if nsdap_normalized + dnvp_normalized >= 0.5; sa_strength += 100 if coup_progress >= 7; sh_strength += 100 if coup_progress >= 7
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

@post_election_1928
on-arrival: {!
var new_party_sum = 0;

// Calculate election results
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'] ?? 0;
    
    if (Q.constitutional_reform > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || 
            (Q.electoral_threshold > 1 && party === 'other') ||
            Q[party + '_banned']) {
            Q[party + '_support'] = 0;
        }
    }
    
    new_party_sum += Q[party + '_support'];
}

for (var party of Q.parties) {
    if (new_party_sum > 0) {
        Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
    } else {
        Q[party + '_r'] = 0;
    }
    Q[party + '_votes'] = Math.round(Q[party + '_r'] * 10) / 10;
}

for (var party of Q.parties) {
    if (Q.use_decimals) {
        Q[party + '_r_disp'] = (Math.ceil(Q[party + '_r'] * 10) / 10).toFixed(1);
    } else {
        Q[party + '_r_disp'] = Math.round(Q[party + '_r']).toString();
    }
    
    Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
    Q['str_change_' + party] = (Q['change_' + party + '_r'] >= 0 ? '+' : '') +
        (Math.ceil(Q['change_' + party + '_r'] * 10) / 10).toFixed(1);
}

// Reset government flags
Q.coalition_dissent = 0;
Q.kpd_coalition_dissent = 0;
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.spd_toleration = 0;
Q.in_bourgeois_coalition = 0;
Q.in_right_coalition = 0;

// Reset KPD goals
Q.kpd_goals_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labor_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.reichswehr_goal = 0;

// ============================================
// COMPREHENSIVE PARTY RELATIONSHIP MATRIX
// ============================================

Q.party_relations = {
    
    // === KPD (Communists) ===
    KPD: {
        SAPD: 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD: Q.kpd_relation,
        SRPD: Q.kpd_relation - 10,
        DDP: 15,
        Z: 10,
        BVP: 5,
        DVP: 5,
        WP: 5,
        DNVP: 0,
        NSDAP: 0
    },
    
    // === SAPD (Left Socialists) ===
    SAPD: {
        KPD: 40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD: 50 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD: 55,
        DDP: 35,
        Z: 30,
        BVP: 25,
        DVP: 20,
        WP: 15,
        DNVP: 10,
        NSDAP: 0
    },
    
    // === SPD (Social Democrats) ===
    SPD: {
        KPD: Q.kpd_relation,
        SAPD: 50 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD: 65,
        DDP: Q.ddp_relation,
        Z: Q.z_relation,
        BVP: Q.bvp_relation || 40,
        DVP: Q.dvp_relation,
        WP: Q.wp_relation || 30,
        DNVP: Q.dnvp_relation,
        NSDAP: Q.nsdap_relation || 5
    },
    
    // === SRPD (Reformist Socialists - if formed) ===
    SRPD: {
        KPD: Q.kpd_relation - 10,
        SAPD: 55,
        SPD: 65,
        DDP: Q.ddp_relation + 10,
        Z: Q.z_relation + 5,
        BVP: (Q.bvp_relation || 40) + 5,
        DVP: Q.dvp_relation - 5,
        WP: (Q.wp_relation || 30) - 5,
        DNVP: Q.dnvp_relation - 10,
        NSDAP: 0
    },
    
    // === DDP (Liberals) ===
    DDP: {
        KPD: 15,
        SAPD: 35,
        SPD: Q.ddp_relation,
        SRPD: Q.ddp_relation + 10,
        Z: 70,
        BVP: 60,
        DVP: 65 - (Q.dvp_right_shift || 0) * 8,
        WP: 55,
        DNVP: Q.dnvp_line === 3 ? 15 : 35,
        NSDAP: 10
    },
    
    // === Z (Center Party) ===
    Z: {
        KPD: 10,
        SAPD: 30,
        SPD: Q.z_relation,
        SRPD: Q.z_relation + 5,
        DDP: 70,
        BVP: 80,
        DVP: 60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        WP: 50,
        DNVP: (Q.dnvp_line === 3 ? 25 : 50) + (Q.z_party_leader === "Kaas" ? 10 : -10),
        NSDAP: Math.max(5, 30 - Q.nazi_urgency * 4)
    },
    
    // === BVP (Bavarian People's Party) ===
    BVP: {
        KPD: 5,
        SAPD: 25,
        SPD: Q.bvp_relation || 40,
        SRPD: (Q.bvp_relation || 40) + 5,
        DDP: 60,
        Z: 80,
        DVP: 55,
        WP: 45,
        DNVP: 50,
        NSDAP: 25 - (Q.nazi_urgency * 2)
    },
    
    // === DVP (People's Party) ===
    DVP: {
        KPD: 5,
        SAPD: 20,
        SPD: Q.dvp_relation,
        SRPD: Q.dvp_relation - 5,
        DDP: 65 - (Q.dvp_right_shift || 0) * 8,
        Z: 60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        BVP: 55,
        WP: 70,
        DNVP: 50 + (Q.dvp_right_shift || 0) * 15,
        NSDAP: 25 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift || 0) * 10
    },
    
    // === WP (Business Party) ===
    WP: {
        KPD: 5,
        SAPD: 15,
        SPD: Q.wp_relation || 30,
        SRPD: (Q.wp_relation || 30) - 5,
        DDP: 55,
        Z: 50,
        BVP: 45,
        DVP: 70,
        DNVP: 45,
        NSDAP: 30 + (Q.capital_strike_progress * 3)
    },
    
    // === DNVP (Nationalists) ===
    DNVP: {
        KPD: 0,
        SAPD: 5,
        SPD: Q.dnvp_relation,
        SRPD: Q.dnvp_relation - 5,
        DDP: Q.dnvp_line === 3 ? 15 : 35,
        Z: (Q.dnvp_line === 3 ? 25 : 50) + (Q.z_party_leader === "Kaas" ? 10 : -10),
        BVP: 50,
        DVP: 50 + (Q.dvp_right_shift || 0) * 15,
        WP: 45,
        NSDAP: Q.dnvp_line === 3 ? 60 : 35
    },
    
    // === NSDAP (Nazis) ===
    NSDAP: {
        KPD: 0,
        SAPD: 0,
        SPD: Q.nsdap_relation || 5,
        SRPD: 0,
        DDP: 10,
        Z: Math.max(5, 30 - Q.nazi_urgency * 4),
        BVP: 25 - (Q.nazi_urgency * 2),
        DVP: 25 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift || 0) * 10,
        WP: 30 + (Q.capital_strike_progress * 3),
        DNVP: Q.dnvp_line === 3 ? 60 : 35
    }
};

// ============================================
// COALITION IMPOSSIBILITIES (RED LINES)
// ============================================

Q.coalition_blocks = {
    // Communist red lines
    KPD_Z: Q.kpd_relation < 65 && Q.z_relation < 65,
    KPD_BVP: true,
    KPD_DVP: true,
    KPD_WP: true,
    KPD_DNVP: true,
    KPD_NSDAP: true,
    KPD_DDP: Q.kpd_relation < 60,
    KPD_SPD: Q.communist_coalition < 3,
    
    // SAPD red lines
    SAPD_DNVP: true,
    SAPD_NSDAP: true,
    SAPD_DVP: Q.dvp_right_shift >= 2,
    
    // SPD red lines
    SPD_NSDAP: true,
    SPD_DNVP: Q.dnvp_relation < 60 || Q.dnvp_line === 3,
    SPD_KPD: Q.communist_coalition < 3,
    
    // SRPD red lines (more moderate)
    SRPD_KPD: Q.kpd_relation < 40,
    SRPD_NSDAP: true,
    SRPD_DNVP: Q.dnvp_line === 3,
    
    // Liberal red lines
    DDP_KPD: Q.kpd_relation < 60,
    DDP_NSDAP: true,
    DDP_DNVP: Q.dnvp_line === 3,
    
    // Center red lines
    Z_KPD: Q.kpd_relation < 65 && Q.z_relation < 45,
    Z_NSDAP: Q.nazi_urgency >= 7,
    Z_DNVP: Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
    
    // BVP red lines
    BVP_KPD: true,
    BVP_SAPD: Q.sapd_r >= Q.spd_r,
    BVP_NSDAP: Q.nazi_urgency >= 8,
    
    // DVP red lines
    DVP_KPD: true,
    DVP_SAPD: true,
    DVP_NSDAP: Q.nazi_urgency >= 6 && Q.capital_strike_progress < 5,
    
    // WP red lines
    WP_KPD: true,
    WP_SAPD: true,
    WP_NSDAP: Q.capital_strike_progress < 6,
    
    // DNVP red lines
    DNVP_KPD: true,
    DNVP_SAPD: true,
    DNVP_SPD: Q.dnvp_line === 3 || Q.dnvp_relation < 40,
    DNVP_Z: Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
    
    // Nazi red lines (they don't join coalitions normally)
    NSDAP_ALL: Q.nsdap_r < 40 || Q.year < 1933
};

// ============================================
// SPECIAL COALITION CONDITIONS
// ============================================

Q.special_conditions = {
    // Popular Front requires conciliators
    popular_front: Q.kpd_party_leader === "Conciliators" && Q.z_party_leader === "Joos",
    
    // Left Front requires good KPD relations
    left_front: Q.communist_coalition >= 3 && Q.kpd_relation >= 50,
    
    // Unity Government requires crisis
    unity_government: Q.nazi_urgency >= 6 || Q.pro_republic < 40,
    
    // Bourgeois coalition requires no SPD
    bourgeois_only: Q.year >= 1929 || Q.spd_r < 25,
    
    // Right coalition requires moderate DNVP
    right_coalition_viable: Q.dnvp_line !== 3 || Q.z_party_leader === "Kaas"
};

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
on-display: {!
data = [
