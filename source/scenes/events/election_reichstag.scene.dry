# ============================================
# CHANCELLOR NEGOTIATION - AI DECIDES
# ============================================

@chancellor_negotiation_ai
on-arrival: {!
// AI chooses chancellor based on various factors
var best_candidate = 0;
var best_score = -999;

for (var i = 0; i < Q.chancellor_candidates.length; i++) {
    var candidate = Q.chancellor_candidates[i];
    var score = candidate.score; // Use pre-calculated score
    
    // Hindenburg preferences
    if (Q.president === "Hindenburg" && Q.year >= 1930) {
        if (candidate.party === "SPD") {
            score -= 20;
        }
        if (candidate.party === "Z") {
            score += 10;
        }
        if (candidate.party === "DVP") {
            score += 5;
        }
    }
    
    if (Q.president === "Hindenburg" && Q.year >= 1932) {
        if (candidate.party === "SPD") {
            score -= 40;
        }
    }
    
    // Formateur bonus
    if (candidate.party === Q.formateur) {
        score += 15;
    }
    
    // Experienced leaders bonus
    if (candidate.name === "Stresemann" && !Q.stresemann_dead) {
        score += 15;
    }
    if (candidate.name === "Brüning") {
        score += 12;
    }
    if (candidate.name === "Müller" && !Q.muller_dead) {
        score += 10;
    }
    if (candidate.name === "Braun") {
        score += 8;
    }
    
    if (score > best_score) {
        best_score = score;
        best_candidate = i;
    }
}

Q.chosen_chancellor_index = best_candidate;
Q.chancellor_party = Q.chancellor_candidates[best_candidate].party;
Q.chancellor = Q.chancellor_candidates[best_candidate].name;
!}
go-to: chancellor_hindenburg_check

# ============================================
# HINDENBURG VETO CHECK
# ============================================

@chancellor_hindenburg_check
on-arrival: {!
Q.hindenburg_vetoed = 0;
Q.hindenburg_forced_change = 0;
Q.hindenburg_forced_z = 0;
Q.hindenburg_forced_dvp = 0;

// Pre-calculate current choice info
Q.vetoed_candidate_name = Q.chancellor_candidates[Q.chosen_chancellor_index].name;
Q.vetoed_candidate_party = Q.chancellor_candidates[Q.chosen_chancellor_index].party;

// Check if Hindenburg will veto
if (Q.president === "Hindenburg" && Q.year >= 1932) {
    if (Q.chancellor_party === "SPD" || Q.chancellor_party === "KPD" || Q.chancellor_party === "SAPD") {
        Q.hindenburg_vetoed = 1;
    }
}

// If vetoed, force change to acceptable candidate
if (Q.hindenburg_vetoed) {
    for (var i = 0; i < Q.chancellor_candidates.length; i++) {
        var party = Q.chancellor_candidates[i].party;
        if (party !== "SPD" && party !== "KPD" && party !== "SAPD") {
            Q.chancellor_party = party;
            Q.chancellor = Q.chancellor_candidates[i].name;
            Q.hindenburg_forced_change = 1;
            Q.chosen_chancellor_index = i;
            
            if (party === "Z") Q.hindenburg_forced_z = 1;
            if (party === "DVP") Q.hindenburg_forced_dvp = 1;
            break;
        }
    }
}
!}
go-to: hindenburg_veto_message if hindenburg_vetoed; chancellor_confirmed if not hindenburg_vetoed

@hindenburg_veto_message

= Presidential Veto

**President Hindenburg refuses to appoint [+ vetoed_candidate_name +] as Chancellor.**

"I cannot in good conscience appoint a [? if vetoed_candidate_party = "SPD" : Social Democrat ?][? if vetoed_candidate_party = "KPD" : Communist ?][? if vetoed_candidate_party = "SAPD" : Socialist ?] to lead the Reich government under current circumstances."

[? if hindenburg_forced_change : **[+ chancellor +] ([+ chancellor_party +]) has been appointed Chancellor instead.** ?]

**Consequences:**
- Relations with the President are severely strained
- The coalition's legitimacy is questioned
- Democratic norms are undermined

- @continue_after_veto: Continue

@continue_after_veto
on-arrival: {!
Q.pro_republic -= 10;
Q.presidential_powers += 1;

if (Q.spd_in_government) {
    Q.reformist_dissent += 10;
    Q.left_dissent += 15;
}
!}
go-to: chancellor_confirmed

# ============================================
# CHANCELLOR CONFIRMED
# ============================================

@chancellor_confirmed
on-arrival: {!
// ============================================
// POLITICAL CONSEQUENCES
// ============================================

// Left Front consequences
if (Q.in_left_front) {
    Q.coup_progress += 3;
    Q.capital_strike_progress += 2;
    Q.kpd_relation += 10;
}

// Popular Front consequences
if (Q.in_popular_front) {
    Q.coup_progress += 2;
    Q.pro_republic += 5;
    Q.kpd_relation += 10;
    Q.z_relation += 5;
}

// Far-right consequences
if (Q.coalition_type === 'far_right') {
    Q.coup_progress += 5;
    Q.pro_republic -= 15;
}

// Bourgeois coalition (SPD excluded)
if (Q.in_bourgeois_coalition && !Q.spd_in_government) {
    Q.workers_spd -= 5;
    Q.left_dissent += 10;
    Q.labor_dissent += 10;
}
!}

= [+ coalition_name +] Formed

**Chancellor:** [+ chancellor +] ([+ chancellor_party +])

**Coalition Partners:**

[+ coalition_partners_list +]

**Total Reichstag Support:** [+ coalition_votes +]%

[? if hindenburg_forced_z : President Hindenburg insisted that the Center Party provide the Chancellor, despite another party being larger in the coalition. ?]

[? if hindenburg_forced_dvp : President Hindenburg insisted that the DVP provide the Chancellor, despite another party being larger in the coalition. ?]

[? if coalition_type = 'left_front' : The formation of a Left Front government including the Communists has sent shockwaves through the establishment. The right-wing may attempt a coup. ?]

[? if coalition_type = 'popular_front' : The unprecedented Popular Front brings together Socialists, Communists, and Catholics in defense of democracy. ?]

[? if coalition_type = 'unity' : A broad Unity Government of democratic parties has been formed to face the crisis. ?]

[? if coalition_type = 'bourgeois' : The bourgeois parties have formed a government without the SPD. ?]

[? if coalition_type = 'far_right' : The Nazis have entered government. This may be the end of democracy. ?]

- @ministry_allocation: Proceed to ministry distribution





@ministry_allocation
on-arrival: {!
// ============================================
// CALCULATE BASE SHARE FROM VOTE COUNT
// ============================================

var coalition = Q.government_parties;
var total_coalition_votes = 0;

// Calculate total coalition votes
for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var party_lower = party.toLowerCase();
    total_coalition_votes += Q[party_lower + '_r'];
}

var leverage = {};

for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var party_lower = party.toLowerCase();
    
    // Base share = party's percentage of total coalition votes
    var base = (Q[party_lower + '_r'] / total_coalition_votes) * 100;
    
    // Relationship modifier
    var relation_var = party_lower + '_relation';
    var relation = Q[relation_var] || 50;
    base += (relation - 50) / 5;  // +/- up to 10 points
    
    // Chancellor bonus
    if (Q.chancellor_party === party) {
        base -= 10;
    }
    
    // President bonus
    if (Q.president === "Braun" && party === "SPD") {
        base += 5;
    }
    
    // Party leader bonuses
    if (party === "Z" && Q.z_party_leader === "Brüning") {
        base += 5;
    }
    if (party === "DVP" && !Q.stresemann_dead) {
        base += 3;
    }
    if (party === "KPD" && Q.kpd_party_leader === "Conciliators") {
        base += 5;
    }
    
    // Special conditions
    if (Q.in_grand_coalition && party === "DVP" && Q.capital_strike_progress >= 3) {
        base += 5;
    }
    
    if (Q.in_left_front && party === "KPD") {
        base -= 5;
    }
    
    // Floor
    leverage[party] = Math.max(base, 10);
}

// ============================================
// ALLOCATE 7 MINISTRIES BASED ON LEVERAGE
// ============================================

var ministries = ['foreign', 'interior', 'justice', 'labor', 'economic', 'finance', 'agriculture', 'transport'];
var allocation = {};
var ministry_count = {};

// Calculate total leverage
var total_leverage = 0;
for (var party in leverage) {
    total_leverage += leverage[party];
}

// Calculate initial allocation
for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var count = Math.round((leverage[party] / total_leverage) * ministries.length);
    allocation[party] = count;
    ministry_count[party] = 0;
}

// Adjust for rounding errors
var total_assigned = 0;
for (var party in allocation) {
    total_assigned += allocation[party];
}

// If over-allocated, remove from non-chancellor parties
while (total_assigned > ministries.length) {
    var max_party = null;
    var max_count = 0;
    for (var party in allocation) {
        if (allocation[party] > max_count && party !== Q.chancellor_party) {
            max_party = party;
            max_count = allocation[party];
        }
    }
    if (max_party) {
        allocation[max_party]--;
        total_assigned--;
    } else {
        break;
    }
}

// If under-allocated, add to highest leverage parties
while (total_assigned < ministries.length) {
    var max_party = null;
    var max_leverage = 0;
    for (var party in leverage) {
        if (leverage[party] > max_leverage) {
            max_party = party;
            max_leverage = leverage[party];
        }
    }
    if (max_party) {
        allocation[max_party]++;
        total_assigned++;
        leverage[max_party] -= 10;  // Reduce to allow others to catch up
    } else {
        break;
    }
}

// Pre-calculate ministry display (AFTER allocation is calculated)
Q.ministry_display_list = "";
for (var party in allocation) {
    var party_votes = Q[party.toLowerCase() + '_r'];
    var rounded_leverage = Math.round(leverage[party] * 10) / 10;
    Q.ministry_display_list += "- **" + party + "**: " + allocation[party] + " ministries (" + Math.round(party_votes * 10) / 10 + "% votes, leverage: " + rounded_leverage + ")\n";
}

// ============================================
// MINISTRY PRIORITIES BY PARTY
// ============================================

var priorities = {
    KPD: ['labor', 'interior', 'economic', 'finance', 'justice', 'foreign', 'agriculture', 'transport'],
    SAPD: ['labor', 'interior', 'justice', 'economic', 'finance', 'foreign', 'agriculture', 'transport'],
    SPD: ['labor', 'interior', 'justice', 'finance', 'economic', 'foreign', 'agriculture', 'transport'],
    SRPD: ['labor', 'justice', 'interior', 'finance', 'economic', 'foreign', 'agriculture', 'transport'],
    DDP: ['justice', 'economic', 'finance', 'interior', 'foreign', 'labor', 'agriculture', 'transport'],
    Z: ['interior', 'foreign', 'finance', 'labor', 'agriculture', 'justice', 'economic', 'transport'],
    BVP: ['agriculture', 'justice', 'interior', 'finance', 'economic', 'foreign', 'labor', 'transport'],
    DVP: ['economic', 'finance', 'foreign', 'justice', 'interior', 'labor', 'agriculture', 'transport'],
    WP: ['economic', 'finance', 'justice', 'agriculture', 'interior', 'foreign', 'labor', 'transport'],
    CNBL: ['agriculture', 'finance', 'economical', 'justice', 'interior', 'foreign', 'labor', 'transport'],
    DNVP: ['interior', 'finance', 'agriculture', 'foreign', 'economic', 'justice', 'labor', 'transport']
};

// ============================================
// ASSIGN MINISTRIES BY PRIORITY
// ============================================

var assignments = {};
for (var i = 0; i < ministries.length; i++) {
    assignments[ministries[i]] = null;
}

// Sort coalition by leverage (descending)
var sorted_coalition = coalition.slice().sort(function(a, b) {
    return leverage[b] - leverage[a];
});

// Assign ministries in rounds
for (var round = 0; round < ministries.length; round++) {
    for (var i = 0; i < sorted_coalition.length; i++) {
        var party = sorted_coalition[i];
        
        if (allocation[party] > ministry_count[party]) {
            var party_priorities = priorities[party] || ministries;
            
            for (var j = 0; j < party_priorities.length; j++) {
                var ministry = party_priorities[j];
                
                if (assignments[ministry] === null) {
                    assignments[ministry] = party;
                    ministry_count[party]++;
                    break;
                }
            }
        }
    }
}

// ============================================
// SET MINISTRY PARTIES AND MINISTERS
// ============================================

Q.foreign_minister_party = assignments.foreign || 'I';
Q.interior_minister_party = assignments.interior || 'I';
Q.justice_minister_party = assignments.justice || 'I';
Q.labor_minister_party = assignments.labor || 'I';
Q.economic_minister_party = assignments.economic || 'I';
Q.finance_minister_party = assignments.finance || 'I';
Q.agriculture_minister_party = assignments.agriculture || 'I';
Q.transport_minister_party = assignments.transport || 'I';
Q.reichswehr_minister_party = 'I';

// [Keep all your minister name assignment code here - it's unchanged]

// Store allocation for display
Q.ministry_allocation = allocation;
Q.ministry_leverage = leverage;

// ============================================
// ASSIGN MINISTER NAMES
// ============================================

// Foreign Ministry
if (Q.foreign_minister_party === 'KPD') Q.foreign_minister = 'Pieck';
else if (Q.foreign_minister_party === 'SAPD') Q.foreign_minister = 'Rosenfeld';
else if (Q.foreign_minister_party === 'SPD') Q.foreign_minister = 'Müller';
else if (Q.foreign_minister_party === 'SRPD') Q.foreign_minister = 'Breitscheid';
else if (Q.foreign_minister_party === 'DDP') Q.foreign_minister = 'Koch-Weser';
else if (Q.foreign_minister_party === 'Z') Q.foreign_minister = 'Curtius';
else if (Q.foreign_minister_party === 'BVP') Q.foreign_minister = 'Held';
else if (Q.foreign_minister_party === 'DVP') Q.foreign_minister = Q.stresemann_dead ? 'Curtius' : 'Stresemann';
else if (Q.foreign_minister_party === 'WP') Q.foreign_minister = 'Lambach';
else if (Q.foreign_minister_party === 'CNBL') Q.foreign_minister = 'Hepp';
else if (Q.foreign_minister_party === 'DNVP') Q.foreign_minister = 'Westarp';
else Q.foreign_minister = 'Unbesetzt';

// Interior Ministry
if (Q.interior_minister_party === 'KPD') Q.interior_minister = 'Ulbricht';
else if (Q.interior_minister_party === 'SAPD') Q.interior_minister = 'Seydewitz';
else if (Q.interior_minister_party === 'SPD') Q.interior_minister = 'Severing';
else if (Q.interior_minister_party === 'SRPD') Q.interior_minister = 'Braun';
else if (Q.interior_minister_party === 'DDP') Q.interior_minister = 'Koch-Weser';
else if (Q.interior_minister_party === 'Z') Q.interior_minister = 'Wirth';
else if (Q.interior_minister_party === 'BVP') Q.interior_minister = 'Schätzel';
else if (Q.interior_minister_party === 'DVP') Q.interior_minister = 'Scholz';
else if (Q.interior_minister_party === 'WP') Q.interior_minister = 'Petersen';
else if (Q.interior_minister_party === 'CNBL') Q.interior_minister = 'Behrens';
else if (Q.interior_minister_party === 'DNVP') Q.interior_minister = 'Hergt';
else Q.interior_minister = 'Unbesetzt';

// Justice Ministry
if (Q.justice_minister_party === 'KPD') Q.justice_minister = 'Heckert';
else if (Q.justice_minister_party === 'SAPD') Q.justice_minister = 'Ledebour';
else if (Q.justice_minister_party === 'SPD') Q.justice_minister = 'Radbruch';
else if (Q.justice_minister_party === 'SRPD') Q.justice_minister = 'Heilmann';
else if (Q.justice_minister_party === 'DDP') Q.justice_minister = 'Koch-Weser';
else if (Q.justice_minister_party === 'Z') Q.justice_minister = 'Bredt';
else if (Q.justice_minister_party === 'BVP') Q.justice_minister = 'Gürtner';
else if (Q.justice_minister_party === 'DVP') Q.justice_minister = 'Heinze';
else if (Q.justice_minister_party === 'WP') Q.justice_minister = 'Drewitz';
