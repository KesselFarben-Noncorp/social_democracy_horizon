@continue_without_spd
on-arrival: {!
// Set opposition status
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;

// Opposition benefits
Q.workers_spd += 3;
Q.left_strength += 5;
!}
go-to: coalition_success






@coalition_success
on-arrival: {!
// ============================================
// COALITION SUCCESSFULLY FORMED
// ============================================

var coalition = Q.chosen_coalition.parties;
Q.government_parties = coalition;
Q.coalition_votes = Q.chosen_coalition.votes;
Q.coalition_type = Q.chosen_coalition.type;

// Pre-calculate coalition partners display
Q.coalition_partners_list = "";
for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var votes = Q[party.toLowerCase() + '_r'];
    Q.coalition_partners_list += "- **" + party + "**: " + Math.round(votes * 10) / 10 + "%\n";
}

// ============================================
// SET COALITION NAME AND FLAGS
// ============================================

if (Q.coalition_type === 'weimar') {
    Q.in_weimar_coalition = 1;
    Q.coalition_name = "Weimar Coalition";
} else if (Q.coalition_type === 'grand' || Q.coalition_type === 'grand_small') {
    Q.in_grand_coalition = 1;
    Q.coalition_name = "Grand Coalition";
} else if (Q.coalition_type === 'social_christian') {
    Q.in_social_christian_coalition = 1;
    Q.coalition_name = "Social - Christian Coalition";
} else if (Q.coalition_type === 'social_liberal') {
    Q.in_social_liberal_coalition = 1;
    Q.coalition_name = "Social - Liberal Coalition";
} else if (Q.coalition_type === 'left_front') {
    Q.in_left_front = 1;
    Q.coalition_name = "Left Front";
} else if (Q.coalition_type === 'popular_front') {
    Q.in_popular_front = 1;
    Q.coalition_name = "Popular Front";
} else if (Q.coalition_type === 'socialist_unity') {
    Q.coalition_name = "Socialist Unity Coalition";
} else if (Q.coalition_type === 'bourgeois' || Q.coalition_type === 'bourgeois_catholic') {
    Q.in_bourgeois_coalition = 1;
    Q.coalition_name = "Bourgeois Coalition";
} else if (Q.coalition_type === 'right' || Q.coalition_type === 'right_business') {
    Q.in_right_coalition = 1;
    Q.coalition_name = "Right Coalition";
} else if (Q.coalition_type === 'far_right') {
    Q.coalition_name = "Far-Right Coalition";
} else if (Q.coalition_type === 'unity') {
    Q.in_unity_government = 1;
    Q.coalition_name = "Unity Government";
} else {
    Q.coalition_name = "Coalition Government";
}

// ============================================
// IDENTIFY CHANCELLOR CANDIDATES
// ============================================

// Helper function to get viable chancellor candidates by party
function get_chancellor_candidates_for_party(party) {
    var candidates = [];
    
    if (party === 'KPD') {
        if (Q.kpd_party_leader === "Conciliators") {
            candidates.push({name: "Neumann", weight: 100});
        } else {
            candidates.push({name: "Thälmann", weight: 100});
        }
    } 
    else if (party === 'SAPD') {
        candidates.push({name: "Rosenfeld", weight: 100});
    } 
    else if (party === 'SPD') {
        // Alternative: if you need the player's preference to determine which ONE candidate appears, not multiple i guess
        if (Q.spd_chancellor_preference === "mueller" && !Q.muller_dead) {
            candidates.push({name: "Müller", weight: 100});
        } else if (Q.spd_chancellor_preference === "wels") {
            candidates.push({name: "Wels", weight: 100});
        } else if (Q.spd_chancellor_preference === "braun") {
            candidates.push({name: "Braun", weight: 100});
        } else if (Q.spd_chancellor_preference === "hilferding" && Q.spd_toleration === 0) {
            candidates.push({name: "Hilferding", weight: 100});
        } else {
            // Default fallback
            if (!Q.muller_dead) {
                candidates.push({name: "Müller", weight: 100});
            } else {
                candidates.push({name: "Wels", weight: 100});
            }
        }
    }
    else if (party === 'SRPD') {
        candidates.push({name: "Horsing", weight: 100});
    } 
    else if (party === 'DDP') {
        candidates.push({name: "Koch-Weser", weight: 100});
        if (Q.ddp_decline < 50) { // If party not too weakened
            candidates.push({name: "Dietrich", weight: 80});
        }
    } 
    else if (party === 'Z') {
        if (Q.z_party_leader === "Joos") {
            candidates.push({name: "Wirth", weight: 100});
            candidates.push({name: "Joos", weight: 80});
        } else if (Q.z_party_leader === "Kaas") {
            candidates.push({name: "Kaas", weight: 100});
            candidates.push({name: "Brüning", weight: 90});
        } else if (Q.z_party_leader === "Brüning") {
            candidates.push({name: "Brüning", weight: 100});
            candidates.push({name: "Marx", weight: 70});
        } else {
            candidates.push({name: "Marx", weight: 100});
            candidates.push({name: "Wirth", weight: 85});
        }
    } 
    else if (party === 'BVP') {
        candidates.push({name: "Held", weight: 100});
        candidates.push({name: "Schäffer", weight: 80});
    } 
    else if (party === 'DVP') {
        if (!Q.stresemann_dead) {
            candidates.push({name: "Stresemann", weight: 100});
            candidates.push({name: "Curtius", weight: 70});
        } else {
            candidates.push({name: "Curtius", weight: 100});
            candidates.push({name: "Dingeldey", weight: 85});
        }
    } 
    else if (party === 'WP') {
        candidates.push({name: "Drewitz", weight: 100});
    } 
    else if (party === 'CSVD') {
        candidates.push({name: "Lambach", weight: 100});
    }
    else if (party === 'CNBL') {
        candidates.push({name: "Hepp", weight: 100});
    } 
    else if (party === 'DNVP') {
        if (Q.dnvp_line === 3) {
            candidates.push({name: "Hugenberg", weight: 100});
        } else {
            candidates.push({name: "Westarp", weight: 100});
            candidates.push({name: "Treviranus", weight: 75});
        }
    }
    
    return candidates;
}

// Build comprehensive candidate list
var all_candidates = [];

for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var votes = Q[party.toLowerCase() + '_r'];
    var party_candidates = get_chancellor_candidates_for_party(party);
    
    for (var j = 0; j < party_candidates.length; j++) {
        var candidate = party_candidates[j];
        all_candidates.push({
            party: party,
            name: candidate.name,
            votes: votes,
            weight: candidate.weight,
            score: votes * (candidate.weight / 100) // Combined score for sorting

        });
    }
}

// Sort by score descending
all_candidates.sort(function(a, b) { return b.score - a.score; });

// Take top 6 candidates
Q.chancellor_candidates = [];
Q.chancellor_candidates_display = "";

var num_candidates = Math.min(6, all_candidates.length);
for (var i = 0; i < num_candidates; i++) {
    var candidate = all_candidates[i];
    
    Q.chancellor_candidates.push({
        party: candidate.party,
        name: candidate.name,
        votes: candidate.votes,
        weight: candidate.weight
    });
    
    Q.chancellor_candidates_display += (i + 1) + ". **" + candidate.name + "** (" + candidate.party + ", " + Math.round(candidate.votes * 10) / 10 + "%)";
    
    // Add contextual notes
    if (candidate.name === "Müller") {
        Q.chancellor_candidates_display += " - Former Chancellor";
    } else if (candidate.name === "Wels") {
        Q.chancellor_candidates_display += " - Party Chairman";
    } else if (candidate.name === "Braun") {
        Q.chancellor_candidates_display += " - Prussian Minister-President";
    } else if (candidate.name === "Hilferding") {
        Q.chancellor_candidates_display += " - Economic Expert";
    } else if (candidate.name === "Brüning") {
        Q.chancellor_candidates_display += " - Financial Expert";
    } else if (candidate.name === "Stresemann") {
        Q.chancellor_candidates_display += " - Foreign Policy Expert";
    }
    
    Q.chancellor_candidates_display += "\n";
}

Q.num_candidates = Q.chancellor_candidates.length;

// Pre-calculate candidate info for display/conditionals
for (var i = 0; i < Q.num_candidates && i < 6; i++) {
    Q['candidate_' + i + '_name'] = Q.chancellor_candidates[i].name;
    Q['candidate_' + i + '_party'] = Q.chancellor_candidates[i].party;
}

// ============================================
// SET COALITION FLAGS
// ============================================

Q.spd_in_government = coalition.indexOf('SPD') >= 0 ? 1 : 0;
Q.kpd_in_government = coalition.indexOf('KPD') >= 0 ? 1 : 0;
Q.sapd_in_government = coalition.indexOf('SAPD') >= 0 ? 1 : 0;
Q.srpd_in_government = coalition.indexOf('SRPD') >= 0 ? 1 : 0;
Q.z_in_government = coalition.indexOf('Z') >= 0 ? 1 : 0;
Q.bvp_in_government = coalition.indexOf('BVP') >= 0 ? 1 : 0;
Q.ddp_in_government = coalition.indexOf('DDP') >= 0 ? 1 : 0;
Q.dvp_in_government = coalition.indexOf('DVP') >= 0 ? 1 : 0;
Q.wp_in_government = coalition.indexOf('WP') >= 0 ? 1 : 0;
Q.dnvp_in_government = coalition.indexOf('DNVP') >= 0 ? 1 : 0;
Q.csvd_in_government = coalition.indexOf('CSVD') >= 0 ? 1 : 0;

!}
go-to: chancellor_negotiation_spd if spd_in_government; chancellor_negotiation_ai if not spd_in_government

- @continue_to_negotiation: Continue to coalition negotiations

@continue_to_negotiation
