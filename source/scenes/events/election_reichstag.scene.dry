[? if srpd_formed = 1 : {!<tr><td><div class="box" style='background-color:#FF6B6B'> </div> !}SRPD: {!</td><td>!} [+ srpd_r +]% {!</td><td>!} [+ str_change_srpd +] {!</td></tr>!} ?]
