@hitler_victory
on-arrival: {!
// Hitler victory most likely - 60% base chance
var roll = Math.random() * 100;
var hitler_bonus = 0;

// Factors favoring Hitler
if (Q.economic_growth > 0) hitler_bonus += 15; // Growing economy helps Hitler's electoral strategy
if (Q.sa_banned) hitler_bonus += 20; // SA bans vindicate Hitler's legal strategy
if (Q.nazi_urgency < 3) hitler_bonus += 15; // Low urgency = we haven't weakened them
if (Q.unemployed < 15) hitler_bonus += 10; // Low unemployment weakens revolutionary appeal
if (Q.capital_strike_progress >= 3) hitler_bonus += 10; // Capitalist support flows to Hitler
if (Q.strasser_seen_as_threat) hitler_bonus -= 15; // If we've built up Strasser
if (Q.rohm_empowered) hitler_bonus -= 15; // If we've empowered SA independence

// Determine outcome
if (roll + hitler_bonus >= 85) {
    Q.nsdap_factionalism = 4; // Split party
} else if (roll + hitler_bonus >= 70) {
    Q.nsdap_factionalism = 3; // Röhm victory
} else if (roll + hitler_bonus >= 55) {
    Q.nsdap_factionalism = 2; // Strasser victory
} else if (roll + hitler_bonus >= 30) {
    Q.nsdap_factionalism = 1; // Hitler challenged
} else {
    Q.nsdap_factionalism = 0; // Hitler clean victory
}
!}
