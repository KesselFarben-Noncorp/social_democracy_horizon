    // ===== GOVERNMENT COMPOSITION =====
    var chancellors = ['Marx', 'Müller', 'Brüning', 'Papen', 'Schleicher', 'Hitler', 'Braun', 'Wels'];
    Q.chancellor = chancellors[Math.floor(Math.random() * chancellors.length)];
    
    var govts = ['SPD', 'Z', 'DVP', 'DNVP', 'NSDAP', 'KPD', 'Coalition', 'Minority'];
    Q.prussian_government = govts[Math.floor(Math.random() * govts.length)];
    
    Q.spd_in_government = Math.floor(Math.random() * 2);
    Q.in_weimar_coalition = Math.floor(Math.random() * 2);
    Q.in_grand_coalition = Math.floor(Math.random() * 2);
    Q.in_popular_front = Math.floor(Math.random() * 2);
    Q.in_left_front = Math.floor(Math.random() * 2);
    
    console.log("=== CHAOS MODE ACTIVATED ===");
    console.log("All variables randomized. Reality is meaningless.");
    console.log("Inflation: " + Q.inflation.toFixed(2) + "%");
    console.log("Unemployment: " + Q.unemployed.toFixed(2) + "%");
    console.log("Year: " + Q.year + "/" + Q.month);
    console.log("Chancellor: " + Q.chancellor);
    console.log("NSDAP: " + Q.nsdap_r.toFixed(1) + "%");
    console.log("SPD: " + Q.spd_r.toFixed(1) + "%");
!}

= CHAOS MODE ACTIVATED

