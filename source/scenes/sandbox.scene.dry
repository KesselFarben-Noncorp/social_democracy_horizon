@gov
subtitle: Set your governments!

Anything?

- @weimar: Weimar
- @technical: Back.

@weimar
on-arrival: {! 
// 1. CLEAR EVERYTHING FIRST
Q.clear_government();

// 2. SET CHANCELLOR
// SPD leads Weimar coalition — but could be Z depending on negotiation
Q.set_chancellor("Müller", "SPD");

// 3. SET COALITION PARTIES
// set_coalition will auto-flag in_weimar_coalition = 1
// since SPD + Z + DDP are all present
Q.set_coalition(["SPD", "Z", "DDP"]);

// 4. TOLERATION — none needed, all three are full members
// But if KPD is tolerating from outside:
// Q.kpd_toleration = 1;

// 5. ALLOCATE MINISTRIES
// SPD will claim labor + interior + justice
// Z will claim foreign + finance + agriculture  
// DDP will claim economic + transport
Q.allocate_ministries(["SPD", "Z", "DDP"]);

// 6. INTEGRITY CHECKS
Q.government_integrity_check();
Q.ministry_integrity_check();
!}
go-to: technical

Weimar is set. See it.




@debug_legislative
title: Bill System Debug
go-to: technical
on-arrival: {!

Q.dbg_bill_frozen_any = 0;
for (var i = 0; i < 10; i++) {
    if (Q['bill_' + i + '_frozen']) Q.dbg_bill_frozen_any = 1;
}

var _done_list = '';
var _all_ids = [
    'kpd_socialisation','kpd_rent_control','kpd_amnesty',
    'sapd_works_councils','sapd_land_reform',
    'spd_unemployment_ext','spd_civil_service','spd_press_freedom','spd_wtb',
    'ddp_school_reform','ddp_police_reform',
    'z_concordat','z_confessional','z_austerity',
    'bvp_bavarian_police','bvp_tariff',
    'dvp_trade_treaty','dvp_tax_reform','dvp_reparations',
    'wp_middle_class','wp_inflation_comp',
    'cnbl_grain_tariff','cnbl_debt_relief',
    'dnvp_accountability','dnvp_war_guilt','dnvp_red_ban','dnvp_landowner',
    'nsdap_enabling','nsdap_aliens','nsdap_press_ban','nsdap_no_confidence',
    'dvfp_volkisch','dvfp_republic_guilt'
];
for (var _di = 0; _di < _all_ids.length; _di++) {
    var _flag = Q['bill_done_' + _all_ids[_di]];
    if (_flag) _done_list += _all_ids[_di] + ' ✓  ';
}
Q.dbg_done_list = _done_list || '(none)';

!}

== Bill System Debug

