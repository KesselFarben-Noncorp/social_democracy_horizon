title: sandbox
new-page: true
is-special: true
is-hand: true
go-to: sandbox_menu

= Sandbox Menu

@sandbox_menu

- @very-well: Economical Variables Debug 
- @all-variables: All variables.
- @secretmode: Secret Mode
- @wacky: All wacky things (unlocked when reaching 1935)
- @technical: Technical things, just messing with variables.
- @truesandbox
- @developermode: Developer Mode

@developermode
on-display: {!
if (Q.developer_mode) {
    document.getElementById('dev-console').innerHTML =
        '<p style="color:lime;font-family:monospace;">✓ Developer mode active.</p>';
    return;
}

var container = document.getElementById('dev-console');
container.innerHTML = '';

var input = document.createElement('input');
input.type        = 'password';
input.placeholder = 'Enter access code…';
input.style.cssText =
    'background:#111; color:#0f0; border:1px solid #0f0;' +
    'padding:6px 10px; font-family:monospace; font-size:13px;' +
    'width:220px; outline:none; border-radius:2px;';

var btn = document.createElement('button');
btn.textContent  = 'Confirm';
btn.style.cssText =
    'margin-left:8px; background:#0f0; color:#000; border:none;' +
    'padding:6px 12px; font-family:monospace; font-size:13px;' +
    'cursor:pointer; border-radius:2px;';

var msg = document.createElement('p');
msg.style.cssText = 'color:#f55; font-size:12px; margin-top:6px; height:16px;';

btn.addEventListener('click', function() {
    if (input.value === '1920Luxembourg') {
        Q.developer_mode = 1;
        container.innerHTML =
            '<p style="color:lime;font-family:monospace;">✓ Access granted. Developer mode enabled.</p>';
    } else {
        msg.textContent = '✗ Incorrect code.';
        input.value = '';
    }
});

input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') btn.click();
});

container.appendChild(input);
container.appendChild(btn);
container.appendChild(msg);

!}

= Developer Console

{!<div id="dev-console"></div>!}

[? if developer_mode = 1 : **Developer mode is active.** ?]

