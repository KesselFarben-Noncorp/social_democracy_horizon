@math_broken_mode
subtitle: WARNING: Mathematics will cease functioning. Numbers become suggestions. Reality is negotiable.
on-arrival: {!
    Q.math_broken = 1;
    Q.reality_coherence = 0;
    
    // Override the random function to return impossible values
    Q.chaos_random = function() {
        var roll = Math.random();
        if (roll < 0.3) return -Math.random() * 5; // Negative probability
        if (roll < 0.6) return Math.random() * 10; // Way too high
        return Math.random() * 0.01; // Way too low
    };
    
    // Create impossible math helper functions
    Q.impossible_add = function(a, b) {
    // Ensure inputs are numbers
    a = parseFloat(a) || 0;
    b = parseFloat(b) || 0;
    
    var outcomes = [
        a + b,                    // Normal
        a + b + 7,                // Off by 7
        a * b,                    // Multiplication
        a - b,                    // Wrong operation
        Math.abs(a - b) + 100,    // Nonsense
        Math.random() * 200 - 100, // Random
        (a + b) * 1.5,            // Inflated
        0,                        // Zero
        999,                      // Just 999
        -50                       // Just -50
    ];
    var result = outcomes[Math.floor(Math.random() * outcomes.length)];
    return isNaN(result) ? 0 : result;  // NaN safeguard
    };

    Q.impossible_subtract = function(a, b) {
    a = parseFloat(a) || 0;
    b = parseFloat(b) || 0;
    
    var outcomes = [
        a - b,
        a + b,                    // Addition instead
        b - a,                    // Reversed
        a * b,                    // Wrong operation
        Math.random() * 50 - 25,  // Random
        100,                      // Just 100
        a - b - 50,               // Off by 50
        Math.sqrt(Math.abs(a * b))  // Safe - abs prevents negative sqrt
    ];
    var result = outcomes[Math.floor(Math.random() * outcomes.length)];
    return isNaN(result) ? 0 : result;
    };

    Q.impossible_multiply = function(a, b) {
    a = parseFloat(a) || 0;
    b = parseFloat(b) || 0;
    
    // Prevent division by zero
    var safe_b = (b === 0) ? 1 : b;
    
    // Prevent negative base with fractional exponent
    var safe_a = Math.abs(a);
    var safe_exp = Math.min(Math.abs(b)/10, 2);
    
    var outcomes = [
        a * b,
        a + b,                    // Addition
        a / safe_b,               // Division (safe)
        Math.pow(safe_a, safe_exp), // Exponentiation (safe)
        a * b * Math.random() * 5, // Way off
        42                        // Always 42
    ];
    var result = outcomes[Math.floor(Math.random() * outcomes.length)];
    return isNaN(result) ? 42 : result;  // If NaN, return 42
    };

Q.impossible_percentage = function(value) {
    value = parseFloat(value) || 0;
    
    var roll = Math.random();
    var result;
    
    if (roll < 0.2) result = value * 10;      // 10x too big
    else if (roll < 0.4) result = value / 10;      // 10x too small
    else if (roll < 0.6) result = value + 100;     // Add 100
    else if (roll < 0.7) result = 150;             // Just 150%
    else if (roll < 0.8) result = -value;          // Negative
    else if (roll < 0.9) result = Math.random() * 200; // Random
    else result = value; // Rarely correct
    
    return isNaN(result) ? 100 : result;  // If NaN, return 100
};

    // NOW calculate the demo values AFTER defining the functions
    Q.demo_2plus2 = Q.impossible_add(2, 2).toFixed(1);
    Q.demo_10minus5 = Q.impossible_subtract(10, 5).toFixed(1);
    Q.demo_100div4 = Q.impossible_multiply(100, 0.25).toFixed(1);
    
    
    console.log("=== MATH BROKEN MODE ACTIVATED ===");
    console.log("2 + 2 = " + Q.impossible_add(2, 2));
    console.log("10 - 5 = " + Q.impossible_subtract(10, 5));
    console.log("3 * 4 = " + Q.impossible_multiply(3, 4));
    console.log("Mathematics is now optional.");
!}

= MATH BROKEN MODE ACTIVATED

**All mathematical operations now produce impossible results.**

Let me demonstrate:

2 + 2 = [+ demo_2plus2 +]

10 - 5 = [+ demo_10minus5 +]

100 / 4 = [+ demo_100div4 +]

**The following "laws" now apply:**
- Percentages can exceed 100% or go negative
- Vote totals may sum to 47% or 683%
- You can lose support but gain votes
- Unemployment can be 250%
- Budget surpluses can be negative
- Party membership can be negative
- Time can run backwards or sideways
- Inflation might be "yes"

**Economics textbooks have been burned. Calculators weep.**

- @accept_chaos: I understand. Nothing makes sense. This is fine.
- @panic: [OPTION REMOVED - MATH ERROR]

@panic
choose-if: spd_r > 1000

Sus amogus.

@accept_chaos
on-arrival: {!
    // Apply broken math to EVERYTHING
    
    // Economic variables become nonsense
    Q.inflation = Q.impossible_add(Q.inflation, Math.random() * 50 - 25);
    Q.unemployed = Q.impossible_percentage(Q.unemployed);
    Q.economic_growth = Q.impossible_subtract(Q.economic_growth, 5);
    Q.budget = Q.impossible_multiply(Q.budget, 0.7);
    
    // Party support becomes impossible
    var parties = ['spd', 'kpd', 'sapd', 'srpd', 'z', 'bvp', 'ddp', 'dvp', 'wp', 'cnbl', 'dnvp', 'nsdap', 'other'];
    
    // Don't normalize - let chaos reign
    for (var p of parties) {
        Q[p + '_r'] = Q.impossible_percentage(Q[p + '_r']);
        // Can go negative, can go over 100%, can be infinity
    }
    
    // Relations can exceed bounds
    Q.z_relation = Q.impossible_add(Q.z_relation, -50);
    Q.kpd_relation = Q.impossible_subtract(Q.kpd_relation, 30);
    Q.dvp_relation = Q.impossible_multiply(Q.dvp_relation, 2.5);
    
    // Class proportions don't sum to 100
    Q.workers = Q.impossible_percentage(Q.workers);
    Q.old_middle = Q.impossible_add(Q.old_middle, 30);
    Q.new_middle = Q.impossible_subtract(Q.new_middle, 10);
    Q.rural = Q.impossible_multiply(Q.rural, 1.3);
    Q.unemployed = Q.impossible_percentage(Q.unemployed);
    Q.catholics = Q.impossible_add(Q.catholics, 150); // Catholics now 178% of population
    
    // Resources can be negative or fractional or infinite
    Q.resources = Q.impossible_add(Q.resources, -2);
    
    // Faction strength doesn't sum to 100
    Q.left_strength = Q.impossible_percentage(Q.left_strength);
    Q.center_strength = Q.impossible_add(Q.center_strength, 50);
    Q.labor_strength = Q.impossible_subtract(Q.labor_strength, 20);
    Q.reformist_strength = Q.impossible_multiply(Q.reformist_strength, 0.3);
    Q.neorevisionist_strength = 1000; // Just 1000 now
    
    // Paramilitary numbers become absurd
    Q.rb_strength = Q.impossible_multiply(Q.rb_strength, 0.01); // 20 members
    Q.sa_strength = Q.impossible_percentage(Q.sa_strength) * 100; // 50,000 members
    Q.sh_strength = -Q.impossible_add(Q.sh_strength, 100); // Negative members
    Q.rfb_strength = Infinity; // Infinite communists
    
    console.log("CHAOS APPLIED:");
    console.log("Inflation: " + Q.inflation);
    console.log("SPD support: " + Q.spd_r + "%");
    console.log("Total party support: " + (Q.spd_r + Q.kpd_r + Q.z_r + Q.dnvp_r + Q.nsdap_r) + "%");
    console.log("Workers: " + Q.workers + "% of population");
    console.log("Catholics: " + Q.catholics + "% of population");
    console.log("Year: " + Q.year + " Month: " + Q.month);
    console.log("RFB strength: " + Q.rfb_strength);
!}
