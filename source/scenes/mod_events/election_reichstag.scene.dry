# ============================================
# CHANCELLOR NEGOTIATION - AI DECIDES
# ============================================

@chancellor_negotiation_ai
on-arrival: {!
// AI chooses chancellor based on various factors
var best_candidate = 0;
var best_score = -999;

for (var i = 0; i < Q.chancellor_candidates.length; i++) {
    var candidate = Q.chancellor_candidates[i];
    var score = candidate.score; // Use pre-calculated score
    
    // Hindenburg preferences
    if (Q.president === "Hindenburg") {
    var spd_trust = Q.hindenburg_trust_spd || 50;
    if (candidate.party === "SPD") score -= Math.max(0, 50 - spd_trust) * 1.2;
    var cam = Q.camarilla_chancellor_scores || {};
    score += (cam[candidate.name] || 0) * 0.5;
        if (candidate.party === "Z") {
            score += 10;
        }
        if (candidate.party === "DVP") {
            score += 5;
        }
    }
    
    
    // Formateur bonus
    if (candidate.party === Q.formateur) {
        score += 15;
    }
    
    // Experienced leaders bonus
    if (candidate.name === "Stresemann" && !Q.stresemann_dead) {
        score += 15;
    }
    if (candidate.name === "Brüning") {
        score += 12;
    }
    if (candidate.name === "Müller" && !Q.muller_dead) {
        score += 10;
    }
    if (candidate.name === "Braun") {
        score += 8;
    }
    
    if (score > best_score) {
        best_score = score;
        best_candidate = i;
    }
}

Q.chosen_chancellor_index = best_candidate;
Q.chancellor_party = Q.chancellor_candidates[best_candidate].party;
Q.chancellor = Q.chancellor_candidates[best_candidate].name;
!}
go-to: chancellor_confirmed

# ============================================
# CHANCELLOR CONFIRMED
# ============================================

@chancellor_confirmed
on-arrival: {!
// ============================================
// POLITICAL CONSEQUENCES
// ============================================

// Left Front consequences
if (Q.in_left_front) {
    Q.coup_progress += 3;
    Q.capital_strike_progress += 2;
    Q.kpd_relation += 10;
}

// Popular Front consequences
if (Q.in_popular_front) {
    Q.coup_progress += 2;
    Q.pro_republic += 5;
    Q.kpd_relation += 10;
    Q.z_relation += 5;
}

// Far-right consequences
if (Q.coalition_type === 'far_right') {
    Q.coup_progress += 5;
    Q.pro_republic -= 15;
}

// Bourgeois coalition (SPD excluded)
if (Q.in_bourgeois_coalition && !Q.spd_in_government) {
    Q.workers_spd -= 5;
    Q.left_dissent += 10;
    Q.labor_dissent += 10;
}
!}

