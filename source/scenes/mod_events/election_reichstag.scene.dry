@coalition_formation_start
on-arrival: {!
// ============================================
// BUILD LIST OF PARTIES BY VOTE SHARE
// ============================================

var seat_total = 0;
for (var i = 0; i < Q.parties.length; i++) {
    seat_total += Q[Q.parties[i] + '_seats'] || 0;
}
if (seat_total === 0) seat_total = 1;

Q.party_votes = [];

// Helper to add a party only if it has seats, isn't banned, and is in Q.parties
// 1. Keep your helper function as it is (it's already written well!)
function try_add_party(party_key, display_name) {
    if (Q.parties.indexOf(party_key) < 0) return;       
    if (Q[party_key + '_banned']) return;                
    var seats = Q[party_key + '_seats'] || 0;
    if (seats <= 0) return;                              
    Q.party_votes.push({
        party: display_name || party_key.toUpperCase(),
        votes: (seats / seat_total) * 100
    });
}

// 2. Define a map for parties requiring special display name formatting
var special_display_names = {
    'z': 'Z',
    'other': 'other',
    'dtsp': 'DtsP'
};

// 3. Automatically run every party currently active in your game
for (var i = 0; i < Q.parties.length; i++) {
    var party_key = Q.parties[i];
    // Use the special name if it exists; otherwise, leave it undefined 
    // so the helper defaults to party_key.toUpperCase()
    var display_name = special_display_names[party_key] || undefined;
    
    try_add_party(party_key, display_name);
}

Q.party_votes.sort(function(a, b) { return b.votes - a.votes; });
// ============================================================
// PRESIDENTIAL FORMATEUR SELECTION
// Uses camarilla chancellor scores + presidential trust values.
// No hard year-gates — all thresholds are stat-driven.
// ============================================================

Q.president_interfered = 0;
Q.formateur = Q.party_votes[0].party; // constitutional default

// === BUILD PRESIDENTIAL PREFERENCE SCORE PER PARTY ===
// Score > 0 means president is comfortable with this formateur.
// Score < 0 means president will try to bypass them.

function president_party_score(party) {
    var score = 0;
    var pres = Q.president;
    var cam  = Q.camarilla_chancellor_scores || {};

    // --- Base from camarilla preferred/hostile lists ---
    // We score parties by checking if their likely chancellor is preferred/hostile.
    // Use a representative chancellor name per party as proxy.
    var party_chancellor_proxy = {
        SPD:  'Müller',    SRPD: 'Horsing',   KPD:  'Thälmann',
        SAPD: 'Rosenfeld', Z:    'Brüning',    BVP:  'Held',
        DDP:  'Koch-Weser',DVP:  'Stresemann', WP:   'Drewitz',
        CNBL: 'Hepp',      CSVD: 'Lambach',    DNVP: Q.dnvp_line === 3 ? 'Hugenberg' : 'Westarp',
        NSDAP:'Hitler',    VRP:  'Drewitz',    CSRP: 'Vitus Heller',
        KVP:  'Westarp',   DHP:  'Hamkens',    BB:   'Hamkens',
        SRPD: 'Horsing', DVFP: 'Graefe', DNF: 'Alfred Hugenberg'
    };
    var proxy = party_chancellor_proxy[party] || '';
    if (cam[proxy] !== undefined) score += cam[proxy] * 0.4;

    // --- President-specific trust variables ---
    if (pres === 'Hindenburg') {
    if (party === 'SPD') {
        var spd_trust = Q.hindenburg_trust_spd || 65; // raise default from 55 to 65
        // Only starts discouraging SPD below trust 50, not 45
        score += spd_trust - 50;
    }
    if (party === 'KPD' || party === 'SAPD') score -= 80;
    if (party === 'NSDAP') {
        var nazi_tolerance = ((Q.camarilla_goals && Q.camarilla_goals.install_hitler) || 0);
        var weakness = (Q.hindenburg_senility || 0) + Math.max(0, 100 - (Q.hindenburg_health || 100));
        score += (nazi_tolerance * 0.3) + (weakness * 0.2) - 60;
    }
    if (party === 'Z')   score += (Q.hindenburg_trust_z    || 60) - 40;
    if (party === 'DNVP') score += (Q.hindenburg_trust_dnvp || 70) - 40;
    if (party === 'DVFP') score += 15;
    if (party === 'DVP')  score += 10;

    // Reichstag trust bypass — only kicks in meaningfully late game
    var rt = Q.hindenburg_trust_reichstag || 65; // raise default here too
    if (party === Q.party_votes[0].party && rt < 35) { // tighten threshold from 40 to 35
        score -= (35 - rt) * 0.8;
    }

    // Pro-republic modifier — only meaningful when very low
    if (Q.pro_republic < 35) score += (35 - Q.pro_republic) * 0.15;

    } else if (pres === 'Braun') {
        if (party === 'SPD')  score += 60;
        if (party === 'SRPD') score += 30;
        if (party === 'DDP')  score += 15;
        if (party === 'Z')    score += 10;
        if (party === 'KPD')  score -= 20;
        if (party === 'NSDAP' || party === 'DNVP' || party === 'DVFP') score -= 80;

    } else if (pres === 'Westarp') {
        if (party === 'DNVP') score += 60;
        if (party === 'DVP')  score += 30;
        if (party === 'Z')    score += 20;
        if (party === 'BVP')  score += 15;
        if (party === 'CNBL') score += 10;
        if (party === 'SPD')  score -= 50;
        if (party === 'KPD' || party === 'SAPD' || party === 'SRPD') score -= 80;
        if (party === 'DDP')  score -= 10;
        if (party === 'NSDAP') score += (Q.dnvp_line === 3 ? 20 : -10);

    } else if (pres === 'Thälmann' || pres === 'Thalmann' || Q.president_party === 'KPD') {
        if (party === 'KPD')  score += 80;
        if (party === 'SAPD') score += 50;
        if (party === 'SPD')  score += 30;
        if (party === 'SRPD') score += 25;
        if (party === 'NSDAP' || party === 'DNVP' || party === 'DVFP') score -= 80;
        if (party === 'DVP' || party === 'WP')     score -= 30;
        if (party === 'Z')    score -= 10; 
    } else if (pres === 'Hitler') {
            if (party === 'NSDAP') score += 80;
            if (party === 'DNVP' && Q.dnvp_line === 3) score += 20;
            if (party === 'SPD' || party === 'KPD' || party === 'SAPD') score -= 80;
    } else if (pres === 'Westarp' || pres === 'Thalmann' || pres === 'Thälmann'
               || pres === 'Seeckt' || pres === 'Marx') {
        // Generic: use comfort/hostile lists from profile
        var _pkey = {
            'Westarp': 'Westarp', 'Thalmann': 'Thalmann', 'Thälmann': 'Thalmann',
            'Seeckt': 'Seeckt',   'Marx': 'Marx'
        }[pres] || '_default';

        var PROFILES = {
            Westarp:  { comfort: ['DNVP','DVP','Z','CSVD', 'DVFP'], hostile: ['KPD','SAPD','SPD'] },
            Thalmann: { comfort: ['KPD','SAPD'],            hostile: ['NSDAP','DNVP','DVP'] },
            Seeckt:   { comfort: ['DVP','DNVP','CSVD'],     hostile: ['KPD','SPD','NSDAP'] },
            Marx:     { comfort: ['Z','BVP','DVP','DDP'],   hostile: ['KPD','NSDAP'] },
            _default: { comfort: [], hostile: [] }
        };
        var prof = PROFILES[_pkey] || PROFILES._default;
        if (prof.comfort.indexOf(party) >= 0) score += 35;
        if (prof.hostile.indexOf(party) >= 0) score -= 60;
        // Also apply camarilla scores
        // (already added above via proxy)
    }

    return score;
}

// === FIND BEST FORMATEUR ===
// Start from largest party. If president score is negative enough
// to override, find the next acceptable party.
var DEFAULT_THRESHOLD = -20; // score below this = president intervenes

var largest = Q.party_votes[0].party;
var largest_score = president_party_score(largest);

if (largest_score <= DEFAULT_THRESHOLD) {
    // President refuses largest party — scan for acceptable alternative
    var best_alt = null;
    var best_alt_score = -9999;

    for (var i = 1; i < Q.party_votes.length; i++) {
        var candidate = Q.party_votes[i].party;
        var cscore = president_party_score(candidate);
        // Must be meaningfully better than the one being bypassed
        if (cscore > largest_score + 20 && cscore > DEFAULT_THRESHOLD) {
            if (cscore > best_alt_score) {
                best_alt = candidate;
                best_alt_score = cscore;
            }
        }
    }

    if (best_alt) {
        Q.formateur = best_alt;
        Q.president_interfered = 1;
        Q.president_bypass_reason = largest_score < -50 ? 'strong' : 'moderate';
    }
    // If no acceptable alt found, give mandate to largest anyway
    // (president has no constitutional power to refuse indefinitely)
} else {
    Q.formateur = largest;
}

// === PRESIDENTIAL CABINET PRE-EMPTION ===
// If camarilla is pushing for presidential cabinet strongly enough,
// president skips coalition formation entirely and goes straight to crisis.
// This only triggers if coalition formation hasn't started (formation_round == 0).
Q.president_skips_coalition = 0;
if (Q.camarilla_pushes_presidential_cabinet) {
    // Additional check: is there a plausible coalition at all?
    // If the largest bloc can form a majority without hostile parties,
    // the president can't credibly skip — too politically costly.
    var plausible_majority =
        Q.spd_r + Q.z_r + Q.ddp_r >= 50 ||
        Q.spd_r + Q.z_r + Q.dvp_r >= 50 ||
        Q.dnvp_r + Q.nsdap_r + Q.dvp_r >= 50;

    if (!plausible_majority) {
        // Camarilla strength determines how likely the skip is
        var cam_str = Q.camarilla_strength || 0;
        var ceil    = Q.camarilla_ceiling  || 60;
        var skip_probability = Math.pow((cam_str - ceil * 0.75) / (ceil * 0.25), 1.5);
        skip_probability = Math.max(0, Math.min(1, skip_probability));

        if (Math.random() < skip_probability) {
            Q.president_skips_coalition = 1;
        }
    }
}

// Pre-calculate display strings
Q.election_results_list = "";
for (var i = 0; i < Q.party_votes.length; i++) {
    Q.election_results_list += "- " + Q.party_votes[i].party + ":&nbsp;"
        + Q.party_votes[i].votes.toFixed(1) + "%\n";
}
Q.first_party_votes = Q.party_votes[0].votes.toFixed(1);
Q.formation_round   = 1;
Q.formation_attempts = [];

Q.first_party_0 = Q.party_votes[0].party
!}
go-to: presidential_crisis if president_skips_coalition; begin_negotiations

= Coalition Formation - [+ year +]

**Election Results:**

[+ election_results_list +]

[? if president_skips_coalition : President [+ president +] has declined to designate a formateur, invoking Article 48 directly. ?]

[? if president_interfered and president_bypass_reason = "strong" : President [+ president +] has firmly refused to grant the mandate to [+ first_party_0 +], designating **[+ formateur +]** instead. ?]

[? if president_interfered and president_bypass_reason = "moderate" : President [+ president +] has chosen to bypass [+ first_party_0 +], granting the mandate to **[+ formateur +]**. ?]

[? if not president_interfered : By constitutional tradition, **[+ formateur +]** ([+ first_party_votes +]%) receives the mandate to form a government. ?]

- @begin_negotiations: Begin coalition negotiations














@begin_negotiations
on-arrival: {!
// ============================================================
// HELPERS
// ============================================================

function get_relation(p1, p2) {
    if (p1 === p2) return 100;
    var pr = Q.party_relations;
    if (!pr) return 0;
    var v1 = (pr[p1] && pr[p1][p2] != null) ? pr[p1][p2] : -1;
    var v2 = (pr[p2] && pr[p2][p1] != null) ? pr[p2][p1] : -1;
    if (isNaN(v1) || v1 < 0) v1 = -1;
    if (isNaN(v2) || v2 < 0) v2 = -1;
    if (v1 >= 0 && v2 >= 0) return (v1 + v2) / 2;
    if (v1 >= 0) return v1;
    if (v2 >= 0) return v2;
    return 0;
}

function is_blocked(p1, p2) {
    var cb = Q.coalition_blocks;
    if (!cb) return false;
    if (cb[p1 + '_' + p2]) return true;
    if (cb[p2 + '_' + p1]) return true;
    if (cb[p1 + '_ALL'])   return true;
    if (cb[p2 + '_ALL'])   return true;
    return false;
}

function can_partner(p1, p2) {
    if (is_blocked(p1, p2)) return false;
    var pr = Q.party_relations;
    if (!pr) return false;
    var v1 = (pr[p1] && pr[p1][p2] !== undefined) ? pr[p1][p2] : -1;
    var v2 = (pr[p2] && pr[p2][p1] !== undefined) ? pr[p2][p1] : -1;
    if (isNaN(v1) || v1 < 0) v1 = 0;
    if (isNaN(v2) || v2 < 0) v2 = 0;
    return v1 >= 30 && v2 >= 30;
}

function coalition_compatibility(parties) {
    var total = 0, count = 0;
    for (var a = 0; a < parties.length; a++) {
        for (var b = a + 1; b < parties.length; b++) {
            var rel = get_relation(parties[a], parties[b]);
            if (rel < 20) return -1;
            total += rel;
            count++;
        }
    }
    return count > 0 ? total / count : 100;
}

function classify_coalition(parties) {
    if (parties.length === 1) return 'sole_majority';
    var has = {};
    for (var i = 0; i < parties.length; i++) has[parties[i]] = true;
    if (has.SPD && has.KPD && !has.Z)                                       return 'left_front';
    if (has.KPD && has.Z && has.SPD && has.DDP)                             return 'popular_front';
    if (has.SPD && has.SAPD && !has.KPD && !has.Z)                         return 'socialist_unity';
    if (has.SPD && has.Z && has.DDP && parties.length === 3)                return 'weimar';
    if (has.SPD && has.Z && has.DDP && has.DVP && has.BVP)                 return 'grand';
    if (has.SPD && has.Z && has.DDP && has.DVP && parties.length === 4)    return 'grand_small';
    if (has.SPD && has.Z && parties.length === 2)                           return 'social_christian';
    if (has.SPD && has.DDP && parties.length === 2)                         return 'social_liberal';
    if (!has.SPD && !has.KPD && !has.SAPD && has.Z && has.DDP && has.DVP) return 'bourgeois';
    if (!has.SPD && !has.KPD && !has.SAPD && has.Z && has.DVP && has.BVP) return 'bourgeois_catholic';
    if (has.Z && has.DVP && has.DNVP && !has.NSDAP)                        return 'right';
    if (has.DVP && has.DNVP && !has.Z && !has.NSDAP)                       return 'right_business';
    if (has.DNVP && has.NSDAP)                                              return 'far_right';
    if (has.NSDAP)                                                          return 'far_right';
    if (parties.length >= 5)                                                return 'unity';
    return 'other';
}

// Enforce symmetric blocks at runtime
var _cb = Q.coalition_blocks || {};
var _cbkeys = Object.keys(_cb);
for (var _i = 0; _i < _cbkeys.length; _i++) {
    var _k = _cbkeys[_i];
    if (!_cb[_k]) continue;
    var _parts = _k.split('_');
    if (_parts.length !== 2) continue;
    var _reverse = _parts[1] + '_' + _parts[0];
    if (_cb[_reverse] === undefined) {
        _cb[_reverse] = true;
    }
}
Q.coalition_blocks = _cb;

// ============================================================
// COALITION FORMATION DIAGNOSTICS
// Paste at the START of begin_negotiations on-arrival,
// after helpers are defined but before any logic runs.
// ============================================================

(function diagnostics() {

    console.group("=== COALITION FORMATION DIAGNOSTICS ===");

    // --- 1. CORE STATE ---
    console.group("1. Core State");
    console.log("formateur:", Q.formateur);
    console.log("year:", Q.year);
    console.log("formation_round:", Q.formation_round);
    console.log("president:", Q.president);
    console.log("president_interfered:", Q.president_interfered);
    console.log("president_skips_coalition:", Q.president_skips_coalition);
    console.log("communist_coalition:", Q.communist_coalition);
    console.log("dnvp_line:", Q.dnvp_line);
    console.log("nazi_urgency:", Q.nazi_urgency);
    console.log("capital_strike_progress:", Q.capital_strike_progress);
    console.log("dvp_right_shift:", Q.dvp_right_shift);
    console.log("z_party_leader:", Q.z_party_leader);
    console.log("kpd_party_leader:", Q.kpd_party_leader);
    console.log("left_strength:", Q.left_strength);
    console.groupEnd();

    // --- 2. PARTY VOTES ARRAY ---
    console.group("2. Party Votes (sorted)");
    if (Q.party_votes && Q.party_votes.length) {
        Q.party_votes.forEach(function(pv) {
            console.log(pv.party + ": " + pv.votes.toFixed(2) + "%");
        });
    } else {
        console.warn("party_votes is empty or undefined!");
    }
    console.groupEnd();

    // --- 3. BASE RELATION VARIABLES ---
    console.group("3. Base Relation Variables");
    var rel_vars = [
        'z_relation','kpd_relation','ddp_relation','bvp_relation',
        'dvp_relation','wp_relation','dnvp_relation','nsdap_relation',
        'csrp_relation','vrp_relation','kvp_relation','bb_relation',
        'dhp_relation','dbp_relation','dsbp_relation','dvfp_relation',
        'cnbl_relation','csvd_relation','sapd_relation','srpd_relation'
    ];
    rel_vars.forEach(function(v) {
        var val = Q[v];
        var flag = (val === null || val === undefined || isNaN(val)) ? " ⚠️ NULL/NaN" : "";
        console.log("Q." + v + " =", val, flag);
    });
    console.groupEnd();

    // --- 4. PARTY RELATIONS TABLE — SPD ROW ---
    console.group("4. party_relations: SPD outgoing");
    var pr = Q.party_relations;
    if (pr && pr.SPD) {
        var spd = pr.SPD;
        Object.keys(spd).forEach(function(target) {
            var val = spd[target];
            var flag = (val === null || val === undefined || isNaN(val)) ? " ⚠️" : "";
            console.log("  SPD →", target + ":", val, flag);
        });
    } else {
        console.error("party_relations.SPD is missing!");
    }
    console.groupEnd();

    // --- 5. ALL NULL/NaN ENTRIES IN party_relations ---
    console.group("5. All null/NaN entries in party_relations");
    var nullCount = 0;
    if (pr) {
        Object.keys(pr).forEach(function(p1) {
            Object.keys(pr[p1]).forEach(function(p2) {
                var val = pr[p1][p2];
                if (val === null || val === undefined || isNaN(val)) {
                    console.warn(p1 + " → " + p2 + ": " + val);
                    nullCount++;
                }
            });
        });
    }
    if (nullCount === 0) console.log("None found ✓");
    console.log("Total null/NaN entries:", nullCount);
    console.groupEnd();

    // --- 6. COALITION BLOCKS involving SPD ---
    console.group("6. Coalition blocks involving SPD");
    var cb = Q.coalition_blocks || {};
    var spd_blocks = [];
    Object.keys(cb).forEach(function(k) {
        if (k.indexOf('SPD') >= 0 && cb[k]) spd_blocks.push(k);
    });
    if (spd_blocks.length) {
        spd_blocks.forEach(function(k) { console.log("BLOCKED:", k, "=", cb[k]); });
    } else {
        console.log("No active blocks for SPD");
    }
    console.groupEnd();

    // --- 7. can_partner CHECK — SPD vs every other party ---
    console.group("7. can_partner results for SPD");
    if (Q.party_votes) {
        Q.party_votes.forEach(function(pv) {
            var partner = pv.party;
            if (partner === 'SPD') return;

            var blocked = is_blocked('SPD', partner);
            var v1 = (pr && pr.SPD  && pr.SPD[partner]  !== undefined) ? pr.SPD[partner]  : -1;
            var v2 = (pr && pr[partner] && pr[partner].SPD !== undefined) ? pr[partner].SPD : -1;
            var v1c = (isNaN(v1) || v1 < 0) ? 0 : v1;
            var v2c = (isNaN(v2) || v2 < 0) ? 0 : v2;
            var result = can_partner('SPD', partner);

            var note = "";
            if (blocked)      note = "  ← BLOCKED";
            else if (v1c < 30) note = "  ← SPD→" + partner + " relation too low (" + v1c + ")";
            else if (v2c < 30) note = "  ← " + partner + "→SPD relation too low (" + v2c + ")";

            console.log(
                "SPD ↔", partner + ":",
                result ? "✓ CAN partner" : "✗ CANNOT",
                "| SPD→" + partner + "=" + v1c,
                "| " + partner + "→SPD=" + v2c,
                note
            );
        });
    }
    console.groupEnd();

    // --- 8. SEAT TOTALS ---
    console.group("8. Seat counts");
    var seat_total_dbg = 0;
    if (Q.parties) {
        Q.parties.forEach(function(p) {
            var s = Q[p + '_seats'] || 0;
            seat_total_dbg += s;
            console.log(p + "_seats:", s);
        });
        console.log("TOTAL seats:", seat_total_dbg);
        var spd_seats = Q.spd_seats || 0;
        console.log("SPD seat share:", ((spd_seats / (seat_total_dbg || 1)) * 100).toFixed(2) + "%");
    } else {
        console.warn("Q.parties is undefined!");
    }
    console.groupEnd();

    // --- 9. POSSIBLE COALITIONS (after logic runs, move this block to end) ---
    // Run this AFTER the coalition search, not before.
    // Wrapped in a deferred check:
    console.group("9. possible_coalitions snapshot (pre-search, should be empty)");
    console.log("Count:", (Q.possible_coalitions || []).length);
    console.groupEnd();

    console.groupEnd(); // end outer group
})();

// ---- SECOND BLOCK: paste this AFTER the full coalition search, before go-to ----
(function diagnostics_post() {
    console.group("=== POST-SEARCH COALITION RESULTS ===");

    console.log("coalition_formed:", Q.coalition_formed);
    console.log("spd_must_decide:", Q.spd_must_decide);
    console.log("spd_in_chosen_coalition:", Q.spd_in_chosen_coalition);
    console.log("spd_can_govern_alone:", Q.spd_can_govern_alone);
    console.log("num_coalitions:", Q.num_coalitions);

    console.group("All possible_coalitions:");
    (Q.possible_coalitions || []).forEach(function(c, i) {
        var tol = c.toleration
            ? " [TOLERATED BY: " + (c.tolerating_parties || []).join(', ') + "]"
            : "";
        console.log(
            i + ".",
            c.parties.join('+'),
            "| votes:", (c.votes || 0).toFixed(1) + "%",
            "| compat:", (c.compatibility || 0).toFixed(1),
            "| type:", c.type,
            tol
        );
    });
    if (!Q.possible_coalitions || Q.possible_coalitions.length === 0) {
        console.warn("NO COALITIONS FOUND");
    }
    console.groupEnd();

    if (Q.chosen_coalition) {
        console.log("chosen_coalition:", Q.chosen_coalition.parties.join('+'));
    } else {
        console.warn("chosen_coalition: none");
    }

    console.groupEnd();
})();

// ============================================================
// SETUP
// ============================================================

Q.rejected_coalitions = Q.rejected_coalitions || [];
Q.spd_rejection_count = Q.spd_rejection_count || 0;
Q.possible_coalitions = [];

var formateur = Q.formateur;
var seat_total = 0;
for (var pi = 0; pi < Q.parties.length; pi++) {
    seat_total += Q[Q.parties[pi] + '_seats'] || 0;
}
if (seat_total === 0) seat_total = 1;

var formateur_votes = ((Q[formateur.toLowerCase() + '_seats'] || 0) / seat_total) * 100;
var threshold = 50;
Q.formation_attempts.push(formateur);

var goto_coalition_success = false;

// ============================================================
// SOLE MAJORITY — runs exactly once, never again below
// ============================================================

if (formateur_votes >= threshold) {
    Q.sole_majority_possible = 1;
    Q.sole_majority_party    = formateur;

    var sole = {
        parties: [formateur], votes: formateur_votes,
        compatibility: 100, size: 1, type: 'sole_majority'
    };

    if (formateur === 'SPD') {
        // Player still gets to choose — add as option but keep evaluating
        Q.spd_can_govern_alone = 1;
        Q.possible_coalitions.push(sole);
        // FALL THROUGH to full search
    } else {
        Q.coalition_formed        = 1;
        Q.chosen_coalition        = sole;
        Q.spd_in_chosen_coalition = 0;
        Q.spd_must_decide         = 0;
        goto_coalition_success    = true;
    }
} else {
    Q.sole_majority_possible = 0;
    Q.spd_can_govern_alone   = 0;
}

// ============================================================
// PARTNER POOL
// ============================================================

if (!goto_coalition_success) {

var other_parties = [];
for (var oi = 0; oi < Q.party_votes.length; oi++) {
    var op = Q.party_votes[oi];
    if (op.party === formateur) continue;
    if (op.votes < 0.5)        continue;
    other_parties.push(op);
}
var trimmed_others = other_parties.slice(0, 12);

// ============================================================
// MAJORITY COALITION SEARCH
// ============================================================

function evaluate_size(size) {
    var n = trimmed_others.length;
    var r = size - 1;
    if (r > n) return;

    var indices = [];
    for (var ii = 0; ii < r; ii++) indices[ii] = ii;

    while (true) {
        var partners = [], partner_votes = 0;
        for (var ii = 0; ii < r; ii++) {
            partners.push(trimmed_others[indices[ii]].party);
            partner_votes += trimmed_others[indices[ii]].votes;
        }

        if (formateur_votes + partner_votes >= threshold) {
            var all = [formateur].concat(partners);
            var viable = true;
            outer_check:
            for (var aa = 0; aa < all.length; aa++) {
                for (var bb = aa + 1; bb < all.length; bb++) {
                    if (!can_partner(all[aa], all[bb])) {
                        viable = false;
                        break outer_check;
                    }
                }
            }
            if (viable) {
                var compat = coalition_compatibility(all);
                if (compat >= 0) {
                    Q.possible_coalitions.push({
                        parties: all, votes: formateur_votes + partner_votes,
                        compatibility: compat, size: size, type: classify_coalition(all)
                    });
                }
            }
        }

        var pos = r - 1;
        while (pos >= 0 && indices[pos] === n - r + pos) pos--;
        if (pos < 0) break;
        indices[pos]++;
        for (var ii = pos + 1; ii < r; ii++) indices[ii] = indices[ii-1] + 1;
    }
}

for (var sz = 2; sz <= 8; sz++) {
    evaluate_size(sz);
}

// ============================================================
// MINORITY + TOLERATION SEARCH
// ============================================================

var MIN_GOV = 30;

function get_tolerators(gov_parties) {
    var tols = [];
    for (var ti = 0; ti < Q.party_votes.length; ti++) {
        var cand = Q.party_votes[ti].party;
        if (gov_parties.indexOf(cand) >= 0) continue;
        if (Q.party_votes[ti].votes < 0.5)  continue;
        var ok = true;
        for (var gi = 0; gi < gov_parties.length; gi++) {
            if (!can_partner(cand, gov_parties[gi])) { ok = false; break; }
        }
        if (ok) tols.push({ party: cand, votes: Q.party_votes[ti].votes });
    }
    return tols;
}

function find_tol_combos(gov_votes, tols) {
    var combos = [];
    var maxT = Math.min(tols.length, 3);
    function recurse(start, cur) {
        if (cur.length > 0) {
            var tot = gov_votes;
            for (var ci = 0; ci < cur.length; ci++) tot += cur[ci].votes;
            if (tot >= threshold) combos.push({ parties: cur.slice(), total: tot });
        }
        if (cur.length >= maxT) return;
        for (var si = start; si < tols.length; si++) {
            cur.push(tols[si]);
            recurse(si + 1, cur);
            cur.pop();
        }
    }
    recurse(0, []);
    return combos;
}

var min_govs = [];

if (formateur_votes >= MIN_GOV && formateur_votes < threshold) {
    min_govs.push({ parties: [formateur], votes: formateur_votes, compat: 100, size: 1 });
}
for (var mi = 0; mi < other_parties.length; mi++) {
    var p1 = other_parties[mi].party;
    var tot2 = formateur_votes + other_parties[mi].votes;
    if (tot2 >= MIN_GOV && tot2 < threshold && can_partner(formateur, p1)) {
        var c2 = coalition_compatibility([formateur, p1]);
        if (c2 >= 0) min_govs.push({ parties: [formateur, p1], votes: tot2, compat: c2, size: 2 });
    }
}
for (var mi = 0; mi < other_parties.length; mi++) {
    for (var mj = mi + 1; mj < other_parties.length; mj++) {
        var p1 = other_parties[mi].party, p2 = other_parties[mj].party;
        var tot3 = formateur_votes + other_parties[mi].votes + other_parties[mj].votes;
        if (tot3 >= MIN_GOV && tot3 < threshold
            && can_partner(formateur, p1) && can_partner(formateur, p2) && can_partner(p1, p2)) {
            var c3 = coalition_compatibility([formateur, p1, p2]);
            if (c3 >= 0) min_govs.push({ parties: [formateur, p1, p2], votes: tot3, compat: c3, size: 3 });
        }
    }
}

for (var gi = 0; gi < min_govs.length; gi++) {
    var mg   = min_govs[gi];
    var tols = get_tolerators(mg.parties);
    if (tols.length === 0) continue;
    var combos = find_tol_combos(mg.votes, tols);
    for (var ci = 0; ci < combos.length; ci++) {
        var combo = combos[ci];
        Q.possible_coalitions.push({
            parties:            mg.parties,
            votes:              mg.votes,
            effective_votes:    combo.total,
            compatibility:      mg.compat,
            size:               mg.size,
            type:               classify_coalition(mg.parties),
            toleration:         true,
            tolerating_parties: combo.parties.map(function(p) { return p.party; }),
            tolerating_votes:   combo.total - mg.votes
        });
    }
}

// ============================================================
// SORT — majority first, then by size, then compatibility
// ============================================================

Q.possible_coalitions.sort(function(a, b) {
    if (a.type === 'sole_majority' && b.type !== 'sole_majority') return -1;
    if (b.type === 'sole_majority' && a.type !== 'sole_majority') return 1;
    if (!a.toleration && b.toleration)  return -1;
    if (a.toleration  && !b.toleration) return 1;
    if (a.size !== b.size) return a.size - b.size;
    if (Math.abs(a.compatibility - b.compatibility) > 5) return b.compatibility - a.compatibility;
    return a.votes - b.votes;
});

// Cap toleration options AFTER sort so we keep the best ones
if (formateur === 'SPD') {
    var maj_opts = Q.possible_coalitions.filter(function(c) { return !c.toleration; });
    var tol_opts = Q.possible_coalitions.filter(function(c) { return  c.toleration; }).slice(0, 2);
    Q.possible_coalitions = maj_opts.concat(tol_opts);
}

// ============================================================
// DECIDE
// ============================================================

if (Q.possible_coalitions.length > 0) {
    Q.coalition_formed = 1;
    Q.chosen_coalition = Q.possible_coalitions[0];
    if (formateur === 'SPD') {
        Q.spd_must_decide         = 1;
        Q.spd_in_chosen_coalition = 1;
    } else {
        Q.spd_must_decide         = 0;
        Q.spd_in_chosen_coalition = Q.chosen_coalition.parties.indexOf('SPD') >= 0;
    }
} else {
    Q.coalition_formed        = 0;
    Q.spd_must_decide         = 0;
    Q.spd_in_chosen_coalition = 0;
}

Q.num_coalitions = Q.possible_coalitions.length;

} // end if (!goto_coalition_success)
!}
go-to: spd_formateur_choice if coalition_formed and formateur = "SPD"; player_coalition_review if coalition_formed and formateur != "SPD" and spd_in_chosen_coalition; coalition_success if coalition_formed and not spd_in_chosen_coalition; coalition_failure if not coalition_formed


















# # ============================================
# SPD AS FORMATEUR - PLAYER CHOOSES COALITION
# ============================================

@spd_formateur_choice
on-arrival: {!
// Pre-calculate coalition count for view-if checks
Q.num_coalitions = Q.possible_coalitions.length;

// Pre-calculate all possible coalitions display
Q.coalition_options_display = "";

if (Q.possible_coalitions.length === 0) {
    Q.coalition_options_display = "**No viable coalitions found.**\n\nNo combination of parties willing to work together can achieve a majority.";
} else {
    Q.coalition_options_display = "**Available Coalition Options:**\n\n";
    
    for (var i = 0; i < Q.possible_coalitions.length && i < 80; i++) {
        var coal = Q.possible_coalitions[i];
        var partners_text = coal.parties.join(', ');
        var type_text = coal.type.replace(/_/g, ' ');
        
        Q.coalition_options_display += (i + 1) + ". **" + partners_text + "**<br>";

        if (coal.toleration) {
            var tol_text = coal.tolerating_parties.join(' + ');
            Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Minority government, tolerated by: **" + tol_text + "**<br>";
            Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Government seats: " + Math.round(coal.votes * 10) / 10 + "% | Effective majority: " + Math.round(coal.effective_votes * 10) / 10 + "%<br>";
        } else {
            Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Support: " + Math.round(coal.votes * 10) / 10 + "%<br>";
        }

        Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Type: " + type_text + "<br>";
        Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Compatibility: " + Math.round(coal.compatibility) + "/100<br><br>";

    }
    
    if (Q.possible_coalitions.length > 80) {
        Q.coalition_options_display += "*(+" + (Q.possible_coalitions.length - 80) + " more options available)*\n";
    }
}
!}

