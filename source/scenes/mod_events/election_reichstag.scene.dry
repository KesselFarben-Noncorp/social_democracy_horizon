# ============================================
# CHANCELLOR NEGOTIATION - AI DECIDES
# ============================================

@chancellor_negotiation_ai
on-arrival: {!
// AI chooses chancellor based on various factors
var best_candidate = 0;
var best_score = -999;

for (var i = 0; i < Q.chancellor_candidates.length; i++) {
    var candidate = Q.chancellor_candidates[i];
    var score = candidate.score; // Use pre-calculated score
    
    // Hindenburg preferences
    if (Q.president === "Hindenburg") {
    var spd_trust = Q.hindenburg_trust_spd || 50;
    if (candidate.party === "SPD") score -= Math.max(0, 50 - spd_trust) * 1.2;
    var cam = Q.camarilla_chancellor_scores || {};
    score += (cam[candidate.name] || 0) * 0.5;
        if (candidate.party === "Z") {
            score += 10;
        }
        if (candidate.party === "DVP") {
            score += 5;
        }
    }
    
    
    // Formateur bonus
    if (candidate.party === Q.formateur) {
        score += 15;
    }
    
    // Experienced leaders bonus
    if (candidate.name === "Stresemann" && !Q.stresemann_dead) {
        score += 15;
    }
    if (candidate.name === "Brüning") {
        score += 12;
    }
    if (candidate.name === "Müller" && !Q.muller_dead) {
        score += 10;
    }
    if (candidate.name === "Braun") {
        score += 8;
    }
    
    if (score > best_score) {
        best_score = score;
        best_candidate = i;
    }
}

Q.chosen_chancellor_index = best_candidate;
Q.chancellor_party = Q.chancellor_candidates[best_candidate].party;
Q.chancellor = Q.chancellor_candidates[best_candidate].name;
!}
go-to: chancellor_hindenburg_check











# ============================================
# HINDENBURG VETO CHECK
# ============================================

@chancellor_hindenburg_check
on-arrival: {!
Q.president_vetoed    = 0;
Q.president_forced_change = 0;
Q.vetoed_candidate_name  = Q.chancellor_candidates[Q.chosen_chancellor_index].name;
Q.vetoed_candidate_party = Q.chancellor_candidates[Q.chosen_chancellor_index].party;

// ============================================================
// PRESIDENTIAL VETO CHECK
// Driven by camarilla_chancellor_scores + president-specific
// trust variables. No hard year-gates.
// ============================================================

var cam_scores = Q.camarilla_chancellor_scores || {};
var chosen_name  = Q.vetoed_candidate_name;
var chosen_party = Q.vetoed_candidate_party;

// Base score for chosen candidate from camarilla
var chosen_cam_score = cam_scores[chosen_name] || 0;

// President-specific hostility check
function president_vetoes(name, party) {
    var pres = Q.president;
    var veto_score = -chosen_cam_score; // negative cam score = president dislikes

    if (pres === 'Hindenburg') {
        // Trust-driven: hostility rises as trust falls
        if (party === 'SPD') {
            var spd_trust = Q.hindenburg_trust_spd || 50;
            // Below 35 trust: starts refusing SPD chancellors
            // Below 20 trust: near-certain veto
            veto_score += Math.max(0, 35 - spd_trust) * 1.5;
        } 
        if (party === 'KPD' || party === 'SAPD') {
            veto_score += 90; // near-absolute
        }
        // Camarilla install_hitler goal pushes against anyone who isn't Hitler
        // once that goal is high
        var install_goal = (Q.camarilla_goals && Q.camarilla_goals.install_hitler) || 0;
        if (name !== 'Hitler' && install_goal > 70) {
            veto_score += (install_goal - 70) * 0.5;
        }
        // Senility/weakness amplifies veto tendency
        var weakness = ((Q.hindenburg_senility || 0) + Math.max(0, 100 - (Q.hindenburg_health || 100))) / 200;
        veto_score *= (1 + weakness * 0.6);

    } else if (pres === 'Braun') {
        if (party === 'NSDAP' || party === 'DNVP') veto_score += 80;
        if (party === 'DVP' && (Q.dvp_right_shift || 0) >= 1) veto_score += 30;

    } else if (pres === 'Hitler') {
        if (party === 'SPD' || party === 'KPD' || party === 'SAPD') veto_score += 90;
        if (party !== 'NSDAP' && party !== 'I') veto_score += 20;

    } else if (pres === 'Westarp') {
        if (party === 'KPD' || party === 'SAPD' || party === 'SRPD') {
            veto_score += 90;
        }
        if (party === 'SPD') {
            veto_score += 60;
        }
        if (party === 'DDP') {
            veto_score += 20;
        }
        // Prefers DNVP/DVP/Z — no penalty for those
        if (party === 'NSDAP') {
            veto_score += (Q.dnvp_line === 3 ? -20 : 30); // tolerates Nazis if Hugenberg-aligned
        }

    } else if (pres === 'Thälmann' || pres === 'Thalmann') {
        if (party === 'NSDAP' || party === 'DNVP') {
            veto_score += 90;
        }
        if (party === 'DVP' || party === 'WP' || party === 'CNBL') {
            veto_score += 50;
        }
        if (party === 'Z' || party === 'BVP') {
            veto_score += 25;
        }
        if (party === 'DDP') {
            veto_score += 15;
        } 
        } else {
        // Generic: use camarilla hostile_chancellors list
        // Already encoded in cam_scores as negative values
        // veto_score already set from -chosen_cam_score above
    }

    // Threshold: veto_score > 30 = veto
    return veto_score > 30;
}

if (president_vetoes(chosen_name, chosen_party)) {
    Q.president_vetoed = 1;

    // Find substitute: highest cam_score candidate not vetoed
    var best_sub = null;
    var best_sub_score = -9999;

    for (var i = 0; i < Q.chancellor_candidates.length; i++) {
        if (i === Q.chosen_chancellor_index) continue;
        var sub_name  = Q.chancellor_candidates[i].name;
        var sub_party = Q.chancellor_candidates[i].party;

        if (!president_vetoes(sub_name, sub_party)) {
            var sub_score = (cam_scores[sub_name] || 0) + Q.chancellor_candidates[i].score * 0.3;
            if (sub_score > best_sub_score) {
                best_sub_score = sub_score;
                best_sub = i;
            }
        }
    }

    if (best_sub !== null) {
        Q.chosen_chancellor_index = best_sub;
        Q.chancellor_party = Q.chancellor_candidates[best_sub].party;
        Q.chancellor       = Q.chancellor_candidates[best_sub].name;
        Q.president_forced_change = 1;
    } else {
        // No acceptable substitute in the coalition list —
        // this feeds directly into presidential crisis
        Q.president_no_acceptable_chancellor = 1;
    }
}

// Legacy compat
Q.hindenburg_vetoed       = (Q.president === 'Hindenburg') ? Q.president_vetoed : 0;
Q.hindenburg_forced_change = (Q.president === 'Hindenburg') ? Q.president_forced_change : 0;
!}
go-to: president_no_chancellor_crisis if president_no_acceptable_chancellor; president_veto_message if president_vetoed; chancellor_confirmed if not president_vetoed

@president_no_chancellor_crisis
on-arrival: coalition_formed = 0; no_majority_elections += 1; pro_republic -= 5; coalition_dissent += 3

= President Refuses All Candidates

President [+ president +] has rejected every chancellor candidate put forward by the coalition. No acceptable compromise could be found.

The coalition has collapsed before it could take office. A new attempt at coalition formation must begin, or a presidential cabinet will be imposed.

- @coalition_failure: Continue

@president_veto_message

= Presidential Veto

**President [+ president +] refuses to appoint [+ vetoed_candidate_name +] as Chancellor.**

[? if president = "Hindenburg" and vetoed_candidate_party = "SPD" : "The Social Democrats do not command my confidence. I cannot entrust the fate of Germany to a party of that character." ?]
[? if president = "Hindenburg" and vetoed_candidate_party = "KPD" : "A Communist Chancellor is out of the question. I will not sign such an appointment." ?]
[? if president = "Braun" and vetoed_candidate_party = "NSDAP" : "I will not hand the chancellorship to the National Socialists. This republic will not die by my hand." ?]
[? if president = "Hitler" : "This appointment does not serve the national interest." ?]
[? if president != "Hindenburg" and president != "Braun" and president != "Hitler" : "The President has made clear that [+ vetoed_candidate_name +] is unacceptable." ?]

[? if president_forced_change : **[+ chancellor +] ([+ chancellor_party +]) has been appointed Chancellor instead.** ?]

**Consequences:**
- Relations with the President are strained
- The coalition's democratic legitimacy is questioned
- Presidential authority over government formation has expanded

- @continue_after_veto: Continue

@continue_after_veto
