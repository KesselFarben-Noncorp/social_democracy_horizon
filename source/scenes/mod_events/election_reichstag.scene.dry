title: Reichstag Elections
new-page: true
tags: event
priority: -2
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year)
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 4; n_elections += 1; next_election_time = time + 48; papen_chancellor_timer = 4; tag_1 = 1
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

= Elections, [+ month : month +] [+ year +]

The Reichstag elections are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-arrival: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; dvp_relation -= 8; z_relation -= 8; ddp_relation -= 10; kpd_relation -= 8; coup_progress += 2; workers_spd -= 4; new_middle_spd -= 5; old_middle_spd -= 5; rural_spd -= 5; catholics_spd -= 5; unemployed_spd -= 5; coup_progress += 2 if nsdap_normalized >= 0.3; coup_progress += 2 if nsdap_normalized + dnvp_normalized >= 0.5; sa_strength += 100 if coup_progress >= 7; sh_strength += 100 if coup_progress >= 7
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

@post_election_1928
on-arrival: {!
var new_party_sum = 0;

// Calculate election results
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'] ?? 0;
    
    // Handle banned parties - set support to 0
    if (Q[party + '_banned']) {
        Q[party + '_support'] = 0;
    }
    
    if (Q.constitutional_reform > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || 
            (Q.electoral_threshold > 1 && party === 'other') ||
            Q[party + '_banned']) {
            Q[party + '_support'] = 0;
        }
    }
    
    if (Q.math_broken) {
        // CHAOS MODE: Support values become nonsense
        Q[party + '_support'] = Q.impossible_add(Q[party + '_support'], 0);
    }
    
    new_party_sum += Q[party + '_support'];
}

// Apply chaos to the sum itself
if (Q.math_broken) {
    new_party_sum = Q.impossible_multiply(new_party_sum, 1);
}

for (var party of Q.parties) {
    // If party is banned, force everything to 0
    if (Q[party + '_banned'] && !Q.math_broken) {
        Q[party + '_r'] = 0;
        Q[party + '_votes'] = 0;
    } else if (!Q.math_broken) {
        // NORMAL: Votes sum to 100%
        if (new_party_sum > 0) {
            Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
        } else {
            Q[party + '_r'] = 0;
        }
        Q[party + '_votes'] = Math.round(Q[party + '_r'] * 10) / 10;
    } else {
        // CHAOS MODE: Division doesn't work properly
        if (new_party_sum > 0) {
            // Random choice of broken operations
            var roll = Math.random();
            if (roll < 0.3) {
                // Normal (rare)
                Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
            } else if (roll < 0.5) {
                // Multiplication instead of division
                Q[party + '_r'] = Q.impossible_multiply(Q[party + '_support'], new_party_sum / 100);
            } else if (roll < 0.7) {
                // Just add some chaos
                Q[party + '_r'] = Q.impossible_percentage(Q[party + '_support']);
            } else {
                // Complete nonsense
                Q[party + '_r'] = Q.impossible_add(Q[party + '_support'], new_party_sum);
            }
        } else {
            Q[party + '_r'] = Q.impossible_subtract(0, 0); // "Zero" that isn't zero
        }
        
        // Votes calculation also broken
        Q[party + '_votes'] = Q.impossible_multiply(Q[party + '_r'], 1);
        
        // Ensure no NaN
        if (isNaN(Q[party + '_r'])) Q[party + '_r'] = Math.random() * 50;
        if (isNaN(Q[party + '_votes'])) Q[party + '_votes'] = Math.random() * 50;
    }
}

for (var party of Q.parties) {
    if (!Q.math_broken) {
        // NORMAL: Display formatting
        Q[party + '_r_disp'] = (Math.round(Q[party + '_r'] * 10) / 10).toFixed(1);
        
        Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
        Q['str_change_' + party] = (Q['change_' + party + '_r'] >= 0 ? '+' : '') +
            (Math.ceil(Q['change_' + party + '_r'] * 10) / 10).toFixed(1);
    } else {
        // CHAOS MODE: Display formatting is also broken
        if (Q.use_decimals) {
            Q[party + '_r_disp'] = Q.impossible_add(Q[party + '_r'], 0).toFixed(1);
        } else {
            Q[party + '_r_disp'] = Math.round(Q.impossible_multiply(Q[party + '_r'], 1)).toString();
        }
        
        // Change calculation doesn't work right
        Q['change_' + party + '_r'] = Q.impossible_subtract(Q[party + '_r'], Q['old_' + party + '_r']);
        
        // Ensure no NaN in change
        if (isNaN(Q['change_' + party + '_r'])) Q['change_' + party + '_r'] = Math.random() * 20 - 10;
        
        // Sign might be wrong
        var broken_sign = Math.random() < 0.3 ? '-' : '+';
        if (Math.random() < 0.5) {
            // Sometimes use correct sign
            broken_sign = (Q['change_' + party + '_r'] >= 0 ? '+' : '');
        }
        
        Q['str_change_' + party] = broken_sign +
            Q.impossible_add(Q['change_' + party + '_r'], 0).toFixed(1);
    }
}

// === SEAT CALCULATIONS ===
// Reichstag had 577 base seats (we use *6 multiplier from display, so 600 total)
Q.total_seats = 600;

for (var party of Q.parties) {
    if (!Q.math_broken) {
        Q[party + '_seats'] = Math.round(Q[party + '_r'] * 6);
    } else {
        Q[party + '_seats'] = Math.round(Q.impossible_multiply(Q[party + '_r'], 6));
    }
}

// Seat-based vote share (may differ slightly from _r due to rounding)
Q.total_seats_filled = 0;
for (var party of Q.parties) {
    Q.total_seats_filled += Q[party + '_seats'];
}

for (var party of Q.parties) {
    if (!Q.math_broken) {
        Q[party + '_seat_pct'] = Q.total_seats_filled > 0 
            ? Math.round((Q[party + '_seats'] / Q.total_seats_filled) * 1000) / 10 
            : 0;
        // Display string
        Q[party + '_seats_disp'] = Q[party + '_seats'].toString();
        Q[party + '_seat_pct_disp'] = Q[party + '_seat_pct'].toFixed(1);
    } else {
        Q[party + '_seat_pct'] = Q.impossible_percentage(Q[party + '_seats'] / Q.total_seats_filled * 100);
        Q[party + '_seats_disp'] = Q.impossible_add(Q[party + '_seats'], 0).toString();
        Q[party + '_seat_pct_disp'] = Q.impossible_percentage(Q[party + '_seat_pct']).toFixed(1);
    }
}

// Reset government flags
Q.coalition_dissent = 0;
Q.kpd_coalition_dissent = 0;
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.spd_toleration = 0;
Q.in_bourgeois_coalition = 0;
Q.in_right_coalition = 0;
Q.in_social_christian_coalition = 0;
Q.in_social_liberal_coalition = 0;

// Reset KPD goals
Q.kpd_goals_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labor_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.reichswehr_goal = 0;

// ============================================
// COMPREHENSIVE PARTY RELATIONSHIP MATRIX
// ============================================

if (!Q.party_relations_check) { 
    Q.party_relations_check = 1;
    Q.party_relations = {

    // === KPD ===
    KPD: {
        SAPD:  40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD:   Q.kpd_relation,
        SRPD:  Q.kpd_relation + 5,
        DDP:   8,
        Z:     5,
        BVP:   3,
        CSRP:  8,
        DVP:   3,
        WP:    3,
        CNBL:  2,
        CSVD:  0,
        DNVP:  0,
        VRP:   3,   // Savers' party = petty bourgeois class enemies, but negligible
        NSDAP: 0,
        KVP:  0,
        DHP:  0,
        BB:   2,
    },

    // === SAPD ===
    SAPD: {
        KPD:   40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD:   55 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD:  60,
        DDP:   20,
        Z:     15,
        BVP:   10,
        CSRP:  15,
        DVP:   8,
        WP:    8,
        CNBL:  8,
        CSVD:  12,
        DNVP:  3,
        VRP:   5,   // Inflation victims get some sympathy but VRP is still bourgeois
        NSDAP: 0,
        KVP:  5,
        DHP:  8,
        BB:   10,
    },

    // === SPD ===
    SPD: {
        KPD:   Q.kpd_relation,
        SAPD:  50 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD:  65,
        DDP:   Q.ddp_relation,
        Z:     Q.z_relation,
        BVP:   Q.bvp_relation  ?? 35,
        DVP:   Q.dvp_relation,
        CSRP:  Q.csrp_relation,
        WP:    Q.wp_relation   ?? 25,
        CNBL:  Q.cnbl_relation ?? 20,
        CSVD:  Q.csvd_relation ?? 35,
        DNVP:  Q.dnvp_relation,
        VRP:   Q.vrp_relation ?? 20,  // SPD is blamed by VRP for inflationary policy; mutual coolness
        NSDAP: Q.nsdap_relation,
        KVP:  Q.kvp_relation,
        DHP:  Q.dhp_relation,
        BB:   Q.bb_relation,
    },

    // === SRPD ===
    SRPD: {
        KPD:   Q.kpd_relation - 10,
        SAPD:  55,
        SPD:   65,
        DDP:   Q.ddp_relation + 10,
        Z:     Q.z_relation + 5,
        BVP:   (Q.bvp_relation ?? 35) + 5,
        DVP:   Q.dvp_relation - 5,
        CSRP:  Q.csrp_relation + 5,
        WP:    (Q.wp_relation ?? 25) - 5,
        CNBL:  (Q.cnbl_relation ?? 20) + 5,
        CSVD:  (Q.csvd_relation ?? 35) + 5,
        DNVP:  Q.dnvp_line === 3 ? 0 : Q.dnvp_relation - 10,
        VRP:   20,  // Same as SPD; SRPD inherits the blame
        NSDAP: 0,
        KVP:  30,
        DHP:  25,
        BB:   25,
    },

    // === DDP ===
    DDP: {
        KPD:   8,
        SAPD:  20,
        SPD:   Q.ddp_relation,
        SRPD:  Q.ddp_relation + 10,
        Z:     70,
        BVP:   60,
        CSRP:  70,
        DVP:   65 - (Q.dvp_right_shift ?? 0) * 10,
        WP:    50,
        CNBL:  35,
        CSVD:  60,
        DNVP:  Q.dnvp_line === 3 ? 5 : 30,
        VRP:   55, // Shared liberal Mittelstand base; DDP sympathetic to revaluation demands
                   // but VRP's single-issue grievance politics limits the warmth
        NSDAP: 0,
        KVP:  55,
        DHP:  40,
        BB:   30,
    },

    // === Z ===
    Z: {
        KPD:   5,
        SAPD:  20,
        SPD:   Q.z_relation,
        SRPD:  Q.z_relation + 5,
        DDP:   70,
        BVP:   80,
        CSRP:  45,
        DVP:   60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        WP:    50,
        CNBL:  35,
        CSVD:  50,
        DNVP:  (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10),
        VRP:   35, // Z passed the 1925 revaluation measures VRP found inadequate;
                   // Catholic savers exist but Z won't restructure policy around them
        NSDAP: Q.nazi_urgency >= 7 ? 0 : Math.max(0, 25 - Q.nazi_urgency * 5),
        KVP:  45,
        DHP:  30,
        BB:   45,
    },

    // === CSRP ===
    CSRP: {
        KPD:   8,
        SAPD:  35,
        SPD:   Q.csrp_relation,
        SRPD:  Q.csrp_relation + 5,
        Z:     60,
        DDP:   65,
        BVP:   70,
        DVP:   25,
        WP:    40,
        CNBL:  20,
        CSVD:  30,
        DNVP:  10,
        VRP:   30, // Some sympathy for small saver; CSRP has a social justice streak,
                   // but VRP's liberal economics clash with Christian social doctrine
        NSDAP: 0,
        KVP:  35,
        DHP:  25,
        BB:   30,
    },

    // === BVP ===
    BVP: {
        KPD:   3,
        SAPD:  15,
        SPD:   Q.bvp_relation ?? 35,
        SRPD:  (Q.bvp_relation ?? 35) + 5,
        DDP:   60,
        Z:     80,
        CSRP:  40,
        DVP:   55,
        WP:    45,
        CNBL:  65,
        CSVD:  45,
        DNVP:  50,
        VRP:   35, // Bavaria had many small savers; BVP modestly sympathetic
                   // but won't prioritise revaluation over confessional politics
        NSDAP: Math.max(0, 15 - Q.nazi_urgency * 3),
        KVP:  40,
        DHP:  25,
        BB:   60,
    },

    // === DVP ===
    // Heavy industry benefited from inflation wiping out debt — VRP views DVP
    // as an arch-enemy representing those who prospered at savers' expense.
    DVP: {
        KPD:   3,
        SAPD:  10,
        SPD:   Q.dvp_relation,
        SRPD:  Q.dvp_relation - 5,
        DDP:   65 - (Q.dvp_right_shift ?? 0) * 10,
        Z:     60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        BVP:   55,
        CSRP:  25,
        WP:    70,
        CNBL:  30,
        CSVD:  50,
        DNVP:  50 + (Q.dvp_right_shift ?? 0) * 15,
        VRP:   20, // DVP represents the inflation profiteers in VRP's worldview;
                   // mutual coolness; some overlap on anti-socialism
        NSDAP: 20 + (Q.capital_strike_progress * 6) + (Q.dvp_right_shift ?? 0) * 12,
        KVP:  55,
        DHP:  40,
        BB:   25,
    },

    // === WP ===
    // WP represents property owners who did WELL from inflation — VRP's direct rival
    // and ideological nemesis within the Mittelstand. Historically they competed
    // directly for the same social stratum with opposite grievances.
    WP: {
        KPD:   3,
        SAPD:  10,
        SPD:   Q.wp_relation ?? 25,
        SRPD:  (Q.wp_relation ?? 25) - 5,
        DDP:   50,
        Z:     50,
        CSRP:  20,
        BVP:   45,
        DVP:   70,
        CNBL:  40,
        CSVD:  50,
        DNVP:  45,
        VRP:   15, // Direct rivals — WP = inflation winners, VRP = inflation losers.
                   // They fight over the same Mittelstand identity with opposite memories
        NSDAP: 35 + (Q.capital_strike_progress * 4),
        KVP:  40,
        DHP:  35,
        BB:   30,
    },

    // === CNBL ===
    CNBL: {
        KPD:   2,
        SAPD:  8,
        SPD:   Q.cnbl_relation ?? 20,
        SRPD:  (Q.cnbl_relation ?? 20) + 5,
        DDP:   30,
        Z:     40,
        CSRP:  15,
        BVP:   55,
        DVP:   35,
        WP:    40,
        CSVD:  40,
        DNVP:  45,
        VRP:   25, // Some rural savers align with VRP's revaluation demands;
                   // but Landbund prioritises agricultural tariffs over savings policy
        NSDAP: 30 + (Q.capital_strike_progress * 4) + (Q.year >= 1930 ? 10 : 0),
        KVP:  45,
        DHP:  55,
        BB:   55,
    },

    // === CSVD ===
    CSVD: {
        KPD:   0,
        SAPD:  15,
        SPD:   Q.csvd_relation ?? 40,
        SRPD:  (Q.csvd_relation ?? 40) + 5,
        DDP:   60,
        Z:     50,
        BVP:   45,
        CSRP:  35,
        DVP:   55,
        WP:    45,
        CNBL:  40,
        DNVP:  Q.dnvp_line === 3 ? 5 : 55,
        VRP:   45, // CSVD has Protestant pietist small-saver constituents who overlap
                   // with VRP's base; both anti-Hugenberg, both pro-republic
        NSDAP: 8,
        KVP:  65,
        DHP:  45,
        BB:   30,
    },

    // === DNVP ===
    DNVP: {
        KPD:   0,
        SAPD:  3,
        SPD:   Q.dnvp_relation,
        SRPD:  Q.dnvp_relation - 5,
        DDP:   Q.dnvp_line === 3 ? 5 : 30,
        Z:     (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10),
        BVP:   50,
        CSRP:  20,
        DVP:   50 + (Q.dvp_right_shift ?? 0) * 15,
        WP:    45,
        CNBL:  45,
        CSVD:  Q.dnvp_line === 3 ? 5 : 55,
        VRP:   30, // DNVP rhetorically sympathised with revaluation but did little;
                   // Hugenberg-era DNVP is too volkisch for VRP's legal-liberal savers
        NSDAP: Q.dnvp_line === 3 ? 70 : 40,
        KVP:  Q.dnvp_line === 3 ? 5 : 60,
        DHP:  Q.dnvp_line === 3 ? 15 : 55,
        BB:   35,
    },

    // === NSDAP ===
    NSDAP: {
        KPD:   0,
        SAPD:  0,
        SPD:   0,
        SRPD:  0,
        DDP:   0,
        CSRP:  0,
        Z:     Q.nazi_urgency >= 7 ? 0 : Math.max(0, 20 - Q.nazi_urgency * 4),
        BVP:   Math.max(0, 15 - Q.nazi_urgency * 3),
        DVP:   25 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift ?? 0) * 10,
        WP:    30 + (Q.capital_strike_progress * 3),
        CNBL:  30,
        CSVD:  8,
        DNVP:  Q.dnvp_line === 3 ? 70 : 40,
        VRP:   25 + (Q.capital_strike_progress * 3),
        // VRP voters are NSDAP's prime recruitment pool — the cheated saver
        // is a central Nazi propaganda figure ("November criminals," "Jewish finance").
        // NSDAP actively courted this demographic.
        KVP:  5,
        DHP:  15,
        BB:   20,
    },

    // === VRP (Volksrechtpartei / People's Justice Party) ===
    // Founded 1926 by the Sparerbund für das Deutsche Reich.
    // Represents small savers, pensioners, and bondholders wiped out by 1923 hyperinflation.
    // Demands full revaluation of savings. Sees WP (inflation property-owners) as rivals.
    // Sees DVP (heavy industry, inflation profiteers) as enemies.
    // Politically: right-liberal, anti-socialist, pro-Rechtsstaat, single-issue grievance.
    // Demographic: elderly rentiers, widows, civil servants, small depositors.
    // Danger: as revaluation hopes fade, this electorate drifts toward NSDAP rapidly.
    VRP: {
        KPD:   3,
        SAPD:  5,
        SPD:   Q.vrp_relation,  // SPD blamed for inflationary Weimar finance policy
        SRPD:  20,
        DDP:   55,  // Natural liberal ally; shared Mittelstand base
        Z:     35,  // Z passed inadequate 1925 measures; disappointment, not hostility
        BVP:   35,
        CSRP:  30,
        DVP:   20,  // DVP = big industry = inflation profiteers in VRP's worldview
        WP:    15,  // Direct rival — WP represents those who GAINED from inflation
        CNBL:  25,
        CSVD:  45,  // Good overlap: Protestant small-saver base, anti-Hugenberg, pro-republic
        DNVP:  Q.dnvp_line === 3 ? 10 : 35, // DNVP talked revaluation but didn't deliver;
                                              // Hugenberg era is too radical for VRP
        NSDAP: 0,    // VRP is a legal party demanding justice through courts and parliament;
                    // but its voters are the Nazis' #1 recruitment target as hope fades
        KVP:  35,
        DHP:  30,
        BB:   25,
    },
    // === KVP ===
    KVP: {
        KPD:   0,
        SAPD:  5,
        SPD:   25,
        SRPD:  30,
        DDP:   5,
        Z:     45,
        BVP:   40,
        CSRP:  35,
        DVP:   55,
        WP:    40,
        CNBL:  45,
        CSVD:  65,
        DNVP:  Q.dnvp_line === 3 ? 5 : 60,
        VRP:   35,
        NSDAP: 5,
        DHP:   50,
        BB:    35,
    },

    // === DHP (German Hannover Party) ===
    DHP: {
        KPD:   0,
        SAPD:  5,
        SPD:   20,
        SRPD:  25,
        DDP:   40,
        Z:     30,
        BVP:   25,
        CSRP:  25,
        DVP:   40,
        WP:    35,
        CNBL:  55,  // Agrarian overlap
        CSVD:  45,
        DNVP:  Q.dnvp_line === 3 ? 15 : 55,
        VRP:   30,
        NSDAP: 15,
        KVP:   50,
        BB:    40,
    },

    // === BB (Bavarian Peasants Party) ===
    BB: {
        KPD:   0,
        SAPD:  5,
        SPD:   20,
        SRPD:  25,
        DDP:   30,
        Z:     45,
        BVP:   60,  // Natural Bavarian Catholic overlap but rivals
        CSRP:  30,
        DVP:   25,
        WP:    30,
        CNBL:  55,  // Agrarian solidarity
        CSVD:  30,
        DNVP:  35,
        VRP:   25,
        NSDAP: 20,  // Agrarian grievance overlap — danger zone
        KVP:   35,
        DHP:   40,
    },
};

// ============================================
// COALITION IMPOSSIBILITIES (RED LINES)
// ============================================

Q.coalition_blocks = {
    // --- KPD ---
    KPD_Z:     Q.z_relation    < 65 || Q.kpd_relation < 65,
    KPD_BVP:   true,
    KPD_DVP:   true,
    KPD_WP:    true,
    KPD_CNBL:  true,
    KPD_DNVP:  true,
    KPD_NSDAP: true,
    KPD_VRP:   true,  // VRP is a bourgeois savers' party; anathema to KPD
    KPD_DDP:   Q.kpd_relation < 65,
    KPD_SPD:   Q.communist_coalition < 3,

    // --- SAPD ---
    SAPD_DVP:   true,
    SAPD_WP:    true,
    SAPD_CNBL:  true,
    SAPD_DNVP:  true,
    SAPD_NSDAP: true,
    SAPD_VRP:   true, // VRP is a single-issue bourgeois grievance party; SAPD won't touch them

    // --- SPD ---
    SPD_NSDAP: true,
    SPD_DNVP:  Q.dnvp_relation < 60 || Q.dnvp_line === 3,
    SPD_KPD:   Q.communist_coalition < 3,
    SPD_VRP:   Q.vrp_relation < 35, // VRP blames SPD for inflation; workable only if relations repaired

    // --- SRPD ---
    SRPD_KPD:   Q.kpd_relation < 40,
    SRPD_NSDAP: true,
    SRPD_DNVP:  Q.dnvp_line === 3,
    SRPD_VRP:   Q.vrp_relation < 30,

    // --- DDP ---
    DDP_KPD:   true,
    DDP_NSDAP: true,
    DDP_DNVP:  Q.dnvp_line === 3,
    // DDP-VRP: no block — natural coalition partners

    // --- Z ---
    Z_KPD:    Q.kpd_relation < 65 || Q.z_relation < 45,
    Z_NSDAP:  Q.nazi_urgency >= 6,
    Z_DNVP:   Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
    // Z-VRP: no hard block but coolness over revaluation issue

    // --- BVP ---
    BVP_KPD:   true,
    BVP_SAPD:  true,
    BVP_NSDAP: Q.nazi_urgency >= 6,

    // --- DVP ---
    DVP_KPD:   true,
    DVP_SAPD:  true,
    DVP_NSDAP: Q.nazi_urgency >= 7 && Q.capital_strike_progress < 4,
    DVP_VRP:   Q.dvp_right_shift >= 2, // As DVP drifts right, VRP (its nemesis on inflation)
                                        // becomes an impossible partner

    // --- WP ---
    WP_KPD:   true,
    WP_SAPD:  true,
    WP_NSDAP: Q.capital_strike_progress < 5,
    WP_VRP:   true, // Hard block — WP and VRP are direct rivals with opposing
                    // memories of and interests in the 1923 inflation

    // --- CNBL ---
    CNBL_KPD:  true,
    CNBL_SAPD: true,
    CNBL_SPD:  Q.cnbl_relation < 30,

    // --- CSVD ---
    // No hard blocks with VRP — they share a base

    // --- DNVP ---
    DNVP_KPD:  true,
    DNVP_SAPD: true,
    DNVP_SPD:  Q.dnvp_line === 3 || Q.dnvp_relation < 40,
    DNVP_DDP:  Q.dnvp_line === 3,
    DNVP_Z:    Q.dnvp_line === 3 && Q.z_party_leader !== "Kaas",
    DNVP_VRP:  Q.dnvp_line === 3, // Hugenberg-era DNVP too radical for rule-of-law savers

    // --- NSDAP ---
    NSDAP_KPD:  true,
    NSDAP_SPD:  true,
    NSDAP_SAPD: true,
    NSDAP_SRPD: true,
    NSDAP_DDP:  true,
    NSDAP_CSRP: true,
    NSDAP_VRP:  true, // NSDAP wants VRP's voters, not their parliamentary cooperation
    NSDAP_BVP:  Q.nazi_urgency >= 6,
    NSDAP_Z:    Q.nazi_urgency >= 6,
    NSDAP_COALITIONS_GENERALLY: Q.nsdap_r < 35 || Q.year < 1932,

    // --- VRP ---
    VRP_KPD:   true,
    VRP_SAPD:  true,
    VRP_WP:    true,  // Hard block — direct rivals, opposing inflation memories
    VRP_NSDAP: true,
    VRP_DNVP:  Q.dnvp_line === 3,
    VRP_DVP:   Q.dvp_right_shift >= 1,  // DVP drift makes them intolerable to VRP
    VRP_SPD:   Q.vrp_relation < 35,      // Only workable if SPD makes amends on revaluation

    // --- KVP ---
    KVP_KPD:   true,
    KVP_SAPD:  true,
    KVP_NSDAP: true,
    KVP_DNVP:  Q.dnvp_line === 3,
    KVP_SPD:   false,  // Workable in emergency

    // --- DHP ---
    DHP_KPD:   true,
    DHP_SAPD:  true,
    DHP_NSDAP: Q.nazi_urgency >= 5,  // Weaker resistance than most

    // --- BB ---
    BB_KPD:   true,
    BB_SAPD:  true,
    BB_NSDAP: Q.nazi_urgency >= 7,   // Agrarian grievance makes them soft on NSDAP longest
    BB_WP:    false,  // No hard block — both small, both grievance parties
    BB_DVP:   true,   // Big industry vs peasants
    };
}

// ============================================
// SPECIAL COALITION CONDITIONS
// ============================================

Q.popular_front_possible = (Q.kpd_party_leader === "Conciliators" && Q.z_party_leader === "Joos") ? 1 : 0;
Q.left_front_possible = (Q.communist_coalition >= 3 && Q.kpd_relation >= 50) ? 1 : 0;
Q.unity_government_possible = (Q.nazi_urgency >= 6 || Q.pro_republic < 40) ? 1 : 0;
Q.bourgeois_only_possible = (Q.year >= 1929 || Q.spd_r < 25) ? 1 : 0;
Q.right_coalition_viable = (Q.dnvp_line !== 3 || Q.z_party_leader === "Kaas") ? 1 : 0;

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
