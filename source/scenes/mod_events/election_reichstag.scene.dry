    <td style="padding: 8px; text-align: right; [? if change_nsdap_r > 0 : color: green; ?][? if change_nsdap_r < 0 : color: red; ?]">[+ str_change_nsdap +]</td>
</tr>
{!</table>!}







@coalition_formation_start
on-arrival: {!
// ============================================
// BUILD LIST OF PARTIES BY VOTE SHARE
// ============================================

Q.party_votes = [
    {party: 'KPD',   votes: Q.kpd_r},
    {party: 'SPD',   votes: Q.spd_r},
    {party: 'Z',     votes: Q.z_r},
    {party: 'NSDAP', votes: Q.nsdap_r},
    {party: 'DNVP',  votes: Q.dnvp_r},
    {party: 'DVP',   votes: Q.dvp_r},
    {party: 'DDP',   votes: Q.ddp_r},
    {party: 'BVP',   votes: Q.bvp_r}
].filter(function(p) { return p.votes > 0; });

if (Q.sapd_formed && Q.sapd_r > 0) Q.party_votes.push({party: 'SAPD', votes: Q.sapd_r});
if (Q.srpd_formed && Q.srpd_r > 0) Q.party_votes.push({party: 'SRPD', votes: Q.srpd_r});
if (Q.vrp_r  && Q.vrp_r  > 0) Q.party_votes.push({party: 'VRP',  votes: Q.vrp_r});
if (Q.wp_r   && Q.wp_r   > 0) Q.party_votes.push({party: 'WP',   votes: Q.wp_r});
if (Q.cnbl_r && Q.cnbl_r > 0) Q.party_votes.push({party: 'CNBL', votes: Q.cnbl_r});
if (Q.csrp_r && Q.csrp_r > 0) Q.party_votes.push({party: 'CSRP', votes: Q.csrp_r});
if (Q.csvd_flee && Q.csvd_r && Q.csvd_r > 0) Q.party_votes.push({party: 'CSVD', votes: Q.csvd_r});
if (Q.kvp_flee  && Q.kvp_r  && Q.kvp_r  > 0) Q.party_votes.push({party: 'KVP',  votes: Q.kvp_r});
if (Q.bb_r  && Q.bb_r  > 0) Q.party_votes.push({party: 'BB',  votes: Q.bb_r});
if (Q.dhp_r && Q.dhp_r > 0) Q.party_votes.push({party: 'DHP', votes: Q.dhp_r});

Q.party_votes.sort(function(a, b) { return b.votes - a.votes; });

// ============================================================
// PRESIDENTIAL FORMATEUR SELECTION
// Uses camarilla chancellor scores + presidential trust values.
// No hard year-gates — all thresholds are stat-driven.
// ============================================================

Q.president_interfered = 0;
Q.formateur = Q.party_votes[0].party; // constitutional default

// === BUILD PRESIDENTIAL PREFERENCE SCORE PER PARTY ===
// Score > 0 means president is comfortable with this formateur.
// Score < 0 means president will try to bypass them.

function president_party_score(party) {
    var score = 0;
    var pres = Q.president;
    var cam  = Q.camarilla_chancellor_scores || {};

    // --- Base from camarilla preferred/hostile lists ---
    // We score parties by checking if their likely chancellor is preferred/hostile.
    // Use a representative chancellor name per party as proxy.
    var party_chancellor_proxy = {
        SPD:  'Müller',    SRPD: 'Horsing',   KPD:  'Thälmann',
        SAPD: 'Rosenfeld', Z:    'Brüning',    BVP:  'Held',
        DDP:  'Koch-Weser',DVP:  'Stresemann', WP:   'Drewitz',
        CNBL: 'Hepp',      CSVD: 'Lambach',    DNVP: Q.dnvp_line === 3 ? 'Hugenberg' : 'Westarp',
        NSDAP:'Hitler',    VRP:  'Drewitz',    CSRP: 'Vitus Heller',
        KVP:  'Westarp',   DHP:  'Hamkens',    BB:   'Hamkens',
        SRPD: 'Horsing'
    };
    var proxy = party_chancellor_proxy[party] || '';
    if (cam[proxy] !== undefined) score += cam[proxy] * 0.4;

    // --- President-specific trust variables ---
    if (pres === 'Hindenburg') {
    if (party === 'SPD') {
        var spd_trust = Q.hindenburg_trust_spd || 65; // raise default from 55 to 65
        // Only starts discouraging SPD below trust 50, not 45
        score += spd_trust - 50;
    }
    if (party === 'KPD' || party === 'SAPD') score -= 80;
    if (party === 'NSDAP') {
        var nazi_tolerance = ((Q.camarilla_goals && Q.camarilla_goals.install_hitler) || 0);
        var weakness = (Q.hindenburg_senility || 0) + Math.max(0, 100 - (Q.hindenburg_health || 100));
        score += (nazi_tolerance * 0.3) + (weakness * 0.2) - 60;
    }
    if (party === 'Z')   score += (Q.hindenburg_trust_z    || 60) - 40;
    if (party === 'DNVP') score += (Q.hindenburg_trust_dnvp || 70) - 40;
    if (party === 'DVP')  score += 10;

    // Reichstag trust bypass — only kicks in meaningfully late game
    var rt = Q.hindenburg_trust_reichstag || 65; // raise default here too
    if (party === Q.party_votes[0].party && rt < 35) { // tighten threshold from 40 to 35
        score -= (35 - rt) * 0.8;
    }

    // Pro-republic modifier — only meaningful when very low
    if (Q.pro_republic < 35) score += (35 - Q.pro_republic) * 0.15;

    } else if (pres === 'Braun') {
        if (party === 'SPD')  score += 60;
        if (party === 'SRPD') score += 30;
        if (party === 'DDP')  score += 15;
        if (party === 'Z')    score += 10;
        if (party === 'KPD')  score -= 20;
        if (party === 'NSDAP' || party === 'DNVP') score -= 80;

    } else if (pres === 'Westarp') {
        if (party === 'DNVP') score += 60;
        if (party === 'DVP')  score += 30;
        if (party === 'Z')    score += 20;
        if (party === 'BVP')  score += 15;
        if (party === 'CNBL') score += 10;
        if (party === 'SPD')  score -= 50;
        if (party === 'KPD' || party === 'SAPD' || party === 'SRPD') score -= 80;
        if (party === 'DDP')  score -= 10;
        if (party === 'NSDAP') score += (Q.dnvp_line === 3 ? 20 : -10);

    } else if (pres === 'Thälmann' || pres === 'Thalmann') {
        if (party === 'KPD')  score += 80;
        if (party === 'SAPD') score += 50;
        if (party === 'SPD')  score += 30;
        if (party === 'SRPD') score += 25;
        if (party === 'NSDAP' || party === 'DNVP') score -= 80;
        if (party === 'DVP' || party === 'WP')     score -= 30;
        if (party === 'Z')    score -= 10; 
    } else if (pres === 'Hitler') {
            if (party === 'NSDAP') score += 80;
            if (party === 'DNVP' && Q.dnvp_line === 3) score += 20;
            if (party === 'SPD' || party === 'KPD' || party === 'SAPD') score -= 80;
    } else if (pres === 'Westarp' || pres === 'Thalmann' || pres === 'Thälmann'
               || pres === 'Seeckt' || pres === 'Marx') {
        // Generic: use comfort/hostile lists from profile
        var _pkey = {
            'Westarp': 'Westarp', 'Thalmann': 'Thalmann', 'Thälmann': 'Thalmann',
            'Seeckt': 'Seeckt',   'Marx': 'Marx'
        }[pres] || '_default';

        var PROFILES = {
            Westarp:  { comfort: ['DNVP','DVP','Z','CSVD'], hostile: ['KPD','SAPD','SPD'] },
            Thalmann: { comfort: ['KPD','SAPD'],            hostile: ['NSDAP','DNVP','DVP'] },
            Seeckt:   { comfort: ['DVP','DNVP','CSVD'],     hostile: ['KPD','SPD','NSDAP'] },
            Marx:     { comfort: ['Z','BVP','DVP','DDP'],   hostile: ['KPD','NSDAP'] },
            _default: { comfort: [], hostile: [] }
        };
        var prof = PROFILES[_pkey] || PROFILES._default;
        if (prof.comfort.indexOf(party) >= 0) score += 35;
        if (prof.hostile.indexOf(party) >= 0) score -= 60;
        // Also apply camarilla scores
        // (already added above via proxy)
    }

    return score;
}

// === FIND BEST FORMATEUR ===
// Start from largest party. If president score is negative enough
// to override, find the next acceptable party.
var DEFAULT_THRESHOLD = -20; // score below this = president intervenes

var largest = Q.party_votes[0].party;
var largest_score = president_party_score(largest);

if (largest_score <= DEFAULT_THRESHOLD) {
    // President refuses largest party — scan for acceptable alternative
    var best_alt = null;
    var best_alt_score = -9999;

    for (var i = 1; i < Q.party_votes.length; i++) {
        var candidate = Q.party_votes[i].party;
        var cscore = president_party_score(candidate);
        // Must be meaningfully better than the one being bypassed
        if (cscore > largest_score + 20 && cscore > DEFAULT_THRESHOLD) {
            if (cscore > best_alt_score) {
                best_alt = candidate;
                best_alt_score = cscore;
            }
        }
    }

    if (best_alt) {
        Q.formateur = best_alt;
        Q.president_interfered = 1;
        Q.president_bypass_reason = largest_score < -50 ? 'strong' : 'moderate';
    }
    // If no acceptable alt found, give mandate to largest anyway
    // (president has no constitutional power to refuse indefinitely)
} else {
    Q.formateur = largest;
}

// === PRESIDENTIAL CABINET PRE-EMPTION ===
// If camarilla is pushing for presidential cabinet strongly enough,
// president skips coalition formation entirely and goes straight to crisis.
// This only triggers if coalition formation hasn't started (formation_round == 0).
Q.president_skips_coalition = 0;
if (Q.camarilla_pushes_presidential_cabinet) {
    // Additional check: is there a plausible coalition at all?
    // If the largest bloc can form a majority without hostile parties,
    // the president can't credibly skip — too politically costly.
    var plausible_majority =
        Q.spd_r + Q.z_r + Q.ddp_r >= 50 ||
        Q.spd_r + Q.z_r + Q.dvp_r >= 50 ||
        Q.dnvp_r + Q.nsdap_r + Q.dvp_r >= 50;

    if (!plausible_majority) {
        // Camarilla strength determines how likely the skip is
        var cam_str = Q.camarilla_strength || 0;
        var ceil    = Q.camarilla_ceiling  || 60;
        var skip_probability = Math.pow((cam_str - ceil * 0.75) / (ceil * 0.25), 1.5);
        skip_probability = Math.max(0, Math.min(1, skip_probability));

        if (Math.random() < skip_probability) {
            Q.president_skips_coalition = 1;
        }
    }
}

// Pre-calculate display strings
Q.election_results_list = "";
for (var i = 0; i < Q.party_votes.length; i++) {
    Q.election_results_list += "- " + Q.party_votes[i].party + ": "
        + Q.party_votes[i].votes + "%\n";
}
Q.first_party_votes = Q.party_votes[0].votes;
Q.formation_round   = 1;
Q.formation_attempts = [];

Q.first_party_0 = Q.party_votes[0].party
!}
go-to: presidential_crisis if president_skips_coalition; begin_negotiations

= Coalition Formation - [+ year +]

**Election Results:**

[+ election_results_list +]

[? if president_skips_coalition : President [+ president +] has declined to designate a formateur, invoking Article 48 directly. ?]

[? if president_interfered and president_bypass_reason = "strong" : President [+ president +] has firmly refused to grant the mandate to [+ first_party_0 +], designating **[+ formateur +]** instead. ?]

[? if president_interfered and president_bypass_reason = "moderate" : President [+ president +] has chosen to bypass [+ first_party_0 +], granting the mandate to **[+ formateur +]**. ?]

[? if not president_interfered : By constitutional tradition, **[+ formateur +]** ([+ first_party_votes +]%) receives the mandate to form a government. ?]

- @begin_negotiations: Begin coalition negotiations














@begin_negotiations
on-arrival: {!
// ============================================
// FORMATEUR EVALUATES POSSIBLE COALITIONS
// ============================================

var formateur = Q.formateur;
var formateur_votes = Q[formateur.toLowerCase() + '_r'];
var threshold = 50;

Q.formation_attempts.push(formateur);

// ============================================
// CHECK FOR SOLE MAJORITY
// ============================================
if (formateur_votes >= threshold) {
    Q.sole_majority_possible = 1;
    Q.sole_majority_party = formateur;
    
    // If SPD has sole majority, let them decide
    if (formateur === 'SPD') {
        Q.spd_can_govern_alone = 1;
        // Still calculate coalitions as options
    } else {
        // Other party with majority governs alone automatically
        Q.coalition_formed = 1;
        Q.chosen_coalition = {
            parties: [formateur],
            votes: formateur_votes,
            compatibility: 100,
            size: 1,
            type: 'sole_majority'
        };
        Q.spd_in_chosen_coalition = 0;
        return; // Skip coalition evaluation
    }
} else {
    Q.sole_majority_possible = 0;
    Q.spd_can_govern_alone = 0;
}

// Helper: Get relation between two parties (handles missing values)
function get_relation(party1, party2) {
    if (party1 === party2) return 100;
    
    var rel1 = (Q.party_relations[party1] && Q.party_relations[party1][party2]) || 0;
    var rel2 = (Q.party_relations[party2] && Q.party_relations[party2][party1]) || 0;
    
    // Use the average, or if one is missing, use the other
    if (rel1 > 0 && rel2 > 0) {
        return (rel1 + rel2) / 2;
    } else if (rel1 > 0) {
        return rel1;
    } else if (rel2 > 0) {
        return rel2;
    } else {
        return 0;
    }
}

// Helper: Check if block exists
function is_blocked(party1, party2) {
    var keys = [
        party1 + '_' + party2,
        party2 + '_' + party1,
        party1 + '_ALL',
        party2 + '_ALL'
    ];
    
    for (var i = 0; i < keys.length; i++) {
        if (Q.coalition_blocks[keys[i]]) return true;
    }
    return false;
}

// Helper: Can these parties work together?
function can_partner(party1, party2) {
    if (is_blocked(party1, party2)) return false;
    
    var avg_rel = get_relation(party1, party2);
    
    // Lower threshold - many historical coalitions had poor relations
    return avg_rel >= 25;
}

// Helper: Calculate coalition compatibility
function coalition_compatibility(parties) {
    var total_rel = 0;
    var count = 0;
    
    // Formateur relations with all partners
    for (var i = 0; i < parties.length; i++) {
        if (parties[i] === formateur) continue;
        
        var rel = get_relation(formateur, parties[i]);
        if (typeof rel === 'undefined') rel = 50;
        if (rel < 35) return -1;
        total_rel += rel;
        count++;
    }
    
    // Partners' relations with each other
    for (var i = 0; i < parties.length; i++) {
        for (var j = i + 1; j < parties.length; j++) {
            if (parties[i] === formateur || parties[j] === formateur) continue;
            
            var rel = get_relation(parties[i], parties[j]);
            if (typeof rel === 'undefined') rel = 50;
            if (rel < 25) return -1;
            total_rel += rel;
            count++;
        }
    }
    
    return count > 0 ? total_rel / count : 0;
}

// Get other parties (exclude formateur and NSDAP unless special conditions)
var other_parties = Q.party_votes.filter(function(p) {
    if (p.party === formateur) return false;
    if (p.party === 'NSDAP' && Q.nsdap_r < 30) return false;
    return true;
});

Q.possible_coalitions = [];

// ============================================
// ADD SOLE MAJORITY AS OPTION (if possible)
// ============================================
if (Q.sole_majority_possible && formateur === 'SPD') {
    Q.possible_coalitions.push({
        parties: [formateur],
        votes: formateur_votes,
        compatibility: 100,
        size: 1,
        type: 'sole_majority'
    });
}

// ============================================
// EVALUATE 2-PARTY COALITIONS
// ============================================

for (var i = 0; i < other_parties.length; i++) {
    var partner = other_parties[i].party;
    var partner_votes = other_parties[i].votes;
    var total = formateur_votes + partner_votes;
    
    if (total >= threshold && can_partner(formateur, partner)) {
        var parties_array = [formateur, partner];
        var compat = coalition_compatibility(parties_array);
        
        if (compat >= 0) {
            Q.possible_coalitions.push({
                parties: parties_array,
                votes: total,
                compatibility: compat,
                size: 2,
                type: classify_coalition(parties_array)
            });
        }
    }
}

// ============================================
// EVALUATE 3-PARTY COALITIONS
// ============================================

for (var i = 0; i < other_parties.length; i++) {
    for (var j = i + 1; j < other_parties.length; j++) {
        var p1 = other_parties[i].party;
        var p2 = other_parties[j].party;
        var v1 = other_parties[i].votes;
        var v2 = other_parties[j].votes;
        var total = formateur_votes + v1 + v2;
        
        if (total >= threshold && 
            can_partner(formateur, p1) && 
            can_partner(formateur, p2) && 
            can_partner(p1, p2)) {
            
            var parties_array = [formateur, p1, p2];
            var compat = coalition_compatibility(parties_array);
            
            if (compat >= 0) {
                Q.possible_coalitions.push({
                    parties: parties_array,
                    votes: total,
                    compatibility: compat,
                    size: 3,
                    type: classify_coalition(parties_array)
                });
            }
        }
    }
}

// ============================================
// EVALUATE 4-PARTY COALITIONS
// ============================================

for (var i = 0; i < other_parties.length; i++) {
    for (var j = i + 1; j < other_parties.length; j++) {
        for (var k = j + 1; k < other_parties.length; k++) {
            var p1 = other_parties[i].party;
            var p2 = other_parties[j].party;
            var p3 = other_parties[k].party;
            var v1 = other_parties[i].votes;
            var v2 = other_parties[j].votes;
            var v3 = other_parties[k].votes;
            var total = formateur_votes + v1 + v2 + v3;
            
            if (total >= threshold &&
                can_partner(formateur, p1) && 
                can_partner(formateur, p2) && 
                can_partner(formateur, p3) &&
                can_partner(p1, p2) &&
                can_partner(p1, p3) &&
                can_partner(p2, p3)) {
                
                var parties_array = [formateur, p1, p2, p3];
                var compat = coalition_compatibility(parties_array);
                
                if (compat >= 0) {
                    Q.possible_coalitions.push({
                        parties: parties_array,
                        votes: total,
                        compatibility: compat,
                        size: 4,
                        type: classify_coalition(parties_array)
                    });
                }
            }
        }
    }
}

// ============================================
// EVALUATE 5-PARTY COALITIONS (UNITY GOVERNMENT)
// ============================================

if (Q.unity_government_possible && Q.possible_coalitions.length === 0) {
    for (var i = 0; i < other_parties.length; i++) {
        for (var j = i + 1; j < other_parties.length; j++) {
            for (var k = j + 1; k < other_parties.length; k++) {
                for (var m = k + 1; m < other_parties.length; m++) {
                    var p1 = other_parties[i].party;
                    var p2 = other_parties[j].party;
                    var p3 = other_parties[k].party;
                    var p4 = other_parties[m].party;
                    var v1 = other_parties[i].votes;
                    var v2 = other_parties[j].votes;
                    var v3 = other_parties[k].votes;
                    var v4 = other_parties[m].votes;
                    var total = formateur_votes + v1 + v2 + v3 + v4;

                    if (total >= threshold) {
                        var parties_array = [formateur, p1, p2, p3, p4];
                        var compat = coalition_compatibility(parties_array);

                        if (compat >= 0) {
                            Q.possible_coalitions.push({
                                parties: parties_array,
                                votes: total,
                                compatibility: compat,
                                size: 5,
                                type: 'unity'
                            });
                        }
                    }
                }
            }
        }
    }
}

// ============================================
// GENERALIZED TOLERATION / EXTERNAL SUPPORT
// ============================================

// After majority coalition evaluation, before declaring failure:

// Helper: Which parties would tolerate a given government?
function get_tolerating_parties(gov_parties, available_parties) {
    var tolerators = [];
    
    for (var i = 0; i < available_parties.length; i++) {
        var candidate = available_parties[i].party;
        
        // Skip parties already in government
        if (gov_parties.indexOf(candidate) >= 0) continue;
        
        // Check relations with ALL government parties
        var willing = true;
        for (var j = 0; j < gov_parties.length; j++) {
            var rel = get_relation(candidate, gov_parties[j]);
            if (rel < 30) { willing = false; break; }
            if (is_blocked(candidate, gov_parties[j])) { willing = false; break; }
        }
        
        if (willing) {
            tolerators.push({
                party: candidate,
                votes: available_parties[i].votes
            });
        }
    }
    
    return tolerators;
}

// Helper: Build all subsets of tolerating parties that push gov over 50%
function find_toleration_combinations(gov_votes, tolerators) {
    var combos = [];
    var n = tolerators.length;
    
    // Try all subsets (up to 3 tolerators for performance)
    var max = Math.min(n, 3);
    
    for (var size = 1; size <= max; size++) {
        find_subsets(tolerators, size, 0, [], gov_votes, combos);
    }
    
    return combos;
}

function find_subsets(arr, size, start, current, gov_votes, results) {
    if (current.length === size) {
        var total_support = gov_votes;
        for (var i = 0; i < current.length; i++) {
            total_support += current[i].votes;
        }
        if (total_support >= 50) {
            results.push({
                parties: current.slice(),
                total_support: total_support
            });
        }
        return;
    }
    for (var i = start; i < arr.length; i++) {
        current.push(arr[i]);
        find_subsets(arr, size, i + 1, current, gov_votes, results);
        current.pop();
    }
}

// ============================================
// EVALUATE MINORITY GOVERNMENTS
// ============================================

var MIN_GOV_SEATS = 39.9; // Government must have some base to be credible

// All possible government compositions (1 to 4 parties), below majority
var minority_gov_candidates = [];

// Single party minority
if (formateur_votes >= MIN_GOV_SEATS && formateur_votes < 50) {
    minority_gov_candidates.push({
        parties: [formateur],
        votes: formateur_votes,
        compatibility: 100,
        size: 1
    });
}

// Multi-party minority (reuse existing coalition logic but don't require >= 50)
// 2-party
for (var i = 0; i < other_parties.length; i++) {
    var p1 = other_parties[i].party;
    var v1 = other_parties[i].votes;
    var total = formateur_votes + v1;
    
    if (total >= MIN_GOV_SEATS && total < 50 && can_partner(formateur, p1)) {
        var compat = coalition_compatibility([formateur, p1]);
        if (compat >= 0) {
            minority_gov_candidates.push({
                parties: [formateur, p1],
                votes: total,
                compatibility: compat,
                size: 2
            });
        }
    }
}

// 3-party
for (var i = 0; i < other_parties.length; i++) {
    for (var j = i + 1; j < other_parties.length; j++) {
        var p1 = other_parties[i].party;
        var p2 = other_parties[j].party;
        var total = formateur_votes + other_parties[i].votes + other_parties[j].votes;
        
        if (total >= MIN_GOV_SEATS && total < 50 &&
            can_partner(formateur, p1) && can_partner(formateur, p2) && can_partner(p1, p2)) {
            
            var compat = coalition_compatibility([formateur, p1, p2]);
            if (compat >= 0) {
                minority_gov_candidates.push({
                    parties: [formateur, p1, p2],
                    votes: total,
                    compatibility: compat,
                    size: 3
                });
            }
        }
    }
}

// Now find which minority govs can survive via external toleration
for (var g = 0; g < minority_gov_candidates.length; g++) {
    var gov = minority_gov_candidates[g];
    
    var tolerators = get_tolerating_parties(gov.parties, Q.party_votes.filter(function(p) {
        return gov.parties.indexOf(p.party) < 0;
    }));
    
    if (tolerators.length === 0) continue;
    
    var toleration_combos = find_toleration_combinations(gov.votes, tolerators);
    
    for (var t = 0; t < toleration_combos.length; t++) {
        var combo = toleration_combos[t];
        var tolerator_parties = combo.parties.map(function(p) { return p.party; });
    
        Q.possible_coalitions.push({
            parties: gov.parties,
            votes: gov.votes,
            effective_votes: combo.total_support,
            compatibility: gov.compatibility,
            size: gov.size,
            type: classify_coalition(gov.parties),
            toleration: true,
            tolerating_parties: tolerator_parties,
            tolerating_votes: combo.total_support - gov.votes
        });
    }
}

// If SPD is formateur (player), cap toleration options at 2 to avoid clutter.
// Keep the 2 with highest effective_votes.
if (formateur === 'SPD') {
    var majority_coalitions = Q.possible_coalitions.filter(function(c) { return !c.toleration; });
    var toleration_coalitions = Q.possible_coalitions.filter(function(c) { return c.toleration; });
    
    // Sort toleration options: prefer smaller gov (easier to manage), then higher effective support
    toleration_coalitions.sort(function(a, b) {
        if (a.size !== b.size) return a.size - b.size;
        return b.effective_votes - a.effective_votes;
    });
    
    // Keep only top 2 toleration options
    toleration_coalitions = toleration_coalitions.slice(0, 2);
    
    Q.possible_coalitions = majority_coalitions.concat(toleration_coalitions);
}










// ============================================
// COALITION CLASSIFICATION HELPER
// ============================================

function classify_coalition(parties) {
    // Sole majority
    if (parties.length === 1) return 'sole_majority';
    
    var has_spd = parties.indexOf('SPD') >= 0;
    var has_kpd = parties.indexOf('KPD') >= 0;
    var has_sapd = parties.indexOf('SAPD') >= 0;
    var has_srpd = parties.indexOf('SRPD') >= 0;
    var has_z = parties.indexOf('Z') >= 0;
    var has_ddp = parties.indexOf('DDP') >= 0;
    var has_bvp = parties.indexOf('BVP') >= 0;
    var has_dvp = parties.indexOf('DVP') >= 0;
    var has_wp = parties.indexOf('WP') >= 0;
    var has_cnbl = parties.indexOf('CNBL') >= 0;
    var has_dnvp = parties.indexOf('DNVP') >= 0;
    var has_nsdap = parties.indexOf('NSDAP') >= 0;
    var has_csvd = parties.indexOf('CSVD') >= 0;
    var has_csrp = parties.indexOf('CSRP') >= 0;
    var has_vrp = parties.indexOf('VRP') >= 0;
    var has_kvp = parties.indexOf('KVP') >= 0;
    var has_bb = parties.indexOf('BB') >= 0;
    var has_dhp = parties.indexOf('DHP') >= 0;
    
    // Left coalitions
    if (has_spd && has_kpd && !has_z) return 'left_front';
    if (has_kpd && has_z && has_spd && has_ddp) return 'popular_front';
    if (has_spd && has_sapd && !has_kpd && !has_z) return 'socialist_unity';
    
    // Democratic coalitions
    if (has_spd && has_z && has_ddp && parties.length === 3) return 'weimar';
    if (has_spd && has_z && has_ddp && has_dvp && has_bvp) return 'grand';
    if (has_spd && has_z && has_ddp && has_dvp && parties.length === 4) return 'grand_small';
    if (has_spd && has_z && parties.length === 2) return 'social_christian';
    if (has_spd && has_ddp && parties.length === 2) return 'social_liberal';

    // Bourgeois coalitions
    if (!has_spd && !has_kpd && !has_sapd && has_z && has_ddp && has_dvp) return 'bourgeois';
    if (!has_spd && !has_kpd && !has_sapd && has_z && has_dvp && has_bvp) return 'bourgeois_catholic';
    
    // Right coalitions
    if (has_z && has_dvp && has_dnvp && !has_nsdap) return 'right';
    if (has_dvp && has_dnvp && !has_z && !has_nsdap) return 'right_business';
    if (has_dnvp && has_nsdap) return 'far_right';
    if (has_nsdap) return 'far_right';
    
    // Unity
    if (parties.length >= 5) return 'unity';
    
    return 'other';
}

// ============================================
// FORMATEUR CHOOSES BEST COALITION
// ============================================

if (Q.possible_coalitions.length === 0) {
    Q.coalition_formed = 0;
} else {
    // Sort by preferences:
    // 1. Sole majority first (if available)
    // 2. Smallest size (easier to manage)
    // 3. Highest compatibility (better relations)
    // 4. Smallest majority (less wasted votes)
    Q.possible_coalitions.sort(function(a, b) {
        if (a.type === 'sole_majority' && b.type !== 'sole_majority') return -1;
        if (b.type === 'sole_majority' && a.type !== 'sole_majority') return 1;
    
        // Majority coalitions before minority/toleration
        if (!a.toleration && b.toleration) return -1;
        if (a.toleration && !b.toleration) return 1;
    
        if (a.size !== b.size) return a.size - b.size;
        if (Math.abs(a.compatibility - b.compatibility) > 5) return b.compatibility - a.compatibility;
        return a.votes - b.votes;
    });
    
    Q.chosen_coalition = Q.possible_coalitions[0];
    Q.coalition_formed = 1;
    }

// After all coalition evaluation is complete:
if (Q.coalition_formed && Q.formateur === 'SPD') {
    Q.spd_must_decide = 1;
    Q.spd_in_chosen_coalition = 1; // SPD is always in their own coalition
    // DO NOT null chosen_coalition — leave possible_coalitions[0] as default
    // Player will override it via choose_coalition_N
} else if (Q.coalition_formed) {
    Q.spd_must_decide = 0;
    Q.spd_in_chosen_coalition = Q.chosen_coalition.parties.indexOf('SPD') >= 0;
} else {
    Q.spd_must_decide = 0;
    Q.spd_in_chosen_coalition = 0;
}
!}
go-to: spd_formateur_choice if coalition_formed and formateur = "SPD"; player_coalition_review if coalition_formed and formateur != "SPD" and spd_in_chosen_coalition; coalition_success if coalition_formed and not spd_in_chosen_coalition; coalition_failure if not coalition_formed




















# ============================================
# SPD AS FORMATEUR - PLAYER CHOOSES COALITION
# ============================================

@spd_formateur_choice
on-arrival: {!
// Pre-calculate coalition count for view-if checks
Q.num_coalitions = Q.possible_coalitions.length;

// Pre-calculate all possible coalitions display
Q.coalition_options_display = "";

if (Q.possible_coalitions.length === 0) {
    Q.coalition_options_display = "**No viable coalitions found.**\n\nNo combination of parties willing to work together can achieve a majority.";
} else {
    Q.coalition_options_display = "**Available Coalition Options:**\n\n";
    
    for (var i = 0; i < Q.possible_coalitions.length && i < 10; i++) {
        var coal = Q.possible_coalitions[i];
        var partners_text = coal.parties.join(', ');
        var type_text = coal.type.replace(/_/g, ' ');
        
        Q.coalition_options_display += (i + 1) + ". **" + partners_text + "**<br>";

        if (coal.toleration) {
            var tol_text = coal.tolerating_parties.join(' + ');
            Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Minority government, tolerated by: **" + tol_text + "**<br>";
            Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Government seats: " + Math.round(coal.votes * 10) / 10 + "% | Effective majority: " + Math.round(coal.effective_votes * 10) / 10 + "%<br>";
        } else {
            Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Support: " + Math.round(coal.votes * 10) / 10 + "%<br>";
        }

        Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Type: " + type_text + "<br>";
        Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Support: " + Math.round(coal.votes * 10) / 10 + "%<br>";
        Q.coalition_options_display += "&nbsp;&nbsp;&nbsp;&nbsp;- Compatibility: " + Math.round(coal.compatibility) + "/100<br><br>";

    }
    
    if (Q.possible_coalitions.length > 10) {
        Q.coalition_options_display += "*(+" + (Q.possible_coalitions.length - 10) + " more options available)*\n";
    }
}
!}

