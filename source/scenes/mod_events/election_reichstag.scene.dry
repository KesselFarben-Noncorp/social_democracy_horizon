@finalize_shuffle
on-arrival: {!
    function assign_minister(ministry, party) {
        var minister_var = ministry + '_minister';
        
        var ministers = {
            foreign: {
                KPD: 'Pieck', SAPD: 'Rosenfeld', SRPD: 'Breitscheid', DDP: 'Koch-Weser',
                Z: 'Curtius', BVP: 'Held', DVP: Q.stresemann_dead ? 'Curtius' : 'Stresemann',
                WP: 'Lambach', CNBL: 'Hepp', DNVP: 'Westarp'
            },
            interior: {
                KPD: 'Ulbricht', SAPD: 'Seydewitz', SRPD: 'Braun', DDP: 'Koch-Weser',
                Z: 'Wirth', BVP: 'Schätzel', DVP: 'Scholz', WP: 'Petersen',
                CNBL: 'Behrens', DNVP: 'Hergt'
            },
            justice: {
                KPD: 'Heckert', SAPD: 'Ledebour', SRPD: 'Heilmann', DDP: 'Koch-Weser',
                Z: 'Bredt', BVP: 'Gürtner', DVP: 'Heinze', WP: 'Drewitz',
                CNBL: 'von Rohr', DNVP: 'Schiele'
            },
            labor: {
                KPD: 'Münzenberg', SAPD: 'Seydewitz', SRPD: 'Aufhäuser', DDP: 'Dietrich',
                Z: 'Stegerwald', BVP: 'Stützel', DVP: 'Brauns', WP: 'Petersen',
                CNBL: 'Lohse', DNVP: 'Schiele'
            },
            economic: {
                KPD: 'Remmele', SAPD: 'Rosenfeld', SRPD: 'Schmidt', DDP: 'Dietrich',
                Z: 'Bredt', BVP: 'Held', DVP: 'Curtius', WP: 'Lambach',
                CNBL: 'Heim', DNVP: 'Schiele'
            },
            finance: {
                KPD: 'Neumann', SAPD: 'Rosenfeld', SRPD: 'Hilferding', DDP: 'Dietrich',
                Z: 'Köhler', BVP: 'Krausneck', DVP: 'Moldenhauer', WP: 'Drewitz',
                CNBL: 'Hepp', DNVP: 'Schiele'
            },
            agriculture: {
                KPD: 'Hoernle', SAPD: 'Baade', SRPD: 'Baade', DDP: 'Dietrich',
                Z: 'Hermes', BVP: 'Wutzlhofer', DVP: 'Schiele', WP: 'Bredt',
                CNBL: 'Hamkens', DNVP: 'Schiele'
            },
            transport: {
                KPD: 'Hoernle', SAPD: 'Baade', SRPD: 'Baade', DDP: 'Dietrich',
                Z: 'Guerard', BVP: 'Wutzlhofer', DVP: 'Schiele', WP: 'Bredt',
                CNBL: 'Hamkens', DNVP: 'Schiele'
            }
        };
        
        if (ministers[ministry] && ministers[ministry][party]) {
            Q[minister_var] = ministers[ministry][party];
        } else {
            Q[minister_var] = 'Unbesetzt';
        }
    }
    
    // Check how many changes were made
    var changes = 0;
    for (var ministry in Q.original_allocation) {
        if (!Q.original_allocation.hasOwnProperty(ministry)) continue;
        var current_party_var = ministry + '_minister_party';
        if (Q.original_allocation[ministry] !== Q[current_party_var]) {
            changes++;
        }
    }
    
    Q.shuffle_changes_made = changes;
    
    // Calculate per-party ministry delta (positive = net loss, negative = net gain)
    var ministry_delta = {};
    for (var i = 0; i < Q.government_parties.length; i++) {
        ministry_delta[Q.government_parties[i]] = 0;
    }
    
    for (var ministry in Q.original_allocation) {
        if (!Q.original_allocation.hasOwnProperty(ministry)) continue;
        var orig_party = Q.original_allocation[ministry];
        if (ministry_delta[orig_party] !== undefined) {
            ministry_delta[orig_party]++;
        }
        var curr_party = Q[ministry + '_minister_party'];
        if (ministry_delta[curr_party] !== undefined) {
            ministry_delta[curr_party]--;
        }
    }
    
    // Identify parties that lost ministries and may demand compensation
    var compensation_needed = [];
    for (var party in ministry_delta) {
        if (!ministry_delta.hasOwnProperty(party)) continue;
        if (party !== 'SPD' && ministry_delta[party] > 0) {
            compensation_needed.push({
                party: party,
                losses: ministry_delta[party],
                leverage: Q.shuffle_leverage[party] || 0
            });
        }
    }
    
    compensation_needed.sort(function(a, b) { return b.leverage - a.leverage; });
    
    Q.coalition_demands = [];
    
    // Build list of SPD ministries that could be seized
    var ministries = ['foreign', 'interior', 'justice', 'labor', 'economic', 'finance', 'agriculture', 'transport'];
    var available_to_take = [];
    for (var i = 0; i < ministries.length; i++) {
        if (Q[ministries[i] + '_minister_party'] === 'SPD') {
            available_to_take.push(ministries[i]);
        }
    }
    
    // Compensation seizures
    for (var i = 0; i < compensation_needed.length; i++) {
        var demand = compensation_needed[i];
        var rel_var = demand.party.toLowerCase() + '_relation';
        var relation = Q[rel_var] || 50;
        var spd_leverage = Q.shuffle_leverage.SPD || 0;
        
        var takeover_chance = demand.leverage > spd_leverage
            ? 0.3 + (demand.losses * 0.15)
            : 0.1 + (demand.losses * 0.1);
        
        if (relation < 40) takeover_chance += 0.2;
        if (relation < 30) takeover_chance += 0.2;
        
        for (var j = 0; j < demand.losses; j++) {
            if (Math.random() < takeover_chance && available_to_take.length > 0) {
                var ministry_idx = Math.floor(Math.random() * available_to_take.length);
                var taken_ministry = available_to_take.splice(ministry_idx, 1)[0];
                
                Q[taken_ministry + '_minister_party'] = demand.party;
                assign_minister(taken_ministry, demand.party);
                
                Q.coalition_demands.push({
                    party: demand.party,
                    ministry: taken_ministry,
                    reason: 'compensation'
                });
                
                changes++;
            }
        }
    }
    
    // Opportunistic grabs when SPD is weak
    if ((Q.shuffle_leverage.SPD || 0) < 40 || Q.coalition_dissent > 3) {
        for (var i = 0; i < Q.government_parties.length; i++) {
            var party = Q.government_parties[i];
            if (party === 'SPD') continue;
            if (ministry_delta[party] < 0) continue; // already gained ministries, skip
            
            var rel_var = party.toLowerCase() + '_relation';
            var relation = Q[rel_var] || 50;
            var party_leverage = Q.shuffle_leverage[party] || 0;
            var spd_leverage = Q.shuffle_leverage.SPD || 0;
            
            var grab_chance = 0;
            if (party_leverage > spd_leverage * 1.3) grab_chance = 0.25;
            if (relation < 35) grab_chance += 0.15;
            if (Q.coalition_dissent > 4) grab_chance += 0.15;
            
            if (Math.random() < grab_chance && available_to_take.length > 0) {
                var ministry_idx = Math.floor(Math.random() * available_to_take.length);
                var taken_ministry = available_to_take.splice(ministry_idx, 1)[0];
                
                Q[taken_ministry + '_minister_party'] = party;
                assign_minister(taken_ministry, party);
                
                Q.coalition_demands.push({
                    party: party,
                    ministry: taken_ministry,
                    reason: 'opportunistic'
                });
                
                changes++;
            }
        }
    }
    
    Q.shuffle_changes_made = changes;
    
    // Coalition stability impact
    if (changes > 5) {
        Q.coalition_dissent += 2;
    } else if (changes > 3) {
        Q.coalition_dissent += 1;
    }
    
    // Build response text — BUG FIX: this is now actually displayed in scene text below
    Q.coalition_response_text = "";
    if (Q.coalition_demands && Q.coalition_demands.length > 0) {
        for (var i = 0; i < Q.coalition_demands.length; i++) {
            var demand = Q.coalition_demands[i];
            var ministry_name = demand.ministry.charAt(0).toUpperCase() + demand.ministry.slice(1);
            if (demand.reason === 'compensation') {
                Q.coalition_response_text += "- The **" + demand.party + "** has seized the **" + ministry_name + " Ministry** as compensation for their losses.\n\n";
            } else {
                Q.coalition_response_text += "- The **" + demand.party + "** has opportunistically claimed the **" + ministry_name + " Ministry**.\n\n";
            }
        }
    }
    
    Q.cal = Q.coalition_demands.length;
!}

[? if shuffle_changes_made > 0 : The cabinet has been reshuffled. ?]
[? if shuffle_changes_made = 0 : No changes were made to the cabinet. ?]

[? if cal > 0 : **Coalition partners have responded:** ?]

[+ coalition_response_text +]

- @ministry_shuffle_complete: Continue

@ministry_shuffle_complete

The ministry reshuffle is complete.

@cancel_shuffle

The current arrangement will remain unchanged.
