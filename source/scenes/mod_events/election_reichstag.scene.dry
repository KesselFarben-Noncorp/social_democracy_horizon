@claim_reichswehr
title: Claim Reichswehr Ministry
unavailable-subtitle: [? if reichswehr_minister_party = "SPD" : Already controlled ?][? if shuffle_spd_variable < 20 : Not enough leverage ?]
choose-if: reichswehr_minister_party != "SPD" and shuffle_spd_variable >= 20
on-arrival: {!
    Q.shuffle_leverage.SPD -= 20;
    Q.shuffle_spd_variable = Q.shuffle_leverage.SPD;
    Q.reichswehr_minister_party = "SPD";
    Q.reichswehr_minister = "Leber";
    Q.reichswehr_loyalty -= 0.15;
    Q.coalition_dissent += 1;
    
    for (var i = 0; i < Q.government_parties.length; i++) {
        var party = Q.government_parties[i];
        if (party !== 'SPD') {
            var rel_var = party.toLowerCase() + '_relation';
            Q[rel_var] = Math.max(0, (Q[rel_var] || 50) - 15);
        }
    }
!}
go-to: ministry_picker

Julius Leber has been appointed Reichswehr Minister. The military is **furious**. The entire coalition is shaken.

// ============================================
// DROP MINISTRIES
// Helper: find the first non-SPD coalition party
// ============================================

@drop_labor
title: Drop Labor Ministry
view-if: labor_minister_party = "SPD"
on-arrival: {!
    Q.shuffle_leverage.SPD += 5;
    Q.shuffle_spd_variable = Q.shuffle_leverage.SPD;

    // Find first non-SPD coalition partner to receive the ministry
    var new_party = 'Z';
    if (Q.government_parties) {
        for (var i = 0; i < Q.government_parties.length; i++) {
            if (Q.government_parties[i] !== 'SPD') {
                new_party = Q.government_parties[i];
                break;
            }
        }
    }
    Q.labor_minister_party = new_party;
    Q.labor_minister = 'Stegerwald';
    if (Q.coalition_dissent > 0) Q.coalition_dissent -= 1;
!}
go-to: ministry_picker

We have relinquished the Labor Ministry.

