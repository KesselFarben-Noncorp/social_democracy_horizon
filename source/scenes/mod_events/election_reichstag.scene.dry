title: Reichstag Elections
new-page: true
tags: event
priority: -2
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year)
on-arrival: last_chancellor = chancellor; old_chancellor = chancellor
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 4; n_elections += 1; next_election_time = time + 48; papen_chancellor_timer = 4; tag_1 = 1; 
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

= Elections, [+ month : month +] [+ year +]

The Reichstag elections are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-arrival: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; dvp_relation -= 8; z_relation -= 8; ddp_relation -= 10; kpd_relation -= 8; coup_progress += 2; workers_spd -= 4; new_middle_spd -= 5; old_middle_spd -= 5; rural_spd -= 5; catholics_spd -= 5; unemployed_spd -= 5; coup_progress += 2 if nsdap_normalized >= 0.3; coup_progress += 2 if nsdap_normalized + dnvp_normalized >= 0.5; sa_strength += 100 if coup_progress >= 7; sh_strength += 100 if coup_progress >= 7
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

@post_election_1928
on-arrival: {!
// === CLEAR GOVERNMENT STATUS ===
// Dynamically reset the government status for all active parties
for (var party of Q.parties) {
    Q[party + '_in_government'] = 0;
}

var new_party_sum = 0;

// Calculate election results
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'] ?? 0;
    Q['old_' + party + '_seat_pct'] = Q[party + '_seat_pct'] ?? 0;
    Q['old_' + party + '_seats'] = Q[party + '_seats'] ?? 0;
    
    // Handle banned parties - set support to 0
    if (Q[party + '_banned']) {
        Q[party + '_support'] = 0;
    }
    
    if (Q.constitutional_reform > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || 
            (Q.electoral_threshold > 1 && party === 'other') ||
            Q[party + '_banned']) {
            Q[party + '_support'] = 0;
        }
    }
    
    if (Q.math_broken) {
        // CHAOS MODE: Support values become nonsense
        Q[party + '_support'] = Q.impossible_add(Q[party + '_support'], 0);
    }
    
    new_party_sum += Q[party + '_support'];
}

// Apply chaos to the sum itself
if (Q.math_broken) {
    new_party_sum = Q.impossible_multiply(new_party_sum, 1);
}

for (var party of Q.parties) {
    // If party is banned, force everything to 0
    if (Q[party + '_banned'] && !Q.math_broken) {
        Q[party + '_r'] = 0;
        Q[party + '_votes'] = 0;
    } else if (!Q.math_broken) {
        // NORMAL: Votes sum to 100%
        if (new_party_sum > 0) {
            Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
        } else {
            Q[party + '_r'] = 0;
        }
        Q[party + '_votes'] = Math.round(Q[party + '_r'] * 10) / 10;
    } else {
        // CHAOS MODE: Division doesn't work properly
        if (new_party_sum > 0) {
            // Random choice of broken operations
            var roll = Math.random();
            if (roll < 0.3) {
                // Normal (rare)
                Q[party + '_r'] = (Q[party + '_support'] / new_party_sum) * 100;
            } else if (roll < 0.5) {
                // Multiplication instead of division
                Q[party + '_r'] = Q.impossible_multiply(Q[party + '_support'], new_party_sum / 100);
            } else if (roll < 0.7) {
                // Just add some chaos
                Q[party + '_r'] = Q.impossible_percentage(Q[party + '_support']);
            } else {
                // Complete nonsense
                Q[party + '_r'] = Q.impossible_add(Q[party + '_support'], new_party_sum);
            }
        } else {
            Q[party + '_r'] = Q.impossible_subtract(0, 0); // "Zero" that isn't zero
        }
        
        // Votes calculation also broken
        Q[party + '_votes'] = Q.impossible_multiply(Q[party + '_r'], 1);
        
        // Ensure no NaN
        if (isNaN(Q[party + '_r'])) Q[party + '_r'] = Math.random() * 50;
        if (isNaN(Q[party + '_votes'])) Q[party + '_votes'] = Math.random() * 50;
    }
}

for (var party of Q.parties) {
    if (!Q.math_broken) {
        // NORMAL: Display formatting
        Q[party + '_r_disp'] = (Math.round(Q[party + '_r'] * 10) / 10).toFixed(1);
        
        Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
        Q['str_change_' + party] = (Q['change_' + party + '_r'] >= 0 ? '+' : '') +
            (Math.ceil(Q['change_' + party + '_r'] * 10) / 10).toFixed(1);
    } else {
        // CHAOS MODE: Display formatting is also broken
        if (Q.use_decimals) {
            Q[party + '_r_disp'] = Q.impossible_add(Q[party + '_r'], 0).toFixed(1);
        } else {
            Q[party + '_r_disp'] = Math.round(Q.impossible_multiply(Q[party + '_r'], 1)).toString();
        }
        
        // Change calculation doesn't work right
        Q['change_' + party + '_r'] = Q.impossible_subtract(Q[party + '_r'], Q['old_' + party + '_r']);
        
        // Ensure no NaN in change
        if (isNaN(Q['change_' + party + '_r'])) Q['change_' + party + '_r'] = Math.random() * 20 - 10;
        
        // Sign might be wrong
        var broken_sign = Math.random() < 0.3 ? '-' : '+';
        if (Math.random() < 0.5) {
            // Sometimes use correct sign
            broken_sign = (Q['change_' + party + '_r'] >= 0 ? '+' : '');
        }
        
        Q['str_change_' + party] = broken_sign +
            Q.impossible_add(Q['change_' + party + '_r'], 0).toFixed(1);
    }
}

// === SEAT CALCULATIONS ===
// Reichstag had 577 base seats (we use *6 multiplier from display, so 600 total)
Q.total_seats = 600;

Q.election_system_name = Q.fptp_variable === 1 ? 'First Past the Post' : 'Proportional Representation';

if (Q.fptp_variable === 1) {
    var fptp_votes = {};
    var fptp_sum = 0;
    for (var i = 0; i < Q.parties.length; i++) {
        var party = Q.parties[i];
        var v = Q[party + '_r'] || 0;
        if (v >= 3 && !Q[party + '_banned']) {  // 3% threshold, softer than 5%
            fptp_votes[party] = v;
            fptp_sum += v;
        } else {
            fptp_votes[party] = 0;
        }
    }

    // Normalise
    var fptp_normalised = {};
    for (var party in fptp_votes) {
        fptp_normalised[party] = fptp_sum > 0
            ? (fptp_votes[party] / fptp_sum) * 100 : 0;
    }

    // Squared rule instead of cube — less brutal amplification
    // s = v² / Σv²
    var sq_sum = 0;
    var squares = {};
    for (var party in fptp_normalised) {
        var v = fptp_normalised[party] / 100;
        squares[party] = v * v;
        sq_sum += squares[party];
    }

    // Using variable 'k' to guarantee absolutely no overlap with existing loops
    for (var k = 0; k < Q.parties.length; k++) {
        var party = Q.parties[k];
        Q[party + '_seats'] = (sq_sum > 0 && squares[party] > 0)
            ? Math.round((squares[party] / sq_sum) * Q.total_seats)
            : 0;
    }

    // Fix rounding on largest party
    var fptp_seat_total = 0;
    var largest_fptp_party = null;
    var largest_fptp_seats = 0;
    for (var m = 0; m < Q.parties.length; m++) {
        var party = Q.parties[m];
        fptp_seat_total += Q[party + '_seats'];
        if (Q[party + '_seats'] > largest_fptp_seats) {
            largest_fptp_seats = Q[party + '_seats'];
            largest_fptp_party = party;
        }
    }
    if (largest_fptp_party) {
        Q[largest_fptp_party + '_seats'] += Q.total_seats - fptp_seat_total;
    }
} else {
    for (var party of Q.parties) {
        if (!Q.math_broken) {
            Q[party + '_seats'] = Math.round(Q[party + '_r'] * 6);
        } else {
            Q[party + '_seats'] = Math.round(Q.impossible_multiply(Q[party + '_r'], 6));
        }
    }
}

// Seat-based vote share (may differ slightly from _r due to rounding)
Q.total_seats_filled = 0;
for (var party of Q.parties) {
    Q.total_seats_filled += Q[party + '_seats'];
}

for (var party of Q.parties) {
    if (!Q.math_broken) {
    Q[party + '_seat_pct'] = Q.total_seats_filled > 0 
        ? Math.round((Q[party + '_seats'] / Q.total_seats_filled) * 1000) / 10 
        : 0;
    // Display string
    Q[party + '_seats_disp'] = Q[party + '_seats'].toString();
    Q[party + '_seat_pct_disp'] = Q[party + '_seat_pct'].toFixed(1);
    Q['change_' + party + '_seat_pct'] = Q[party + '_seat_pct'] - Q['old_' + party + '_seat_pct'];
    Q['str_change_' + party + '_seats'] = (Q['change_' + party + '_seat_pct'] >= 0 ? '+' : '') +
        (Math.round(Q['change_' + party + '_seat_pct'] * 10) / 10).toFixed(1);
    // NEW: number-based seat delta
    Q['change_' + party + '_seats_num'] = Q[party + '_seats'] - Q['old_' + party + '_seats'];
    Q['str_change_' + party + '_seats_num'] = (Q['change_' + party + '_seats_num'] >= 0 ? '+' : '') +
        Q['change_' + party + '_seats_num'].toString();
    }
}

for (var party of Q.parties) {
    if (Q[party + '_support'] === 0 || Q[party + '_r'] === 0) {
        Q[party + '_seats'] = 0;
        Q[party + '_seat_pct'] = 0;
        Q[party + '_r'] = 0;
        Q[party + '_votes'] = 0;
    }
}

// Reset government flags
Q.coalition_dissent = 0;
Q.kpd_coalition_dissent = 0;
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.spd_toleration = 0;
Q.in_bourgeois_coalition = 0;
Q.in_right_coalition = 0;
Q.in_social_christian_coalition = 0;
Q.in_social_liberal_coalition = 0;

// Reset KPD goals
Q.kpd_goals_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labor_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.reichswehr_goal = 0;

// ============================================
// SPECIAL COALITION CONDITIONS
// ============================================

Q.popular_front_possible = (Q.kpd_party_leader === "Conciliators" && Q.z_party_leader === "Joos") ? 1 : 0;
Q.left_front_possible = (Q.communist_coalition >= 3 && Q.kpd_relation >= 50) ? 1 : 0;
Q.unity_government_possible = (Q.nazi_urgency >= 6 || Q.pro_republic < 40) ? 1 : 0;
Q.bourgeois_only_possible = (Q.year >= 1929 || Q.spd_r < 25) ? 1 : 0;
Q.right_coalition_viable = (Q.dnvp_line !== 3 || Q.z_party_leader === "Kaas") ? 1 : 0;

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
on-display: {!
var partyData = [
{ id: "kapd", name: "KAPD",       color: "#5C0000", seats: Q.kapd_seats, show: !!(Q.kapd_r > 0) },
{ id: "faud", name: "FAUD",       color: "#1C1C1C", seats: Q.faud_seats, show: !!(Q.faud_r > 0) },
{ id: "kpd",  name: "KPD",        color: "#8B0000", seats: Q.kpd_seats,  show: !!(Q.kpd_r  && Q.kpd_r  > 0) },
{ id: "sapd", name: "SAPD",       color: "#C40000", seats: Q.sapd_seats, show: !!(Q.sapd_formed && Q.sapd_r) },
{ id: "lb",   name: "LB",         color: "#6B0000", seats: Q.lb_seats,   show: !!(Q.lb_r   && Q.lb_r   > 0) },
{ id: "sl",   name: "SL",         color: "#005B96", seats: Q.sl_seats,   show: !!(Q.sl_r   && Q.sl_r   > 0) },
{ id: "kpo",  name: "KPO",        color: "#990000", seats: Q.kpo_seats,  show: !!(Q.kpo_r  && Q.kpo_r  > 0) },
{ id: "spd",  name: "SPD",        color: "#E3000F", seats: Q.spd_seats,  show: !!(Q.spd_r  && Q.spd_r  > 0) },
{ id: "srpd", name: "SRPD",       color: "#FF6B6B", seats: Q.srpd_seats, show: !!(Q.srpd_formed && Q.srpd_r) },
{ id: "rdp",  name: "RDP",        color: "#B8B000", seats: Q.rdp_seats,  show: !!(Q.rdp_r  && Q.rdp_r  > 0) },
{ id: "ddp",  name: Q.ddp_name,   color: "#DCCA4A", seats: Q.ddp_seats,  show: !!(Q.ddp_r  && Q.ddp_r  > 0) },
{ id: "dbp",  name: "DBP",        color: "#03A331",  seats: Q.dbp_seats,  show: !!(Q.dbp_r  && Q.dbp_r  > 0) },
{ id: "cvp",  name: "CVP",        color: "#1A1A1A", seats: Q.cvp_seats,  show: !!(Q.cvp_r  && Q.cvp_r  > 0) },
{ id: "z",    name: "Center",     color: "#000000", seats: Q.z_seats,    show: !!(Q.z_r    && Q.z_r    > 0) },
{ id: "bb",   name: "BB",         color: "#69A2BE", seats: Q.bb_seats,   show: !!(Q.bb_r   && Q.bb_r   > 0) },
{ id: "bvp",  name: "BVP",        color: "#69A2BE", seats: Q.bvp_seats,  show: !!(Q.bvp_r  && Q.bvp_r  > 0) },
{ id: "csrp", name: "CSRP",       color: "#FFCCFF", seats: Q.csrp_seats, show: !!(Q.csrp_r && Q.csrp_r > 0) },
{ id: "sls",  name: "SLS",        color: "#4A7C59", seats: Q.sls_seats,  show: !!(Q.sls_r  && Q.sls_r  > 0) },
{ id: "aspd", name: "ASPD",       color: "#B22222", seats: Q.aspd_seats, show: !!(Q.aspd_r && Q.aspd_r > 0) },
{ id: "dhp",  name: "DHP",        color: "#69A2BE", seats: Q.dhp_seats,  show: !!(Q.dhp_r  && Q.dhp_r  > 0) },
{ id: "dsbp", name: Q.dsbp_name, color: Q.dsbp_name === "DLP" ? "#F7FF05" : "#7A9DB5", seats: Q.dsbp_seats, show: !!(Q.dsbp_r && Q.dsbp_r > 0) },
{ id: "dvp",  name: "DVP",        color: "#D5AC27", seats: Q.dvp_seats,  show: !!(Q.dvp_r  && Q.dvp_r  > 0) },
{ id: "vrp",  name: "VRP",        color: "#8B7355", seats: Q.vrp_seats,  show: !!(Q.vrp_r  && Q.vrp_r  > 0) },
{ id: "wp",   name: "WP",         color: "#424242", seats: Q.wp_seats,   show: !!(Q.wp_r   && Q.wp_r   > 0) },
{ id: "hl",   name: "HL",         color: "#2E8B57", seats: Q.hl_seats,   show: !!(Q.hl_r   && Q.hl_r   > 0) },
{ id: "vnr",  name: "VNR",        color: "#4B5320", seats: Q.vnr_seats,  show: !!(Q.vnr_r  && Q.vnr_r  > 0) },
{ id: "cnbl", name: "CNBL",       color: "#5D4E37", seats: Q.cnbl_seats, show: !!(Q.cnbl_r && Q.cnbl_r > 0) },
{ id: "csvd", name: "CSVD",       color: "#3f7bc1", seats: Q.csvd_seats, show: !!(Q.csvd_r > 0) },
{ id: "kvp",  name: "KVP",        color: "#3f7bc1", seats: Q.kvp_seats,  show: !!(Q.kvp_r  > 0) },
{ id: "rlb",  name: "RLB",        color: "#4A5D23", seats: Q.rlb_seats,  show: !!(Q.rlb_r && Q.rlb_r > 0) },
{ id: "dnvp", name: "DNVP",       color: "#3f7bc1", seats: Q.dnvp_seats, show: !!(Q.dnvp_r && Q.dnvp_r > 0) },
{ id: "dnf", name: "DNF",         color:  "#000F70", seats: Q.dnf_seats, show: !!(Q.dnf_r && Q.dnf_r > 0) },
{ id: "other",name: "Other",      color: "#a0a0a0", seats: Q.other_seats,show: !!(Q.other_r && Q.other_r > 0) },
{ id: "nsdap",name: "NSDAP",      color: "#954B00", seats: Q.nsdap_seats,show: !!(Q.nsdap_r && Q.nsdap_r > 0) },
{ id: "dtsp", name: "DtsP",       color: "#3B1A00", seats: Q.dtsp_seats, show: !!(Q.dtsp_r  && Q.dtsp_r  > 0) },
{ id: "dvfp", name: "DVFP",       color: "#1A0F00", seats: Q.dvfp_seats, show: !!(Q.dvfp_formed && Q.dvfp_r > 0) },
];

var visibleParties = partyData.filter(function(p) { return p.show && p.seats > 0; });

// Parliament diagram data
var data = visibleParties.map(function(p) {
    return { id: p.id, legend: p.name, name: p.name, seats: p.seats };
});

if (window && d3) {
    var width = 600;
    var height = 300;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = Math.round(width / 2);
        document.getElementById("reichstag").style.height = height + "px";
    }
    document.getElementById("reichstag").style.width = width + "px";
    document.getElementById("reichstag").style.height = height + "px";

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);

    // Color bar
    var totalSeats = visibleParties.reduce(function(sum, p) { return sum + p.seats; }, 0);
    var bar = document.getElementById("party-color-bar");
    bar.innerHTML = "";
    bar.style.display = "flex";
    bar.style.width = "100%";
    bar.style.height = "28px";
    bar.style.marginTop = "8px";
    bar.style.overflow = "hidden";
    bar.style.borderRadius = "3px";

    visibleParties.forEach(function(p) {
        var pct = p.seats / totalSeats;
        var seg = document.createElement("div");
        seg.style.width = (pct * 100) + "%";
        seg.style.height = "100%";
        seg.style.backgroundColor = p.color;
        seg.style.display = "flex";
        seg.style.alignItems = "center";
        seg.style.justifyContent = "center";
        seg.style.overflow = "hidden";
        seg.style.boxSizing = "border-box";
        seg.title = p.name + ": " + p.seats + " seats";

        // Label if segment wide enough (roughly >3.5% of total)
        if (pct > 0.035) {
            var label = document.createElement("span");
            label.style.fontSize = "10px";
            label.style.fontWeight = "bold";
            label.style.color = "#fff";
            label.style.textShadow = "0 0 2px #000, 0 0 2px #000";
            label.style.whiteSpace = "nowrap";
            label.style.pointerEvents = "none";
            label.textContent = p.name + " " + Math.round(pct * 100) + "%";
            seg.appendChild(label);
        }

        bar.appendChild(seg);
    });
}
!}
go-to: coalition_formation_start

= Election results

[? if fptp_variable = 1 : <p style="font-size:0.8em; color:#888; font-style:italic;">⚑ First Past the Post seat allocation — cube rule with 5% threshold</p> ?]

{!<svg id="reichstag" style="width: 600px; height: 300px;"> </svg>
<div id="party-color-bar"></div>!}

{!<table style="width:100%; border-collapse: collapse;">
<tr style="border-bottom: 2px solid #333;">
    <td style="padding: 8px; font-weight: bold;">Party</td>
    <td style="padding: 8px; font-weight: bold; text-align: right;">Votes</td>
    <td style="padding: 8px; font-weight: bold; text-align: right;">Δ Votes</td>
    <td style="padding: 8px; font-weight: bold; text-align: right;">Seats</td>
    <td style="padding: 8px; font-weight: bold; text-align: right;">Δ Seats</td>
</tr>!}
[? if kapd_votes > 0 :
<tr class="row-far-left">
    <td style="padding: 8px;"><div class="box" style='background-color:#5C0000; display:inline-block; margin-right:8px;'> </div>KAPD</td>
    <td style="padding: 8px; text-align: right; font-weight: bold;">[+ kapd_r_disp +]%</td>
    <td style="padding: 8px; text-align: right; [? if change_kapd_r > 0 : color: green; ?][? if change_kapd_r < 0 : color: red; ?]">[+ str_change_kapd +]</td>
    <td style="padding: 8px; text-align: right;">[+ kapd_seats +]</td>
    <td style="padding: 8px; text-align: right; [? if change_kapd_seats_num > 0 : color: green; ?][? if change_kapd_seats_num < 0 : color: red; ?]">[+ str_change_kapd_seats_num +]</td>
</tr>
?]
[? if faud_votes > 0 :
<tr class="row-far-left">
    <td style="padding: 8px;"><div class="box" style='background-color:#1C1C1C; display:inline-block; margin-right:8px;'> </div>FAUD</td>
    <td style="padding: 8px; text-align: right; font-weight: bold;">[+ faud_r_disp +]%</td>
    <td style="padding: 8px; text-align: right; [? if change_faud_r > 0 : color: green; ?][? if change_faud_r < 0 : color: red; ?]">[+ str_change_faud +]</td>
    <td style="padding: 8px; text-align: right;">[+ faud_seats +]</td>
    <td style="padding: 8px; text-align: right; [? if change_faud_seats_num > 0 : color: green; ?][? if change_faud_seats_num < 0 : color: red; ?]">[+ str_change_faud_seats_num +]</td>
</tr>
?]
[? if kpd_votes > 0 :
<tr class="row-left">
