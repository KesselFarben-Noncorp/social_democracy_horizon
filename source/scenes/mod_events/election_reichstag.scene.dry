@spd_decline_formateur
on-arrival: {!
// SPD refuses to form government
Q.coalition_formed = 0;
Q.spd_accepted_coalition = 0;

// Political consequences
Q.left_dissent += 5;
Q.reformist_dissent += 5;
Q.pro_republic -= 3;

// Note: This will trigger coalition_failure and pass mandate to next party
!}

= SPD Declines to Form Government

We have chosen not to form a government at this time.

**Consequences:**
- The mandate will pass to the next largest party
- Our reputation for governmental responsibility may suffer
- Some within the party question this decision

**The President will now approach the next party in line.**

- @coalition_failure: Continue

# ============================================
# PLAYER REVIEWS COALITION INVITATION (NON-FORMATEUR)
# ============================================

@player_coalition_review
on-arrival: {!
// Pre-calculate display if coalition exists
if (Q.coalition_formed) {
    var seat_total = 0;
for (var i = 0; i < Q.parties.length; i++) {
    seat_total += Q[Q.parties[i] + '_seats'] || 0;
}
if (seat_total === 0) seat_total = 1;

Q.coalition_partners_list = "";
for (var i = 0; i < Q.chosen_coalition.parties.length; i++) {
    var party = Q.chosen_coalition.parties[i];
    var seat_pct = ((Q[party.toLowerCase() + '_seats'] || 0) / seat_total) * 100;
    Q.coalition_partners_list += "- " + party + " (" + Math.round(seat_pct * 10) / 10 + "%)\n";
}
    Q.coalition_total_votes = Q.chosen_coalition.votes;
    Q.coalition_is_minority = Q.chosen_coalition.toleration ? 1 : 0;
    Q.coalition_toleration_display = "";
    if (Q.chosen_coalition.toleration) {
        Q.coalition_toleration_display = "\n**External Toleration (not in cabinet):**\n";
        var tols = Q.chosen_coalition.tolerating_parties;
        for (var i = 0; i < tols.length; i++) {
    var tpct = ((Q[tols[i].toLowerCase() + '_seats'] || 0) / seat_total) * 100;
    Q.coalition_toleration_display += "- " + tols[i] + " (" + Math.round(tpct * 10) / 10 + "%) — tolerating\n";
        }
        Q.coalition_effective_votes = Q.chosen_coalition.effective_votes;
    }
}
!}

= Coalition Invitation - [+ formateur +] Proposes Government

**[+ formateur +] has successfully negotiated a coalition and invites the SPD to participate.**

**Proposed Coalition:**

[+ coalition_partners_list +]

**Total Reichstag Support:** [+ coalition_total_votes +]%

[? if coalition_is_minority : This is a **minority government** that will rely on external toleration to survive votes of no confidence. ?]

[+ coalition_toleration_display +]

[? if coalition_is_minority : **Effective majority with tolerating parties:** [+ coalition_effective_votes +]% ?]

**Chancellor:** [+ formateur +] will provide the Chancellor.

**What is our decision?**

- @accept_coalition_invitation: Accept the invitation and join this coalition
- @reject_coalition_invitation: Decline the invitation

@accept_coalition_invitation
on-arrival: spd_accepted_coalition = 1

We accept the invitation to join this coalition government.

- @coalition_success: Alright.

@reject_coalition_invitation

= Declining Coalition Participation

**Are you certain you want to decline this coalition?**

**Consequences:**
- [+ formateur +] will attempt to form a government without the SPD
- We will sit in opposition
- Relations with [+ formateur +] will worsen
- The coalition may lack a majority and fail

- @confirm_reject_coalition: Yes, decline the invitation
- @accept_coalition_invitation: No, accept the coalition after all

@confirm_reject_coalition
on-arrival: {!
var formateur_lower = Q.formateur.toLowerCase();
var relation_var = formateur_lower + '_relation';
if (Q[relation_var] !== undefined) {
    Q[relation_var] -= 5;
}

// Track rejections
Q.spd_rejection_count = (Q.spd_rejection_count || 0) + 1;

// Mark this coalition as rejected so we skip it
if (!Q.rejected_coalitions) Q.rejected_coalitions = [];
Q.rejected_coalitions.push(JSON.stringify(Q.chosen_coalition.parties.slice().sort()));

// Find next viable coalition that hasn't been rejected
Q.next_coalition_found = 0;
for (var i = 0; i < Q.possible_coalitions.length; i++) {
    var coal = Q.possible_coalitions[i];
    var key = JSON.stringify(coal.parties.slice().sort());
    var already_rejected = false;
    for (var j = 0; j < Q.rejected_coalitions.length; j++) {
        if (Q.rejected_coalitions[j] === key) { already_rejected = true; break; }
    }
    if (!already_rejected && coal.parties.indexOf('SPD') >= 0) {
        Q.chosen_coalition = coal;
        Q.next_coalition_found = 1;
        break;
    }
}

Q.spd_accepted_coalition = 0;
Q.spd_in_chosen_coalition = Q.next_coalition_found;

// Political consequences
!}
go-to: player_coalition_review if next_coalition_found and spd_rejection_count < 3; coalition_failure if not next_coalition_found or spd_rejection_count >= 3

@coalition_formed_without_spd

= Coalition Formed Without SPD

**[+ formateur +] has formed a government without the SPD.**

**Coalition Partners:**

[+ coalition_partners_list +]

**Total Support:** [+ coalition_total_votes +]%

The SPD will sit in opposition. [? if coalition_total_votes < 55 : This is a narrow majority and may prove unstable. ?]

- @continue_without_spd: Continue

@continue_without_spd
on-arrival: {!
// Set opposition status
Q.spd_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;

// Opposition benefits
Q.workers_spd += 3;
Q.left_strength += 5;
!}
go-to: coalition_success






@coalition_success
on-arrival: {!
// ============================================
// COALITION SUCCESSFULLY FORMED
// ============================================

Q.is_minority_government = Q.chosen_coalition.toleration ? 1 : 0;
Q.tolerating_parties = Q.chosen_coalition.toleration ? Q.chosen_coalition.tolerating_parties : [];
Q.spd_toleration = (Q.chosen_coalition.toleration && Q.chosen_coalition.tolerating_parties.indexOf('SPD') >= 0) ? 1 : 0;

// Set flags for each tolerating party
if (Q.chosen_coalition.toleration) {
    for (var i = 0; i < Q.chosen_coalition.tolerating_parties.length; i++) {
        var t = Q.chosen_coalition.tolerating_parties[i].toLowerCase();
        Q[t + '_tolerating'] = 1;
    }
}

var coalition = Q.chosen_coalition.parties;
Q.government_parties = coalition;
Q.coalition_votes = Q.chosen_coalition.votes;
Q.coalition_type = Q.chosen_coalition.type;

// Replace the coalition_partners_list building block in @coalition_success:

var seat_total_cs = 0;
for (var i = 0; i < Q.parties.length; i++) {
    seat_total_cs += Q[Q.parties[i] + '_seats'] || 0;
}
if (seat_total_cs === 0) seat_total_cs = 1;

Q.coalition_partners_list = "";
for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var seat_pct = ((Q[party.toLowerCase() + '_seats'] || 0) / seat_total_cs) * 100;
    Q.coalition_partners_list += "- **" + party + "**: " + Math.round(seat_pct * 10) / 10 + "%\n";
}

if (Q.chosen_coalition.toleration) {
    Q.coalition_partners_list += "\n**External Support (Toleration):**\n";
    var tol_parties = Q.chosen_coalition.tolerating_parties;
    for (var i = 0; i < tol_parties.length; i++) {
        var tparty = tol_parties[i];
        var tpct = ((Q[tparty.toLowerCase() + '_seats'] || 0) / seat_total_cs) * 100;
        Q.coalition_partners_list += "- **" + tparty + "**: " + Math.round(tpct * 10) / 10 + "% *(tolerating)*\n";
    }
    Q.coalition_votes_display = Math.round(Q.chosen_coalition.votes * 10) / 10 + "% (effective: " + Math.round(Q.chosen_coalition.effective_votes * 10) / 10 + "%)";
} else {
    Q.coalition_votes_display = Math.round(Q.chosen_coalition.votes * 10) / 10 + "%";
}

// ============================================
// SET COALITION NAME AND FLAGS
// ============================================

if (Q.coalition_type === 'weimar') {
    Q.in_weimar_coalition = 1;
    Q.coalition_name = "Weimar Coalition";
} else if (Q.coalition_type === 'grand' || Q.coalition_type === 'grand_small') {
    Q.in_grand_coalition = 1;
    Q.coalition_name = "Grand Coalition";
} else if (Q.coalition_type === 'social_christian') {
    Q.in_social_christian_coalition = 1;
    Q.coalition_name = "Social - Christian Coalition";
} else if (Q.coalition_type === 'social_liberal') {
    Q.in_social_liberal_coalition = 1;
    Q.coalition_name = "Social - Liberal Coalition";
} else if (Q.coalition_type === 'left_front') {
    Q.in_left_front = 1;
    Q.coalition_name = "Left Front";
} else if (Q.coalition_type === 'popular_front') {
    Q.in_popular_front = 1;
    Q.coalition_name = "Popular Front";
} else if (Q.coalition_type === 'socialist_unity') {
    Q.coalition_name = "Socialist Unity Coalition";
} else if (Q.coalition_type === 'bourgeois' || Q.coalition_type === 'bourgeois_catholic') {
    Q.in_bourgeois_coalition = 1;
    Q.coalition_name = "Bourgeois Coalition";
} else if (Q.coalition_type === 'right' || Q.coalition_type === 'right_business') {
    Q.in_right_coalition = 1;
    Q.coalition_name = "Right Coalition";
} else if (Q.coalition_type === 'far_right') {
    Q.coalition_name = "Far-Right Coalition";
} else if (Q.coalition_type === 'unity') {
    Q.in_unity_government = 1;
    Q.coalition_name = "Unity Government";
} else {
    Q.coalition_name = "Coalition Government";
}

// ============================================
// IDENTIFY CHANCELLOR CANDIDATES
// ============================================

// Helper function to get viable chancellor candidates by party
function get_chancellor_candidates_for_party(party) {
    var candidates = [];
    
    if (party === 'KPD') {
        if (Q.kpd_party_leader === "Conciliators") {
            candidates.push({name: "Neumann", weight: 100});
        } else {
            candidates.push({name: "Thälmann", weight: 100});
        }
    } 
    else if (party === 'SAPD') {
        candidates.push({name: "Rosenfeld", weight: 100});
    } 
    else if (party === 'SPD') {
        // Alternative: if you need the player's preference to determine which ONE candidate appears, not multiple i guess
        if (Q.spd_chancellor_preference === "mueller" && !Q.muller_dead) {
            candidates.push({name: "Müller", weight: 100});
        } else if (Q.spd_chancellor_preference === "wels") {
            candidates.push({name: "Wels", weight: 100});
        } else if (Q.spd_chancellor_preference === "braun") {
            candidates.push({name: "Braun", weight: 100});
        } else if (Q.spd_chancellor_preference === "hilferding" && Q.spd_toleration === 0) {
            candidates.push({name: "Hilferding", weight: 100});
        } else if (Q.spd_chancellor_preference === "breitscheid") {
            candidates.push({name: "Breitscheid", weight: 100});
        } else if (Q.spd_chancellor_preference === "mr_monopoly") {
            candidates.push({name: "Rich Uncle Pennybags", weight: 200});
        } else {
            // Default fallback
            if (!Q.muller_dead) {
                candidates.push({name: "Müller", weight: 100});
            } else {
                candidates.push({name: "Wels", weight: 100});
            }
        }
    }
    else if (party === 'SRPD') {
        candidates.push({name: "Horsing", weight: 100});
    } 
    else if (party === 'DDP') {
        candidates.push({name: "Koch-Weser", weight: 100});
        if (Q.ddp_votes < 3) { // If party not too weakened
            candidates.push({name: "Dietrich", weight: 80});
        }
        if (Q.ddp_name === "DStP") {
            candidates.push({name: "Arthur Mahraun", weight: 99});
        } 
        }
    else if (party === 'Z') {
        if (Q.z_party_leader === "Joos") {
            candidates.push({name: "Wirth", weight: 100});
            candidates.push({name: "Joos", weight: 80});
        } else if (Q.z_party_leader === "Kaas") {
            candidates.push({name: "Kaas", weight: 100});
            candidates.push({name: "Brüning", weight: 90});
        } else if (Q.z_party_leader === "Brüning") {
            candidates.push({name: "Brüning", weight: 100});
            candidates.push({name: "Kaas", weight: 70});
        } else {
            candidates.push({name: "Joos", weight: 100});
            candidates.push({name: "Wirth", weight: 85});
            candidates.push({name: "Marx", weight: 40});
        }
    } 
    else if (party === 'CSRP') {
        candidates.push({name: "Heller", weight: 50});
    } 
    else if (party === 'BVP') {
        candidates.push({name: "Held", weight: 100});
        candidates.push({name: "Schäffer", weight: 80});
    } 
    else if (party === 'DVP') {
        if (!Q.stresemann_dead) {
            candidates.push({name: "Stresemann", weight: 100});
            candidates.push({name: "Scholz", weight: 70});
        } else {
            candidates.push({name: "Curtius", weight: 100});
            candidates.push({name: "Dingeldey", weight: 85});
        }
    } 
    else if (party === 'WP') {
        candidates.push({name: "Drewitz", weight: 100});
    } 
    else if (party === 'CSVD') {
        candidates.push({name: "Lambach", weight: 100});
    }
    else if (party === 'CNBL') {
        candidates.push({name: "Hepp", weight: 100});
    } 
    else if (party === 'DNVP') {
        if (Q.dnvp_line === 3) {
            candidates.push({name: "Hugenberg", weight: 100});
        } else if (Q.dnvp_line === 2) {
            candidates.push({name: "Westarp", weight: 100});
        } else {
            candidates.push({name: "Treviranus", weight: 75});
        }
    } else if (party === 'DVFP') {
    // Graefe is the primary political leader
    candidates.push({name: "Graefe", weight: 60});
    
    // Ludendorff is the 'prestige' candidate (The General)
    candidates.push({name: "Ludendorff", weight: 30});
    
    // Reventlow represents the radical 'social' wing of the völkisch movement
    candidates.push({name: "Reventlow", weight: 10});
    }
 
    
    return candidates;
}

// Build comprehensive candidate list
var all_candidates = [];

for (var i = 0; i < coalition.length; i++) {
    var party = coalition[i];
    var votes = Q[party.toLowerCase() + '_r'];
    var party_candidates = get_chancellor_candidates_for_party(party);
    
    for (var j = 0; j < party_candidates.length; j++) {
        var candidate = party_candidates[j];
        all_candidates.push({
            party: party,
            name: candidate.name,
            votes: votes,
            weight: candidate.weight,
            score: votes * (candidate.weight / 100) // Combined score for sorting

        });
    }
}

// Sort by score descending
all_candidates.sort(function(a, b) { return b.score - a.score; });

// Take top 6 candidates
Q.chancellor_candidates = [];
Q.chancellor_candidates_display = "";

var num_candidates = Math.min(10, all_candidates.length);
for (var i = 0; i < num_candidates; i++) {
    var candidate = all_candidates[i];
    
    Q.chancellor_candidates.push({
        party: candidate.party,
        name: candidate.name,
        votes: candidate.votes,
        weight: candidate.weight
    });
    
    Q.chancellor_candidates_display += (i + 1) + ". **" + candidate.name + "** (" + candidate.party + ", " + Math.round(candidate.votes * 10) / 10 + "%)";
    
    // Add contextual notes
    if (candidate.name === "Müller") {
        Q.chancellor_candidates_display += " - Former Chancellor";
    } else if (candidate.name === "Wels") {
        Q.chancellor_candidates_display += " - Party Chairman";
    } else if (candidate.name === "Braun") {
        Q.chancellor_candidates_display += " - Prussian Minister-President";
    } else if (candidate.name === "Hilferding") {
        Q.chancellor_candidates_display += " - Economic Expert";
    } else if (candidate.name === "Brüning") {
        Q.chancellor_candidates_display += " - Financial Expert";
    } else if (candidate.name === "Stresemann") {
        Q.chancellor_candidates_display += " - Foreign Policy Expert";
    }
    
    Q.chancellor_candidates_display += "\n";
}

Q.num_candidates = Q.chancellor_candidates.length;

// Pre-calculate candidate info for display/conditionals
for (var i = 0; i < Q.num_candidates && i < 6; i++) {
    Q['candidate_' + i + '_name'] = Q.chancellor_candidates[i].name;
    Q['candidate_' + i + '_party'] = Q.chancellor_candidates[i].party;
}

// ============================================
// SET COALITION FLAGS
// ============================================

// Convert the coalition array to lowercase for safe comparison
var lowercase_coalition = coalition.map(function(p) { return p.toLowerCase(); });

// Loop through all parties and set their government flag dynamically
for (var party of Q.parties) {
    Q[party + '_in_government'] = lowercase_coalition.indexOf(party) >= 0 ? 1 : 0;
}


!}
