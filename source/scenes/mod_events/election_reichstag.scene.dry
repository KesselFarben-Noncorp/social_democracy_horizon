    Q.shuffle_spd_variable = Q.shuffle_leverage.SPD;
    Q.previous_interior_party = Q.interior_minister_party;
    Q.interior_minister_party = "SPD";
    Q.interior_minister = "Severing";
    
    if (Q.previous_interior_party && Q.previous_interior_party !== 'I') {
        var rel_var = Q.previous_interior_party.toLowerCase() + '_relation';
        Q[rel_var] = Math.max(0, (Q[rel_var] || 50) - 8);
    }
!}
