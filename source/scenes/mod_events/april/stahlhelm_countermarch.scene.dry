Title: Stahlhelm initiates counter-march...
subtitle: Balance is slowly collapsing...
tags: event
new-page: true
face-image img/stahlhelm.jpg
on-arrival: sh_strength *= 1.01; sh_militancy += 0.01; dnvp_relation += 1; rfb_strength += 10
