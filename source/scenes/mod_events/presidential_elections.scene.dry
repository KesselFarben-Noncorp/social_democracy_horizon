@finalize_candidates
on-arrival: {!

// Hard kill: if Hindenburg is dead, zero out any stale candidate assignments
if (Q.hindenburg_dead) {
    Q.hindenburg_running = 0;
    var all_parties = ['spd','z','bvp','ddp','dvp','kpd','nsdap','dnvp',
                       'cnbl','sapd','csvd','srpd','csrp','wp','kvp','dhp','bb','vrp', 'dvfp' ,'other'];
    for (var i = 0; i < all_parties.length; i++) {
        if (Q[all_parties[i] + '_candidate'] === 'Hindenburg') {
            Q[all_parties[i] + '_candidate'] = null;
        }
        if (Q[all_parties[i] + '_default_candidate'] === 'Hindenburg') {
            Q[all_parties[i] + '_default_candidate'] = null;
        }
    }
}
    // ========================================
    // FINALIZE BASED ON SPD CHOICE
    // ========================================
    
    // ========================================
    // Z (CENTER PARTY)
    // ========================================
    if (Q.spd_candidate === Q.kpd_candidate) {
        // SPD supporting communists - Z runs own
        Q.z_candidate = Q.z_default_candidate;
        
    } else if (Q.is_unity_candidate) {
        // SPD proposing unity candidate
        if (Q.spd_candidate === Q.z_default_candidate) {
            // SPD directly supports Z candidate - accept
            Q.z_candidate = Q.spd_candidate;
        } else if (Q.z_relation >= 50 || (Q.z_relation >= 35 && Q.z_party_leader === "Joos")) {
            // Good relations - join unity
            Q.z_candidate = Q.spd_candidate;
        } else if (Q.z_relation >= 30) {
            // Moderate relations - might join with incentive
            if (Q.spd_candidate === "Eckener" || Q.spd_candidate === "Gessler") {
                Q.z_candidate = Q.spd_candidate;
            } else {
                Q.z_candidate = Q.z_default_candidate;
            }
        } else {
            // Poor relations - run own
            Q.z_candidate = Q.z_default_candidate;
        }
        
    } else if (Q.spd_candidate === "Braun" || Q.spd_candidate === "Schumacher" || Q.is_cultural_candidate) {
        // SPD running own candidate
        if (Q.z_relation >= 60 || (Q.z_relation >= 45 && Q.z_party_leader === "Joos")) {
            // Excellent relations - support SPD
            Q.z_candidate = Q.spd_candidate;
        } else {
            // Run own candidate
            Q.z_candidate = Q.z_default_candidate;
        }
        
    } else if (Q.spd_candidate === "Juchacz") {
        // Woman candidate - higher threshold
        if (Q.z_relation >= 65 || (Q.z_relation >= 50 && Q.z_party_leader === "Joos")) {
            Q.z_candidate = Q.spd_candidate;
        } else {
            Q.z_candidate = Q.z_default_candidate;
        }
        
    } else {
        // Default - run own
        Q.z_candidate = Q.z_default_candidate;
    }

    // ========================================
    // CSRP (CHRISTIAN SOCIAL REICH PARTY)
    // ========================================
    Q.csrp_candidate = Q.z_candidate;
    
    // ========================================
    // BVP (BAVARIAN PEOPLE'S PARTY)
    // ========================================
    if (Q.z_candidate === Q.spd_candidate && Q.bvp_relation < 40) {
        // Conservative BVP breaks with Z over SPD support
        if (!Q.dnvp_banned && Q.dnvp_candidate) {
            Q.bvp_candidate = Q.dnvp_candidate;
        } else {
            Q.bvp_candidate = Q.bvp_default_candidate;
        }
    } else if (Q.z_candidate === Q.kpd_candidate) {
        // Never support communists
        Q.bvp_candidate = Q.bvp_default_candidate;
    } else if (Q.z_candidate) {
        // Follow Z (usual case)
        Q.bvp_candidate = Q.z_candidate;
    } else {
        // Independent
        Q.bvp_candidate = Q.bvp_default_candidate;
    }

    // ========================================
    // VRP - finalize after SPD choice
    // ========================================
    if (Q.vrp_formed) {
        var vrp_desperate = Q.inflation >= 5 || Q.unemployed >= 20 || Q.economy_growth <= -3;
        
        if (vrp_desperate) {
            // Crisis locks in protest vote regardless of SPD
            Q.vrp_candidate = "Böhm";
            
        } else if (Q.vrp_default_candidate && Q.vrp_default_candidate !== "Böhm") {
            // Already aligned with a liberal candidate - check if SPD disrupts that
            if (Q.spd_candidate === Q.kpd_candidate) {
                // SPD went left - VRP breaks from any SPD-adjacent candidate
                Q.vrp_candidate = Q.ddp_candidate !== Q.spd_candidate
                    ? Q.ddp_candidate || "Böhm"
                    : "Böhm";
            } else if (Q.is_unity_candidate && Q.vrp_relation >= 40 && Q.ddp_candidate === Q.spd_candidate) {
                // Unity candidate with DDP support - VRP joins
                Q.vrp_candidate = Q.spd_candidate;
            } else {
                // Keep pre-SPD choice
                Q.vrp_candidate = Q.vrp_default_candidate;
            }
            
        } else {
            // Was running Böhm - only abandon if SPD proposes DDP-style unity
            if (Q.is_unity_candidate && Q.ddp_candidate === Q.spd_candidate && Q.vrp_relation >= 45) {
                Q.vrp_candidate = Q.spd_candidate;
            } else {
                Q.vrp_candidate = "Böhm";
            }
        }
    }
    
    // ========================================
    // DVP (PEOPLE'S PARTY)
    // ========================================
    if (Q.dvp_candidate) {
        // Already decided (Stresemann running, or independent)
        // Keep existing choice
    } else if (Q.is_unity_candidate && Q.spd_candidate !== Q.kpd_candidate) {
        // SPD proposing unity, DVP considering
        if (Q.dvp_relation >= 45) {
            Q.dvp_candidate = Q.spd_candidate;
        } else if (Q.z_candidate && Q.z_candidate !== Q.spd_candidate) {
            Q.dvp_candidate = Q.z_candidate;
        } else {
            Q.dvp_candidate = "Gessler";
        }
    } else if (Q.dvp_relation >= 55 && Q.spd_candidate !== Q.kpd_candidate) {
        // Excellent SPD relations - support them
        Q.dvp_candidate = Q.spd_candidate;
    } else if (Q.z_candidate && Q.z_relation >= 35) {
        // Support Z instead
        Q.dvp_candidate = Q.z_candidate;
    } else {
        // Independent liberal
        Q.dvp_candidate = "Gessler";
    }
    
    // ========================================
    // DDP/DStP (DEMOCRATS)
    // ========================================
    if (Q.ddp_candidate) {
        // Already decided (running own or Gessler)
        // Keep existing choice
    } else if (Q.is_unity_candidate && Q.spd_candidate !== Q.kpd_candidate) {
        // SPD proposing unity
        if (Q.ddp_relation >= 35) {
            Q.ddp_candidate = Q.spd_candidate;
        } else if (Q.z_candidate) {
            Q.ddp_candidate = Q.z_candidate;
        } else {
            Q.ddp_candidate = "Gessler";
        }
    } else if (Q.ddp_relation >= 50 && Q.spd_candidate !== Q.kpd_candidate) {
        // Excellent SPD relations
        Q.ddp_candidate = Q.spd_candidate;
    } else if (Q.z_candidate && Q.z_relation >= 30) {
        // Support Z
        Q.ddp_candidate = Q.z_candidate;
    } else {
        // Independent liberal
        Q.ddp_candidate = Q.ddp_name === "DStP" ? "Koch-Weser" : "Gessler";
    }
    
    // ========================================
    // WP (ECONOMIC PARTY)
    // ========================================
    if (Q.wp_default_candidate && Q.wp_default_candidate === "Drewitz") {
        // Running protest candidate - keep it
        Q.wp_candidate = "Drewitz";
    } else if (Q.dvp_candidate) {
        // Follow DVP
        Q.wp_candidate = Q.dvp_candidate;
    } else if (Q.is_unity_candidate && Q.wp_relation >= 40) {
        Q.wp_candidate = Q.spd_candidate;
    } else {
        Q.wp_candidate = Q.dvp_candidate || "Gessler";
    }
    
    // ========================================
    // CNBL (AGRARIAN PARTY)
    // ========================================
    if (Q.cnbl_default_candidate && (Q.cnbl_default_candidate === "Hamkens" || Q.cnbl_default_candidate === "Behrens")) {
        // Running protest - keep it
        Q.cnbl_candidate = Q.cnbl_default_candidate;
    } else if (Q.cnbl_default_candidate === Q.nsdap_candidate || Q.cnbl_default_candidate === Q.dnvp_candidate) {
        // Already aligned with conservatives
        Q.cnbl_candidate = Q.cnbl_default_candidate;
    } else if (Q.z_candidate && Q.cnbl_relation >= 35) {
        Q.cnbl_candidate = Q.z_candidate;
    } else {
        Q.cnbl_candidate = Q.cnbl_default_candidate || "Hamkens";
    }
    
    // ========================================
    // SAPD
    // ========================================
    if (Q.sapd_formed) {
        if (Q.sapd_candidate === Q.kpd_candidate && Q.spd_candidate === Q.kpd_candidate) {
            // United left
            Q.sapd_candidate = Q.kpd_candidate;
        } else if (Q.spd_sapd_relation >= 55) {
            // Good SPD relations - support them
            Q.sapd_candidate = Q.spd_candidate;
        } else {
            // Independent or stay with KPD
            Q.sapd_candidate = Q.sapd_candidate || "Rosenfeld";
        }
    }
    
    // ========================================
    // SRPD
    // ========================================
    if (Q.srpd_formed) {
        if (Q.srpd_relation >= 60) {
            // Very close - follow SPD
            Q.srpd_candidate = Q.spd_candidate;
        } else if (Q.is_unity_candidate && Q.srpd_relation >= 45) {
            // Unity candidate appeal
            Q.srpd_candidate = Q.spd_candidate;
        } else {
            // Independent
            Q.srpd_candidate = "Horsing";
        }
    }

// ========================================
    // KVP - finalize after SPD choice
    // ========================================
    if (Q.kvp_flee === 1 && !Q.kvp_banned) {
        if (Q.kvp_default_candidate && Q.kvp_default_candidate !== "Hitler"
            && Q.kvp_default_candidate !== "Hugenberg") {
            // Already aligned with moderate conservative - keep unless SPD disrupts
            if (Q.spd_candidate === Q.kpd_candidate) {
                // SPD went far left - KVP will not follow any SPD-adjacent candidate
                Q.kvp_candidate = Q.kvp_default_candidate;
            } else if (Q.is_unity_candidate && Q.z_candidate === Q.spd_candidate
                       && Q.dnvp_line !== 3) {
                // Unity candidate with Z - KVP joins if moderate enough
                Q.kvp_candidate = Q.spd_candidate;
            } else {
                Q.kvp_candidate = Q.kvp_default_candidate;
            }
        } else {
            Q.kvp_candidate = Q.z_candidate || "Westarp";
        }
    }

    // ========================================
    // DHP - finalize after SPD choice
    // ========================================
    if (!Q.dhp_banned) {
        if (Q.spd_candidate === Q.kpd_candidate) {
            // Far left SPD - DHV locks in conservative agrarian choice
            Q.dhp_candidate = Q.dhp_default_candidate || "Hamkens";
        } else if (Q.is_unity_candidate && Q.cnbl_candidate === Q.spd_candidate
                   && Q.dnvp_line !== 3) {
            // CNBL joined unity - DHV follows agrarian allies
            Q.dhp_candidate = Q.spd_candidate;
        } else {
            Q.dhp_candidate = Q.dhv_default_candidate || "Hamkens";
        }
    }

    // ========================================
    // BB - finalize after SPD choice
    // ========================================
    if (!Q.bb_banned) {
        var bb_crisis = Q.inflation < 0 || Q.unemployed >= 15;
        
        if (bb_crisis) {
            // Crisis locks protest vote regardless of SPD
            Q.bb_candidate = "Hamkens";
        } else if (Q.spd_candidate === Q.kpd_candidate) {
            // Far left - BB retreats to BVP or CNBL
            Q.bb_candidate = Q.bvp_candidate || Q.cnbl_candidate || "Hamkens";
        } else if (Q.bvp_candidate === Q.spd_candidate && Q.z_candidate === Q.spd_candidate) {
            // Broad Catholic unity including BVP - BB joins
            Q.bb_candidate = Q.spd_candidate;
        } else {
            Q.bb_candidate = Q.bb_default_candidate || "Hamkens";
        }
    }

    // ========================================
    // DVFP (VÖLKISCH FREEDOM PARTY) - Finalize
    // ========================================
    if (Q.dvfp_banned) {
        Q.dvfp_candidate = null;
    } else if (Q.spd_candidate === Q.kpd_candidate) {
        // SPD went Communist - DVFP doubles down on radical right
        // They will never follow a Red Front.
        Q.dvfp_candidate = Q.dvfp_default_candidate || "Ludendorff";
        
    } else if (Q.is_unity_candidate) {
        // SPD proposing a "Unity" candidate (e.g., a moderate liberal)
        // DVFP views "Unity" as a betrayal of the national cause.
        if (Q.dnvp_line === 3 && Q.dnvp_candidate === Q.nsdap_candidate) {
            // Far-right is united - DVFP stays with the radical bloc
            Q.dvfp_candidate = Q.nsdap_candidate;
        } else if (Q.dnvp_candidate === Q.spd_candidate && Q.dnvp_line !== 3) {
            // DNVP went moderate and joined SPD unity - DVFP BREAKS with DNVP
            // They run Ludendorff as the 'true' nationalist protest.
            Q.dvfp_candidate = "Ludendorff";
        } else {
            // Otherwise, keep their pre-decided radical choice
            Q.dvfp_candidate = Q.dvfp_default_candidate;
        }
        
    } else {
        // Default: keep the choice from the arrival logic (Hitler, Hugenberg, or Ludendorff)
        Q.dvfp_candidate = Q.dvfp_default_candidate;
    }


    // ========================================
    // HINDENBURG (INDEPENDENT) - 1932 only
    // ========================================
    if (!Q.hindenburg_dead && Q.year >= 1932) {
    Q.hindenburg_running = 1;
    Q.hindenburg_candidate = "Hindenburg";
    
    // Most parties support Hindenburg automatically
    // Only extremes (KPD, NSDAP if strong) and far-left SPD refuse
    
    // Z, BVP - automatic support
    if (Q.z_party_leader !== "Joos" || Q.z_relation < 35) {
        Q.z_candidate = "Hindenburg";
        Q.z_default_candidate = "Hindenburg";
    }
    Q.bvp_candidate = "Hindenburg";
    Q.bvp_default_candidate = "Hindenburg";
    
    // DVP, DDP - automatic support
    Q.dvp_candidate = "Hindenburg";
    Q.dvp_default_candidate = "Hindenburg";
    Q.ddp_candidate = "Hindenburg";
    Q.ddp_default_candidate = "Hindenburg";
    
    // DNVP - support unless line 3 (Hugenberg)
    if (Q.dnvp_line !== 3) {
        Q.dnvp_candidate = "Hindenburg";
    }
    
    // WP, CNBL, CSVD - automatic support
    if (Q.wp_r && Q.wp_r > 2) {
        Q.wp_candidate = "Hindenburg";
        Q.wp_default_candidate = "Hindenburg";
    }
    if (Q.cnbl_r && Q.cnbl_r > 1.5) {
        Q.cnbl_candidate = "Hindenburg";
        Q.cnbl_default_candidate = "Hindenburg";
    }
    if (Q.csvd_flee === 1) {
        Q.csvd_candidate = "Hindenburg";
        Q.csvd_default_candidate = "Hindenburg";
    }
    
    // SRPD - likely support
    if (Q.srpd_formed && Q.reformist_strength >= 30) {
        Q.srpd_candidate = "Hindenburg";
    }
    // CSRP sure.
    Q.csrp_candidate = "Hindenburg";

    // VRP - savers are broadly pro-Hindenburg as a stable constitutional figure.
    Q.vrp_candidate = "Hindenburg";
    Q.vrp_default_candidate = "Hindenburg";

    // DVFP - 1932 Hindenburg Logic
    if (Q.dvfp_r && Q.dvfp_r > 0) {
        if (Q.dnvp_line === 3 && Q.dnvp_candidate !== "Hindenburg") {
            // If Hugenberg and Hitler are opposing Hindenburg, DVFP joins them.
            // This reflects the Harzburg Front alignment.
            Q.dvfp_candidate = Q.dnvp_candidate;
            Q.dvfp_default_candidate = Q.dnvp_candidate;
        } else if (Q.nationalism >= 60 && Q.unrest_factor >= 2.5) {
            // In high-tension nationalist scenarios, they run Ludendorff
            // as the radical alternative to the 'Constitutional' Hindenburg.
            Q.dvfp_candidate = "Ludendorff";
            Q.dvfp_default_candidate = "Ludendorff";
        } else {
            // If the right is fragmented or Hindenburg seems like the only 
            // "National" winner, they reluctantly support the Field Marshal.
            Q.dvfp_candidate = "Hindenburg";
            Q.dvfp_default_candidate = "Hindenburg";
        }
    }

}
!}
go-to: r1_finalized

@r1_finalized

The candidates have been finalized:

**Far Right:**
[? if not nsdap_banned : - NSDAP: [+ nsdap_candidate +] ?]

[? if not dvfp_banned and dvfp_formed : - DVFP: [+ dvfp_candidate +] ?]

[? if dnvp_candidate and dnvp_candidate != nsdap_candidate and dnvp_candidate != z_dnvp_joint_candidate and not dnvp_banned : - DNVP: [+ dnvp_candidate +] ?]
[? if dnvp_candidate == nsdap_candidate and not dnvp_banned : - DNVP: Supporting [+ nsdap_candidate +] ?]

**Left:**
[? if kpd_candidate : - KPD: [+ kpd_candidate +] ?]
[? if sapd_candidate and sapd_candidate != kpd_candidate and sapd_candidate != spd_candidate : - SAPD: [+ sapd_candidate +] ?]
[? if sapd_candidate == spd_candidate : - SAPD: Supporting [+ spd_candidate +] ?]

**Center/Liberal:**
- SPD: [+ spd_candidate +]

[? if srpd_formed == 1 and srpd_candidate : - SRPD: [+ srpd_candidate +] ?]
[? if csrp_votes > 1: CSRP: [+ csrp_candidate +] ?]

[? if z_candidate and z_candidate != spd_candidate and not z_dnvp_joint_possible : - Center (Z): [+ z_candidate +] ?]
[? if z_candidate == spd_candidate : - Center (Z): Supporting [+ spd_candidate +] ?]

[? if bvp_candidate and bvp_candidate != z_candidate and bvp_candidate != spd_candidate and not z_dnvp_joint_possible : - BVP: [+ bvp_candidate +] ?]
[? if bvp_candidate == spd_candidate : - BVP: Supporting [+ spd_candidate +] ?]

[? if ddp_candidate and ddp_candidate != spd_candidate and ddp_candidate != z_candidate : - [+ ddp_name +]: [+ ddp_candidate +] ?]
[? if ddp_candidate == spd_candidate : - [+ ddp_name +]: Supporting [+ spd_candidate +] ?]

[? if dvp_candidate and dvp_candidate != spd_candidate and dvp_candidate != z_candidate and dvp_candidate != ddp_candidate and dvp_candidate != z_dnvp_joint_candidate : - DVP: [+ dvp_candidate +] ?]
[? if dvp_candidate == spd_candidate : - DVP: Supporting [+ spd_candidate +] ?]

[? if wp_candidate and wp_candidate != spd_candidate and wp_candidate != z_candidate and wp_candidate != dvp_candidate and wp_candidate != z_dnvp_joint_candidate : - WP: [+ wp_candidate +] ?]
[? if wp_candidate == spd_candidate : - WP: Supporting [+ spd_candidate +] ?]

[? if cnbl_candidate and cnbl_candidate != z_dnvp_joint_candidate : - CNBL: [+ cnbl_candidate +] ?]

[? if csvd_candidate and csvd_candidate != z_dnvp_joint_candidate : - CSVD: [+ csvd_candidate +] ?]

- @r1_menu: Continue to first round.

@r1_menu
view-if: round = 0

Before the first round begins, we can try to convince other parties to change their support.

- @convince_z_unity: Try to convince the Center Party.
- @convince_ddp_unity: Try to convince the [+ ddp_name +].
- @convince_dvp_unity: Try to convince the DVP.
- @convince_kpd_spd: Try to convince the KPD.
- @round_1: Proceed to first round voting.

@convince_z_unity
title: Convince the Center Party to support [+ spd_candidate +].
view-if: z_candidate != spd_candidate and spd_candidate != kpd_candidate
max-visits: 1

- @pay_z: Offer resources (-2 resources).
- @r1_menu: Never mind.

@pay_z
choose-if: resources >= 2
subtitle: -2 resources
unavailable-subtitle: Not enough resources.
on-arrival: resources -= 2; z_candidate = spd_candidate; bvp_candidate = spd_candidate if bvp_candidate == z_candidate; Seldte_bonus += 2.5 if z_relation < 40;
go-to: r1_menu

With our resources, the Center is convinced to support [+ spd_candidate +].

@convince_ddp_unity
title: Convince the [+ ddp_name +] to support [+ spd_candidate +].
view-if: ddp_candidate != spd_candidate and spd_candidate != kpd_candidate
max-visits: 1
on-arrival: ddp_candidate = spd_candidate if ddp_relation >= 30;
go-to: r1_menu

[? if ddp_candidate == spd_candidate : The [+ ddp_name +] agrees to support [+ spd_candidate +]! ?]
[? if ddp_candidate != spd_candidate : The [+ ddp_name +] refuses to change their support. ?]

@convince_dvp_unity
title: Convince the DVP to support [+ spd_candidate +].
view-if: dvp_candidate != spd_candidate and spd_candidate != kpd_candidate
max-visits: 1
on-arrival: dvp_candidate = spd_candidate if dvp_relation >= 40;
go-to: r1_menu

[? if dvp_candidate == spd_candidate : The DVP agrees to support [+ spd_candidate +]! ?]
[? if dvp_candidate != spd_candidate : The DVP refuses to change their support. ?]

@convince_kpd_spd
title: Convince the KPD to support [+ spd_candidate +].
view-if: kpd_candidate != spd_candidate and spd_candidate != nsdap_candidate and spd_candidate != dnvp_candidate
choose-if: spd_votes >= kpd_votes
unavailable-subtitle: The KPD is more popular than us.
max-visits: 1

The KPD might be convinced to support [+ spd_candidate +].

- @kpd_resources: Use resources (-3 resources).
- @kpd_relations: Use our good relations.
- @r1_menu: Never mind.

@kpd_resources
view-if: kpd_relation >= 50
choose-if: resources >= 3
subtitle: -3 resources
unavailable-subtitle: Not enough resources.
on-arrival: resources -= 3; kpd_candidate = spd_candidate; sapd_candidate = spd_candidate;
go-to: r1_menu

The KPD now supports [+ spd_candidate +]!

@kpd_relations
view-if: kpd_relation >= 60 or (kpd_party_leader == "Conciliators" and kpd_relation >= 45)
unavailable-subtitle: Relations not good enough.
on-arrival: kpd_candidate = spd_candidate; sapd_candidate = spd_candidate;
go-to: r1_menu

The KPD now supports [+ spd_candidate +]!

@round_1
on-arrival: round = 1;
go-to: election_algorithm
set-jump: post_r1

@post_r1
on-arrival: {!
    // === CALCULATE ROUND 1 RESULTS ===
    
    var candidate_descs = {
    Hindenburg: "Paul von Hindenburg (I)",
    Hitler: "Adolf Hitler (NSDAP)",
    Göring: "Hermann Göring (NSDAP)",
    Goring: "Hermann Göring (NSDAP)",
    Goebbels: "Joseph Goebbels (NSDAP)",
    Seldte: "Franz Seldte (DNVP/Stahlhelm)",
    Westarp: "Kuno von Westarp (DNVP)",
    Eckener: "Hugo Eckener (Unity)",
    Adenauer: "Konrad Adenauer (Z)",
    Kaas: "Ludwig Kaas (Z)",
    Brüning: "Heinrich Brüning (Z)",
    Bruning: "Heinrich Brüning (Z)",
    Gessler: "Otto Gessler (Liberal)",
    Stresemann: "Gustav Stresemann (DVP)",
    Thälmann: "Ernst Thälmann (KPD)",
    Thalmann: "Ernst Thälmann (KPD)",
    Münzenberg: "Willi Münzenberg (KPD)",
    Munzenberg: "Willi Münzenberg (KPD)",
    Braun: "Otto Braun (SPD)",
    Schumacher: "Kurt Schumacher (SPD)",
    Schmid: "Carlo Schmid (SPD - R)",
    Ollenhauer: "Erich Ollenhauer (SPD - L)",
    Juchacz: "Marie Juchacz (SPD)",
    Einstein: "Albert Einstein (Independent)",
    Mann: "Heinrich Mann (Independent)",
    Ossietzky: "Carl von Ossietzky (Independent)",
    Noske: "Gustav Noske (SPD - SC)",
    Rosenfeld: "Kurt Rosenfeld (SAPD)",
    Schäffer: "Franz Schäffer (BVP)",
    Schaffer: "Franz Schäffer (BVP)",
    Drewitz: "Max Drewitz (WP)",
    Horsing: "Otto Hörsing (SRPD)",
    Hamkens: "Wilhelm Hamkens (CNBL)",
    Behrens: "Wilhelm Behrens (CNBL)",
    Lemmer: "Ernst Lemmer (DDP)",
    Heuss: "Theodor Heuss (DDP)",
    Dietrich: "Hermann Dietrich (DDP)",
    Lüders: "Hermann Lüders (DDP)",
    Mahraun: "Arthur Mahraun (DStP/Jungdo)",
    "Koch-Weser": "Erich Koch-Weser (DStP)",
    Maier: "Reinhold Maier (DStP)",
    Treviranus: "Gottfried Treviranus (DNVP)",
    Lambach: "Walter Lambach (DNVP)",
    Lindeiner: "Hans von Lindeiner-Wildau (DNVP)",
    Hugenberg: "Alfred Hugenberg (DNVP)",
    Scholz: "Ernst Scholz (DVP)",
    Dingeldey: "Eduard Dingeldey (DVP)",
    Curtius: "Julius Curtius (DVP)",
    Reinhold: "Peter Reinhold (DVP)",
    Lambach2: "Walther Lambach (CSVD)",
    Graefe: "Albrecht von Graefe (DVFP)",
    Ludendorff: "Erich Ludendorff (DVFP/Völkisch)",
};
    
    // Mark running candidates
    for (var k in candidate_descs) {
        Q[k + '_running'] = 0;
    }
    
    // Aggregate votes
    var candidate_votes = {};
    var parties = ['spd', 'z', 'bvp', 'ddp', 'dvp', 'kpd', 'nsdap', 'dnvp', 
                   'cnbl', 'sapd', 'csvd', 'srpd', 'csrp', 'wp', 'kvp', 'dhp', 'bb', 'dvfp', 'other'];
    
    for (var i = 0; i < parties.length; i++) {
        var party = parties[i];
        var supported_candidate = Q[party + '_candidate'];
        
        if (!supported_candidate) continue;
        
        // Normalize candidate name
        supported_candidate = supported_candidate.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        Q[supported_candidate + '_running'] = 1;
        
        // Get party vote share
        var party_votes = Q[party + '_r'] || Q[party + '_votes'] || 0;
        
        // Aggregate to candidate
        if (candidate_votes[supported_candidate]) {
            candidate_votes[supported_candidate] += party_votes;
        } else {
            candidate_votes[supported_candidate] = party_votes;
        }
    }
    
    // Apply bonuses
    for (var k in candidate_votes) {
        if (Q[k + '_bonus']) {
            candidate_votes[k] += Q[k + '_bonus'] / 100;
        }
    }
    
    // Find winner and check for majority
    var total_votes = 0;
    Q.winner = "";
    Q.winner_votes = 0;
    Q.has_majority = 0;
    
    for (var k in candidate_votes) {
        total_votes += candidate_votes[k];
        if (candidate_votes[k] > Q.winner_votes) {
            Q.winner = k;
            Q.winner_votes = candidate_votes[k];
        }
    }
    
    // Convert to percentages and find top 3
    var candidates_array = [];
    for (var k in candidate_votes) {
        var pct = Math.round(1000 * candidate_votes[k] / total_votes) / 10;
        Q[k + '_votes'] = pct;
        Q[k + '_votes_disp'] = pct.toFixed(1);
        candidates_array.push({name: k, votes: candidate_votes[k], pct: pct});
    }
    
    // Sort by votes descending
    candidates_array.sort(function(a, b) {
        return b.votes - a.votes;
    });
    
    Q.round1_winner = candidates_array[0].name;
    Q.round1_runner_up = candidates_array.length > 1 ? candidates_array[1].name : null;
    Q.round1_winner_votes = candidates_array[0].pct;
    Q.round1_runner_up_votes = candidates_array.length > 1 ? candidates_array[1].pct : 0;

    Q.round1_third = candidates_array.length > 2 ? candidates_array[2].name : null;
    Q.round1_third_votes = candidates_array.length > 2 ? candidates_array[2].pct : 0;
    Q.round1_third_votes_disp = Q.round1_third_votes > 0 ? Q.round1_third_votes.toFixed(1) : "0.0";
    Q.third_stays = Q.round1_third ? 1 : 0;
    Q.round2_has_third = Q.third_stays;

    // Set all desc variables consistently here
    Q.round1_winner_desc = candidate_descs[Q.round1_winner] || Q.round1_winner || "";
    Q.round1_runner_up_desc = Q.round1_runner_up ? (candidate_descs[Q.round1_runner_up] || Q.round1_runner_up) : "";
    Q.round1_third_desc = Q.round1_third ? (candidate_descs[Q.round1_third] || Q.round1_third) : "";
    
    // Check for majority
    Q.has_majority = Q.round1_winner_votes >= 50;
    
    Q.winner_votes = Q.round1_winner_votes;
    Q.winner_votes_disp = Q.winner_votes.toFixed(1);
    Q.winner_desc = Q.round1_winner_desc;

    // Record all candidates from round 1
    Q.round1_all_candidates = [];
    for (var i = 0; i < candidates_array.length; i++) {
        Q.round1_all_candidates.push({
            name: candidates_array[i].name,
            desc: candidate_descs[candidates_array[i].name],
            votes: candidates_array[i].pct.toFixed(1)
        });
    }

    // If first round victory, record it immediately
    if (Q.has_majority) {
        Q.president_history = Q.president_history || [];
        Q.president_history.push({
            name: Q.winner,
            desc: Q.winner_desc,
            year_start: Q.year,
            votes: Q.winner_votes_disp,
            runnerup: Q.round1_runner_up,
            runnerup_votes: Q.round1_runner_up_votes.toFixed(1),
            rounds: 1,
            all_candidates: Q.round1_all_candidates
        });
        Q.president_history_count = Q.president_history.length;
    }
!}
go-to: r1_results

@r1_results
on-display: {!
var partyColors = {
    spd:"#E3000F", kpd:"#8B0000", sapd:"#C40000", srpd:"#FF6B6B",
    z:"#000000",   bvp:"#69A2BE", csrp:"#FFCCFF", ddp:"#DCCA4A",
    dvp:"#D5AC27", wp:"#424242",  cnbl:"#5D4E37", csvd:"#3f7bc1",
    dnvp:"#3f7bc1",nsdap:"#954B00",kvp:"#3f7bc1", dhp:"#5D4E37",
    bb:"#69A2BE",  vrp:"#8B7355", dvfp:"#7A5C12", other:"#a0a0a0",
};

var partyLabels = {
    spd:"SPD", kpd:"KPD", sapd:"SAPD", srpd:"SRPD", z:"Z", bvp:"BVP",
    csrp:"CSRP", ddp:Q.ddp_name||"DDP", dvp:"DVP", wp:"WP",
    cnbl:"CNBL", csvd:"CSVD", dnvp:"DNVP", nsdap:"NSDAP", kvp:"KVP",
    dhp:"DHP", bb:"BB", vrp:"VRP", dvfp:"DVFP", other:"Other",
};

var allParties = ['spd','z','bvp','ddp','dvp','kpd','nsdap','dnvp',
                  'cnbl','sapd','csvd','srpd','csrp','wp','kvp','dhp',
                  'bb','vrp','dvfp','other'];

var displayNames = {
    Thalmann:"Thälmann", Munzenberg:"Münzenberg", Bruning:"Brüning",
    Schaffer:"Schäffer", Goring:"Göring", KochWeser:"Koch-Weser",
    Lambach2:"Lambach (CSVD)",
};
function dname(k) { return displayNames[k] || k; }

// ── Build candidate totals and party groupings ─────────────────
var candidateTotals = {};
var grouped = {};

for (var i = 0; i < allParties.length; i++) {
    var p = allParties[i];
    var cand = Q[p + '_candidate'];
    if (!cand) continue;
    var candNorm = cand.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    var votes = Q[p + '_r'] || Q[p + '_votes'] || 0;
    if (votes <= 0) continue;
    if (!candidateTotals[candNorm]) candidateTotals[candNorm] = 0;
    candidateTotals[candNorm] += votes;
    if (!grouped[candNorm]) grouped[candNorm] = [];
    grouped[candNorm].push({ party: p, votes: votes });
}

var total = 0;
for (var k in candidateTotals) total += candidateTotals[k];

// Sort candidates by vote share descending
var candOrder = Object.keys(candidateTotals).sort(function(a,b){
    return candidateTotals[b] - candidateTotals[a];
});

var container = document.getElementById('pres_r1_chart');
if (!container) return;
container.innerHTML = "";
container.style.cssText = "width:100%; max-width:620px; font-family:sans-serif;";

// ── SECTION 1: Candidate summary bars (with 50% line) ─────────
var summaryHeader = document.createElement('div');
summaryHeader.style.cssText = "font-size:11px; font-weight:bold; color:#888; letter-spacing:0.08em;"
    + "text-transform:uppercase; margin-bottom:6px;";
summaryHeader.textContent = "First Round Results";
container.appendChild(summaryHeader);

var maxCandVotes = candidateTotals[candOrder[0]] || 1;

candOrder.forEach(function(cand) {
    var votes = candidateTotals[cand];
    var pct = total > 0 ? votes / total * 100 : 0;
    var barW = Math.round(votes / maxCandVotes * 100);

    // Pick color from the first party supporting this candidate
    var repParty = grouped[cand][0].party;
    var repColor = partyColors[repParty] || "#aaa";

    var row = document.createElement('div');
    row.style.cssText = "display:flex; align-items:center; gap:6px; margin-bottom:5px;";

    var nameEl = document.createElement('div');
    nameEl.style.cssText = "width:110px; font-size:12px; font-weight:bold; text-align:right;"
        + "flex-shrink:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:#1a1a1a;";
    nameEl.textContent = dname(cand);

    var barWrap = document.createElement('div');
    barWrap.style.cssText = "flex:1; background:#e8e8e8; height:18px; border-radius:2px; position:relative;";

    var bar = document.createElement('div');
    bar.style.cssText = "height:100%; border-radius:2px; background:" + repColor
        + "; width:" + barW + "%; transition:width 0.3s;";

    // 50% threshold line
    var threshold = document.createElement('div');
    threshold.style.cssText = "position:absolute; top:0; left:50%; width:2px; height:100%;"
        + "background:rgba(0,0,0,0.3); z-index:2;";

    var pctEl = document.createElement('div');
    pctEl.style.cssText = "width:42px; font-size:12px; color:#333; flex-shrink:0;";
    pctEl.textContent = pct.toFixed(1) + "%";

    barWrap.appendChild(bar);
    barWrap.appendChild(threshold);
    row.appendChild(nameEl);
    row.appendChild(barWrap);
    row.appendChild(pctEl);
    container.appendChild(row);
});

// 50% legend
var legend = document.createElement('div');
legend.style.cssText = "font-size:11px; color:#888; margin-top:2px; margin-bottom:14px; padding-left:116px;";
legend.textContent = "▲ 50% majority threshold";
container.appendChild(legend);

// ── SECTION 2: Party-by-party breakdown ───────────────────────
var divider = document.createElement('div');
divider.style.cssText = "font-size:11px; font-weight:bold; color:#888; letter-spacing:0.08em;"
    + "text-transform:uppercase; border-top:1px solid #ddd; padding-top:8px; margin-bottom:6px;";
divider.textContent = "Party Support Breakdown";
container.appendChild(divider);

candOrder.forEach(function(cand) {
    if (!grouped[cand] || grouped[cand].length === 0) return;

    var candTotal = candidateTotals[cand];
    var candPct = total > 0 ? candTotal / total * 100 : 0;

    // Candidate sub-header
    var candLabel = document.createElement('div');
    candLabel.style.cssText = "font-size:12px; font-weight:bold; color:#1a1a1a; margin-bottom:4px; margin-top:2px;";
    candLabel.textContent = dname(cand) + "  (" + candPct.toFixed(1) + "%)";
    container.appendChild(candLabel);

    var parties = grouped[cand].slice().sort(function(a,b){return b.votes-a.votes;});
    var maxVotes = parties[0].votes;

    parties.forEach(function(item) {
        var row = document.createElement('div');
        row.style.cssText = "display:flex; align-items:center; gap:5px; margin-bottom:3px;";

        var chip = document.createElement('div');
        chip.style.cssText = "width:10px; height:10px; border-radius:2px; flex-shrink:0; background:"
            + (partyColors[item.party]||"#aaa") + ";";

        var nameEl = document.createElement('div');
        nameEl.style.cssText = "width:44px; font-size:11px; color:#333; flex-shrink:0; text-align:right;";
        nameEl.textContent = partyLabels[item.party] || item.party;

        var barWrap = document.createElement('div');
        barWrap.style.cssText = "flex:1; background:#f0f0f0; height:12px; border-radius:2px;";

        var bar = document.createElement('div');
        var barW = Math.round(item.votes / maxVotes * 100);
        bar.style.cssText = "height:100%; border-radius:2px; background:" + (partyColors[item.party]||"#aaa")
            + "; width:" + barW + "%; opacity:0.85;";

        var pctEl = document.createElement('div');
        pctEl.style.cssText = "width:36px; font-size:11px; color:#444; text-align:left; flex-shrink:0;";
        pctEl.textContent = item.votes.toFixed(1) + "%";

        barWrap.appendChild(bar);
        row.appendChild(chip);
        row.appendChild(nameEl);
        row.appendChild(barWrap);
        row.appendChild(pctEl);
        container.appendChild(row);
    });

    var spacer = document.createElement('div');
    spacer.style.cssText = "height:8px;";
    container.appendChild(spacer);
});

// ── Majority status banner ────────────────────────────────────
var winner = candOrder[0];
var winnerPct = total > 0 ? candidateTotals[winner] / total * 100 : 0;
var hasMajority = winnerPct >= 50;

var banner = document.createElement('div');
banner.style.cssText = "margin-top:4px; padding:6px 10px; border-radius:2px; font-size:12px; font-weight:bold;"
    + (hasMajority
        ? "background:#f0fff0; border-left:4px solid #2a7a2a; color:#1a1a1a;"
        : "background:#fff8f0; border-left:4px solid #c07000; color:#1a1a1a;");
banner.textContent = hasMajority
    ? "✓ " + dname(winner) + " wins with " + winnerPct.toFixed(1) + "% — majority achieved"
    : "⚠ No majority — " + dname(winner) + " leads with " + winnerPct.toFixed(1) + "% — runoff required";
container.appendChild(banner);
!}
go-to: election_end if has_majority; r2_start if not has_majority

**First Round Results:**

{!<div id="pres_r1_chart"></div>!}

@r2_start
on-arrival: {!
    // === ROUND 2 CONSOLIDATION ===

    var finalists = [Q.round1_winner, Q.round1_runner_up];
    if (Q.round2_has_third && Q.round1_third) finalists.push(Q.round1_third);

    var far_left = ["Thälmann", "Thalmann", "Münzenberg", "Munzenberg"];
    var left = ["Braun", "Schumacher", "Juchacz", "Rosenfeld", "Ollenhauer"];
    var center_left = ["Eckener", "Gessler", "Stresemann", "Horsing", "Schmid"];
    var center = ["Adenauer", "Kaas", "Brüning", "Bruning", "Noske"];
    var center_right = ["Schäffer", "Schaffer", "Westarp", "Drewitz", "Hamkens", "Behrens", "Lambach2"];
    var far_right = ["Hitler", "Göring", "Goring", "Goebbels", "Seldte", "Hugenberg", "Graefe", "Ludendorff"];
    var cultural = ["Einstein", "Mann", "Ossietzky"];

    if (!Q.hindenburg_dead) {
        center_left.push("Hindenburg");
        center.push("Hindenburg");
        center_right.push("Hindenburg");
    }

    function isInBlock(candidate, block) {
        return block.indexOf(candidate) !== -1;
    }

    function getIdeologicalDistance(candidate1, candidate2) {
        var blocks = [far_left, left, cultural, center_left, center, center_right, far_right];
        var pos1 = -1, pos2 = -1;
        for (var i = 0; i < blocks.length; i++) {
            if (isInBlock(candidate1, blocks[i])) pos1 = i;
            if (isInBlock(candidate2, blocks[i])) pos2 = i;
        }
        return Math.abs(pos1 - pos2);
    }

    // === FAR-RIGHT CONSOLIDATION ===
    if (Q.nsdap_candidate !== Q.dnvp_candidate) {
        var nsdap_in_runoff = finalists.indexOf(Q.nsdap_candidate) !== -1;
        var dnvp_in_runoff = finalists.indexOf(Q.dnvp_candidate) !== -1;
    
        if (nsdap_in_runoff && !dnvp_in_runoff) {
            Q.dnvp_candidate = Q.nsdap_candidate;
            Q.other_candidate = Q.nsdap_candidate;
        } else if (dnvp_in_runoff && !nsdap_in_runoff) {
            Q.nsdap_candidate = Q.dnvp_candidate;
        } else if (!nsdap_in_runoff && !dnvp_in_runoff) {
            var nsdap_votes = Q[Q.nsdap_candidate + '_votes'] || 0;
            var dnvp_votes = Q[Q.dnvp_candidate + '_votes'] || 0;
            if (nsdap_votes > dnvp_votes) {
                if (isInBlock(finalists[0], far_right) || isInBlock(finalists[0], center_right)) {
                    Q.nsdap_candidate = finalists[0];
                    Q.dnvp_candidate = finalists[0];
                } else if (isInBlock(finalists[1], far_right) || isInBlock(finalists[1], center_right)) {
                    Q.nsdap_candidate = finalists[1];
                    Q.dnvp_candidate = finalists[1];
                } else {
                    Q.nsdap_candidate = finalists[0];
                    Q.dnvp_candidate = finalists[0];
                }
            } else {
                if (isInBlock(finalists[0], far_right) || isInBlock(finalists[0], center_right) || isInBlock(finalists[0], center)) {
                    Q.dnvp_candidate = finalists[0];
                    Q.nsdap_candidate = finalists[0];
                } else {
                    Q.dnvp_candidate = finalists[1];
                    Q.nsdap_candidate = finalists[1];
                }
            }
        }
    }

    function pickClosestFinalist(current_candidate, party_ideology_priority) {
        if (finalists.indexOf(current_candidate) !== -1) {
            return current_candidate;
        }
        for (var i = 0; i < party_ideology_priority.length; i++) {
            var preferred_block = party_ideology_priority[i];
            for (var j = 0; j < finalists.length; j++) {
                if (isInBlock(finalists[j], preferred_block)) {
                    return finalists[j];
                }
            }
        }
        var bestFinalist = finalists[0];
        var bestDist = getIdeologicalDistance(current_candidate, finalists[0]);
        for (var f = 1; f < finalists.length; f++) {
            var d = getIdeologicalDistance(current_candidate, finalists[f]);
            if (d < bestDist) {
                bestDist = d;
                bestFinalist = finalists[f];
            }
        }
        return bestFinalist;
    }

    if (Q.z_party_leader === "Kaas") {
        Q.z_candidate = pickClosestFinalist(Q.z_candidate, [center, center_right, center_left, far_right]);
    } else {
        Q.z_candidate = pickClosestFinalist(Q.z_candidate, [center, center_left, left, center_right]);
    }

    Q.csrp_candidate = pickClosestFinalist(Q.csrp_candidate, [center, center_left, left, far_left, cultural, center_right]);
    Q.bvp_candidate = pickClosestFinalist(Q.bvp_candidate, [center_right, center, far_right, center_left]);
    Q.dvp_candidate = pickClosestFinalist(Q.dvp_candidate, [center_left, center, center_right, left]);
    Q.ddp_candidate = pickClosestFinalist(Q.ddp_candidate, [center_left, center, left, cultural]);
    Q.kpd_candidate = pickClosestFinalist(Q.kpd_candidate, [far_left, left, cultural]);

    if (Q.sapd_formed) {
        Q.sapd_candidate = pickClosestFinalist(Q.sapd_candidate, [left, far_left, cultural, center_left]);
    }
    if (Q.srpd_formed) {
        Q.srpd_candidate = pickClosestFinalist(Q.srpd_candidate, [center_left, center, center_right, left, far_left]);
    }
    if (Q.wp_candidate) {
        Q.wp_candidate = pickClosestFinalist(Q.wp_candidate, [center_right, center, center_left, far_right, left]);
    }
    if (Q.cnbl_candidate) {
        Q.cnbl_candidate = pickClosestFinalist(Q.cnbl_candidate, [center_right, center, far_right, center_left, left]);
    }
    if (Q.vrp_candidate) {
        Q.vrp_candidate = pickClosestFinalist(Q.vrp_candidate, [center_right, center, center_left, far_right, left]);
    }
    if (Q.csvd_candidate) {
        Q.csvd_candidate = pickClosestFinalist(Q.csvd_candidate, [center_right, center, center_left, cultural, left]);
    }
    if (Q.kvp_flee === 1 && Q.kvp_candidate) {
        Q.kvp_candidate = pickClosestFinalist(Q.kvp_candidate, [center_right, center, center_left, far_right, left]);
    }
    if (Q.dhp_candidate) {
        Q.dhp_candidate = pickClosestFinalist(Q.dhp_candidate, [center_right, center, far_right, center_left, left]);
    }
    if (Q.bb_candidate) {
        Q.bb_candidate = pickClosestFinalist(Q.bb_candidate, [center_right, center, far_right, center_left, left, far_left]);
    }
    if (Q.dvfp_candidate) {
        Q.dvfp_candidate = pickClosestFinalist(Q.dvfp_candidate, [far_right, center_right, center]);
    }

    Q.other_candidate = pickClosestFinalist(Q.other_candidate, [far_right, center_right, center]);

    if (!Q.round2_has_third) {
        var parties_r2 = ['z','bvp','ddp','dvp','kpd','nsdap','dnvp',
                          'cnbl','sapd','csvd','srpd','csrp','wp','kvp','dhp','bb','vrp','dvfp','other'];
        for (var i = 0; i < parties_r2.length; i++) {
            var p = parties_r2[i];
            var cand = Q[p + '_candidate'];
            if (!cand) continue;
            var candNorm = cand.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            if (candNorm === Q.round1_third) {
                Q[p + '_candidate'] = pickClosestFinalist(cand,
                    [center_left, center, center_right, left, far_left, far_right]);
            }
        }
    }
!}

**Second Round Runoff**

No candidate achieved a majority in the first round. The candidates advance to a runoff:

1. **[+ round1_winner_desc +]** - [+ round1_winner_votes +]%

2. **[+ round1_runner_up_desc +]** - [+ round1_runner_up_votes +]%

[? if round2_has_third : 3. **[+ round1_third_desc +]** - [+ round1_third_votes_disp +]% ?]

- @r2_menu: What should we do?

@r2_menu

[? if round2_has_third : Three candidates remain in the runoff: **[+ round1_winner +]** ([+ round1_winner_votes +]%), **[+ round1_runner_up +]** ([+ round1_runner_up_votes +]%), and **[+ round1_third +]** ([+ round1_third_votes_disp +]%). ?]
[? if not round2_has_third : Two candidates remain: **[+ round1_winner +]** ([+ round1_winner_votes +]%) and **[+ round1_runner_up +]** ([+ round1_runner_up_votes +]%). ?]

- @r2_push_out_third: Try to push out the third candidate. 
- @r2_switch_spd: Change our own support.
- @r2_convince: Try to convince other parties.
- @r2_vote: Proceed to the final vote.

@r2_push_out_third
view-if: round2_has_third = 1
max-visits: 1

[+ round1_third_desc +] is still in the race with [+ round1_third_votes_disp +]%. We could try to convince them to withdraw.

- @push_third_resources: Spend resources to negotiate withdrawal (-2 resources).
- @push_third_relations: Use our political relationships (if relations are good enough).
- @r2_menu: Leave them in.

@push_third_resources
choose-if: resources >= 2
unavailable-subtitle: Not enough resources.
on-arrival: {!
    resources -= 2;
    Q.round2_has_third = 0;
    Q.third_stays = 0;
    // Redistribute their party support
    var parties_r2 = ['z','bvp','ddp','dvp','kpd','nsdap','dnvp',
                      'cnbl','sapd','csvd','srpd','csrp','wp','kvp','dhp','bb','vrp', 'dvfp', 'other'];
    var far_left     = ["Thalmann", "Munzenberg"];
    var left         = ["Braun", "Schumacher", "Juchacz", "Rosenfeld", "Ollenhauer"];
    var center_left  = ["Eckener", "Gessler", "Stresemann", "Horsing", "Schmid", "Hindenburg"];
    var center       = ["Adenauer", "Kaas", "Bruning", "Hindenburg", "Noske"];
    var center_right = ["Schaffer", "Westarp", "Treviranus", "Lambach", "Lindeiner", "Drewitz", "Hamkens", "Lambach2"];
    // Added Graefe and Ludendorff to far_right
    var far_right    = ["Hitler", "Goring", "Goebbels", "Seldte", "Hugenberg", "Graefe", "Ludendorff"];

    var finalists = [Q.round1_winner, Q.round1_runner_up];
    function isInBlock(c, b) { return b.indexOf(c) !== -1; }
    function pickClosest(cand, priority) {
        if (finalists.indexOf(cand) !== -1) return cand;
        for (var i = 0; i < priority.length; i++) {
            for (var j = 0; j < finalists.length; j++) {
                if (isInBlock(finalists[j], priority[i])) return finalists[j];
            }
        }
        return finalists[0];
    }
    for (var i = 0; i < parties_r2.length; i++) {
        var p = parties_r2[i];
        var cand = Q[p + '_candidate'];
        if (!cand) continue;
        var candNorm = cand.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        if (candNorm === Q.round1_third) {
            Q[p + '_candidate'] = pickClosest(cand, [center_left,center,center_right,left,far_left,far_right]);
        }
    }
!}
go-to: r2_menu

[+ round1_third_desc +] has agreed to withdraw. Their supporters will redistribute.

@push_third_relations
view-if: (z_relation >= 60 and round1_third != "Thalmann" and round1_third != "Munzenberg" and round1_third != "Hitler" and round1_third != "Goring" and round1_third != "Goebbels") or (kpd_relation >= 65 and (round1_third = "Thalmann" or round1_third = "Munzenberg"))
unavailable-subtitle: Relations not strong enough to pressure a withdrawal.
on-arrival: {!
    Q.round2_has_third = 0;
    Q.third_stays = 0;
    var parties_r2 = ['z','bvp','ddp','dvp','kpd','nsdap','dnvp',
                      'cnbl','sapd','csvd','srpd','csrp','wp','kvp','dhp','bb','vrp', 'dvfp', 'other'];
    var far_left     = ["Thalmann", "Munzenberg"];
    var left         = ["Braun", "Schumacher", "Juchacz", "Rosenfeld", "Ollenhauer"];
    var center_left  = ["Eckener", "Gessler", "Stresemann", "Horsing", "Schmid", "Hindenburg"];
    var center       = ["Adenauer", "Kaas", "Bruning", "Hindenburg", "Noske"];
    var center_right = ["Schaffer", "Westarp", "Treviranus", "Lambach", "Lindeiner", "Drewitz", "Hamkens", "Lambach2"];
    // Added Graefe and Ludendorff to far_right
    var far_right    = ["Hitler", "Goring", "Goebbels", "Seldte", "Hugenberg", "Graefe", "Ludendorff"];

    function isInBlock(c, b) { return b.indexOf(c) !== -1; }
    function pickClosest(cand, priority) {
        if (finalists.indexOf(cand) !== -1) return cand;
        for (var i = 0; i < priority.length; i++) {
            for (var j = 0; j < finalists.length; j++) {
                if (isInBlock(finalists[j], priority[i])) return finalists[j];
            }
        }
        return finalists[0];
    }
    for (var i = 0; i < parties_r2.length; i++) {
        var p = parties_r2[i];
        var cand = Q[p + '_candidate'];
        if (!cand) continue;
        var candNorm = cand.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        if (candNorm === Q.round1_third) {
            Q[p + '_candidate'] = pickClosest(cand, [center_left,center,center_right,left,far_left,far_right]);
        }
    }
!}
go-to: r2_menu

[+ round1_third_desc +] has agreed to stand down through political pressure.

@r2_switch_spd

We are currently supporting **[+ spd_candidate +]**.

[? if round2_has_third : Three candidates remain. We can support any of them. ?]
[? if not round2_has_third : Two candidates remain. ?]

- @switch_to_finalist1: Support [+ round1_winner +] ([+ round1_winner_votes +]%)
- @switch_to_finalist2: Support [+ round1_runner_up +] ([+ round1_runner_up_votes +]%)
- @switch_to_third: Support [+ round1_third +] ([+ round1_third_votes_disp +]%)
- @r2_menu: Keep current support.

@switch_to_finalist1
view-if: spd_candidate != round1_winner
choose-if: (round1_winner != "Hitler" and round1_winner != "Goring" and round1_winner != "Goebbels" and round1_winner != "Hugenberg" and round1_winner != "Seldte") or (kpd_relation >= 65 and (round1_winner = "Thalmann" or round1_winner = "Munzenberg"))
unavailable-subtitle: We cannot support this candidate.
on-arrival: spd_candidate = round1_winner; is_unity_candidate = 1 if round1_winner != "Thalmann" and round1_winner != "Munzenberg";
go-to: r2_menu

We now support [+ round1_winner +].

@switch_to_finalist2
view-if: spd_candidate != round1_runner_up
choose-if: (round1_runner_up != "Hitler" and round1_runner_up != "Goring" and round1_runner_up != "Goebbels" and round1_runner_up != "Hugenberg" and round1_runner_up != "Seldte") or (kpd_relation >= 65 and (round1_runner_up = "Thalmann" or round1_runner_up = "Munzenberg"))
unavailable-subtitle: We cannot support this candidate.
on-arrival: spd_candidate = round1_runner_up; is_unity_candidate = 1 if round1_runner_up != "Thalmann" and round1_runner_up != "Munzenberg";
go-to: r2_menu

We now support [+ round1_runner_up +].

@switch_to_third
view-if: round2_has_third = 1 and spd_candidate != round1_third
choose-if: (round1_third != "Hitler" and round1_third != "Goring" and round1_third != "Goebbels" and round1_third != "Hugenberg" and round1_third != "Seldte") or (kpd_relation >= 65 and (round1_third = "Thalmann" or round1_third = "Munzenberg"))
unavailable-subtitle: We cannot support this candidate.
on-arrival: spd_candidate = round1_third;
go-to: r2_menu

We now support [+ round1_third +].

@r2_convince

- @convince_z_r2: Try to convince the Center Party.
- @convince_ddp_r2: Try to convince the [+ ddp_name +].
- @convince_dvp_r2: Try to convince the DVP.
- @convince_kpd_r2: Try to convince the KPD.
- @convince_csrp_r2: Try to convince the CSRP.
- @r2_menu: Back.

@convince_csrp_r2
view-if: csrp_candidate != spd_candidate
on-arrival: csrp_candidate = spd_candidate if csrp_relation >= 40;
go-to: r2_convince

[? if csrp_candidate == spd_candidate : The CSRP now supports [+ spd_candidate +]! ?]
[? if csrp_candidate != spd_candidate : The CSRP refuses. ?]


@convince_z_r2
view-if: z_candidate != spd_candidate

- @pay_z_r2: Offer resources (-2 resources).
- @r2_convince: Back.

@pay_z_r2
choose-if: resources >= 2 and z_relation >= 35
subtitle: -2 resources
unavailable-subtitle: [? if resources < 2 : Not enough resources. ?][? if z_relation < 35 : Relations not good enough. ?]
on-arrival: resources -= 2; z_candidate = spd_candidate; bvp_candidate = spd_candidate if bvp_candidate == z_candidate;
go-to: r2_convince

The Center Party now supports [+ spd_candidate +]!

@convince_ddp_r2
view-if: ddp_candidate != spd_candidate
on-arrival: ddp_candidate = spd_candidate if ddp_relation >= 35;
go-to: r2_convince

[? if ddp_candidate == spd_candidate : The [+ ddp_name +] now supports [+ spd_candidate +]! ?]
[? if ddp_candidate != spd_candidate : The [+ ddp_name +] refuses. ?]

@convince_dvp_r2
view-if: dvp_candidate != spd_candidate
on-arrival: dvp_candidate = spd_candidate if dvp_relation >= 45;
go-to: r2_convince

[? if dvp_candidate == spd_candidate : The DVP now supports [+ spd_candidate +]! ?]
[? if dvp_candidate != spd_candidate : The DVP refuses. ?]

@convince_kpd_r2
view-if: kpd_candidate != spd_candidate
choose-if: kpd_relation >= 55
unavailable-subtitle: Relations not good enough.
on-arrival: kpd_candidate = spd_candidate; sapd_candidate = spd_candidate;
go-to: r2_convince

The KPD now supports [+ spd_candidate +]!

@r2_vote
on-arrival: round = 2;
go-to: election_algorithm
set-jump: post_r2

@post_r2
on-arrival: {!
    // === CALCULATE ROUND 2 RESULTS ===
    
    var candidate_votes = {};
    var parties = ['spd', 'z', 'bvp', 'ddp', 'dvp', 'kpd', 'nsdap', 'dnvp', 
                   'cnbl', 'sapd', 'csvd', 'srpd', 'csrp', 'wp', 'kvp', 'dhp', 'bb', 'dvfp', 'vrp', 'other'];
    
    for (var i = 0; i < parties.length; i++) {
        var party = parties[i];
        var supported_candidate = Q[party + '_candidate'];
        
        if (!supported_candidate) continue;
        
        supported_candidate = supported_candidate.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        
        var party_votes = Q[party + '_r'] || Q[party + '_votes'] || 0;
        
        if (candidate_votes[supported_candidate]) {
            candidate_votes[supported_candidate] += party_votes;
        } else {
            candidate_votes[supported_candidate] = party_votes;
        }
        
        // Store individual party vote for display
        Q[party + '_r2_votes'] = party_votes;
    }
    
    // Apply bonuses
    for (var k in candidate_votes) {
        if (Q[k + '_bonus']) {
            candidate_votes[k] += Q[k + '_bonus'] / 100;
        }
    }
    
    // Find winner
    var total_votes = 0;
    Q.winner = "";
    Q.winner_votes = 0;
    
    for (var k in candidate_votes) {
        total_votes += candidate_votes[k];
        if (candidate_votes[k] > Q.winner_votes) {
            Q.winner = k;
            Q.winner_votes = candidate_votes[k];
        }
    }
    
    Q.winner_votes = Math.round(1000 * Q.winner_votes / total_votes) / 10;
    Q.winner_votes_disp = Q.winner_votes.toFixed(1);
    
    // Store runner-up info
    Q.runnerup = Q.round1_winner === Q.winner ? Q.round1_runner_up : Q.round1_winner;
    Q.runnerup_votes = Math.round(1000 * candidate_votes[Q.runnerup] / total_votes) / 10;
    Q.runnerup_votes_disp = Q.runnerup_votes.toFixed(1)
    
    var candidate_descs = {
    Hindenburg: "Paul von Hindenburg (I)",
    Hitler: "Adolf Hitler (NSDAP)",
    Göring: "Hermann Göring (NSDAP)",
    Goring: "Hermann Göring (NSDAP)",
    Goebbels: "Joseph Goebbels (NSDAP)",
    Seldte: "Franz Seldte (DNVP/Stahlhelm)",
    Westarp: "Kuno von Westarp (DNVP)",
    Eckener: "Hugo Eckener (Unity)",
    Adenauer: "Konrad Adenauer (Z)",
    Kaas: "Ludwig Kaas (Z)",
    Brüning: "Heinrich Brüning (Z)",
    Bruning: "Heinrich Brüning (Z)",
    Gessler: "Otto Gessler (Liberal)",
    Stresemann: "Gustav Stresemann (DVP)",
    Thälmann: "Ernst Thälmann (KPD)",
    Thalmann: "Ernst Thälmann (KPD)",
    Münzenberg: "Willi Münzenberg (KPD)",
    Munzenberg: "Willi Münzenberg (KPD)",
    Braun: "Otto Braun (SPD)",
    Schumacher: "Kurt Schumacher (SPD)",
    Schmid: "Carlo Schmid (SPD - R)",
    Ollenhauer: "Erich Ollenhauer (SPD - L)",
    Juchacz: "Marie Juchacz (SPD)",
    Einstein: "Albert Einstein (Independent)",
    Mann: "Heinrich Mann (Independent)",
    Ossietzky: "Carl von Ossietzky (Independent)",
    Rosenfeld: "Kurt Rosenfeld (SAPD)",
    Schäffer: "Franz Schäffer (BVP)",
    Schaffer: "Franz Schäffer (BVP)",
    Drewitz: "Max Drewitz (WP)",
    Horsing: "Otto Hörsing (SRPD)",
    Hamkens: "Wilhelm Hamkens (CNBL)",
    Behrens: "Wilhelm Behrens (CNBL)",
    // DDP candidates
    Lemmer: "Ernst Lemmer (DDP)",
    Heuss: "Theodor Heuss (DDP)",
    Dietrich: "Hermann Dietrich (DDP)",
    Lüders: "Hermann Lüders (DDP)", // or Marie-Elisabeth depending on context
    // DStP candidates
    Mahraun: "Arthur Mahraun (DStP/Jungdo)",
    "Koch-Weser": "Erich Koch-Weser (DStP)",
    Maier: "Reinhold Maier (DStP)",
    // DNVP candidates
    Treviranus: "Gottfried Treviranus (DNVP)",
    Lambach: "Walter Lambach (DNVP)",
    Lindeiner: "Hans von Lindeiner-Wildau (DNVP)",
    Hugenberg: "Alfred Hugenberg (DNVP)",
    // DVP (NEW)
    Scholz: "Ernst Scholz (DVP)",
    Dingeldey: "Eduard Dingeldey (DVP)",
    Curtius: "Julius Curtius (DVP)",
    Reinhold: "Peter Reinhold (DVP)",
    Lambach2: "Walther Lambach (CSVD)",
    Graefe: "Albrecht von Graefe (DVFP)",
    Ludendorff: "Erich Ludendorff (DVFP/Völkisch)",
    Noske: "Gustav Noske (SPD - SC)",
    
};
    
    Q.winner_desc = candidate_descs[Q.winner];
!}
on-display: {!
var partyColors = {
    spd:"#E3000F", kpd:"#8B0000", sapd:"#C40000", srpd:"#FF6B6B",
    z:"#000000",   bvp:"#69A2BE", csrp:"#FFCCFF", ddp:"#DCCA4A",
    dvp:"#D5AC27", wp:"#424242",  cnbl:"#5D4E37", csvd:"#3f7bc1",
    dnvp:"#3f7bc1",nsdap:"#954B00",kvp:"#3f7bc1", dhp:"#5D4E37",
    bb:"#69A2BE",  vrp:"#8B7355", dvfp:"#7A5C12", other:"#a0a0a0",
};

var partyLabels = {
    spd:"SPD", kpd:"KPD", sapd:"SAPD", srpd:"SRPD", z:"Z", bvp:"BVP",
    csrp:"CSRP", ddp:Q.ddp_name||"DDP", dvp:"DVP", wp:"WP",
    cnbl:"CNBL", csvd:"CSVD", dnvp:"DNVP", nsdap:"NSDAP", kvp:"KVP",
    dhp:"DHP", bb:"BB", vrp:"VRP", dvfp:"DVFP", other:"Other",
};

var allParties = ['spd','z','bvp','ddp','dvp','kpd','nsdap','dnvp',
                  'cnbl','sapd','csvd','srpd','csrp','wp','kvp','dhp',
                  'bb','vrp','dvfp','other'];

var displayNames = {
    Thalmann:"Thälmann", Munzenberg:"Münzenberg", Bruning:"Brüning",
    Schaffer:"Schäffer", Goring:"Göring", KochWeser:"Koch-Weser",
};
function dname(k) { return displayNames[k] || k; }

var finalist1 = Q.round1_winner;
var finalist2 = Q.round1_runner_up;

// ── Build buckets ──────────────────────────────────────────────
var buckets = {};
buckets[finalist1] = [];
buckets[finalist2] = [];
var thirdKey = null;

for (var i = 0; i < allParties.length; i++) {
    var p = allParties[i];
    var cand = Q[p + '_candidate'];
    if (!cand) continue;
    var candNorm = cand.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    var votes = Q[p + '_r'] || Q[p + '_votes'] || 0;
    if (votes <= 0) continue;
    var bucket = candNorm === finalist1 ? finalist1
               : candNorm === finalist2 ? finalist2
               : candNorm;
    if (!buckets[bucket]) { buckets[bucket] = []; thirdKey = bucket; }
    buckets[bucket].push({ party: p, votes: votes });
}

function sumBucket(b) { return b.reduce(function(s,x){return s+x.votes;},0); }

var total = sumBucket(buckets[finalist1]) + sumBucket(buckets[finalist2])
          + (thirdKey ? sumBucket(buckets[thirdKey]) : 0);

var cols = [finalist1, finalist2];
if (thirdKey) cols.push(thirdKey);
var colTotals = cols.map(function(k){return sumBucket(buckets[k]);});
var colPcts   = colTotals.map(function(v){return total>0?v/total*100:0;});

var container = document.getElementById('pres_r2_chart');
if (!container) return;
container.innerHTML = "";
container.style.cssText = "width:100%; max-width:620px; font-family:sans-serif;";

// ── SECTION 1: Stacked column chart ───────────────────────────
var headerRow = document.createElement('div');
headerRow.style.cssText = "display:flex; gap:4px; margin-bottom:4px;";
cols.forEach(function(k, idx) {
    var isWinner = (k === Q.winner);
    var h = document.createElement('div');
    h.style.cssText = "flex:" + colPcts[idx] + "; text-align:center; font-size:12px; font-weight:bold;"
        + "white-space:nowrap; overflow:hidden; text-overflow:ellipsis; padding:2px 0;"
        + (isWinner ? "color:#1a1a1a;" : "color:#666;");
    h.textContent = dname(k) + " — " + colPcts[idx].toFixed(1) + "%"
        + (isWinner ? " ★" : "");
    headerRow.appendChild(h);
});
container.appendChild(headerRow);

var barRow = document.createElement('div');
barRow.style.cssText = "display:flex; gap:4px; height:130px; align-items:flex-end; margin-bottom:16px;";
cols.forEach(function(k, colIdx) {
    var colWrap = document.createElement('div');
    colWrap.style.cssText = "flex:" + colPcts[colIdx] + "; display:flex; flex-direction:column;"
        + "height:100%; border-radius:3px; overflow:hidden;"
        + (Q.round2_has_third && k === Q.round1_third ? "opacity:0.8; outline:2px dashed #aaa;" : "");

    var parties = buckets[k].slice().sort(function(a,b){return b.votes-a.votes;});
    var colTotal = colTotals[colIdx];
    parties.forEach(function(p) {
        var segPct = colTotal > 0 ? p.votes / colTotal * 100 : 0;
        var seg = document.createElement('div');
        seg.style.cssText = "flex:" + segPct + "; background:" + (partyColors[p.party]||"#aaa")
            + "; display:flex; align-items:center; justify-content:center; overflow:hidden; min-height:0;";
        seg.title = (partyLabels[p.party]||p.party) + ": " + p.votes.toFixed(1) + "%";
        if (segPct > 5) {
            var lbl = document.createElement('span');
            lbl.style.cssText = "font-size:10px; font-weight:bold; color:#fff;"
                + "text-shadow:0 0 2px #000,0 0 2px #000; white-space:nowrap; pointer-events:none;";
            lbl.textContent = (partyLabels[p.party]||p.party) + " " + p.votes.toFixed(1) + "%";
            seg.appendChild(lbl);
        }
        colWrap.appendChild(seg);
    });
    barRow.appendChild(colWrap);
});
container.appendChild(barRow);

// ── SECTION 2: Party-by-party infographic rows ────────────────
var divider = document.createElement('div');
divider.style.cssText = "font-size:11px; font-weight:bold; color:#888; letter-spacing:0.08em;"
    + "text-transform:uppercase; border-top:1px solid #ddd; padding-top:8px; margin-bottom:6px;";
divider.textContent = "Party Support Breakdown";
container.appendChild(divider);

// Collect all parties that actually voted, grouped by their candidate
var grouped = {};
for (var i = 0; i < allParties.length; i++) {
    var p = allParties[i];
    var cand = Q[p + '_candidate'];
    if (!cand) continue;
    var candNorm = cand.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    var votes = Q[p + '_r'] || Q[p + '_votes'] || 0;
    if (votes <= 0) continue;
    if (!grouped[candNorm]) grouped[candNorm] = [];
    grouped[candNorm].push({ party: p, votes: votes, cand: candNorm });
}

// Sort candidates: winner first, then runner-up, then third
var candOrder = [Q.winner, Q.runnerup];
if (thirdKey && thirdKey !== Q.winner && thirdKey !== Q.runnerup) candOrder.push(thirdKey);

// For each candidate, render a labelled block of party rows
candOrder.forEach(function(cand) {
    if (!grouped[cand] || grouped[cand].length === 0) return;

    var isWinner = (cand === Q.winner);
    var candTotal = grouped[cand].reduce(function(s,x){return s+x.votes;},0);
    var candPct = total > 0 ? candTotal / total * 100 : 0;

    // Candidate sub-header
    var candHeader = document.createElement('div');
    candHeader.style.cssText = "display:flex; align-items:center; gap:6px; margin-bottom:4px; margin-top:2px;";

    var candLabel = document.createElement('div');
    candLabel.style.cssText = "font-size:12px; font-weight:bold; color:" + (isWinner?"#1a1a1a":"#555") + ";";
    candLabel.textContent = dname(cand) + (isWinner ? " ★" : "") + "  (" + candPct.toFixed(1) + "%)";

    candHeader.appendChild(candLabel);
    container.appendChild(candHeader);

    // Sort parties by vote share descending
    var parties = grouped[cand].slice().sort(function(a,b){return b.votes-a.votes;});
    var maxVotes = parties[0].votes;

    parties.forEach(function(item) {
        var row = document.createElement('div');
        row.style.cssText = "display:flex; align-items:center; gap:5px; margin-bottom:3px;";

        // Party color chip + label
        var chip = document.createElement('div');
        chip.style.cssText = "width:10px; height:10px; border-radius:2px; flex-shrink:0; background:"
            + (partyColors[item.party]||"#aaa") + ";";

        var nameEl = document.createElement('div');
        nameEl.style.cssText = "width:44px; font-size:11px; color:#333; flex-shrink:0; text-align:right;";
        nameEl.textContent = partyLabels[item.party] || item.party;

        // Mini bar
        var barWrap = document.createElement('div');
        barWrap.style.cssText = "flex:1; background:#f0f0f0; height:12px; border-radius:2px; position:relative;";

        var bar = document.createElement('div');
        var barW = Math.round(item.votes / maxVotes * 100);
        bar.style.cssText = "height:100%; border-radius:2px; background:" + (partyColors[item.party]||"#aaa")
            + "; width:" + barW + "%; opacity:0.85;";

        // Vote label on right
        var pctEl = document.createElement('div');
        pctEl.style.cssText = "width:36px; font-size:11px; color:#444; text-align:left; flex-shrink:0;";
        pctEl.textContent = item.votes.toFixed(1) + "%";

        barWrap.appendChild(bar);
        row.appendChild(chip);
        row.appendChild(nameEl);
        row.appendChild(barWrap);
        row.appendChild(pctEl);
        container.appendChild(row);
    });

    // Small spacer between candidate groups
    var spacer = document.createElement('div');
    spacer.style.cssText = "height:8px;";
    container.appendChild(spacer);
});

// ── Winner banner ─────────────────────────────────────────────
var banner = document.createElement('div');
banner.style.cssText = "margin-top:8px; padding:6px 10px; background:#f5f5f5; border-left:4px solid #333;"
    + "border-radius:2px; font-size:12px; color:#1a1a1a; font-weight:bold;";
banner.textContent = "✓ " + dname(Q.winner) + " elected with " + (Q.winner_votes_disp||"—") + "% of the vote";
container.appendChild(banner);
!}
go-to: election_end

**Final Results:**

{!<div id="pres_r2_chart"></div>!}

[+ winner_desc +] has won the presidency with [+ winner_votes_disp +]% of the vote!

@election_end
on-departure: {!
Q.presidential_election_active = 0;
Q.president_term_start = Q.year;
Q.president_term_ended = 0;

// Set next presidential election: 7 years from current year, always in March
var next_year = Q.year + 7;
var next_month = Q.month;

// Guard-rail: if somehow month is invalid, normalize it
if (!next_month || next_month < 1 || next_month > 12) {
    next_month = 3;
}
if (!next_year || next_year < Q.year + 1) {
    next_year = Q.year + 7;
}

Q.next_presidential_election_year = next_year;
Q.next_presidential_election_month = next_month;

// Safety: ensure last_presidential_election is recorded
Q.last_presidential_election = Q.year;

if (!Q.has_majority) {
    Q.president_history = Q.president_history || [];
    Q.president_history.push({
    name: Q.winner,
    desc: Q.winner_desc,
    year_start: Q.year,
    votes: Q.winner_votes_disp,
    runnerup: Q.runnerup,
    runnerup_votes: Q.runnerup_votes_disp,
    third: Q.round1_third || null,
    third_desc: Q.round1_third_desc || null,
    third_votes: Q.round1_third_votes_disp || null,
    third_stayed: Q.round2_has_third ? 1 : 0,
    rounds: 2,
    round1_candidates: Q.round1_all_candidates
    });
    Q.president_history_count = Q.president_history.length;
}

// Normalize umlaut names
var name_map = {
    'Thalmann':  'Thälmann',
    'Munzenberg':'Münzenberg',
    'Goring':    'Göring',
    'Bruning':   'Brüning',
    'Schaffer':  'Schäffer',
    'Horsing':   'Otto Horsing'
};
if (name_map[Q.winner]) Q.winner = name_map[Q.winner];

Q.president = Q.winner;
Q.president_term_start = Q.year;
Q.presidential_election_active = 0;
Q.president_term_ended = 0;

// Set president_party
var spd_winners   = ['Braun','Schumacher','Juchacz','Schmid','Ollenhauer', 'Noske'];
var kpd_winners   = ['Thälmann','Thalmann','Münzenberg','Munzenberg'];
var nsdap_winners = ['Hitler','Göring','Goring','Goebbels'];
var dnvp_winners  = ['Seldte','Westarp','Treviranus','Lambach','Lindeiner','Hugenberg'];
var z_winners     = ['Adenauer','Kaas','Brüning','Bruning'];
var bvp_winners   = ['Schäffer','Schaffer'];
var dvp_winners   = ['Stresemann','Gessler','Scholz','Dingeldey','Curtius','Reinhold'];
var ddp_winners   = ['Heuss','Dietrich','Lüders','Lemmer','Mahraun','Koch-Weser','Maier'];
var ind_winners   = ['Hindenburg','Eckener','Einstein','Mann','Ossietzky'];
var dvfp_winners  = ['Graefe','Ludendorff']; // Added DVFP winners


var w = Q.winner;
if      (spd_winners.indexOf(w)   >= 0) Q.president_party = 'SPD';
else if (kpd_winners.indexOf(w)   >= 0) Q.president_party = 'KPD';
else if (nsdap_winners.indexOf(w) >= 0) Q.president_party = 'NSDAP';
else if (dnvp_winners.indexOf(w)  >= 0) Q.president_party = 'DNVP';
else if (z_winners.indexOf(w)     >= 0) Q.president_party = 'Z';
else if (bvp_winners.indexOf(w)   >= 0) Q.president_party = 'BVP';
else if (dvp_winners.indexOf(w)   >= 0) Q.president_party = 'DVP';
else if (ddp_winners.indexOf(w)   >= 0) Q.president_party = 'DDP';
else if (dvfp_winners.indexOf(w)  >= 0) Q.president_party = 'DVFP'; // Added check
else if (w === 'Rosenfeld')              Q.president_party = 'SAPD';
else if (w === 'Horsing')           Q.president_party = 'SRPD';
else if (w === 'Drewitz')               Q.president_party = 'WP';
else if (w === 'Hamkens' || w === 'Behrens') Q.president_party = 'CNBL';
else if (w === 'Lambach2')             Q.president_party = 'CSVD';
else if (ind_winners.indexOf(w)   >= 0) Q.president_party = 'I';



!}
on-arrival: president_term_start = year; presidential_election_active = 0;
go-to: ollenhauer_victory if winner = "Ollenhauer"; dvfp_victory if winner = "Graefe" or winner = "Ludendorff";  hindenburg_victory if winner = "Hindenburg"; hitler_victory if winner = "Hitler" or winner = "Göring" or winner = "Goring" or winner = "Goebbels"; seldte_victory if winner = "Seldte"; thalmann_victory if winner = "Thälmann" or winner = "Thalmann"; munzenberg_victory if winner = "Münzenberg" or winner = "Munzenberg"; eckener_win if winner = "Eckener"; juchacz_win if winner = "Juchacz"; bundesrepublik_win if winner = "Schumacher" or winner = "Schmid" or winner = "Adenauer" or winner = "Lambach_2"; nazis_lose if winner = "Braun" or winner = "Gessler" or winner = "Stresemann" or winner = "Westarp"; cultural_victory if winner = "Ossietzky" or winner = "Mann"; einstein_victory if winner = "Einstein"; z_victory if winner = "Kaas" or winner = "Brüning" or winner = "Bruning"; bvp_victory if winner = "Schäffer" or winner = "Schaffer"; sapd_victory if winner = "Rosenfeld"; wp_victory if winner = "Drewitz"; srpd_victory if winner = "Horsing"; cnbl_victory if winner = "Hamkens" or winner = "Behrens"; noske_win if winner = "Noske"        

[+ winner_desc +] is now President of Germany.

@noske_win
on-arrival: social_fascism_accepted = 1; dnvp_relation += 20; reichswehr_loyalth += 0.10; kpd_relation -= 30; left_dissent += 10; rfb_strength *= 1.20
achievement: noske_leader

Gustav Noske, formerly the Reichswehr_minister, has won the presidency. Let's see what he can do. Be aware of communists. They always lurk.

@dvfp_victory
on-arrival: president_party = "DVFP"; nationalism += 25; nsdap_relation -= 10; dnvp_relation -= 10; democratization -= 3

[? if winner = "Ludendorff" : General Erich Ludendorff, the hero of the Great War and champion of the völkisch movement, has achieved the victory he was denied in 1925. ?]
[? if winner = "Graefe" : Albrecht von Graefe and the Völkisch Freedom Party have stunned the republic, bringing the radical racial-nationalist movement to the highest office. ?]

The "System" has been dealt a mortal blow. The new President speaks of a national spiritual renewal and the purging of "un-German" influences. 

[? if nsdap_banned = 0 : The Nazis are jubilant, seeing this as the final precursor to their own total power, though Ludendorff has no intention of being Hitler's subordinate. ?]

[? if presidential_powers == 0 : With full presidential powers, the völkisch regime begins a rapid dismantling of the Weimar Constitution. ?]
[? if presidential_powers >= 1 : Our previous constitutional reforms act as a final barrier, forcing the new President to contend with a hostile Reichstag. ?]

- @game_over


@ollenhauer_victory
on-arrival: president_party = "SPD"; socialism += 5; kpd_relation *= 1.25; sapd_relation *= 1.50; workers_spd += 5

Erich Ollenhauer, supporter of the leftist - marxist orientation of our party, currently head of Saxony has won the election. 

@hindenburg_victory
on-arrival: president_party = "I"; nationalism += 10; dnvp_relation += 5; camarilla_strength *= 2; judiciary_reform -= 2

Paul von Hindenburg, the aging field marshal, becomes President of Germany. The old military hero represents traditional conservative values.

[? if presidential_powers >= 1 : However, constitutional reforms limit his ability to rule by decree... ?]

[? if presidential_powers = 0 : With full presidential powers, Hindenburg rules as a conservative figurehead, heavily influenced by his DNVP backers. ?]

- @game_over

@cnbl_victory

CNBL has secured the win.

@srpd_victory

Otto Hörsing has achieved the victory. Republic shall survive once more.

@wp_victory

Economic party has achieved victory it has never dreamt of! Middle class will be represented under the leadership of the Drewitz! Hopefully crisis finally settles down of the middle class.

@hitler_victory
on-arrival: chancellor = "Hitler"; chancellor_party = "NSDAP"

The Nazis waste no time consolidating power. [? if president != "Hitler" : The new president immediately appoints Hitler as chancellor. ?][? if president = "Hitler" : Hitler appoints himself chancellor. ?]

[? if presidential_powers >= 1 : However, we have limited presidential powers through constitutional reform... ?][? if presidential_powers = 0 : With full presidential powers at his disposal, Hitler moves to reshape Germany. ?]

- @game_over

@seldte_victory
on-arrival: chancellor = "Seldte"; chancellor_party = "DNVP"; nationalism += 20

Franz Seldte, leader of the Stahlhelm, becomes President and immediately declares martial law.

[? if presidential_powers >= 1 : However, our constitutional reforms limit his ability to rule by decree... ?]

[? if presidential_powers = 0 : With full presidential powers at his disposal, Seldte establishes a military-backed authoritarian regime. He appoints himself Chancellor and begins dismantling democratic institutions. ?]

[? if nsdap_banned = 0 and hitler_deported = 0 : The NSDAP is furious - they expected Seldte to be their puppet, but the old Stahlhelm general has his own plans. Hitler is placed under house arrest. ?]

[? if nsdap_banned = 0 and hitler_deported = 1 : The NSDAP protests, but with Hitler in exile, they lack the strength to challenge Seldte's military regime. ?]

[? if nsdap_banned = 1 : With the Nazis already banned, Seldte consolidates a conservative-nationalist dictatorship without fascist competition. ?]

Germany enters an era of military authoritarianism under the old veterans of the Great War.

@thalmann_victory
go-to: thalmann_democrat if presidential_powers; thalmann_civil_war if not presidential_powers

@thalmann_civil_war
on-arrival: kpd_relation += 20

Thälmann moves to consolidate power. The far-right launches a coup attempt. Civil war looms...

- @game_over

@thalmann_democrat
on-arrival: kpd_relation += 10

Despite fears, Thälmann respects constitutional limits. Germany has a Communist president, but democracy endures.

- @game_over

@munzenberg_victory
achievement: rote_millionar
on-arrival: kpd_relation += 10

Willi Münzenberg becomes president. The "Red Millionaire" promises to respect democratic institutions.

- @game_over

@eckener_win
achievement: zeppelin_kapitan

Hugo Eckener, the Zeppelin captain, becomes president - a symbol of German technical achievement and republican unity.

- @game_over

@juchacz_win
achievement: wahlrechts

Historic! Marie Juchacz becomes the world's first elected female president!

- @game_over

@bundesrepublik_win
achievement: bundesrepublik
go-to: nazis_lose

A new era begins with [+ winner_desc +] as president.

@einstein_victory
achievement: republik_der_wissenschaft

Albert Einstein becomes president - science and reason triumph!

- @game_over

@cultural_victory

[+ winner_desc +] becomes president, representing Germany's cultural and intellectual achievements.

- @game_over

@z_victory

The Center Party's candidate becomes president, strengthening Catholic political power.

- @game_over

@bvp_victory

The Bavarian People's Party achieves a surprising victory, with regional interests now in the presidency.

- @game_over

@sapd_victory

The SAPD achieves an unexpected victory! The socialist split has paid off.

- @game_over

@nazis_lose

The Nazis have been defeated. The far-right coalition collapses into infighting and bankruptcy. Democracy survives another challenge.

- @game_over

@game_over
