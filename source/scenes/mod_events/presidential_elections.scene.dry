title: Presidential Election
subtitle: The presidential term has ended
new-page: true
view-if: (year = next_presidential_election_year and month >= next_presidential_election_month) or (year > next_presidential_election_year)
on-arrival: presidential_election_active = 1; round = 0; last_presidential_election = year; hindenburg_running = 1 if not hindenburg_dead; hindenburg_running = 0 if hindenburg_dead
max-visits: 999
tags: event
face-image: img/reichstag_2.jpg

= Presidential Election

[? if president : The term of President [+ president +] has ended. ?][? if not president : Germany requires a new president. ?]

Presidential elections will be held. If no candidate receives a majority in the first round, the top two candidates will advance to a runoff election.

All major parties are preparing their candidates for the race.

- @party_candidates: Who are the candidates?

@party_candidates
on-arrival: {!

    // Calculate conservative unity strength if it forms
    if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
        Q.conservative_unity_estimate = (Q.z_r || 0) + (Q.dnvp_r || 0) + (Q.bvp_r || 0);
        
        if (Q.dvp_candidate === Q.z_dnvp_joint_candidate) {
            Q.conservative_unity_estimate += (Q.dvp_r || 0);
        }
        if (Q.wp_candidate === Q.z_dnvp_joint_candidate) {
            Q.conservative_unity_estimate += (Q.wp_r || 0);
        }
        if (Q.cnbl_candidate === Q.z_dnvp_joint_candidate) {
            Q.conservative_unity_estimate += (Q.cnbl_r || 0);
        }
        
        Q.conservative_unity_estimate = Math.round(Q.conservative_unity_estimate * 10) / 10;
    }


    // ========================================
    // HELPER FUNCTION: Get relation between two parties
    // ========================================
    function getRelation(party1, party2) {
        if (!Q.party_relations[party1] || !Q.party_relations[party1][party2]) {
            return 0;
        }
        return Q.party_relations[party1][party2];
    }
    
    // ========================================
    // HELPER FUNCTION: Check if party would support candidate
    // ========================================
    function wouldSupport(party, candidate_party, threshold) {
        threshold = threshold || 40; // Default threshold
        var relation = getRelation(party, candidate_party);
        return relation >= threshold;
    }

    // === INITIALIZE VARIABLES ===
    Q.is_unity_candidate = 0;
    Q.is_cultural_candidate = 0;
    
    // Reset all candidate variables
    var all_candidates = [
    "Hitler", "Göring", "Goring", "Goebbels", "Seldte", "Westarp", "Treviranus", 
    "Lambach", "Lindeiner", "Hugenberg", "Eckener", "Adenauer", "Kaas", "Brüning", 
    "Bruning", "Gessler", "Stresemann", "Scholz", "Dingeldey", "Curtius", "Reinhold",
    "Thälmann", "Thalmann", "Münzenberg", "Munzenberg", "Braun", "Schumacher", 
    "Juchacz", "Einstein", "Mann", "Ossietzky", "Rosenfeld", "Schäffer", "Schaffer", 
    "Drewitz", "Horsing", "Hamkens", "Behrens", "Lemmer", "Heuss", "Dietrich", 
    "Lüders", "Mahraun", "Koch-Weser", "Maier" , "Schmid", "Lambach_2", "Hindenburg", "Ollenhauer", "Graefe", "Ludendorff", "Noske"
];
    for (var i = 0; i < all_candidates.length; i++) {
        Q[all_candidates[i] + '_bonus'] = 0;
        Q[all_candidates[i] + '_running'] = 0;
    }
    
    // ========================================
    // NSDAP (NAZIS)
    // ========================================
    if (Q.nsdap_banned) {
        Q.nsdap_candidate = null;
    } else if (Q.hitler_dead) {
        Q.nsdap_candidate = "Goebbels";
    } else if (Q.hitler_deported) {
        Q.nsdap_candidate = "Göring";
    } else {
        Q.nsdap_candidate = "Hitler";
    }

    // ========================================
    // SPECIAL: Z-DNVP JOINT CANDIDATE
    // ========================================
    Q.z_dnvp_joint_possible = 0;
    Q.z_dnvp_joint_candidate = null;

    if (!Q.dnvp_banned && (Q.dnvp_line === 1 || Q.dnvp_line === 0 || Q.dnvp_line === 2)) {
        // DNVP is moderate/traditional, not Hugenberg radicals
    
        var z_dnvp_relation = getRelation("Z", "DNVP");
        var dnvp_z_relation = getRelation("DNVP", "Z");
        var z_bvp_relation = getRelation("Z", "BVP");
    
        if (z_dnvp_relation >= 40 && dnvp_z_relation >= 40 && z_bvp_relation >= 70) {
            // Good mutual relations between conservative parties
        
            if ((Q.nsdap_r >= 20 || Q.kpd_r >= 12) && Q.year >= 1930) {
                // Extremist threat is severe - conservatives unite
                Q.z_dnvp_joint_possible = 1;
            
                // Determine the joint candidate based on party strength and leadership
                if (Q.z_party_leader === "Kaas" && Q.dnvp_line === 0) {
                    // Both right-wing - pick based on strength
                    if (Q.z_r >= Q.dnvp_r) {
                        Q.z_dnvp_joint_candidate = "Kaas";
                    } else {
                        Q.z_dnvp_joint_candidate = "Westarp";
                    }
                } else if (Q.z_party_leader === "Brüning" || Q.z_party_leader === "Bruning") {
                    // Brüning as technocratic unity candidate
                    Q.z_dnvp_joint_candidate = "Brüning";
                } else if (Q.dnvp_line === 1) {
                    // Democratic DNVP - Westarp leads
                    Q.z_dnvp_joint_candidate = "Westarp";
                } else if (Q.bvp_r >= 3 && Q.z_r >= Q.dnvp_r) {
                    // Strong Catholic bloc - BVP candidate
                    Q.z_dnvp_joint_candidate = "Schäffer";
                } else {
                    // Default: Adenauer as consensus builder
                    Q.z_dnvp_joint_candidate = "Adenauer";
                }
            }
        }
    }





    // ========================================
    // Z (CENTER PARTY)
    // ========================================
    if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
        // Joint conservative candidate takes priority
        Q.z_candidate = Q.z_dnvp_joint_candidate;
        Q.z_default_candidate = Q.z_dnvp_joint_candidate;
    } else if (Q.z_party_leader === "Kaas") {
        Q.z_default_candidate = "Kaas";
    } else if (Q.z_party_leader === "Joos") {
        Q.z_default_candidate = "Adenauer";
    } else if (Q.z_party_leader === "Brüning" || Q.z_party_leader === "Bruning") {
        Q.z_default_candidate = "Brüning";
    } else {
        Q.z_default_candidate = "Adenauer";
    }
    Q.z_candidate = null; // Will finalize after SPD

    // ========================================
    // BVP (BAVARIAN PEOPLE'S PARTY)
    // ========================================
    if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
        // BVP automatically joins Z-DNVP conservative coalition
        Q.bvp_default_candidate = Q.z_dnvp_joint_candidate;
        Q.bvp_candidate = null; // Will finalize after SPD
    } else {
        Q.bvp_default_candidate = "Schäffer";
        Q.bvp_candidate = null;
    }

    // ========================================
    // CSRP (CHRISTIAN SOCIAL REICH PARTY)
    // ========================================
    Q.csrp_default_candidate = Q.z_default_candidate;
    Q.csrp_candidate = null;








    // ========================================
    // DNVP (NATIONALISTS)
    // ========================================
    if (Q.dnvp_banned) {
        Q.dnvp_candidate = null;
    } else if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
        // Join the conservative unity ticket
        Q.dnvp_candidate = Q.z_dnvp_joint_candidate;
    } else {
        // DNVP candidate depends on internal faction control
    
        if (Q.dnvp_line === 1) {
            // MODERATE/CONSTITUTIONAL DNVP (Westarp faction)
            // Committed to parliamentary democracy
            Q.dnvp_candidate = "Westarp";
        
        } else if (Q.dnvp_line === 0) {
            // TRADITIONAL CONSERVATIVE DNVP (Pre-Hugenberg consensus)
            // Old guard conservatives, not yet radicalized
        
            if (Q.dnvp_party_leader === "Westarp") {
                Q.dnvp_candidate = "Westarp";
            } else if (Q.dnvp_party_leader === "Treviranus") {
                Q.dnvp_candidate = "Treviranus";
            } else if (Q.dnvp_party_leader === "Lambach") {
                Q.dnvp_candidate = "Lambach";
            } else if (Q.dnvp_party_leader === "Lindeiner-Wildau") {
                Q.dnvp_candidate = "Lindeiner";
            } else {
                // Default traditional conservative
                Q.dnvp_candidate = "Treviranus";
            }
        
        } else if (Q.dnvp_line === 2) {
            // MODERATE NATIONALIST (Post-split compromise)
            // Westarp returns to leadership after Hugenberg crisis
            Q.dnvp_candidate = "Westarp";
        
        } else if (Q.dnvp_line === 3) {
            // HUGENBERG DNVP (Far-right/proto-fascist)
            // Will support or merge with Nazis
        
            if (Q.nsdap_banned) {
                // Nazis banned - DNVP runs own far-right candidate
                Q.dnvp_candidate = "Hugenberg";
            } else if (Q.hitler_dead) {
                // Hitler dead - DNVP might lead far-right
                if (Q.dnvp_relation_nsdap >= 70) {
                    Q.dnvp_candidate = "Goebbels"; // Support remaining Nazi leadership
                } else {
                    Q.dnvp_candidate = "Hugenberg";
                }
            } else if (Q.hitler_deported) {
                // Hitler deported - DNVP backs Göring
                Q.dnvp_candidate = "Göring";
            } else {
                // Normal Hugenberg DNVP - supports Hitler
                Q.dnvp_candidate = "Hitler";
            }
        
        } else {
            // FALLBACK (shouldn't happen, but just in case)
            Q.dnvp_candidate = "Seldte";
        }
    }








    // ========================================
    // KPD (COMMUNISTS)
    // ========================================
    if (Q.kpd_banned) {
        Q.kpd_candidate = null;
    } else if (Q.kpd_party_leader === "Conciliators") {
        Q.kpd_candidate = "Münzenberg";
    } else {
        Q.kpd_candidate = "Thälmann";
    }
    
    // ========================================
    // DVP (PEOPLE'S PARTY)
    // ========================================
    if (!Q.stresemann_dead && Q.year <= 1929) {
        // Stresemann is alive - he runs
        Q.dvp_candidate = "Stresemann";
        Q.dvp_default_candidate = "Stresemann";
    } else {
        // POST-STRESEMANN DVP - Multiple factions compete
    
        if (Q.dvp_party_leader === "Scholz") {
            // Ernst Scholz - right-liberal, business-oriented
            if (Q.dvp_right_shift >= 2 || Q.capital_strike_progress >= 3) {
                // Right-shifted or crisis - support conservatives
                if (Q.dnvp_line === 1 && Q.dnvp_relation >= 50) {
                    Q.dvp_candidate = "Westarp";
                    Q.dvp_default_candidate = "Westarp";
                } else {
                    Q.dvp_candidate = "Scholz";
                    Q.dvp_default_candidate = "Scholz";
                }
            } else if (Q.dvp_relation >= 50 && Q.in_grand_coalition) {
                // In grand coalition with good SPD relations
                Q.dvp_candidate = null; // Wait for SPD
                Q.dvp_default_candidate = null;
            } else {
                // Independent liberal
                Q.dvp_candidate = "Gessler";
                Q.dvp_default_candidate = "Gessler";
            }
        
        } else if (Q.dvp_party_leader === "Dingeldey") {
            // Eduard Dingeldey - centrist, pragmatic
            if (Q.z_relation >= 45 && Q.dvp_relation >= 40) {
                // Strong coalition ties - wait or join unity
                Q.dvp_candidate = null;
                Q.dvp_default_candidate = "Gessler";
            } else if (Q.dvp_right_shift >= 1) {
                Q.dvp_candidate = "Dingeldey";
                Q.dvp_default_candidate = "Dingeldey";
            } else {
                Q.dvp_candidate = "Gessler";
                Q.dvp_default_candidate = "Gessler";
            }
        
        } else if (Q.dvp_party_leader === "Curtius") {
            // Julius Curtius - moderate, pro-republic
            if (Q.dvp_relation >= 45 || Q.in_grand_coalition) {
                // Pro-coalition - wait for SPD
                Q.dvp_candidate = null;
                Q.dvp_default_candidate = null;
            } else {
                Q.dvp_candidate = "Curtius";
                Q.dvp_default_candidate = "Curtius";
            }
        
        } else if (Q.finance_minister === "Reinhold" && Q.economic_policy_seen) {
            // Peter Reinhold (Finance Minister) - technocratic liberal
            Q.dvp_candidate = "Reinhold";
            Q.dvp_default_candidate = "Reinhold";
        
        } else {
        // POST-STRESEMANN DVP
        
        // Check if DVP joins conservative unity ticket
        if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
            // DVP considers joining based on several factors
            
            if (Q.dvp_right_shift >= 2 && Q.dnvp_relation >= 40) {
                // Right-shifted DVP naturally joins conservative bloc
                Q.dvp_candidate = Q.z_dnvp_joint_candidate;
                Q.dvp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.z_relation >= 50 && Q.dnvp_line === 1) {
                // Good Z relations + democratic DNVP = join unity ticket
                Q.dvp_candidate = Q.z_dnvp_joint_candidate;
                Q.dvp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.in_grand_coalition && Q.dnvp_line === 1 && Q.nsdap_r >= 25) {
                // In grand coalition, Nazis very strong, DNVP democratic - join for stability
                Q.dvp_candidate = Q.z_dnvp_joint_candidate;
                Q.dvp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.dvp_relation >= 50) {
                // Good SPD relations - wait to see what SPD does
                Q.dvp_candidate = null;
                Q.dvp_default_candidate = null;
                
            } else {
                // DVP stays independent liberal
                Q.dvp_candidate = "Gessler";
                Q.dvp_default_candidate = "Gessler";
            }
            
        } else {
            // No joint ticket - normal DVP logic
            
            if (Q.dvp_right_shift >= 2) {
                if (Q.dnvp_line === 1 && Q.dnvp_relation >= 50) {
                    Q.dvp_candidate = "Westarp";
                    Q.dvp_default_candidate = "Westarp";
                } else {
                    Q.dvp_candidate = "Gessler";
                    Q.dvp_default_candidate = "Gessler";
                }
            } else if (Q.dvp_relation >= 50) {
                Q.dvp_candidate = null;
                Q.dvp_default_candidate = null;
            } else {
                Q.dvp_candidate = "Gessler";
                Q.dvp_default_candidate = "Gessler";
            }
        }
    }
    }




    
    // ========================================
    // DDP/DStP (DEMOCRATS)
    // ========================================
    if (Q.ddp_name === "DStP") {
        // STATE PARTY (DStP) - more nationalist-liberal
        if (Q.jungdo_strength >= 300 && Q.year >= 1930) {
            // Jungdo influence strong - Arthur Mahraun (Jungdo leader)
            Q.ddp_own_candidate = "Mahraun";
        } else if (Q.ddp_party_leader === "Koch-Weser" || !Q.ddp_party_leader) {
            // Koch-Weser faction (centrist liberal)
            Q.ddp_own_candidate = "Koch-Weser";
        } else if (Q.ddp_party_leader === "Maier") {
            // Reinhold Maier (southwestern liberal)
            Q.ddp_own_candidate = "Maier";
        } else if (Q.economic_democracy >= 2 || Q.reformist_strength >= 50) {
            // Hermann Lüders (left-liberal, economic reformer)
            Q.ddp_own_candidate = "Lüders";
        } else {
            // Default - Koch-Weser
            Q.ddp_own_candidate = "Koch-Weser";
        }
        
        // DStP decision logic
        if (Q.ddp_relation >= 55) {
            // Excellent SPD relations - will wait for SPD choice
            Q.ddp_candidate = null;
            Q.ddp_default_candidate = null;
        } else {
            // Run own candidate
            Q.ddp_candidate = Q.ddp_own_candidate;
            Q.ddp_default_candidate = Q.ddp_own_candidate;
        }
        
    } else {
        // CLASSIC DDP (Democratic Party) - progressive liberals
        if (Q.womens_rights >= 4 && Q.pro_republic > 80 && Q.nationalism < 20) {
            // Marie-Elisabeth Lüders (women's rights champion)
            Q.ddp_own_candidate = "Lüders";
        } else if (Q.ddp_party_leader === "Dietrich" || Q.finance_minister === "Dietrich") {
            // Hermann Dietrich (agrarian liberal, finance expert)
            Q.ddp_own_candidate = "Dietrich";
        } else if (Q.ddp_party_leader === "Heuss") {
            // Theodor Heuss (cultural liberal, intellectual)
            Q.ddp_own_candidate = "Heuss";
        } else if (Q.rb_strength >= 800 && Q.rb_militancy > 0.30 && Q.year >= 1932) {
            // Ernst Lemmer (Reichsbanner liberal, militant democrat)
            Q.ddp_own_candidate = "Lemmer";
        } else {
            // Default - Heuss (most prominent)
            Q.ddp_own_candidate = "Heuss";
        }
        
        // Classic DDP decision logic
        if (Q.ddp_relation >= 45) {
            // Good SPD relations - will wait for SPD choice
            Q.ddp_candidate = null;
            Q.ddp_default_candidate = null;
        } else {
            // Run own candidate or Gessler as unity liberal
            if (Q.dvp_candidate === "Gessler" || Q.z_relation >= 35) {
                // Liberal unity with DVP or coalition potential
                Q.ddp_candidate = "Gessler";
                Q.ddp_default_candidate = "Gessler";
            } else {
                // Independent DDP candidate
                Q.ddp_candidate = Q.ddp_own_candidate;
                Q.ddp_default_candidate = Q.ddp_own_candidate;
            }
        }
    }


    // WP (ECONOMIC PARTY)
    // ========================================
    if (Q.wp_r && Q.wp_r > 2) {
        // WP is large enough to have its own candidate considerations
        
        if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
            // Conservative unity ticket exists
            
            if (Q.capital_strike_progress >= 5 || Q.inflation >= 6 || Q.unemployed >= 15) {
                // Severe economic crisis - WP runs protest candidate
                Q.wp_candidate = "Drewitz";
                Q.wp_default_candidate = "Drewitz";
                
            } else if (Q.dnvp_relation >= 45 && Q.z_relation >= 35 && Q.economic_minister_party === "WP") {
                // In government with conservatives - join unity ticket
                Q.wp_candidate = Q.z_dnvp_joint_candidate;
                Q.wp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.dvp_candidate === Q.z_dnvp_joint_candidate && Q.dvp_relation >= 45) {
                // DVP joined, WP follows liberal allies
                Q.wp_candidate = Q.z_dnvp_joint_candidate;
                Q.wp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.nsdap_r >= 30 && (Q.dnvp_line === 1 || Q.dnvp_line === 2)) {
                // Nazi threat extreme, moderate DNVP - join unity for stability
                Q.wp_candidate = Q.z_dnvp_joint_candidate;
                Q.wp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.dvp_candidate && Q.dvp_relation >= 40) {
                // Follow DVP (natural liberal allies)
                Q.wp_candidate = Q.dvp_candidate;
                Q.wp_default_candidate = Q.dvp_candidate;
                
            } else {
                // Independent middle-class candidate
                Q.wp_candidate = "Drewitz";
                Q.wp_default_candidate = "Drewitz";
            }
            
        } else {
            // No joint ticket - normal WP logic
            
            if (Q.capital_strike_progress >= 5 || Q.inflation >= 6 || Q.unemployed >= 15) {
                Q.wp_candidate = "Drewitz";
                Q.wp_default_candidate = "Drewitz";
            } else if (Q.dvp_candidate && Q.dvp_relation >= 40) {
                Q.wp_candidate = Q.dvp_candidate;
                Q.wp_default_candidate = Q.dvp_candidate;
            } else {
                Q.wp_candidate = "Drewitz";
                Q.wp_default_candidate = "Drewitz";
            }
        }
    } else {
        // Too small - fold into DVP or conservatives
        if (Q.dvp_candidate) {
            Q.wp_candidate = Q.dvp_candidate;
            Q.wp_default_candidate = Q.dvp_candidate;
        } else if (Q.z_dnvp_joint_candidate) {
            Q.wp_candidate = Q.z_dnvp_joint_candidate;
            Q.wp_default_candidate = Q.z_dnvp_joint_candidate;
        } else {
            Q.wp_candidate = "Gessler";
            Q.wp_default_candidate = "Gessler";
        }
    }
    
    // ========================================
    // CNBL (AGRARIAN PARTY)
    // ========================================
    if (Q.cnbl_r && Q.cnbl_r > 1.5) {
        // CNBL is large enough to be relevant
        
        if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
            // Conservative unity ticket exists
            
            if (Q.agricultural_finance < 2 || Q.land_reform >= 2) {
                // Agricultural crisis or hostile policy - protest candidate
                Q.cnbl_candidate = "Hamkens";
                Q.cnbl_default_candidate = "Hamkens";
                
            } else if (Q.dnvp_relation >= 50 && Q.dnvp_line !== 3) {
                // Strong DNVP ties, moderate DNVP - join unity
                Q.cnbl_candidate = Q.z_dnvp_joint_candidate;
                Q.cnbl_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.bvp_candidate === Q.z_dnvp_joint_candidate && Q.bvp_relation >= 40) {
                // BVP in unity ticket, good relations - Catholic agrarian solidarity
                Q.cnbl_candidate = Q.z_dnvp_joint_candidate;
                Q.cnbl_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.z_relation >= 45 && Q.agricultural_minister_party === "Z") {
                // Z controls agriculture ministry and in unity ticket - join
                Q.cnbl_candidate = Q.z_dnvp_joint_candidate;
                Q.cnbl_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else if (Q.nsdap_r >= 25 && Q.rural_nsdap_support < 15) {
                // Nazis strong but not in countryside - join anti-Nazi unity
                Q.cnbl_candidate = Q.z_dnvp_joint_candidate;
                Q.cnbl_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else {
                // Independent agrarian
                Q.cnbl_candidate = "Hamkens";
                Q.cnbl_default_candidate = "Hamkens";
            }
            
        } else {
            // No joint ticket - normal CNBL logic
            
            if (Q.agricultural_finance < 2 || Q.land_reform >= 2) {
                Q.cnbl_candidate = "Hamkens";
                Q.cnbl_default_candidate = "Hamkens";
            } else if (Q.dnvp_candidate && Q.dnvp_line !== 3 && !Q.dnvp_banned && Q.dnvp_relation >= 40) {
                Q.cnbl_candidate = Q.dnvp_candidate;
                Q.cnbl_default_candidate = Q.dnvp_candidate;
            } else if (Q.dnvp_line === 3 && !Q.nsdap_banned && Q.year >= 1932) {
                Q.cnbl_candidate = Q.nsdap_candidate;
                Q.cnbl_default_candidate = Q.nsdap_candidate;
            } else {
                Q.cnbl_candidate = "Hamkens";
                Q.cnbl_default_candidate = "Hamkens";
            }
        }
    } else {
        // Too small - fold into conservative bloc
        if (!Q.dnvp_banned && Q.dnvp_candidate) {
            Q.cnbl_candidate = Q.dnvp_candidate;
            Q.cnbl_default_candidate = Q.dnvp_candidate;
        } else if (Q.z_dnvp_joint_candidate) {
            Q.cnbl_candidate = Q.z_dnvp_joint_candidate;
            Q.cnbl_default_candidate = Q.z_dnvp_joint_candidate;
        } else {
            Q.cnbl_candidate = Q.bvp_default_candidate;
            Q.cnbl_default_candidate = Q.bvp_default_candidate;
        }
    }

    // ========================================
    // CSVD (CHRISTIAN-SOCIAL PEOPLE'S SERVICE)
    // ========================================
    if (Q.csvd_flee === 1) {
        // CSVD only exists if it split from DNVP
    
        // CSVD's behavior depends heavily on DNVP's line
    
        // === SCENARIO 1: Z-DNVP CONSERVATIVE UNITY TICKET ===
        if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate && Q.dnvp_line !== 3) {
            // Conservative unity ticket exists AND DNVP is moderate
            // CSVD automatically joins - this is their ideal scenario
            Q.csvd_candidate = Q.z_dnvp_joint_candidate;
            Q.csvd_default_candidate = Q.z_dnvp_joint_candidate;
            
        // === SCENARIO 2: MODERATE DNVP EXISTS (but no unity ticket) ===
        } else if (Q.dnvp_line === 1 || Q.dnvp_line === 2) {
            // DNVP is moderate/constitutional - CSVD allies with them
        
            if (Q.dnvp_candidate && Q.dnvp_candidate !== "Hitler" && Q.dnvp_candidate !== "Hugenberg") {
                // Support moderate DNVP candidate
                Q.csvd_candidate = Q.dnvp_candidate;
                Q.csvd_default_candidate = Q.dnvp_candidate;
            
            } else if (Q.z_candidate && Q.z_candidate !== Q.spd_candidate) {
                // If DNVP has no good candidate, support Center
                Q.csvd_candidate = Q.z_candidate;
                Q.csvd_default_candidate = Q.z_candidate;
            
            } else if (Q.dvp_candidate && Q.dvp_candidate !== Q.spd_candidate) {
                // Or support liberal DVP
                Q.csvd_candidate = Q.dvp_candidate;
                Q.csvd_default_candidate = Q.dvp_candidate;
            
            } else {
                // Independent moderate conservative
                Q.csvd_candidate = "Lambach_2"; // CSVD's own figure
                Q.csvd_default_candidate = "Lambach_2";
            }
        
        // === SCENARIO 3: HUGENBERG DNVP (Line 3) - CSVD OPPOSES ===
        } else if (Q.dnvp_line === 3) {
            // DNVP is radicalized under Hugenberg
            // CSVD exists BECAUSE of this - they will NOT support Hugenberg or Hitler
        
            if (Q.nsdap_r >= 35 && Q.kpd_r >= 15) {
                // EXTREME CRISIS - Both extremes very strong
                // CSVD might even work with moderate left to stop Nazis
            
                if (Q.z_candidate && Q.z_candidate !== "Hitler" && Q.z_candidate !== Q.kpd_candidate) {
                    // Support Center (safest bet)
                    Q.csvd_candidate = Q.z_candidate;
                    Q.csvd_default_candidate = Q.z_candidate;
                
                } else if (Q.dvp_candidate && Q.dvp_candidate !== "Hitler") {
                    // Support liberals
                    Q.csvd_candidate = Q.dvp_candidate;
                    Q.csvd_default_candidate = Q.dvp_candidate;
                
                } else if (Q.spd_candidate && Q.spd_candidate !== Q.kpd_candidate && Q.pro_republic >= 70) {
                    // DESPERATE: Support SPD to stop Hitler
                    // (Only if SPD hasn't allied with KPD and republic is strong)
                    Q.csvd_candidate = Q.spd_candidate;
                    Q.csvd_default_candidate = Q.spd_candidate;
                
                } else {
                    // Run own candidate as Protestant moderate alternative
                    Q.csvd_candidate = "Lambach2";
                    Q.csvd_default_candidate = "Lambach2";
                }
            
            } else if (Q.nsdap_r >= 25) {
                // NAZI THREAT SERIOUS but not overwhelming
                // CSVD positions as Protestant anti-Nazi option
            
                if (Q.z_candidate && Q.z_candidate !== "Hitler") {
                    // Join with Center against Nazis
                    Q.csvd_candidate = Q.z_candidate;
                    Q.csvd_default_candidate = Q.z_candidate;
                
                } else if (Q.bvp_candidate && Q.bvp_candidate !== "Hitler") {
                    // Even work with BVP (fellow Christian party)
                    Q.csvd_candidate = Q.bvp_candidate;
                    Q.csvd_default_candidate = Q.bvp_candidate;
                
                } else if (Q.dvp_candidate && Q.dvp_candidate !== "Hitler") {
                    // Or liberals
                    Q.csvd_candidate = Q.dvp_candidate;
                    Q.csvd_default_candidate = Q.dvp_candidate;
                
                } else {
                    // Independent Protestant conservative
                    Q.csvd_candidate = "Lambach2";
                    Q.csvd_default_candidate = "Lambach2";
                }
            
            } else {
                // Nazis not overwhelming yet - CSVD can be independent
                Q.csvd_candidate = "Lambach2";
                Q.csvd_default_candidate = "Lambach2";
            }
        
        // === SCENARIO 4: TRADITIONAL DNVP (Line 0) ===
        } else if (Q.dnvp_line === 0) {
            // Traditional conservative DNVP
            // CSVD may or may not have split yet - if they have, they're wary
        
            if (Q.year >= 1930 && Q.nsdap_r >= 15) {
                // Nazis rising - CSVD wants to distinguish itself
            
                if (Q.z_candidate) {
                    // Prefer Center over DNVP
                    Q.csvd_candidate = Q.z_candidate;
                    Q.csvd_default_candidate = Q.z_candidate;
                
                } else if (Q.dvp_candidate) {
                    // Or DVP
                    Q.csvd_candidate = Q.dvp_candidate;
                    Q.csvd_default_candidate = Q.dvp_candidate;
                
                } else if (Q.dnvp_candidate && Q.dnvp_candidate !== "Hitler") {
                    // Reluctantly support DNVP
                    Q.csvd_candidate = Q.dnvp_candidate;
                    Q.csvd_default_candidate = Q.dnvp_candidate;
                
                } else {
                    Q.csvd_candidate = "Lambach2";
                    Q.csvd_default_candidate = "Lambach2";
                }
            
            } else {
                // Early period or low Nazi threat - CSVD still allies with DNVP
                if (Q.dnvp_candidate) {
                    Q.csvd_candidate = Q.dnvp_candidate;
                    Q.csvd_default_candidate = Q.dnvp_candidate;
                } else {
                    Q.csvd_candidate = "Lambach2";
                    Q.csvd_default_candidate = "Lambach2";
                }
            }
        
        // === FALLBACK ===
        } else {
            // Default: Independent Protestant conservative
            Q.csvd_candidate = "Lambach2";
            Q.csvd_default_candidate = "Lambach2";
        }
    
    } else {
        // CSVD doesn't exist yet
        Q.csvd_candidate = null;
        Q.csvd_default_candidate = null;
    }

// ========================================
    // VRP (VOLKSRECHTPARTEI)
    // ========================================
    if (Q.vrp_votes > 0.2) {
        
        // VRP's mood depends on economic misery and revaluation progress
        var vrp_desperate = Q.inflation >= 5 || Q.unemployed >= 20 || Q.economy_growth <= -3;
        var vrp_anxious   = Q.inflation >= 3 || Q.unemployed >= 12 || Q.economy_growth <= -1;
        
        if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
            // Conservative unity ticket exists
            
            if (vrp_desperate) {
                // Economic crisis has radicalized savers - protest candidate
                Q.vrp_candidate = "Böhm";
                Q.vrp_default_candidate = "Böhm";
                
            } else if (Q.dnvp_line !== 3 && Q.ddp_relation >= 40 && Q.dvp_relation < 35) {
                // Moderate DNVP in ticket, good DDP ties, DVP hostile (inflation profiteers)
                // VRP joins if DDP is also in
                if (Q.ddp_candidate === Q.z_dnvp_joint_candidate) {
                    Q.vrp_candidate = Q.z_dnvp_joint_candidate;
                    Q.vrp_default_candidate = Q.z_dnvp_joint_candidate;
                } else {
                    // DDP not in - VRP follows DDP, not unity ticket
                    Q.vrp_candidate = Q.ddp_candidate || "Böhm";
                    Q.vrp_default_candidate = Q.ddp_candidate || "Böhm";
                }
                
            } else if (Q.dnvp_line === 3) {
                // Hugenberg DNVP in ticket - VRP will not touch it
                // Too radical, too volkisch, not about legal restitution
                Q.vrp_candidate = Q.ddp_candidate || "Böhm";
                Q.vrp_default_candidate = Q.ddp_candidate || "Böhm";
                
            } else if (Q.dvp_candidate === Q.z_dnvp_joint_candidate && Q.ddp_candidate === Q.z_dnvp_joint_candidate) {
                // Both liberal parties joined - VRP follows
                Q.vrp_candidate = Q.z_dnvp_joint_candidate;
                Q.vrp_default_candidate = Q.z_dnvp_joint_candidate;
                
            } else {
                // Unclear - VRP prefers DDP over unity ticket
                Q.vrp_candidate = Q.ddp_candidate || "Böhm";
                Q.vrp_default_candidate = Q.ddp_candidate || "Böhm";
            }
            
        } else {
            // No unity ticket - normal VRP logic
            
            if (vrp_desperate) {
                // Desperation: protest candidate, voters hemorrhaging to NSDAP
                Q.vrp_candidate = "Böhm";
                Q.vrp_default_candidate = "Böhm";
                
            } else if (vrp_anxious) {
                // Anxious: follow DDP if possible, otherwise own candidate
                if (Q.ddp_candidate && Q.ddp_relation >= 35) {
                    Q.vrp_candidate = Q.ddp_candidate;
                    Q.vrp_default_candidate = Q.ddp_candidate;
                } else {
                    Q.vrp_candidate = "Böhm";
                    Q.vrp_default_candidate = "Böhm";
                }
                
            } else {
                // Stable economy: VRP acts like cooperative liberal party
                // Follows DDP first, then CSVD (shared Protestant saver base)
                // Never follows WP (direct rival - inflation winners)
                if (Q.ddp_candidate && Q.ddp_relation >= 40) {
                    Q.vrp_candidate = Q.ddp_candidate;
                    Q.vrp_default_candidate = Q.ddp_candidate;
                    
                } else if (Q.csvd_flee === 1 && Q.csvd_candidate && Q.csvd_relation >= 40) {
                    Q.vrp_candidate = Q.csvd_candidate;
                    Q.vrp_default_candidate = Q.csvd_candidate;
                    
                } else if (Q.dvp_candidate && Q.dvp_right_shift < 1 && Q.dvp_relation >= 35) {
                    // DVP acceptable only if not yet captured by heavy industry right
                    Q.vrp_candidate = Q.dvp_candidate;
                    Q.vrp_default_candidate = Q.dvp_candidate;
                    
                } else {
                    Q.vrp_candidate = "Böhm";
                    Q.vrp_default_candidate = "Böhm";
                }
            }
        }
        
    } else {
        Q.vrp_candidate = null;
        Q.vrp_default_candidate = null;
    }
    
    // ========================================
    // SAPD (SOCIALIST WORKERS' PARTY)
    // ========================================
    if (Q.sapd_formed) {
        if (Q.kpd_relation >= 60 && Q.spd_sapd_relation < 40 && !Q.kpd_banned) {
            // Close to KPD, distant from SPD
            Q.sapd_candidate = Q.kpd_candidate;
        } else {
            // Independent left-socialist
            Q.sapd_candidate = "Rosenfeld";
        }
    } else {
        Q.sapd_candidate = null;
    }
    
    // ========================================
    // SRPD (SOCIAL REPUBLICANS)
    // ========================================
    if (Q.srpd_formed) {
        if (Q.srpd_relation >= 60) {
            // Very close to SPD - will likely follow
            Q.srpd_candidate = null; // Wait for SPD
        } else {
            // Independent social republican
            Q.srpd_candidate = "Horsing";
        }
    } else {
        Q.srpd_candidate = null;
    }

// ========================================
    // KVP (CONSERVATIVE PEOPLE'S PARTY)
    // ========================================
    if (Q.kvp_flee === 1 && !Q.kvp_banned) {
        // KVP exists only as DNVP splinter under Hugenberg
        // Their natural candidate is always a moderate conservative
        if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate && Q.dnvp_line !== 3) {
            // Join conservative unity - this is ideal for KVP
            Q.kvp_candidate = Q.z_dnvp_joint_candidate;
            Q.kvp_default_candidate = Q.z_dnvp_joint_candidate;
        } else if (Q.dnvp_candidate && Q.dnvp_candidate !== "Hitler" 
                   && Q.dnvp_candidate !== "Hugenberg" && Q.dnvp_line !== 3) {
            // Support moderate DNVP candidate
            Q.kvp_candidate = Q.dnvp_candidate;
            Q.kvp_default_candidate = Q.dnvp_candidate;
        } else if (Q.csvd_candidate && Q.csvd_candidate !== "Hitler") {
            // Fellow DNVP splinter - natural ally
            Q.kvp_candidate = Q.csvd_candidate;
            Q.kvp_default_candidate = Q.csvd_candidate;
        } else if (Q.z_candidate) {
            // Fall back to Center as moderate conservative anchor
            Q.kvp_candidate = Q.z_default_candidate;
            Q.kvp_default_candidate = Q.z_default_candidate;
        } else {
            // Independent - Westarp is the obvious KVP figure
            Q.kvp_candidate = "Westarp";
            Q.kvp_default_candidate = "Westarp";
        }
    } else {
        Q.kvp_candidate = null;
        Q.kvp_default_candidate = null;
    }

    // ========================================
    // DHP (GERMAN HANNOVER PARTY)
    // ========================================
    if (!Q.dhp_banned) {
        // Protestant agrarian regionalists - anti-Prussian, vaguely conservative
        // Never support NSDAP or KPD
        // Natural home: moderate DNVP, CNBL, or CSVD
        if (Q.cnbl_candidate && Q.cnbl_candidate !== "Hitler" 
            && Q.cnbl_candidate !== "Hugenberg" && Q.cnbl_candidate !== Q.kpd_candidate) {
            // Agrarian solidarity - follow CNBL
            Q.dhp_candidate = Q.cnbl_candidate;
            Q.dhp_default_candidate = Q.cnbl_candidate;
        } else if (Q.dnvp_line !== 3 && Q.dnvp_candidate 
                   && Q.dnvp_candidate !== "Hitler" && !Q.dnvp_banned) {
            // Moderate DNVP acceptable
            Q.dhp_candidate = Q.dnvp_candidate;
            Q.dhp_default_candidate = Q.dnvp_candidate;
        } else if (Q.csvd_candidate && Q.csvd_candidate !== "Hitler") {
            // Fellow Protestant conservative
            Q.dhp_candidate = Q.csvd_candidate;
            Q.dhp_default_candidate = Q.csvd_candidate;
        } else if (Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate) {
            // Unity ticket if DNVP is moderate
            Q.dhp_candidate = Q.z_dnvp_joint_candidate;
            Q.dhp_default_candidate = Q.z_dnvp_joint_candidate;
        } else {
            // Independent - Hamkens as rural Protestant default
            Q.dhp_candidate = "Hamkens";
            Q.dhp_default_candidate = "Hamkens";
        }
    } else {
        Q.dhp_candidate = null;
        Q.dhp_default_candidate = null;
    }

    // ========================================
    // BB (BAVARIAN PEASANTS PARTY)
    // ========================================
    if (!Q.bb_banned) {
        // Agrarian populists, Catholic but not clericalist
        // More radical than BVP on farm issues, less tied to church
        var bb_crisis = Q.inflation < 0 || Q.unemployed >= 15;
        
        if (bb_crisis) {
            // Agricultural crisis - protest candidate, won't follow BVP establishment
            Q.bb_candidate = "Hamkens";
            Q.bb_default_candidate = "Hamkens";
        } else if (Q.bvp_candidate && Q.bvp_candidate !== "Hitler" 
                   && Q.bvp_candidate !== Q.kpd_candidate) {
            // Normal times - follow BVP as fellow Bavarian Catholics
            Q.bb_candidate = Q.bvp_candidate;
            Q.bb_default_candidate = Q.bvp_candidate;
        } else if (Q.cnbl_candidate && Q.cnbl_candidate !== "Hitler") {
            // Agrarian solidarity with CNBL
            Q.bb_candidate = Q.cnbl_candidate;
            Q.bb_default_candidate = Q.cnbl_candidate;
        } else if (Q.z_candidate && Q.z_candidate !== Q.kpd_candidate) {
            // Z as Catholic fallback
            Q.bb_candidate = Q.z_candidate;
            Q.bb_default_candidate = Q.z_candidate;
        } else {
            Q.bb_candidate = "Hamkens";
            Q.bb_default_candidate = "Hamkens";
        }
    } else {
        Q.bb_candidate = null;
        Q.bb_default_candidate = null;
    }
    
    // ========================================
    // OTHER (Minor parties/splinters)
    // ========================================
    if (!Q.dnvp_banned && Q.dnvp_candidate) {
        Q.other_candidate = Q.dnvp_candidate;
    } else if (!Q.nsdap_banned && Q.nsdap_candidate) {
        Q.other_candidate = Q.nsdap_candidate;
    } else {
        Q.other_candidate = "Gessler";
    }

    // ========================================
    // DVFP (VÖLKISCH FREEDOM PARTY)
    // ========================================
    if (Q.dvfp_banned) {
        Q.dvfp_candidate = null;
    } else if (!Q.nsdap_banned && !Q.hitler_dead && Q.nsdap_r >= 15) {
        // If Nazis are strong and Hitler is available, DVFP supports the 'Führer'
        // This represents the 1924-1925 NSFP era alignment.
        Q.dvfp_candidate = "Hitler";
        Q.dvfp_default_candidate = "Hitler";
    } else if (Q.dnvp_line === 3 && !Q.dnvp_banned) {
        // If DNVP is in its radical Hugenberg phase, DVFP aligns with them
        // against the "system" parties.
        Q.dvfp_candidate = "Hugenberg";
        Q.dvfp_default_candidate = "Hugenberg";
    } else if (Q.hitler_dead && !Q.nsdap_banned) {
        // Hitler is dead; DVFP tries to lead the völkisch movement or backs Göring
        Q.dvfp_candidate = "Ludendorff";
        Q.dvfp_default_candidate = "Ludendorff";
    } else {
        // Independent völkisch run
        // Graefe is the political leader, Ludendorff is the 'prestige' choice
        if (Q.unrest_factor >= 2.0 || Q.nationalism >= 60) {
            Q.dvfp_candidate = "Ludendorff";
            Q.dvfp_default_candidate = "Ludendorff";
        } else {
            Q.dvfp_candidate = "Graefe";
            Q.dvfp_default_candidate = "Graefe";
        }
    }

!}

