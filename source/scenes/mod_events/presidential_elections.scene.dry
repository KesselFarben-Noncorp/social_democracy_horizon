title: Presidential Election
subtitle: The presidential term has ended
new-page: true
view-if: (year = next_presidential_election_year and month >= next_presidential_election_month) or (year > next_presidential_election_year)
on-arrival: presidential_election_active = 1; round = 0; last_presidential_election = year; hindenburg_running = 1 if not hindenburg_dead; hindenburg_running = 0 if hindenburg_dead
max-visits: 999
tags: event
face-image: img/reichstag_2.jpg

= Presidential Election

[? if president : The term of President [+ president +] has ended. ?][? if not president : Germany requires a new president. ?]

Presidential elections will be held. If no candidate receives a majority in the first round, the top two candidates will advance to a runoff election.

All major parties are preparing their candidates for the race.

- @party_candidates: Who are the candidates?

@party_candidates
on-arrival: {!

// =====================================================================
// REGISTRY-DRIVEN ELECTION ENGINE
// ---------------------------------------------------------------------
// Everything about "who can run, for whom, and where they sit
// ideologically" lives in three tables below: CANDIDATES, PARTIES,
// and LEADER_PREFERENCE. To add a new candidate, party, or leader
// branch, add ONE row to ONE table here. Then mirror the candidate's
// name/party/bloc in the small CAND_INFO lookup that appears in
// @finalize_candidates, @post_r1, @r2_start, and @post_r2 (those blocks
// only need display info, not resolver logic).
// =====================================================================

var CANDIDATES = {
    Hindenburg: { name: "Paul von Hindenburg", party: "I",     bloc: "center" },
    Eckener:    { name: "Hugo Eckener",        party: "Unity", bloc: "center_left" },
    Gessler:    { name: "Otto Gessler",        party: "Liberal", bloc: "center_left" },
    Einstein:   { name: "Albert Einstein",     party: "Independent", bloc: "cultural" },
    Mann:       { name: "Heinrich Mann",       party: "Independent", bloc: "cultural" },
    Ossietzky:  { name: "Carl von Ossietzky",  party: "Independent", bloc: "cultural" },
    Hitler:     { name: "Adolf Hitler",        party: "NSDAP", bloc: "far_right" },
    Goring:     { name: "Hermann Göring",      party: "NSDAP", bloc: "far_right", aliases: ["Göring"] },
    Goebbels:   { name: "Joseph Goebbels",     party: "NSDAP", bloc: "far_right" },
    Westarp:    { name: "Kuno von Westarp",       party: "DNVP", bloc: "center_right" },
    Treviranus: { name: "Gottfried Treviranus",   party: "DNVP", bloc: "center_right" },
    Lambach:    { name: "Walter Lambach",         party: "DNVP", bloc: "center_right" },
    Lindeiner:  { name: "Hans von Lindeiner-Wildau", party: "DNVP", bloc: "center_right" },
    Hugenberg:  { name: "Alfred Hugenberg",       party: "DNVP", bloc: "far_right" },
    Seldte:     { name: "Franz Seldte",           party: "DNVP/Stahlhelm", bloc: "far_right" },
    Adenauer:   { name: "Konrad Adenauer",     party: "Z", bloc: "center" },
    Kaas:       { name: "Ludwig Kaas",         party: "Z", bloc: "center" },
    Bruning:    { name: "Heinrich Brüning",    party: "Z", bloc: "center", aliases: ["Brüning"] },
    Schaffer:   { name: "Franz Schäffer",      party: "BVP", bloc: "center_right", aliases: ["Schäffer"] },
    Stresemann: { name: "Gustav Stresemann",   party: "DVP", bloc: "center_left" },
    Scholz:     { name: "Ernst Scholz",        party: "DVP", bloc: "center_right" },
    Dingeldey:  { name: "Eduard Dingeldey",    party: "DVP", bloc: "center_right" },
    Curtius:    { name: "Julius Curtius",      party: "DVP", bloc: "center" },
    Reinhold:   { name: "Peter Reinhold",      party: "DVP", bloc: "center_left" },
    Heuss:      { name: "Theodor Heuss",       party: "DDP",  bloc: "center_left" },
    Dietrich:   { name: "Hermann Dietrich",    party: "DDP",  bloc: "center_left" },
    Luders:     { name: "Hermann Lüders",      party: "DDP",  bloc: "center_left", aliases: ["Lüders"] },
    Lemmer:     { name: "Ernst Lemmer",        party: "DDP",  bloc: "center_left" },
    Mahraun:    { name: "Arthur Mahraun",      party: "DStP/Jungdo", bloc: "center_right" },
    KochWeser:  { name: "Erich Koch-Weser",    party: "DStP", bloc: "center_left", aliases: ["Koch-Weser"] },
    Maier:      { name: "Reinhold Maier",      party: "DStP", bloc: "center_left" },
    Thalmann:   { name: "Ernst Thälmann",      party: "KPD", bloc: "far_left", aliases: ["Thälmann"] },
    Munzenberg: { name: "Willi Münzenberg",    party: "KPD", bloc: "far_left", aliases: ["Münzenberg"] },
    Braun:      { name: "Otto Braun",          party: "SPD", bloc: "left" },
    Schumacher: { name: "Kurt Schumacher",     party: "SPD", bloc: "left" },
    Schmid:     { name: "Carlo Schmid",        party: "SPD (Reformist)", bloc: "center_left" },
    Ollenhauer: { name: "Erich Ollenhauer",    party: "SPD (Left)", bloc: "left" },
    Juchacz:    { name: "Marie Juchacz",       party: "SPD", bloc: "left" },
    Noske:      { name: "Gustav Noske",        party: "SPD (Right)", bloc: "center" },
    Rosenfeld:  { name: "Kurt Rosenfeld",      party: "SAPD", bloc: "far_left" },
    Horsing:    { name: "Otto Hörsing",        party: "SRPD", bloc: "center_left" },
    Hamkens:    { name: "Wilhelm Hamkens",     party: "CNBL", bloc: "center_right" },
    Behrens:    { name: "Wilhelm Behrens",     party: "CNBL", bloc: "center_right" },
    Fehr:       { name: "Anton Fehr",          party: "DBP",  bloc: "center" },
    Drewitz:    { name: "Max Drewitz",         party: "WP", bloc: "center_right" },
    Lambach2:   { name: "Walther Lambach",     party: "CSVD", bloc: "center_right" },
    Graefe:     { name: "Albrecht von Graefe", party: "DVFP", bloc: "far_right" },
    Ludendorff: { name: "Erich Ludendorff",    party: "DVFP/Völkisch", bloc: "far_right" },
    Quidde:     { name: "Ludwig Quidde",       party: "RDP",  bloc: "center_left" },
    Bohm:       { name: "Johannes Böhm",       party: "VRP",  bloc: "center_right", aliases: ["Böhm"] },
    Kunze:      { name: "Wilhelm Kunze",       party: "DTSP", bloc: "far_right" }
};

var CANDIDATE_ALIAS = {};
for (var ck in CANDIDATES) {
    CANDIDATE_ALIAS[ck] = ck;
    if (CANDIDATES[ck].aliases) {
        for (var a = 0; a < CANDIDATES[ck].aliases.length; a++) {
            CANDIDATE_ALIAS[CANDIDATES[ck].aliases[a]] = ck;
        }
    }
}

function canon(name) {
    if (!name) return name;
    if (CANDIDATE_ALIAS[name]) return CANDIDATE_ALIAS[name];
    var stripped = name.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/_/g, "");
    return CANDIDATE_ALIAS[stripped] || stripped;
}
function candDesc(name) {
    var key = canon(name);
    var c = CANDIDATES[key];
    return c ? (c.name + " (" + c.party + ")") : (name || "");
}
function candBloc(name) {
    var key = canon(name);
    var c = CANDIDATES[key];
    return c ? c.bloc : "center";
}

var BLOC_ORDER = ["far_left", "left", "cultural", "center_left", "center", "center_right", "far_right"];
function blocIndex(blocName) {
    var i = BLOC_ORDER.indexOf(blocName);
    return i === -1 ? 4 : i;
}

// ---------------------------------------------------------------------
// PARTIES — display info + tier. "minor" tier parties have no rows in
// LEADER_PREFERENCE at all; they always just inherit their parent's pick.
// ---------------------------------------------------------------------
var PARTIES = {
    spd:   { label: "SPD",  tier: "major" },
    z:     { label: "Z",    tier: "major" },
    dnvp:  { label: "DNVP", tier: "major", requires: "!Q.dnvp_banned" },
    dvp:   { label: "DVP",  tier: "major" },
    ddp:   { label: "",     tier: "major" },
    kpd:   { label: "KPD",  tier: "major", requires: "!Q.kpd_banned" },
    nsdap: { label: "NSDAP",tier: "major", requires: "!Q.nsdap_banned" },
    bvp:   { label: "BVP",  tier: "major" },
    wp:    { label: "WP",   tier: "major" },
    cnbl:  { label: "CNBL", tier: "major" },
    bb:    { label: "BB",   tier: "major", requires: "!Q.bb_banned" },
    dhp:   { label: "DHP",  tier: "major", requires: "!Q.dhp_banned" },
    csvd:  { label: "CSVD", tier: "major", requires: "Q.csvd_flee === 1" },
    kvp:   { label: "KVP",  tier: "major", requires: "Q.kvp_flee === 1 && !Q.kvp_banned" },
    vrp:   { label: "VRP",  tier: "major", requires: "Q.vrp_votes > 0.2" },
    sapd:  { label: "SAPD", tier: "major", requires: "Q.sapd_formed" },
    srpd:  { label: "SRPD", tier: "major", requires: "Q.srpd_formed" },
    dbp:   { label: "DBP",  tier: "major", requires: "Q.dbp_r > 0 && !Q.dbp_banned" },
    dsbp:  { label: "DSBP", tier: "major", requires: "Q.dsbp_r > 0 && !Q.dsbp_banned" },
    dvfp:  { label: "DVFP", tier: "major", requires: "!Q.dvfp_banned" },
    csrp:  { label: "CSRP", tier: "major" },

    kpo:   { label: "KPO",  tier: "minor", parent: "kpd",  requires: "Q.kpo_r > 0" },
    sl:    { label: "SL",   tier: "minor", parent: "sapd", requires: "Q.sl_r > 0" },
    aspd:  { label: "ASPD", tier: "minor", parent: "dvp",  requires: "Q.aspd_r > 0" },
    vnr:   { label: "VNR",  tier: "minor", parent: "dvp",  requires: "Q.vnr_r > 0" },
    hl:    { label: "HL",   tier: "minor", parent: "dhp",  requires: "Q.hl_r > 0" },
    lb:    { label: "LB",   tier: "minor", parent: "kpd",  requires: "Q.lb_r > 0" },
    rdp:   { label: "RDP",  tier: "minor", parent: "ddp",  requires: "Q.rdp_r > 0" },
    cvp:   { label: "CVP",  tier: "minor", parent: "z",    requires: "Q.cvp_r > 0" },
    sls:   { label: "SLS",  tier: "minor", parent: "spd",  requires: "Q.sls_r > 0" },
    dtsp:  { label: "DtsP", tier: "minor", parent: "nsdap",requires: "Q.dtsp_r > 0" }
};

function partyActive(p) {
    var req = PARTIES[p].requires;
    if (!req) return true;
    try { return !!eval(req); } catch (e) { return true; }
}

// ---------------------------------------------------------------------
// GENERIC RESOLVER — walks a party's preference rows top to bottom.
// First row whose "if" is true wins; "pick" may be a literal candidate
// key or a function returning one (for cases that need to read another
// party's already-resolved candidate). A "pick" that resolves to a
// falsy value (e.g. "follow the joint ticket" when none exists) falls
// through to later rows rather than returning null early.
// ---------------------------------------------------------------------
function resolveCandidate(rows) {
    for (var i = 0; i < rows.length; i++) {
        var row = rows[i];
        if (row.default !== undefined) {
            return (typeof row.default === "function") ? row.default() : row.default;
        }
        var ok;
        try { ok = !!eval(row.if); } catch (e) { ok = false; }
        if (ok) {
            var result = (typeof row.pick === "function") ? row.pick() : row.pick;
            if (result) return result;
        }
    }
    return null;
}

function jointActive() { return Q.z_dnvp_joint_possible && Q.z_dnvp_joint_candidate; }
function jointCand() { return Q.z_dnvp_joint_candidate; }
function getRelationSafe(a, b) {
    if (!Q.party_relations || !Q.party_relations[a] || !Q.party_relations[a][b]) return 0;
    return Q.party_relations[a][b];
}

// ---------------------------------------------------------------------
// LEADER_PREFERENCE — one ranked list per major party. To add a new
// leader-driven branch for a party, add one row to that party's array.
// To add a wholly new major party, add a new key here plus a matching
// entry in PARTIES above and in RESOLUTION_ORDER below.
// ---------------------------------------------------------------------
var LEADER_PREFERENCE = {

    nsdap: [
        { if: "Q.hitler_dead", pick: "Goebbels" },
        { if: "Q.hitler_deported", pick: "Goring" },
        { default: "Hitler" }
    ],

    dnvp: [
        { if: "jointActive() && Q.dnvp_line !== 3", pick: jointCand },
        { if: "Q.dnvp_line === 1", pick: "Westarp" },
        { if: "Q.dnvp_line === 2", pick: "Westarp" },
        { if: "Q.dnvp_line === 0 && Q.dnvp_party_leader === 'Westarp'", pick: "Westarp" },
        { if: "Q.dnvp_line === 0 && Q.dnvp_party_leader === 'Treviranus'", pick: "Treviranus" },
        { if: "Q.dnvp_line === 0 && Q.dnvp_party_leader === 'Lambach'", pick: "Lambach" },
        { if: "Q.dnvp_line === 0 && Q.dnvp_party_leader === 'Lindeiner-Wildau'", pick: "Lindeiner" },
        { if: "Q.dnvp_line === 0", pick: "Treviranus" },
        { if: "Q.dnvp_line === 3 && Q.nsdap_banned", pick: "Hugenberg" },
        { if: "Q.dnvp_line === 3 && Q.hitler_dead && Q.dnvp_relation_nsdap >= 70", pick: "Goebbels" },
        { if: "Q.dnvp_line === 3 && Q.hitler_dead", pick: "Hugenberg" },
        { if: "Q.dnvp_line === 3 && Q.hitler_deported", pick: "Goring" },
        { if: "Q.dnvp_line === 3", pick: "Hitler" },
        { default: "Seldte" }
    ],

    z: [
        { if: "jointActive()", pick: jointCand },
        { if: "Q.z_party_leader === 'Kaas'", pick: "Kaas" },
        { if: "Q.z_party_leader === 'Joos'", pick: "Adenauer" },
        { if: "Q.z_party_leader === 'Bruning'", pick: "Bruning" },
        { default: "Adenauer" }
    ],

    bvp: [
        { if: "jointActive()", pick: jointCand },
        { default: "Schaffer" }
    ],

    dvp: [
        { if: "!Q.stresemann_dead && Q.year <= 1929", pick: "Stresemann" },
        { if: "Q.dvp_party_leader === 'Scholz' && (Q.dvp_right_shift >= 2 || Q.capital_strike_progress >= 3) && Q.dnvp_line === 1 && Q.dnvp_relation >= 50", pick: "Westarp" },
        { if: "Q.dvp_party_leader === 'Scholz' && (Q.dvp_right_shift >= 2 || Q.capital_strike_progress >= 3)", pick: "Scholz" },
        { if: "Q.dvp_party_leader === 'Scholz' && Q.dvp_relation >= 50 && Q.in_grand_coalition", pick: null },
        { if: "Q.dvp_party_leader === 'Scholz'", pick: "Gessler" },
        { if: "Q.dvp_party_leader === 'Dingeldey' && Q.z_relation >= 45 && Q.dvp_relation >= 40", pick: null },
        { if: "Q.dvp_party_leader === 'Dingeldey' && Q.dvp_right_shift >= 1", pick: "Dingeldey" },
        { if: "Q.dvp_party_leader === 'Dingeldey'", pick: "Gessler" },
        { if: "Q.dvp_party_leader === 'Curtius' && (Q.dvp_relation >= 45 || Q.in_grand_coalition)", pick: null },
        { if: "Q.dvp_party_leader === 'Curtius'", pick: "Curtius" },
        { if: "Q.finance_minister === 'Reinhold' && Q.economic_policy_seen", pick: "Reinhold" },
        { if: "jointActive() && Q.dvp_right_shift >= 2 && Q.dnvp_relation >= 40", pick: jointCand },
        { if: "jointActive() && Q.z_relation >= 50 && Q.dnvp_line === 1", pick: jointCand },
        { if: "jointActive() && Q.in_grand_coalition && Q.dnvp_line === 1 && Q.nsdap_r >= 25", pick: jointCand },
        { if: "jointActive() && Q.dvp_relation >= 50", pick: null },
        { if: "jointActive()", pick: "Gessler" },
        { if: "Q.dvp_right_shift >= 2 && Q.dnvp_line === 1 && Q.dnvp_relation >= 50", pick: "Westarp" },
        { if: "Q.dvp_right_shift >= 2", pick: "Gessler" },
        { if: "Q.dvp_relation >= 50", pick: null },
        { default: "Gessler" }
    ],

    kpd: [
        { if: "Q.kpd_party_leader === 'Conciliators'", pick: "Munzenberg" },
        { default: "Thalmann" }
    ],

    wp: [
        { if: "!(Q.wp_r > 2)", pick: function () { return Q.dvp_candidate || "Gessler"; } },
        { if: "Q.capital_strike_progress >= 5 || Q.inflation >= 6 || Q.unemployed >= 15", pick: "Drewitz" },
        { if: "jointActive() && Q.dnvp_relation >= 45 && Q.z_relation >= 35 && Q.economic_minister_party === 'WP'", pick: jointCand },
        { if: "jointActive() && Q.dvp_candidate === Q.z_dnvp_joint_candidate && Q.dvp_relation >= 45", pick: jointCand },
        { if: "jointActive() && Q.nsdap_r >= 30 && (Q.dnvp_line === 1 || Q.dnvp_line === 2)", pick: jointCand },
        { if: "Q.dvp_candidate && Q.dvp_relation >= 40", pick: function () { return Q.dvp_candidate; } },
        { default: "Drewitz" }
    ],

    cnbl: [
        { if: "!(Q.cnbl_r > 1.5)", pick: function () { return Q.dnvp_candidate || jointCand() || Q.bvp_candidate || "Hamkens"; } },
        { if: "Q.agricultural_finance < 2 || Q.land_reform >= 2", pick: "Hamkens" },
        { if: "jointActive() && Q.dnvp_relation >= 50 && Q.dnvp_line !== 3", pick: jointCand },
        { if: "jointActive() && Q.bvp_candidate === Q.z_dnvp_joint_candidate && Q.bvp_relation >= 40", pick: jointCand },
        { if: "jointActive() && Q.z_relation >= 45 && Q.agricultural_minister_party === 'Z'", pick: jointCand },
        { if: "jointActive() && Q.nsdap_r >= 25 && Q.rural_nsdap_support < 15", pick: jointCand },
        { if: "jointActive()", pick: "Hamkens" },
        { if: "Q.dnvp_candidate && Q.dnvp_line !== 3 && !Q.dnvp_banned && Q.dnvp_relation >= 40", pick: function () { return Q.dnvp_candidate; } },
        { if: "Q.dnvp_line === 3 && !Q.nsdap_banned && Q.year >= 1932", pick: function () { return Q.nsdap_candidate; } },
        { default: "Hamkens" }
    ],

    bb: [
        { if: "Q.inflation < 0 || Q.unemployed >= 15", pick: "Hamkens" },
        { if: "Q.bvp_candidate && Q.bvp_candidate !== 'Hitler' && Q.bvp_candidate !== Q.kpd_candidate", pick: function () { return Q.bvp_candidate; } },
        { if: "Q.cnbl_candidate && Q.cnbl_candidate !== 'Hitler'", pick: function () { return Q.cnbl_candidate; } },
        { if: "Q.z_candidate && Q.z_candidate !== Q.kpd_candidate", pick: function () { return Q.z_candidate; } },
        { default: "Hamkens" }
    ],

    dhp: [
        { if: "Q.cnbl_candidate && Q.cnbl_candidate !== 'Hitler' && Q.cnbl_candidate !== 'Hugenberg' && Q.cnbl_candidate !== Q.kpd_candidate", pick: function () { return Q.cnbl_candidate; } },
        { if: "Q.dnvp_line !== 3 && Q.dnvp_candidate && Q.dnvp_candidate !== 'Hitler' && !Q.dnvp_banned", pick: function () { return Q.dnvp_candidate; } },
        { if: "Q.csvd_candidate && Q.csvd_candidate !== 'Hitler'", pick: function () { return Q.csvd_candidate; } },
        { if: "jointActive()", pick: jointCand },
        { default: "Hamkens" }
    ],

    csvd: [
        { if: "jointActive() && Q.dnvp_line !== 3", pick: jointCand },
        { if: "(Q.dnvp_line === 1 || Q.dnvp_line === 2) && Q.dnvp_candidate && Q.dnvp_candidate !== 'Hitler' && Q.dnvp_candidate !== 'Hugenberg'", pick: function () { return Q.dnvp_candidate; } },
        { if: "(Q.dnvp_line === 1 || Q.dnvp_line === 2) && Q.z_candidate && Q.z_candidate !== Q.spd_candidate", pick: function () { return Q.z_candidate; } },
        { if: "(Q.dnvp_line === 1 || Q.dnvp_line === 2) && Q.dvp_candidate && Q.dvp_candidate !== Q.spd_candidate", pick: function () { return Q.dvp_candidate; } },
        { if: "Q.dnvp_line === 3 && Q.nsdap_r >= 35 && Q.kpd_r >= 15 && Q.z_candidate && Q.z_candidate !== 'Hitler' && Q.z_candidate !== Q.kpd_candidate", pick: function () { return Q.z_candidate; } },
        { if: "Q.dnvp_line === 3 && Q.nsdap_r >= 35 && Q.kpd_r >= 15 && Q.dvp_candidate && Q.dvp_candidate !== 'Hitler'", pick: function () { return Q.dvp_candidate; } },
        { if: "Q.dnvp_line === 3 && Q.nsdap_r >= 35 && Q.kpd_r >= 15 && Q.spd_candidate && Q.spd_candidate !== Q.kpd_candidate && Q.pro_republic >= 70", pick: function () { return Q.spd_candidate; } },
        { if: "Q.dnvp_line === 3 && Q.nsdap_r >= 25 && Q.z_candidate && Q.z_candidate !== 'Hitler'", pick: function () { return Q.z_candidate; } },
        { if: "Q.dnvp_line === 3 && Q.nsdap_r >= 25 && Q.bvp_candidate && Q.bvp_candidate !== 'Hitler'", pick: function () { return Q.bvp_candidate; } },
        { if: "Q.dnvp_line === 3 && Q.nsdap_r >= 25 && Q.dvp_candidate && Q.dvp_candidate !== 'Hitler'", pick: function () { return Q.dvp_candidate; } },
        { if: "Q.dnvp_line === 0 && Q.year >= 1930 && Q.nsdap_r >= 15 && Q.z_candidate", pick: function () { return Q.z_candidate; } },
        { if: "Q.dnvp_line === 0 && Q.year >= 1930 && Q.nsdap_r >= 15 && Q.dvp_candidate", pick: function () { return Q.dvp_candidate; } },
        { if: "Q.dnvp_line === 0 && Q.year >= 1930 && Q.nsdap_r >= 15 && Q.dnvp_candidate && Q.dnvp_candidate !== 'Hitler'", pick: function () { return Q.dnvp_candidate; } },
        { if: "Q.dnvp_line === 0 && Q.dnvp_candidate", pick: function () { return Q.dnvp_candidate; } },
        { default: "Lambach2" }
    ],

    kvp: [
        { if: "jointActive() && Q.dnvp_line !== 3", pick: jointCand },
        { if: "Q.dnvp_candidate && Q.dnvp_candidate !== 'Hitler' && Q.dnvp_candidate !== 'Hugenberg' && Q.dnvp_line !== 3", pick: function () { return Q.dnvp_candidate; } },
        { if: "Q.csvd_candidate && Q.csvd_candidate !== 'Hitler'", pick: function () { return Q.csvd_candidate; } },
        { if: "Q.z_candidate", pick: function () { return Q.z_default_candidate; } },
        { default: "Westarp" }
    ],

    vrp: [
        { if: "Q.inflation >= 5 || Q.unemployed >= 20 || Q.economy_growth <= -3", pick: "Bohm" },
        { if: "jointActive() && Q.dnvp_line !== 3 && Q.ddp_relation >= 40 && Q.dvp_relation < 35 && Q.ddp_candidate === Q.z_dnvp_joint_candidate", pick: jointCand },
        { if: "jointActive() && Q.dnvp_line !== 3 && Q.ddp_relation >= 40 && Q.dvp_relation < 35", pick: function () { return Q.ddp_candidate || "Bohm"; } },
        { if: "jointActive() && Q.dnvp_line === 3", pick: function () { return Q.ddp_candidate || "Bohm"; } },
        { if: "jointActive() && Q.dvp_candidate === Q.z_dnvp_joint_candidate && Q.ddp_candidate === Q.z_dnvp_joint_candidate", pick: jointCand },
        { if: "jointActive()", pick: function () { return Q.ddp_candidate || "Bohm"; } },
        { if: "Q.inflation >= 3 || Q.unemployed >= 12 || Q.economy_growth <= -1", pick: function () { return (Q.ddp_candidate && Q.ddp_relation >= 35) ? Q.ddp_candidate : "Bohm"; } },
        { if: "Q.ddp_candidate && Q.ddp_relation >= 40", pick: function () { return Q.ddp_candidate; } },
        { if: "Q.csvd_flee === 1 && Q.csvd_candidate && Q.csvd_relation >= 40", pick: function () { return Q.csvd_candidate; } },
        { if: "Q.dvp_candidate && Q.dvp_right_shift < 1 && Q.dvp_relation >= 35", pick: function () { return Q.dvp_candidate; } },
        { default: "Bohm" }
    ],

    sapd: [
        { if: "Q.kpd_relation >= 60 && Q.spd_sapd_relation < 40 && !Q.kpd_banned", pick: function () { return Q.kpd_candidate; } },
        { default: "Rosenfeld" }
    ],

    srpd: [
        { if: "Q.srpd_relation >= 60", pick: null },
        { default: "Horsing" }
    ],

    dvfp: [
        { if: "!Q.nsdap_banned && !Q.hitler_dead && Q.nsdap_r >= 15", pick: "Hitler" },
        { if: "Q.dnvp_line === 3 && !Q.dnvp_banned", pick: "Hugenberg" },
        { if: "Q.hitler_dead && !Q.nsdap_banned", pick: "Ludendorff" },
        { if: "Q.unrest_factor >= 2.0 || Q.nationalism >= 60", pick: "Ludendorff" },
        { default: "Graefe" }
    ],

    dbp: [
        { if: "Q.inflation < 0 || Q.unemployed >= 15", pick: "Fehr" },
        { if: "jointActive() && Q.bb_candidate === Q.z_dnvp_joint_candidate && Q.bb_relation >= 40", pick: jointCand },
        { if: "jointActive() && Q.cnbl_candidate === Q.z_dnvp_joint_candidate && Q.cnbl_relation >= 40", pick: jointCand },
        { if: "jointActive() && Q.dnvp_line === 3 && Q.bb_candidate && Q.bb_candidate !== Q.z_dnvp_joint_candidate", pick: function () { return Q.bb_candidate; } },
        { if: "jointActive() && Q.dnvp_line === 3 && Q.ddp_candidate", pick: function () { return Q.ddp_candidate; } },
        { if: "jointActive() && Q.dnvp_line === 3", pick: "Fehr" },
        { if: "jointActive() && Q.ddp_candidate === Q.z_dnvp_joint_candidate", pick: jointCand },
        { if: "jointActive()", pick: "Fehr" },
        { if: "Q.nsdap_r >= 30 && Q.rural_nsdap_support >= 20 && Q.bb_candidate && Q.bb_candidate !== 'Hitler'", pick: function () { return Q.bb_candidate; } },
        { if: "Q.nsdap_r >= 30 && Q.rural_nsdap_support >= 20 && Q.ddp_candidate && Q.ddp_candidate !== 'Hitler'", pick: function () { return Q.ddp_candidate; } },
        { if: "Q.nsdap_r >= 30 && Q.rural_nsdap_support >= 20 && Q.cnbl_candidate && Q.cnbl_candidate !== 'Hitler'", pick: function () { return Q.cnbl_candidate; } },
        { if: "Q.nsdap_r >= 30 && Q.rural_nsdap_support >= 20", pick: "Fehr" },
        { if: "Q.bb_candidate && Q.bb_candidate !== 'Hitler' && Q.bb_candidate !== Q.kpd_candidate", pick: function () { return Q.bb_candidate; } },
        { if: "Q.cnbl_candidate && Q.cnbl_candidate !== 'Hitler'", pick: function () { return Q.cnbl_candidate; } },
        { if: "Q.ddp_candidate && Q.ddp_relation >= 40", pick: function () { return Q.ddp_candidate; } },
        { default: "Fehr" }
    ],

    dsbp: [
        { if: "Q.inflation < 0 || Q.unemployed >= 15", pick: "Gessler" },
        { if: "jointActive() && Q.dnvp_line !== 3", pick: jointCand },
        { if: "Q.dvp_candidate && Q.ddp_candidate && Q.dvp_candidate === Q.ddp_candidate", pick: function () { return Q.dvp_candidate; } },
        { if: "Q.dvp_candidate && Q.dvp_right_shift >= 1", pick: function () { return Q.ddp_candidate || "Gessler"; } },
        { if: "Q.ddp_relation >= 45 || Q.dvp_relation >= 45", pick: null },
        { default: "Gessler" }
    ],

    csrp: [
        { default: function () { return Q.z_candidate; } }
    ],

    ddp: [
        { if: "Q.ddp_name === 'DStP' && Q.ddp_relation >= 55", pick: null },
        { if: "Q.ddp_name === 'DStP'", pick: function () { return ddpOwnCandidate(); } },
        { if: "Q.ddp_name !== 'DStP' && Q.ddp_relation >= 45", pick: null },
        { if: "Q.ddp_name !== 'DStP' && (Q.dvp_candidate === 'Gessler' || Q.z_relation >= 35)", pick: "Gessler" },
        { default: function () { return ddpOwnCandidate(); } }
    ]
};

function ddpOwnCandidate() {
    if (Q.ddp_name === "DStP") {
        if (Q.jungdo_strength >= 300 && Q.year >= 1930) return "Mahraun";
        if (Q.ddp_party_leader === "Koch-Weser" || !Q.ddp_party_leader) return "KochWeser";
        if (Q.ddp_party_leader === "Maier") return "Maier";
        if (Q.economic_democracy >= 2 || Q.reformist_strength >= 50) return "Luders";
        return "KochWeser";
    }
    if (Q.womens_rights >= 4 && Q.pro_republic > 80 && Q.nationalism < 20) return "Luders";
    if (Q.ddp_party_leader === "Dietrich" || Q.finance_minister === "Dietrich") return "Dietrich";
    if (Q.ddp_party_leader === "Heuss") return "Heuss";
    if (Q.rb_strength >= 800 && Q.rb_militancy > 0.30 && Q.year >= 1932) return "Lemmer";
    return "Heuss";
}

// =====================================================================
// ORCHESTRATION
// =====================================================================
Q.is_unity_candidate = 0;
Q.is_cultural_candidate = 0;

for (var ckk in CANDIDATES) {
    Q[ckk + '_bonus'] = Q[ckk + '_bonus'] || 0;
    Q[ckk + '_running'] = 0;
}

// --- Joint Z-DNVP conservative unity ticket -------------------------
Q.z_dnvp_joint_possible = 0;
Q.z_dnvp_joint_candidate = null;

if (!Q.dnvp_banned && (Q.dnvp_line === 0 || Q.dnvp_line === 1 || Q.dnvp_line === 2)) {
    var z_dnvp_rel = getRelationSafe("Z", "DNVP");
    var dnvp_z_rel = getRelationSafe("DNVP", "Z");
    var z_bvp_rel = getRelationSafe("Z", "BVP");

    if (z_dnvp_rel >= 40 && dnvp_z_rel >= 40 && z_bvp_rel >= 70) {
        if ((Q.nsdap_r >= 20 || Q.kpd_r >= 12) && Q.year >= 1930) {
            Q.z_dnvp_joint_possible = 1;
            if (Q.z_party_leader === "Kaas" && Q.dnvp_line === 0) {
                Q.z_dnvp_joint_candidate = (Q.z_r >= Q.dnvp_r) ? "Kaas" : "Westarp";
            } else if (Q.z_party_leader === "Bruning") {
                Q.z_dnvp_joint_candidate = "Bruning";
            } else if (Q.dnvp_line === 1) {
                Q.z_dnvp_joint_candidate = "Westarp";
            } else if (Q.bvp_r >= 3 && Q.z_r >= Q.dnvp_r) {
                Q.z_dnvp_joint_candidate = "Schaffer";
            } else {
                Q.z_dnvp_joint_candidate = "Adenauer";
            }
        }
    }

    Q.conservative_unity_estimate = (Q.z_r || 0) + (Q.dnvp_r || 0) + (Q.bvp_r || 0);
    if (Q.dvp_candidate === Q.z_dnvp_joint_candidate) Q.conservative_unity_estimate += (Q.dvp_r || 0);
    if (Q.wp_candidate === Q.z_dnvp_joint_candidate) Q.conservative_unity_estimate += (Q.wp_r || 0);
    if (Q.cnbl_candidate === Q.z_dnvp_joint_candidate) Q.conservative_unity_estimate += (Q.cnbl_r || 0);
    Q.conservative_unity_estimate = Math.round(Q.conservative_unity_estimate * 10) / 10;
}

// --- Resolve every major party (minor parties wait for finalize step,
//     same as the original design's "fold into parent" simplification).
var RESOLUTION_ORDER = [
    "nsdap", "kpd", "dnvp", "z", "bvp", "dvp", "ddp", "wp", "cnbl",
    "bb", "dhp", "csvd", "kvp", "vrp", "sapd", "srpd", "dbp", "dsbp",
    "dvfp", "csrp"
];

for (var ri = 0; ri < RESOLUTION_ORDER.length; ri++) {
    var pkey = RESOLUTION_ORDER[ri];
    if (!partyActive(pkey)) { Q[pkey + '_candidate'] = null; Q[pkey + '_default_candidate'] = null; continue; }
    var picked = resolveCandidate(LEADER_PREFERENCE[pkey]);
    Q[pkey + '_candidate'] = picked;
    Q[pkey + '_default_candidate'] = picked;
}

// Z and BVP wait for SPD's choice unless a joint ticket already locked
// them in (mirrors the original "will finalize after SPD" design).
if (!jointActive()) {
    Q.z_candidate = null;
    Q.bvp_candidate = null;
}

// --- Minor parties: always mirror their parent's CURRENT pick so the
//     declaration screen shows something sensible even before SPD acts.
//     They get re-synced again in @finalize_candidates once SPD and
//     every major party has settled.
var MINOR_PARENTS = { kpo:"kpd", sl:"sapd", aspd:"dvp", vnr:"dvp", hl:"dhp", lb:"kpd", rdp:"ddp", cvp:"z", sls:"spd", dtsp:"nsdap" };
for (var mp in MINOR_PARENTS) {
    if (!partyActive(mp)) { Q[mp + '_candidate'] = null; continue; }
    Q[mp + '_candidate'] = Q[MINOR_PARENTS[mp] + '_candidate'] || null;
}

!}

