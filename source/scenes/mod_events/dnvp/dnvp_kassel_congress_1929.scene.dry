    visibleFactions.forEach(function(f) { d3.selectAll("#dnvp-congress-compromise circle").filter(function(d) { return d && d.data && d.data.id === f.id; }).style("stroke", f.outline).style("stroke-width", "2px").style("fill", f.color); });
