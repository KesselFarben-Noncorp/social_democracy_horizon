on-arrival: dnvp_radicalism += 5; internal_friction += 10; rural_dnvp += 10; young_delayed = 1

{!<svg id="dnvp-congress-compromise" style="width:600px; height:300px;"></svg>!}
{!<div id="dnvp-verdict-compromise"></div>!}

*The final tally of delegate votes:*
*Hugenberg (Radical Bloc): [+ final_hug +]*
*[+ leader_mod +] (Constitutionalists): [+ final_mod +]*
*[+ leader_agr +] (Agrarians): [+ final_agr +]*
*[+ leader_soc +] (Socials): [+ final_soc +]*

Martin Schiele steps to the microphone, bypassing the screaming matches over the Young Plan entirely. Instead, he speaks of the "Green Front"—the crushing debt of the farmers and the falling grain prices. 

With the Agrarian wing holding the swing votes, Schiele proposes a masterstroke of distraction: the party will officially *postpone* the vote on the Penal Clause, and instead unite to demand an immediate "Agrarian Emergency Decree" from President Hindenburg. The radicals lose their momentum, and the moderates avoid a walkout. The party remains united, but the ideological rot has merely been papered over with grain subsidies.

@moderate_rejection
on-display: {!
var factionData = [
    { id: "faction_soc", name: Q.leader_soc, subtitle: Q.leader_soc_title, votes: Q.final_soc, color: "#1a3a5c", outline: "#00cc44", label: "Socials", side: "moderate" },
    { id: "faction_mod", name: Q.leader_mod, subtitle: Q.leader_mod_title, votes: Q.final_mod, color: "#4a7c59", outline: "#00cc44", label: "Constitutionalists", side: "moderate" },
    { id: "faction_agr", name: Q.leader_agr, subtitle: Q.leader_agr_title, votes: Q.final_agr, color: "#5c4a1e", outline: "#00cc44", label: "Agrarians", side: "moderate" },
    { id: "hugenberg", name: "Alfred Hugenberg", subtitle: "Radical Bloc / Pan-Germans", votes: Q.final_hug, color: "#3d0000", outline: "#cc0000", label: "Hugenberg Bloc", side: "radical" }
];
var totalVotes = factionData.reduce(function(s, f) { return s + (f.votes || 0); }, 0);
var visibleFactions = factionData.filter(function(f) { return f.votes > 0; });
if (window && d3 && document.getElementById("dnvp-congress-rejection")) {
    var width = 600, height = 300; var contentEl = document.getElementById('content');
    var screenWidth = contentEl ? contentEl.offsetWidth : 600; if (screenWidth < width - 50) { width = screenWidth - 50; height = Math.round(width / 2); }
    var svg = document.getElementById("dnvp-congress-rejection"); svg.style.width = width + "px"; svg.style.height = height + "px";
    var data = visibleFactions.map(function(f) { return { id: f.id, legend: f.label, name: f.label, seats: Math.round(f.votes), color: f.color }; });
    var parliament = d3.parliament().width(width).height(height).innerRadiusCoef(0.4); parliament.enter.fromCenter(true).smallToBig(true); parliament.exit.toCenter(false).bigToSmall(true); d3.select("#dnvp-congress-rejection").datum(data).call(parliament);
    visibleFactions.forEach(function(f) { d3.selectAll("#dnvp-congress-rejection circle").filter(function(d) { return d && d.data && d.data.id === f.id; }).style("stroke", f.outline).style("stroke-width", "2px").style("fill", f.color); });
}
var verdict = document.getElementById("dnvp-verdict-rejection");
if (verdict) {
    var modPct = totalVotes > 0 ? ((Q.final_mod + Q.final_soc) / totalVotes * 100) : 0;
    verdict.style.marginTop = "14px"; verdict.style.padding = "10px 14px"; verdict.style.borderRadius = "4px"; verdict.style.fontSize = "0.88em"; verdict.style.fontStyle = "italic"; verdict.style.fontFamily = "Georgia, serif";
    verdict.style.backgroundColor = "#1a3320"; verdict.style.color = "#ccffcc"; verdict.style.border = "1px solid #00cc44";
    verdict.textContent = "⚖ The moderate alliance secures " + modPct.toFixed(1) + "% of the delegates. The Radical Bloc is defeated on the floor.";
}
!}
on-arrival: dnvp_radicalism -= 15; dnvp_moderation += 20; nazi_alignment -= 20; dnvp_stabilized = 1; industrial_funding -= 20

{!<svg id="dnvp-congress-rejection" style="width:600px; height:300px;"></svg>!}
{!<div id="dnvp-verdict-rejection"></div>!}

*The final tally of delegate votes:*
*Hugenberg (Radical Bloc): [+ final_hug +]*
*[+ leader_mod +] (Constitutionalists): [+ final_mod +]*
*[+ leader_agr +] (Agrarians): [+ final_agr +]*
*[+ leader_soc +] (Socials): [+ final_soc +]*

"We are a party of Prussian Law, not a lynch mob!" Count Westarp declares to thunderous applause. By pooling their delegates, the Constitutionalists and the Social Wing successfully outvote the Pan-German radicals, striking the Penal Clause from the party's official platform. 

The victory, however, comes at a steep price. Humiliated on the floor, Hugenberg threatens to withdraw his massive financial support, and his newspapers begin a scorched-earth campaign against the "Traitors in Kassel." The alliance with Hitler is shattered. The DNVP has preserved its soul and remains a viable partner for the Republic, but it is now a party under siege from its own wealthiest patron.
