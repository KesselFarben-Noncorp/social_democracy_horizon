@run_estimate
on-arrival: {!

Q.resources -= 1

var n         = Q.estimate_target || 0;
var _slot     = Q['queued_' + n + '_slot'];
var _bill_party = Q['queued_' + n + '_party'];
var _bill_ideo  = Q['queued_' + n + '_ideo'] || 5;
var _bill_name  = Q['queued_' + n + '_name'];
var _bill_type  = Q['queued_' + n + '_type'];

Q.estimate_bill_name  = _bill_name;
Q.estimate_bill_party = _bill_party;
Q.estimate_bill_type  = _bill_type;
Q.estimate_bill_ideo  = _bill_ideo;

var _gov_parties = Q.government_parties || ['SPD'];

var _party_list = ['KPD','SAPD','SPD','SRPD','DDP','Z','BVP','CSRP',
                   'DVP','WP','VRP','CNBL','CSVD','KVP','DHP','BB',
                   'DNVP','NSDAP','DVFP'];

var IDEO_POS = {
    KPD:1, SAPD:2, SPD:3, SRPD:3,
    DDP:5, CSRP:5, Z:5, BVP:6, CSVD:6, KVP:6,
    DVP:7, WP:7, VRP:7, DHP:7,
    BB:7, CNBL:8, DNVP:9, NSDAP:10, DVFP:10
};

// Run clean simulation — SPD assumed to vote 'for' for estimate purposes
var _spd_assumed = 'for';

var _for = 0, _against = 0, _abstain = 0;

for (var i = 0; i < _party_list.length; i++) {
    var _p = _party_list[i];
    var _r = Q[_p.toLowerCase() + '_r'] || 0;
    if (_r <= 0) continue;
    var _seats  = Math.round(_r * 6);
    var _in_gov = (_gov_parties.indexOf(_p) >= 0) ? 1 : 0;

    var _result;

    if (_p === 'SPD') {
        _result = _spd_assumed;
    } else if (_p === _bill_party) {
        _result = 'for';
    } else if (_p === 'NSDAP' && _bill_ideo <= 4) {
        _result = 'against';
    } else if (_p === 'NSDAP' && _bill_ideo >= 8) {
        _result = 'for';
    } else if (_p === 'KPD' && _bill_ideo >= 8) {
        _result = 'against';
    } else if (_p === 'KPD' && _bill_ideo <= 2) {
        _result = 'for';
    } else {
        var _rel = 50;
        if (Q.party_relations && Q.party_relations[_p]) {
            var _rv = Q.party_relations[_p][_bill_party];
            _rel = (_rv !== undefined) ? _rv : 50;
        }
        var _gap   = Math.abs((IDEO_POS[_p] || 5) - _bill_ideo);
        var _score = (_rel - 50) - (_gap * 1.5);
        if (_in_gov) {
            _score += 20;
            var _diss = Q[_p.toLowerCase() + '_dissent'] || 0;
            if (_diss >= 2) _score -= _diss * 3;
        }
        if (_score >= 12)       _result = 'for';
        else if (_score >= -8)  _result = 'abstain';
        else                    _result = 'against';
    }

    if (_result === 'for')     _for     += _seats;
    else if (_result === 'against') _against += _seats;
    else                            _abstain += _seats;
}

// Apply fixed noise — ±15% of total seats
var _total      = Q.total_seats_filled || 600;
var _noise_max  = Math.round(_total * 0.15);

function _noisy(val) {
    var _n = Math.floor(Math.random() * (_noise_max * 2 + 1)) - _noise_max;
    return Math.max(0, val + _n);
}

var _est_for     = _noisy(_for);
var _est_against = _noisy(_against);
var _est_abstain = _noisy(_abstain);

// Range display — show ± half noise_max
var _range = Math.round(_noise_max / 2);

Q.estimate_for_mid     = _est_for;
Q.estimate_against_mid = _est_against;
Q.estimate_abstain_mid = _est_abstain;
Q.estimate_for_lo      = Math.max(0, _est_for     - _range);
Q.estimate_for_hi      = _est_for     + _range;
Q.estimate_against_lo  = Math.max(0, _est_against - _range);
Q.estimate_against_hi  = _est_against + _range;
Q.estimate_abstain_lo  = Math.max(0, _est_abstain - _range);
Q.estimate_abstain_hi  = _est_abstain + _range;

// Outcome label
var _margin = _est_for - _est_against;
var _threshold = Math.round(_total * 0.08);

if (_margin > _threshold) {
    Q.estimate_outcome       = 'likely_pass';
    Q.estimate_outcome_label = 'Likely passes';
} else if (_margin < -_threshold) {
    Q.estimate_outcome       = 'likely_fail';
    Q.estimate_outcome_label = 'Likely fails';
} else {
    Q.estimate_outcome       = 'too_close';
    Q.estimate_outcome_label = 'Too close to call';
}

!}

= Intelligence Report: [+ estimate_bill_name +]

Your contacts have sounded out the chamber on **[+ estimate_bill_name +]** ([+ estimate_bill_party +]).

*(Assumes SPD votes in favour. Accuracy is approximate.)*

**Projected outcome: [+ estimate_outcome_label +]**

[? if estimate_outcome = 'likely_pass' : The numbers look favourable. Barring surprises, this bill has the votes. ?]
[? if estimate_outcome = 'likely_fail' : The chamber is hostile. This bill faces an uphill struggle. ?]
[? if estimate_outcome = 'too_close' : It could go either way. The whips will be working hard on both sides. ?]

— For: approximately **[+ estimate_for_lo +] – [+ estimate_for_hi +]**
— Against: approximately **[+ estimate_against_lo +] – [+ estimate_against_hi +]**
— Abstaining: approximately **[+ estimate_abstain_lo +] – [+ estimate_abstain_hi +]**

[? if estimate_bill_ideo <= 3 : Left-wing bills tend to bleed support in the centre — the range here may be wider than it looks. ?]
[? if estimate_bill_ideo >= 8 : Far-right bills are harder to read. Nationalist sentiment can shift votes unpredictably. ?]
[? if estimate_bill_type = 'constitutional' : Constitutional bills carry extra uncertainty — party discipline tends to fracture. ?]

