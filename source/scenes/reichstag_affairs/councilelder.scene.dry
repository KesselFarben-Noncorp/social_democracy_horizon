@propose_spd_own
view-if: can_propose = 1 and num_spd_unqueued > 0

= Introduce an SPD Bill

Choose which SPD bill to introduce and bring immediately to a vote:

- @introduce_spd_0: [+ spd_unqueued_0_name +]
- @introduce_spd_1: [+ spd_unqueued_1_name +]
- @introduce_spd_2: [+ spd_unqueued_2_name +]
- @introduce_spd_3: [+ spd_unqueued_3_name +]
- @root: Cancel


@introduce_spd_0
view-if: num_spd_unqueued >= 1
on-arrival: {!
    var id   = Q.spd_unqueued_0_id;
    var name = Q.spd_unqueued_0_name;
    var type = Q.spd_unqueued_0_type;

    // Push into first empty slot
    for (var i = 0; i < 10; i++) {
        if (!Q['bill_' + i + '_id']) {
            Q['bill_' + i + '_id']     = id;
            Q['bill_' + i + '_name']   = name;
            Q['bill_' + i + '_party']  = 'SPD';
            Q['bill_' + i + '_type']   = type;
            Q['bill_' + i + '_ideo']   = 3;
            Q['bill_' + i + '_timer']  = 0;
            Q['bill_' + i + '_crisis'] = '';
            Q['bill_' + i + '_frozen'] = 0;
            Q.active_bill_slot  = i;
            break;
        }
    }
    Q.active_bill_name  = name;
    Q.active_bill_party = 'SPD';
    Q.active_bill_type  = type;
    Q.active_bill_ideo  = 3;
    Q.bill_proposed_this_month = 1;
!}
go-to: propose_spd_vote_choice

