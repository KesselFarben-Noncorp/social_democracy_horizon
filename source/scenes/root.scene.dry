// alternative is the Conciliators as party leader
// party leader - can be Ludwig Kaas, Joseph Joos, or Adam Stegerwald after the 1928 December conference. Joos will be most friendly to the SPD.

Q.spd_party_leader = "Collective"; // SPD has no single leader by design
Q.z_party_leader = "Marx"; // Wilhelm Marx (1928 start)
Q.bvp_party_leader = "Held"; // Heinrich Held
Q.ddp_party_leader = "Koch-Weser"; // Erich Koch-Weser
Q.dvp_party_leader = "Stresemann"; // Gustav Stresemann (until 1929)
Q.dnvp_party_leader = "Kuno von Westarp"; // Kuno von Westarp (moderate, until 1928)
Q.nsdap_party_leader = "Hitler"; // Adolf Hitler
Q.kpd_party_leader = "Thälmann"; // Ernst Thälmann (or "Conciliators" if they take over)
Q.wp_party_leader = "Drewitz"; // Hermann Drewitz
Q.csrp_party_leader = "Heller"; // Vitus Heller. Chrisliche Soziale Reichspartei
Q.vrp_party_leader = "Bauser"; // Adolf Bauser, chairman of Reichspartei für Volksrecht und Aufwertung, also known as the People's Justice Party Volksrechtpartei, VRP
Q.cnbl_party_leader = "Hepp";        // Georg Hepp, Reichs-Landbund chairman
Q.srpd_party_leader = "Horsing";     // Otto Hörsing, Reichsbanner founder
Q.sapd_party_leader = "Rosenfeld";          // Not formed yet in 1928
Q.csvd_party_leader = "Lambach";          // Not formed yet in 1928 (splits ~1929-30)
Q.kvp_party_leader = "Westarp";           // Not formed yet in 1928
Q.dhp_party_leader = "Boden";        // Wilhelm Boden, Deutsch-Hannoversche Partei
Q.bb_party_leader = "Eisenberger";   // Karl Eisenberger, Bayerischer Bauernbund chairman
Q.dbp_party_leader = "Fehr";
Q.dnf_party_leader = "Alfred Hugenberg";
Q.rlb_party_leader = "Martin Schiele"
Q.aspd_party_leader = "Wilhelm Buck"


