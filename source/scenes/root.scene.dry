@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 0;
Q.year = 1927;
Q.month = 12;
// how many actions have been taken this month?
Q.month_actions = 0;
if (!Q.rng_seed) {
    Q.rng_seed = Date.now() & 0xFFFFFFFF;
}





































// ========================================
// HINDENBURG & CAMARILLA VARIABLES
// ========================================
// Add these to your main variable initialization (likely in a starting scene or setup)


// === HINDENBURG PERSONAL STATE ===
Q.hindenburg_president = 0;           // Is Hindenburg currently president?
Q.hindenburg_health = 100;            // 0-100, declines with age/stress
Q.hindenburg_age = 78;                // Born 1847, starts at 78 in 1925
Q.hindenburg_senility = 0;            // 0-100, increases over time
Q.hindenburg_stubbornness = 75;       // 0-100, resistance to pressure
Q.hindenburg_trust_reichstag = 50;    // 0-100, faith in parliament
Q.hindenburg_trust_military = 85;     // 0-100, faith in Reichswehr
Q.hindenburg_trust_spd = 30;          // 0-100, trust in Social Democrats
Q.hindenburg_trust_z = 60;            // 0-100, trust in Center Party
Q.hindenburg_trust_dnvp = 70;         // 0-100, trust in Nationalists
Q.hindenburg_monarchist_sentiment = 65; // 0-100, desire to restore Kaiser
    
    // === CAMARILLA (INNER CIRCLE) ===
Q.camarilla_exists = 0;               // Does the camarilla exist yet?
Q.camarilla_strength = 0;             // 0-100, overall influence over Hindenburg
Q.camarilla_unified = 0;              // 0-100, internal unity of camarilla
    
    // Individual camarilla member influence (0-100 each)
Q.meissner_influence = 0;             // Otto Meißner - State Secretary
Q.schleicher_influence = 0;           // Kurt von Schleicher - General/Intriguer
Q.oskar_influence = 0;                // Oskar von Hindenburg - Son
Q.oldenburg_influence = 0;            // Elard von Oldenburg-Januschau - Junker
Q.papen_influence = 0;                // Franz von Papen - Aristocrat (joins later)
Q.hugenberg_influence = 0;            // Alfred Hugenberg - Media mogul (indirect)
    
    // Camarilla member status
Q.meissner_exposed = 0;               // Has Meißner been exposed for corruption?
Q.schleicher_exposed = 0;             // Has Schleicher been exposed for plotting?
Q.oskar_bribed = 0;                   // Has Oskar been bribed (Osthilfe scandal)?
Q.oskar_convinced = 0;                // Has Oskar been convinced to oppose camarilla?
Q.papen_in_camarilla = 0;             // Has Papen joined the inner circle?
Q.oldenburg_scandal = 0;              // Junker subsidy scandal exposed?
    
    // === CAMARILLA GOALS ===
Q.camarilla_goal_destroy_parliament = 0;    // 0-100, desire to end democracy
Q.camarilla_goal_install_papen = 0;         // 0-100, desire to make Papen Chancellor
Q.camarilla_goal_military_dictatorship = 0; // 0-100, desire for Reichswehr rule
Q.camarilla_goal_restore_monarchy = 0;      // 0-100, desire to restore Kaiser
Q.camarilla_goal_crush_left = 0;            // 0-100, desire to destroy SPD/KPD
Q.camarilla_goal_protect_junkers = 0;       // 0-100, desire to protect East Elbian estates
Q.camarilla_goal_install_hitler = 0;        // 0-100, willingness to use Hitler
    
    // === PRESIDENTIAL CRISIS TRACKING ===
Q.hindenburg_crisis_threshold = 0;          // Accumulating crisis points
Q.hindenburg_interventions = 0;             // Count of Article 48 emergency decree uses
Q.hindenburg_reichstag_dissolutions = 0;    // Count of Reichstag dissolutions
Q.hindenburg_government_dismissals = 0;     // Count of governments dismissed
    
    // === PRESIDENTIAL CABINET ERA ===
Q.presidential_cabinet = 0;                 // Is current government a "Presidential Cabinet"?
Q.presidential_cabinet_count = 0;           // How many presidential cabinets so far?
Q.bruning_cabinet = 0;                      // Is Brüning currently Chancellor?
Q.papen_cabinet = 0;                        // Is Papen currently Chancellor?
Q.schleicher_cabinet = 0;                   // Is Schleicher currently Chancellor?
Q.bruning_dismissed = 0;                    // Has Brüning been dismissed?
Q.papen_dismissed = 0;                      // Has Papen been dismissed?
    
    // === KEY CAMARILLA PLOTS ===
Q.schleicher_bruning_plot = 0;              // Has Schleicher plotted to install Brüning?
Q.schleicher_bruning_plotted = 0;           // Has the plot been executed?
Q.camarilla_tired_of_bruning = 0;           // Has camarilla turned against Brüning?
Q.papen_appointment_plot = 0;               // Is Papen appointment being plotted?
Q.papen_appointment_prevented = 0;          // Did SPD prevent Papen appointment?
Q.schleicher_papen_rivalry = 0;             // 0-100, rivalry between Schleicher and Papen
Q.camarilla_final_plot = 0;                 // Is the Hitler appointment plot active?
Q.hitler_appointment_prevented = 0;         // Did SPD prevent Hitler appointment?
    
    // === OSTHILFE SCANDAL ===
Q.osthilfe_scandal = 0;                     // Eastern Aid scandal (bribing Hindenburg/Oskar)
Q.osthilfe_exposed = 0;                     // Has the scandal been exposed?
Q.osthilfe_investigation = 0;               // Is there an active investigation?
Q.osthilfe_cover_up = 0;                    // Has the camarilla covered it up?
Q.hindenburg_estate_neudeck = 0;            // Did Hindenburg receive estate as bribe?
    
    // === ALTERNATIVE CHANCELLORS ===
Q.goerdeler_prominence = 0;                 // 0-10, Carl Goerdeler's national prominence
Q.goerdeler_chancellor_possible = 0;        // Can Goerdeler become Chancellor?
Q.hammerstein_coup_ready = 0;               // Is Hammerstein ready to launch coup?
Q.hammerstein_coup_attempted = 0;           // Has coup been attempted?
Q.hammerstein_coup_success = 0;             // Did the coup succeed?
    
    // === SCHLEICHER'S QUERFRONT ===
Q.schleicher_querfront_attempt = 0;         // Is Schleicher attempting cross-front?
Q.schleicher_querfront_attempted = 0;       // Has it been attempted?
Q.schleicher_querfront_success = 0;         // Did it succeed?
Q.schleicher_querfront_spd_support = 0;     // Does SPD support the Querfront?
Q.schleicher_querfront_success_chance = 30; // Base chance of success
Q.strasser_splits_nsdap = 0;                // Did Gregor Strasser split from NSDAP?
    
    // === PAPEN DICTATORSHIP ATTEMPT ===
Q.papen_dictatorship_attempt = 0;           // Is Papen attempting dictatorship?
Q.papen_second_term = 0;                    // Is this Papen's second chancellorship?
Q.cabinet_of_barons = 0;                    // Is current cabinet the "Cabinet of Barons"?
Q.center_split_risk = 0;                    // Does Papen threaten to split Center Party?
    
    // === MILITARY EMERGENCY GOVERNMENT ===
Q.military_emergency_government = 0;        // Is military ruling?
Q.military_dictatorship = 0;                // Is this a full military dictatorship?
Q.military_dictatorship_brewing = 0;        // Is military dictatorship being prepared?
Q.article_48_permanent = 0;                 // Has Article 48 become permanent rule?
    
    // === NAZI APPOINTMENT ===
Q.nazi_takeover_begins = 0;                 // Has Hitler been appointed Chancellor?
Q.hugenberg_hitler_pact = 0;                // Hugenberg-Hitler government pact?
Q.vice_chancellor = "";                     // Who is Vice Chancellor?
Q.vice_chancellor_party = "";               // Vice Chancellor's party
    
    // === SPD COUNTER-STRATEGIES ===
Q.hindenburg_relationship_efforts = 0;      // Count of attempts to improve Hindenburg relations
Q.camarilla_counter_efforts = 0;            // Count of attempts to counter camarilla
Q.bruning_saved_by_spd = 0;                 // Did SPD save Brüning from dismissal?
Q.schleicher_appointment_prevented = 0;     // Did SPD prevent Schleicher appointment?
    
    // === HINDENBURG DEATH/SUCCESSION ===
Q.hindenburg_historical_death = 0;          // Historical death date (Aug 1934) reached?
Q.hindenburg_death_year = 0;                // Year of death (if different)
Q.hindenburg_successor_crisis = 0;          // Crisis over succession?
    
    // === TRACKED EVENTS ===
Q.hindenburg_1925_elected = 0;              // Hindenburg elected in 1925?
Q.hindenburg_1928_seen = 0;                 // 1928 intro event seen?
Q.hindenburg_1932_reelected = 0;            // Hindenburg reelected in 1932?
Q.hindenburg_opposes_hitler_1932 = 0;       // Did Hindenburg initially oppose Hitler?
    
    // === CAMARILLA MEETINGS ===
Q.camarilla_meeting_count = 0;              // Number of camarilla meetings tracked
Q.last_camarilla_meeting = "";              // Description of last meeting
Q.oskar_house_meeting = 0;    






Q.hindenburg_age = 78 + (Q.year - 1925);
Q.hindenburg_health = 90;
Q.hindenburg_senility = 10;
Q.camarilla_strength = 35;
Q.meissner_influence = 55;
Q.oskar_influence = 60;
Q.oldenburg_influence = 45;
Q.schleicher_influence = 40;
Q.camarilla_goal_protect_junkers = 70;
Q.camarilla_goal_crush_left = 50;
Q.camarilla_goal_destroy_parliament = 15;













Q.president_relation = 50;
Q.next_presidential_election_year = 1932;
Q.next_presidential_election_month = 5;
Q.next_austria_election = 1930;
Q.hindenburg_trust_spd = 50;

Q.dues_workers = 1; 
Q.dues_unemployed = 0.5; 
Q.dues_new_middle = 2;
Q.dues_old_middle = 1; 
Q.dues_rural = 1; 
Q.dues_catholics = 1;


//Influence power for SPD la KPD.

Q.young_socialists = 1;
Q.ideology = "centrist"

// === Macro Impulse & Pressure Variables (Cycle-Level, Continuous) ===

// Fiscal / demand-side
Q.fiscal_stance        = 0.0; // net contraction (+) / expansion (-)
Q.demand_impulse       = 0.0; // consumption pressure
Q.supply_impulse       = 0.0; // investment / productivity pressure

// Distribution & capital
Q.distribution_shift   = 0.0; // progressivity (+) vs regressivity (-)
Q.capital_pressure     = 0.0; // capital strike / investment flight risk

// Prices & inflation channels
Q.price_pressure       = 0.0; // inflationary (+) / deflationary (-) force

// External sector
Q.trade_pressure       = 0.0; // retaliation, openness, trade friction

// Memory / smoothing (used elsewhere)
Q.policy_momentum      = 0.0; // accumulated policy direction
Q.shock_residual       = 0.0; // leftover short-term shocks


// Reichsbank


Q.schacht_relation = 5;
Q.reichsbank_independent = 2;
Q.reichsbank_loyalty = 40;
Q.reichsbank_president = "Schacht";


// international relations

Q.west_relation = 0
Q.britain_relation = 1;
Q.france_relation = -1;
Q.italy_relation = 0
Q.hungary_relation = 0
Q.poland_relation = 0
Q.czech_relation = 0
Q.austria_relation = 0

// International situation
// Did we favor Ruhr labor?
Q.ruhr_labor = 0
// Was Tyrole Danubian Pact signed?
Q.tyrole_signed = 0
// Did young plan collapse?
young_plan_catastrophy  = 0

//austrian government
austria_govt = 1

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;
// use decimals for reichstag seats
// TODO: not yet implemented
Q.use_decimals = 0;

// party resources
Q.resources = 2;
// party dues
Q.dues = 2;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// factions
Q.factions = ['left', 'center', 'labor', 'reformist', 'neorevisionist'];
// should this be normalized to 100%?
Q.left_strength = 12;
Q.left_dissent = 20;
Q.center_strength = 33;
Q.center_dissent = 0;
Q.labor_strength = 25;
Q.labor_dissent = 5;
Q.reformist_strength = 25;
Q.reformist_dissent = 5;
Q.neorevisionist_strength = 5;
Q.neorevisionist_dissent = 10;

// SPLIT EVENTS or OTHER
Q.unions_independent = 0;
Q.centrists_resign = 0;
Q.left_split = 0;
Q.reformists_resigned = 0;
Q.sapd_formed = 0;
Q.neorevisionism = 0;
Q.srpd_formed = 0;
Q.neorev_split = 0;

// crisis_urgency indicates how seriously the SPD is taking the economic crisis - scale from 0 to 10.
Q.crisis_urgency = 0;
// nazi_urgency indicates how seriously the SPD takes the nazis - scale from 0 to 10.
Q.nazi_urgency = 0;
// radicalization indicates how radical the SPD's rhetoric is - scale from 0 to 10.
Q.radicalization = 0;
// Support for the WTB plan and proto-Keynesian works creation plans in general
Q.wtb_support = 0;
// Support for Pacifism within the SPD relative to 1928
Q.pacifism = 0;
// Support for democratic reform within the SPD relative to 1928
Q.democratization = 0;
// Support for a communist coalition relative to 1928
Q.communist_coalition = 0;
// economic_plan: have we adopted *any* economic plan?
// 1 - WTB plan, 2 - AfA-bund plan, 3 - radical plan (mass nationalization of industries)
Q.economic_plan = 0;
// have we officially adopted the WTB plan?
Q.wtb_adopted = 0;
// have we formed the iron front?
Q.iron_front_formed = 0;
// people's party support
Q.peoples_party_support = 0;
// support for nationalizations
Q.nationalization_support = 0;
Q.nationalization_adopted = 0;
// moderate economic plan
Q.moderate_plan_support = 0;
Q.moderate_plan_adopted = 0;

// organizations



Q.party_relations = {

    // === KPD ===
    KPD: {
        SAPD:  40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD:   Q.kpd_relation,
        SRPD:  Q.kpd_relation + 5,
        DDP:   8,
        Z:     5,
        BVP:   3,
        CSRP:  8,
        DVP:   3,
        WP:    3,
        CNBL:  2,
        CSVD:  0,
        DNVP:  0,
        VRP:   3,   // Savers' party = petty bourgeois class enemies, but negligible
        NSDAP: 0,
        KVP:  0,
        DHP:  0,
        BB:   2,
    },

    // === SAPD ===
    SAPD: {
        KPD:   40 + (Q.kpd_party_leader === "Conciliators" ? 20 : 0),
        SPD:   55 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD:  60,
        DDP:   20,
        Z:     15,
        BVP:   10,
        CSRP:  15,
        DVP:   8,
        WP:    8,
        CNBL:  8,
        CSVD:  12,
        DNVP:  3,
        VRP:   5,   // Inflation victims get some sympathy but VRP is still bourgeois
        NSDAP: 0,
        KVP:  5,
        DHP:  8,
        BB:   10,
    },

    // === SPD ===
    SPD: {
        KPD:   Q.kpd_relation,
        SAPD:  50 + (Q.left_strength >= 50 ? 15 : 0),
        SRPD:  65,
        DDP:   Q.ddp_relation,
        Z:     Q.z_relation,
        BVP:   Q.bvp_relation  ?? 35,
        DVP:   Q.dvp_relation,
        CSRP:  Q.csrp_relation,
        WP:    Q.wp_relation   ?? 25,
        CNBL:  Q.cnbl_relation ?? 20,
        CSVD:  Q.csvd_relation ?? 35,
        DNVP:  Q.dnvp_relation,
        VRP:   Q.vrp_relation ?? 20,  // SPD is blamed by VRP for inflationary policy; mutual coolness
        NSDAP: Q.nsdap_relation,
        KVP:  Q.kvp_relation,
        DHP:  Q.dhp_relation,
        BB:   Q.bb_relation,
    },

    // === SRPD ===
    SRPD: {
        KPD:   Q.kpd_relation - 10,
        SAPD:  55,
        SPD:   65,
        DDP:   Q.ddp_relation + 10,
        Z:     Q.z_relation + 5,
        BVP:   (Q.bvp_relation ?? 35) + 5,
        DVP:   Q.dvp_relation - 5,
        CSRP:  Q.csrp_relation + 5,
        WP:    (Q.wp_relation ?? 25) - 5,
        CNBL:  (Q.cnbl_relation ?? 20) + 5,
        CSVD:  (Q.csvd_relation ?? 35) + 5,
        DNVP:  Q.dnvp_line === 3 ? 0 : Q.dnvp_relation - 10,
        VRP:   20,  // Same as SPD; SRPD inherits the blame
        NSDAP: 0,
        KVP:  30,
        DHP:  25,
        BB:   25,
    },

    // === DDP ===
    DDP: {
        KPD:   8,
        SAPD:  20,
        SPD:   Q.ddp_relation,
        SRPD:  Q.ddp_relation + 10,
        Z:     70,
        BVP:   60,
        CSRP:  70,
        DVP:   65 - (Q.dvp_right_shift ?? 0) * 10,
        WP:    50,
        CNBL:  35,
        CSVD:  60,
        DNVP:  Q.dnvp_line === 3 ? 5 : 30,
        VRP:   55, // Shared liberal Mittelstand base; DDP sympathetic to revaluation demands
                   // but VRP's single-issue grievance politics limits the warmth
        NSDAP: 0,
        KVP:  55,
        DHP:  40,
        BB:   30,
    },

    // === Z ===
    Z: {
        KPD:   5,
        SAPD:  20,
        SPD:   Q.z_relation,
        SRPD:  Q.z_relation + 5,
        DDP:   70,
        BVP:   80,
        CSRP:  45,
        DVP:   60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        WP:    50,
        CNBL:  35,
        CSVD:  50,
        DNVP:  (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10),
        VRP:   35, // Z passed the 1925 revaluation measures VRP found inadequate;
                   // Catholic savers exist but Z won't restructure policy around them
        NSDAP: Q.nazi_urgency >= 7 ? 0 : Math.max(0, 25 - Q.nazi_urgency * 5),
        KVP:  45,
        DHP:  30,
        BB:   45,
    },

    // === CSRP ===
    CSRP: {
        KPD:   8,
        SAPD:  35,
        SPD:   Q.csrp_relation,
        SRPD:  Q.csrp_relation + 5,
        Z:     60,
        DDP:   65,
        BVP:   70,
        DVP:   25,
        WP:    40,
        CNBL:  20,
        CSVD:  30,
        DNVP:  10,
        VRP:   30, // Some sympathy for small saver; CSRP has a social justice streak,
                   // but VRP's liberal economics clash with Christian social doctrine
        NSDAP: 0,
        KVP:  35,
        DHP:  25,
        BB:   30,
    },

    // === BVP ===
    BVP: {
        KPD:   3,
        SAPD:  15,
        SPD:   Q.bvp_relation ?? 35,
        SRPD:  (Q.bvp_relation ?? 35) + 5,
        DDP:   60,
        Z:     80,
        CSRP:  40,
        DVP:   55,
        WP:    45,
        CNBL:  65,
        CSVD:  45,
        DNVP:  50,
        VRP:   35, // Bavaria had many small savers; BVP modestly sympathetic
                   // but won't prioritise revaluation over confessional politics
        NSDAP: Math.max(0, 15 - Q.nazi_urgency * 3),
        KVP:  40,
        DHP:  25,
        BB:   60,
    },

    // === DVP ===
    // Heavy industry benefited from inflation wiping out debt — VRP views DVP
    // as an arch-enemy representing those who prospered at savers' expense.
    DVP: {
        KPD:   3,
        SAPD:  10,
        SPD:   Q.dvp_relation,
        SRPD:  Q.dvp_relation - 5,
        DDP:   65 - (Q.dvp_right_shift ?? 0) * 10,
        Z:     60 + (Q.z_party_leader === "Kaas" ? 10 : 0),
        BVP:   55,
        CSRP:  25,
        WP:    70,
        CNBL:  30,
        CSVD:  50,
        DNVP:  50 + (Q.dvp_right_shift ?? 0) * 15,
        VRP:   20, // DVP represents the inflation profiteers in VRP's worldview;
                   // mutual coolness; some overlap on anti-socialism
        NSDAP: 20 + (Q.capital_strike_progress * 6) + (Q.dvp_right_shift ?? 0) * 12,
        KVP:  55,
        DHP:  40,
        BB:   25,
    },

    // === WP ===
    // WP represents property owners who did WELL from inflation — VRP's direct rival
    // and ideological nemesis within the Mittelstand. Historically they competed
    // directly for the same social stratum with opposite grievances.
    WP: {
        KPD:   3,
        SAPD:  10,
        SPD:   Q.wp_relation ?? 25,
        SRPD:  (Q.wp_relation ?? 25) - 5,
        DDP:   50,
        Z:     50,
        CSRP:  20,
        BVP:   45,
        DVP:   70,
        CNBL:  40,
        CSVD:  50,
        DNVP:  45,
        VRP:   15, // Direct rivals — WP = inflation winners, VRP = inflation losers.
                   // They fight over the same Mittelstand identity with opposite memories
        NSDAP: 35 + (Q.capital_strike_progress * 4),
        KVP:  40,
        DHP:  35,
        BB:   30,
    },

    // === CNBL ===
    CNBL: {
        KPD:   2,
        SAPD:  8,
        SPD:   Q.cnbl_relation ?? 20,
        SRPD:  (Q.cnbl_relation ?? 20) + 5,
        DDP:   30,
        Z:     40,
        CSRP:  15,
        BVP:   55,
        DVP:   35,
        WP:    40,
        CSVD:  40,
        DNVP:  45,
        VRP:   25, // Some rural savers align with VRP's revaluation demands;
                   // but Landbund prioritises agricultural tariffs over savings policy
        NSDAP: 30 + (Q.capital_strike_progress * 4) + (Q.year >= 1930 ? 10 : 0),
        KVP:  45,
        DHP:  55,
        BB:   55,
    },

    // === CSVD ===
    CSVD: {
        KPD:   0,
        SAPD:  15,
        SPD:   Q.csvd_relation ?? 40,
        SRPD:  (Q.csvd_relation ?? 40) + 5,
        DDP:   60,
        Z:     50,
        BVP:   45,
        CSRP:  35,
        DVP:   55,
        WP:    45,
        CNBL:  40,
        DNVP:  Q.dnvp_line === 3 ? 5 : 55,
        VRP:   45, // CSVD has Protestant pietist small-saver constituents who overlap
                   // with VRP's base; both anti-Hugenberg, both pro-republic
        NSDAP: 8,
        KVP:  65,
        DHP:  45,
        BB:   30,
    },

    // === DNVP ===
    DNVP: {
        KPD:   0,
        SAPD:  3,
        SPD:   Q.dnvp_relation,
        SRPD:  Q.dnvp_relation - 5,
        DDP:   Q.dnvp_line === 3 ? 5 : 30,
        Z:     (Q.dnvp_line === 3 ? 20 : 50) + (Q.z_party_leader === "Kaas" ? 15 : -10),
        BVP:   50,
        CSRP:  20,
        DVP:   50 + (Q.dvp_right_shift ?? 0) * 15,
        WP:    45,
        CNBL:  45,
        CSVD:  Q.dnvp_line === 3 ? 5 : 55,
        VRP:   30, // DNVP rhetorically sympathised with revaluation but did little;
                   // Hugenberg-era DNVP is too volkisch for VRP's legal-liberal savers
        NSDAP: Q.dnvp_line === 3 ? 70 : 40,
        KVP:  Q.dnvp_line === 3 ? 5 : 60,
        DHP:  Q.dnvp_line === 3 ? 15 : 55,
        BB:   35,
    },

    // === NSDAP ===
    NSDAP: {
        KPD:   0,
        SAPD:  0,
        SPD:   0,
        SRPD:  0,
        DDP:   0,
        CSRP:  0,
        Z:     Q.nazi_urgency >= 7 ? 0 : Math.max(0, 20 - Q.nazi_urgency * 4),
        BVP:   Math.max(0, 15 - Q.nazi_urgency * 3),
        DVP:   25 + (Q.capital_strike_progress * 5) + (Q.dvp_right_shift ?? 0) * 10,
        WP:    30 + (Q.capital_strike_progress * 3),
        CNBL:  30,
        CSVD:  8,
        DNVP:  Q.dnvp_line === 3 ? 70 : 40,
        VRP:   25 + (Q.capital_strike_progress * 3),
        // VRP voters are NSDAP's prime recruitment pool — the cheated saver
        // is a central Nazi propaganda figure ("November criminals," "Jewish finance").
        // NSDAP actively courted this demographic.
        KVP:  5,
        DHP:  15,
        BB:   20,
    },

    // === VRP (Volksrechtpartei / People's Justice Party) ===
    // Founded 1926 by the Sparerbund für das Deutsche Reich.
    // Represents small savers, pensioners, and bondholders wiped out by 1923 hyperinflation.
    // Demands full revaluation of savings. Sees WP (inflation property-owners) as rivals.
    // Sees DVP (heavy industry, inflation profiteers) as enemies.
    // Politically: right-liberal, anti-socialist, pro-Rechtsstaat, single-issue grievance.
    // Demographic: elderly rentiers, widows, civil servants, small depositors.
    // Danger: as revaluation hopes fade, this electorate drifts toward NSDAP rapidly.
    VRP: {
        KPD:   3,
        SAPD:  5,
        SPD:   Q.vrp_relation,  // SPD blamed for inflationary Weimar finance policy
        SRPD:  20,
        DDP:   55,  // Natural liberal ally; shared Mittelstand base
        Z:     35,  // Z passed inadequate 1925 measures; disappointment, not hostility
        BVP:   35,
        CSRP:  30,
        DVP:   20,  // DVP = big industry = inflation profiteers in VRP's worldview
        WP:    15,  // Direct rival — WP represents those who GAINED from inflation
        CNBL:  25,
        CSVD:  45,  // Good overlap: Protestant small-saver base, anti-Hugenberg, pro-republic
        DNVP:  Q.dnvp_line === 3 ? 10 : 35, // DNVP talked revaluation but didn't deliver;
                                              // Hugenberg era is too radical for VRP
        NSDAP: 0,    // VRP is a legal party demanding justice through courts and parliament;
                    // but its voters are the Nazis' #1 recruitment target as hope fades
        KVP:  35,
        DHP:  30,
        BB:   25,
    },
    // === KVP ===
    KVP: {
        KPD:   0,
        SAPD:  5,
        SPD:   25,
        SRPD:  30,
        DDP:   5,
        Z:     45,
        BVP:   40,
        CSRP:  35,
        DVP:   55,
        WP:    40,
        CNBL:  45,
        CSVD:  65,
        DNVP:  Q.dnvp_line === 3 ? 5 : 60,
        VRP:   35,
        NSDAP: 5,
        DHP:   50,
        BB:    35,
    },

    // === DHP (German Hannover Party) ===
    DHP: {
        KPD:   0,
        SAPD:  5,
        SPD:   20,
        SRPD:  25,
        DDP:   40,
        Z:     30,
        BVP:   25,
        CSRP:  25,
        DVP:   40,
        WP:    35,
        CNBL:  55,  // Agrarian overlap
        CSVD:  45,
        DNVP:  Q.dnvp_line === 3 ? 15 : 55,
        VRP:   30,
        NSDAP: 15,
        KVP:   50,
        BB:    40,
    },

    // === BB (Bavarian Peasants Party) ===
    BB: {
        KPD:   0,
        SAPD:  5,
        SPD:   20,
        SRPD:  25,
        DDP:   30,
        Z:     45,
        BVP:   60,  // Natural Bavarian Catholic overlap but rivals
        CSRP:  30,
        DVP:   25,
        WP:    30,
        CNBL:  55,  // Agrarian solidarity
        CSVD:  30,
        DNVP:  35,
        VRP:   25,
        NSDAP: 20,  // Agrarian grievance overlap — danger zone
        KVP:   35,
        DHP:   40,
    },
};



