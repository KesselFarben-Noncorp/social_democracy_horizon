};

// ---- DECAY RATES PER DIMENSION ----
// Fraction of (target - current) closed per tick.
// Economic is fast, cultural is slow.

Q.grievance_decay = {
    economic: 0.12,
    security: 0.10,
    political: 0.07,
    cultural: 0.04,
};

// ---- CRISIS PARTY DEFINITIONS PER CLASS ----
// Which parties benefit from low QOL in each class.
// Used in computeTarget() patch to apply asymmetric multiplier.

Q.crisis_parties_by_class = {
    workers:    ['kpd', 'sapd', 'nsdap'],
    unemployedc:['kpd', 'sapd', 'nsdap'],
    old_middle: ['nsdap', 'dvfp', 'dnvp'],
    new_middle: ['nsdap', 'dvfp', 'dnvp'],
    rural:      ['nsdap', 'cnbl', 'dnvp'],
};

// ---- INITIALIZE GRIEVANCE DIMENSIONS ----
// All start at 50 (neutral). Composite QOL starts at 100 (1928 baseline).
// Format: Q.[class]_grievance_[dimension]

const _CLASSES_QOL    = ['workers', 'unemployedc', 'old_middle', 'new_middle', 'rural'];
const _DIMENSIONS_QOL = ['economic', 'security', 'political', 'cultural'];

for (const _c of _CLASSES_QOL) {
    for (const _d of _DIMENSIONS_QOL) {
        Q[_c + '_grievance_' + _d] = 50;
    }
    // Composite QOL — replaces the old unused Q.[class]_qol
    Q[_c + '_qol'] = 100;
}

// ---- INITIALIZE QOL MEMORY ----
// Tracks last-tick QOL for velocity/momentum (used in postevent)
for (const _c of _CLASSES_QOL) {
    Q[_c + '_qol_last'] = 100;
    Q[_c + '_qol_vel']  = 0;
}


Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployedc'];
