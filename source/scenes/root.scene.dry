Q.custom_party_dvp   = Q.custom_party_dvp   || 1;
Q.custom_party_dnvp  = Q.custom_party_dnvp  || 1;
Q.custom_party_nsdap = Q.custom_party_nsdap || 1;
Q.custom_party_lb    = Q.custom_party_lb    || 0;
Q.custom_party_kpo   = Q.custom_party_kpo   || 0;

// ============================================================
// AUTO IDEOLOGY SCORER — derives 0 (far-left) to 20 (far-right)

const IDEO_KEYWORDS = [
    // 0 — revolutionary / Leninist left
    [/marxism-leninism/i,                 1],
    [/council communism/i,                0],

    // 2 — revolutionary but non-Leninist / left socialist
    [/revolutionary socialism/i,          2],
    [/left-wing socialism/i,              3],

    // NEW — Social Democracy family (must precede generic soc-dem/soc-rep below)
    [/social democracy \(revolutionary\)/i,      3],  // Left
    [/social democracy \(center marxist\)/i,     4],  // Center
    [/social democracy \(reformist\)/i,          6],  // Reformist
    [/laborism/i,                                7],  // Labor
    [/social republicanism \(neorevisionist\)/i, 8],  // Neorevisionist

    // 5 — mainstream social democracy
    [/social democracy/i,                 6],
    [/social republicanism/i,             7],

    // 7 — right social democracy / soft-left liberal
    [/right-wing social democracy/i,      8],

    // 10 — center / centrist liberal / cross-class Christian
    [/social liberalism/i,                10],
    [/christian socialism/i,              6],
    [/catholic tent/i,                    12],
    [/middle-class interest/i,            13],

    // 13 — moderate conservative / regional Catholic conservative
    [/bavarian conservatism/i,            13],
    [/protestant social conservatism/i,   13],
    [/moderate conservatism/i,            14],
    [/liberal agrarianism/i,              12],

    // 15 — national liberal / agrarian-liberal right-center
    [/national liberalism/i,              15],
    [/hanoverian agrarianism/i,           15],
    [/hanseatic agrarian conservatism/i,  15],

    // 17 — hard agrarian conservative
    [/agrarian conservatism/i,            17],
    [/social corporatism/i,               16],

    // 18 — national conservative
    [/national conservatism/i,            18],

    // 20 — far-right nationalist / völkisch / Nazi
    [/national socialism/i,               20],
    [/völkisch nationalism/i,             20],
    [/völkisch liberalism/i,              16],
];

function ideoScore(ideologyString) {
    if (!ideologyString) return 10; // Fallback to absolute center (10)
    for (const [pattern, score] of IDEO_KEYWORDS) {
        if (pattern.test(ideologyString)) return score;
    }
    return 10; // Unrecognized ideology string -> treat as centrist/unknown
}

// Apply to every active party, reading straight from Q.[party]_ideology
for (const p of Q.parties) {
    const key = p + '_ideology';
    Q[p + '_ideo_score'] = ideoScore(Q[key]);
}

// Also cover parties tracked outside Q.parties but referenced in
// party_relations / coalition_blocks (splinters, KPO, LB, etc.)
const EXTRA_IDEO_PARTIES = [
    'kpo', 'sl', 'sapd', 'srpd', 'ddp', 'z', 'bvp', 'csrp', 'dvp', 'wp',
    'cnbl', 'csvd', 'dnvp', 'vrp', 'kvp', 'dhp', 'bb', 'dvfp',
    'aspd', 'vnr', 'hl', 'lb', 'rdp', 'cvp', 'sls', 'dtsp', 'dbp', 'dsbp', 'dnf', 'rlb', 'faud', 'kapd'
];
for (const p of EXTRA_IDEO_PARTIES) {
    const key = p + '_ideology';
    if (Q[key] !== undefined) {
        Q[p + '_ideo_score'] = ideoScore(Q[key]);
    }
}


!}
