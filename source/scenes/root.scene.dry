on-arrival: {!
if (Q.hindenburg_challenge === 1) {
    Q.hindenburg_dead = 1;
    Q.president = "Gessler";
    Q.president_party = "DDP";
}

if (Q.duel_challenge === 1) {
    Q.dvp_banned = 1;
    Q.bvp_banned = 1;
    Q.kpd_banned = 1;
    Q.bb_banned = 1;
    Q.dhp_banned = 1;
    Q.kvp_banned = 1;
    Q.nsdap_banned = 1;
    Q.other_banned = 1;
    Q.csvd_banned = 1;
    Q.wp_banned = 1;
    Q.cnbl_banned = 1;
    Q.vrp_banned = 1;
    Q.srpd_banned = 1;
    Q.sapd_banned = 1;
    Q.z_banned = 1;
    Q.ddp_banned = 1;
    Q.spd_banned = 0;
    Q.dnvp_banned = 0;
    Q.dvfp_banned = 1;
    Q.csrp_banned = 1;
    Q.vrp_banned = 1;
}

if (Q.spartac_challenge === 1) {
    Q.dvp_banned = 1;
    Q.bvp_banned = 1;
    Q.dnvp_banned = 1;
    Q.bb_banned = 1;
    Q.dhp_banned = 1;
    Q.kvp_banned = 1;
    Q.nsdap_banned = 1;
    Q.other_banned = 1;
    Q.csvd_banned = 1;
    Q.wp_banned = 1;
    Q.cnbl_banned = 1;
    Q.vrp_banned = 1;
    Q.parties.push('sapd');
    Q.parties.push('srpd');
    Q.srpd_formed = 1;
    Q.sapd_formed = 1;
}

if (Q.dice_challenge === 1) {
    Q.dice_mode = 1;
    Q.resources += 2;
    Q.budget += 1;
    }

if (Q.vn_challenge === 1) {
    Q.dhp_banned = 1;
    Q.bb_banned = 1;
    Q.kvp_banned = 1;
    Q.csvd_banned = 1;
    Q.wp_banned = 1;
    Q.cnbl_banned = 1;
    Q.srpd_banned = 1;
    Q.csrp_banned = 1;
    Q.vrp_banned = 1;
    Q.camarilla_strength = -1000;
    Q.general_strike_progress = -1000;
}

if (Q.dem_challenge === 1) {
    Q.nsdap_banned = 1;
    Q.kpd_banned = 1;
}

if (Q.cmr_challenge === 1) {
    Q.camarilla_strength += 120;
    Q.papen_in_camarilla = 1;
    Q.hindenburg_health = 50;
    Q.meissner_influence += 10;
    Q.schleicher_influence += 15;
    Q.hindenburg_patience = 10;
    }

if (Q.new_partei_challenge === 1) {
    Q.rural_spd = 1;
    Q.workers_spd = 1;
    Q.new_middle_spd = 1;
    Q.old_middle_spd = 1;
    Q.unemployed_spd = 1;
}

if (Q.gang_challenge === 1) {
    Q.srpd_formed = 1;
    Q.kvp_flee = 1;
    Q.old_middle_kvp = 10;
    Q.sapd_formed = 1;
    Q.csvd_flee = 1;
    Q.unemployed_sapd = 10;
    Q.workers_srpd = 10;
    Q.rural_csvd = 10;
    Q.parties.push('sapd');
    Q.parties.push('kvp');
    Q.parties.push('srpd');
    Q.parties.push('csvd');
}
if (Q.peasant_revolution === 1) {
    Q.rural = 60; // Massively inflated rural population
    Q.old_middle = 5;
    Q.new_middle = 0;
    Q.workers = 20; // Industry collapsed
    Q.unemployedc = 10;
    // Rural parties (CNBL, DNVP, BVP) start strong
    Q.rural_cnbl = 25;
    Q.rural_dnvp = 30;
    Q.rural_bvp = 20;
    // SPD weak in cities too
    Q.workers_spd = 15;
}

if (Q.inverted_challenge === 1) {
    // ===== PARTY RELATIONS =====
    Q.z_relation = Math.random() * 100;
    Q.kpd_relation = Math.random() * 100;
    Q.sapd_relation = Math.random() * 100;
    Q.srpd_relation = Math.random() * 100;
    Q.ddp_relation = Math.random() * 100;
    Q.bvp_relation = Math.random() * 100;
    Q.dvp_relation = Math.random() * 100;
    Q.wp_relation = Math.random() * 100;
    Q.dnvp_relation = Math.random() * 100;
    Q.nsdap_relation = Math.random() * 100;

    // ===== PARTY RELATIONS MATRIX =====
    Q.party_relations = {
        KPD: {},
        SAPD: {},
        SPD: {},
        SRPD: {},
        DDP: {},
        Z: {},
        CSRP: {},
        VRP: {},
        CSVD: {},
        BVP: {},
        DVP: {},
        WP: {},
        DHP: {},
        BB: {},
        KVP: {},
        CNBL: {},
        DNVP: {},
        NSDAP: {}
    };

    var all_parties = ['KPD', 'SAPD', 'SPD', 'SRPD', 'DDP', 'Z', 'BVP', 'CSRP', 'VRP', 'CSVD', 'DVP', 'WP', 'CNBL', 'KVP', 'BB', 'DHP', 'DNVP', 'NSDAP'];

    // Randomize all party-to-party relations
    for (var party1 of all_parties) {
        for (var party2 of all_parties) {
            if (party1 !== party2) {
                // Random value between 0-100
                Q.party_relations[party1][party2] = Math.floor(Math.random() * 101);
            }
        }
    }

    Q.coalition_blocks = {
    KPD_Z:     false,
    KPD_BVP:   false,
    KPD_DVP:   false,
    KPD_WP:    false,
    KPD_CNBL:  false,
    KPD_DNVP:  false,
    KPD_NSDAP: false,
    KPD_VRP:   false,
    KPD_DDP:   false,
    KPD_SPD:   false,

    SAPD_DVP:   false,
    SAPD_WP:    false,
    SAPD_CNBL:  false,
    SAPD_DNVP:  false,
    SAPD_NSDAP: false,
    SAPD_VRP:   false,

    SPD_NSDAP:  false,
    SPD_DNVP:   false,
    SPD_KPD:    false,
    SPD_VRP:    false,

    SRPD_KPD:   false,
    SRPD_NSDAP: false,
    SRPD_DNVP:  false,
    SRPD_VRP:   false,

    DDP_KPD:    false,
    DDP_NSDAP:  false,
    DDP_DNVP:   false,

    Z_KPD:      false,
    Z_NSDAP:    false,
    Z_DNVP:     false,

    BVP_KPD:    false,
    BVP_SAPD:   false,
    BVP_NSDAP:  false,

    DVP_KPD:    false,
