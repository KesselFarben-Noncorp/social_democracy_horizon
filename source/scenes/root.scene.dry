@spartacus

= Spartacus

Spartacists have won and only left wing parties remain, as others are banned. SAPD and SRPD are formed by the start.

- @spartacus_2: True
- @spartacus_3: False
- @challenge: Back.

@spartacus_2
view-if: spartac_challenge = 0
on-arrival: spartac_challenge = 1
go-to: spartacus

Turned on!

@spartacus_3
view-if: spartac_challenge = 1
on-arrival: spartac_challenge = 0
go-to: spartacus

Turned off!

@gang

= Gang

Everyone, even splitters are here! Let's see how party dynamics will go. CSVD, SRPD and SAPD are formed by the start of the game.

- @gang_2: True
- @gang_3: False
- @challenge: Back.

@gang_2
view-if: gang_challenge = 0
on-arrival: gang_challenge = 1
go-to: gang

Turned on!

@gang_3
view-if: gang_challenge = 1
on-arrival: gang_challenge = 0
go-to: gang

Turned off!

@1928_easy
on-arrival: difficulty = -1; resources = 4; dues = 3; rb_strength = 2500; kpd_relation = 28; z_relation = 52; dvp_relation = 47; budget = 4;
go-to: 1928_main

@1928_hard
on-arrival: difficulty = 1; resources = 0; dues = 1; rb_strength = 1000; reformist_dissent = 25; left_dissent = 30; labor_dissent = 25; center_dissent = 25; z_relation = 41; kpd_relation = 16; dvp_relation = 31; budget = 3;
go-to: 1928_main

@1928_historical
subtitle: Saving, loading, and polls will be disabled. [? if not achievement_game_completed: Not recommended for a first playthrough. ?]
on-arrival: {!
Q.difficulty = 2;
Q.historical_mode = 1;
Q.resources = 2;
Q.dues = 1;
Q.rb_strength = 2000;
Q.reformist_dissent = 25;
Q.left_dissent = 30;
Q.labor_dissent = 25;
Q.center_dissent = 25;
Q.z_relation = 41;
Q.bvp_relation = 25;
Q.kpd_relation = 16;
Q.dvp_relation = 31;
Q.budget = 2;
this.state.disableSaves = true;
!}
go-to: 1928_main

@1928_main
audio: shuffle music/1928_1930/FruhlingsliedMendelssohn.mp3 music/1928_1930/AUF_HOHEN_BERGEN_noise_reduced.mp3 music/1928_1930/MarekWeber.mp3 music/1928_1930/BAUERNKAPELLE.mp3 music/1928_1933/DERLINDENBAUM_normalized.mp3 music/1928_1933/ZurSonne_zurFreiheit.mp3 music/1928_1933/arbeiter_marseille.mp3 music/1928_1933/Wann_wir_schreiten_Seit_an_Seit.mp3 music/1930_1933/Internationale-de_normalized.ogg music/1928_1930/LiedDerPompadour.mp3 music/1928_1933/SozialistenMarsch.mp3
new-page: true
on-arrival: {!
if (Q.hindenburg_challenge === 1) {
    Q.hindenburg_dead = 1;
    Q.president = "Gessler";
    Q.president_party = "DDP";
}

if (Q.april_challenge === 1) {
    Q.parties.push('dvfp');
    Q.parties.push('kpo');
    Q.parties.push('sl');
    Q.dvfp_formed = 1;
    Q.nsdap_banned = 1;
    Q.sa_banned = 1;
    Q.sa_strength *= 0.00000000001;
    Q.inflation += 10;
    Q.dnvp_relation += 30;
    Q.kpd_relation -= 10;
    Q.wp_relation += 20; 
    Q.dvp_relation += 20;
    Q.cnbl_relation += 20;
    Q.dhp_relation += 10;
    Q.vrp_relation += 10;
    Q.rfb_strength += 100;
    Q.rfb_militancy += 0.05;
    Q.reichswehr_loyalty += 0.25;
}

if (Q.duel_challenge === 1) {
    Q.dvp_banned = 1;
    Q.bvp_banned = 1;
    Q.kpd_banned = 1;
    Q.bb_banned = 1;
    Q.dhp_banned = 1;
    Q.kvp_banned = 1;
    Q.nsdap_banned = 1;
    Q.other_banned = 1;
    Q.csvd_banned = 1;
    Q.wp_banned = 1;
    Q.cnbl_banned = 1;
    Q.vrp_banned = 1;
    Q.srpd_banned = 1;
    Q.sapd_banned = 1;
    Q.z_banned = 1;
    Q.ddp_banned = 1;
    Q.spd_banned = 0;
    Q.dnvp_banned = 0;
    Q.dvfp_banned = 1;
    Q.csrp_banned = 1;
    Q.vrp_banned = 1;
}

if (Q.spartac_challenge === 1) {
    Q.dvp_banned = 1;
    Q.bvp_banned = 1;
    Q.dnvp_banned = 1;
    Q.bb_banned = 1;
    Q.dhp_banned = 1;
    Q.kvp_banned = 1;
    Q.nsdap_banned = 1;
    Q.other_banned = 1;
    Q.csvd_banned = 1;
    Q.wp_banned = 1;
    Q.cnbl_banned = 1;
    Q.vrp_banned = 1;
    Q.parties.push('sapd');
    Q.parties.push('srpd');
    Q.srpd_formed = 1;
    Q.sapd_formed = 1;
}

if (Q.dice_challenge === 1) {
    Q.dice_mode = 1;
    Q.resources += 2;
    Q.budget += 1;
    }

if (Q.vn_challenge === 1) {
    Q.dhp_banned = 1;
    Q.bb_banned = 1;
    Q.kvp_banned = 1;
    Q.csvd_banned = 1;
    Q.wp_banned = 1;
    Q.cnbl_banned = 1;
    Q.srpd_banned = 1;
    Q.csrp_banned = 1;
    Q.vrp_banned = 1;
    Q.camarilla_strength = -1000;
    Q.general_strike_progress = -1000;
}

if (Q.dem_challenge === 1) {
    Q.nsdap_banned = 1;
    Q.kpd_banned = 1;
}

if (Q.modern_variable === 1) {
    Q.electoral_threshold = 5;
    Q.constitutional_reform += 1;
}

if (Q.cmr_challenge === 1) {
    Q.camarilla_strength += 120;
    Q.papen_in_camarilla = 1;
    Q.hindenburg_health = 50;
    Q.meissner_influence += 10;
    Q.schleicher_influence += 15;
    Q.hindenburg_patience = 10;
    }

if (Q.new_partei_challenge === 1) {
    Q.rural_spd = 1;
    Q.workers_spd = 1;
    Q.new_middle_spd = 1;
    Q.old_middle_spd = 1;
    Q.unemployed_spd = 1;
}

if (Q.gang_challenge === 1) {
    Q.srpd_formed = 1;
    Q.kvp_flee = 1;
    Q.old_middle_kvp = 10;
    Q.sapd_formed = 1;
    Q.csvd_flee = 1;
    Q.unemployed_sapd = 10;
    Q.workers_srpd = 10;
    Q.rural_csvd = 10;
    Q.parties.push('sapd');
    Q.parties.push('kvp');
    Q.parties.push('srpd');
    Q.parties.push('csvd');
    Q.parties.push('vrp');
Q.parties.push('aspd');
Q.parties.push('hl');
Q.parties.push('kpo');
Q.parties.push('vnr');
Q.parties.push('dvfp');
Q.parties.push('csrp');
Q.parties.push('bb');
Q.parties.push('dhp');
Q.parties.push('sl');
Q.parties.push('cnbl');
Q.parties.push('rdp');
Q.parties.push('sls');
Q.parties.push('cvp');
Q.parties.push('dtsp');
Q.parties.push('lb');
}
if (Q.peasant_revolution === 1) {
    Q.rural = 60; // Massively inflated rural population
    Q.old_middle = 5;
    Q.new_middle = 0;
    Q.workers = 20; // Industry collapsed
    Q.unemployedc = 10;
    // Rural parties (CNBL, DNVP, BVP) start strong
    Q.rural_cnbl = 25;
    Q.rural_dnvp = 30;
    Q.rural_bvp = 20;
    // SPD weak in cities too
    Q.workers_spd = 15;
    Q.parties.push('bb');
    Q.parties.push('cnbl');
}

if (Q.inverted_challenge === 1) {

    var all_parties = Q.parties
        .filter(p => p !== 'other')
        .map(p => p.toUpperCase());

    // ===== PARTY RELATIONS =====
    // Derive from all_parties rather than declaring one by one
    for (var p of all_parties) {
        Q[p.toLowerCase() + '_relation'] = Math.random() * 100;
    }

    // ===== PARTY RELATIONS MATRIX =====
    Q.party_relations = {};
    for (var party1 of all_parties) {
        Q.party_relations[party1] = {};
        for (var party2 of all_parties) {
            if (party1 !== party2) {
                Q.party_relations[party1][party2] = Math.floor(Math.random() * 101);
            }
        }
    }

    // ===== COALITION BLOCKS (all false in inverted mode) =====
    Q.coalition_blocks = {};
    for (var p1 of all_parties) {
        for (var p2 of all_parties) {
            if (p1 !== p2) {
                Q.coalition_blocks[p1 + '_' + p2] = false;
            }
        }
    }
    Q.coalition_blocks.NSDAP_COALITIONS_GENERALLY = false;

    // ===== IDEOLOGY OVERRIDES =====
    var IDEO_DEFAULTS = {
        KPD: 1, SAPD: 2, SPD: 3, SRPD: 3,
        DDP: 5, CSRP: 5, Z: 5, BVP: 6, CSVD: 6, KVP: 6,
        DVP: 7, WP: 7, VRP: 7, DHP: 7,
        BB: 7, CNBL: 8, DNVP: 9, NSDAP: 10, DVFP: 10
    };

    for (var ip of all_parties) {
        var base   = IDEO_DEFAULTS[ip] || 5;
        var jitter = Math.floor(Math.random() * 7) - 3;
        Q[ip.toLowerCase() + '_ideo_override'] = Math.max(1, Math.min(10, base + jitter));
    }

}
!}
go-to: apberg if april_challenge = 1; starum if april_challenge = 0

= 1927, [+ month: month +]

@apberg
set-bg: img/weimar_2.jpg
go-to: main if difficulty >= 0; main.main_easy if difficulty < 0

@starum
set-bg: img/weimar.jpg
go-to: main if difficulty >= 0; main.main_easy if difficulty < 0
