@debug
on-arrival: {!

console.log("=== INVERTED CHALLENGE DEBUG ===");

// 1. PARTIES ARRAY
console.log("1. Q.parties:", JSON.stringify(Q.parties));
console.log("1. Q.parties length:", Q.parties ? Q.parties.length : "UNDEFINED");

// 2. CLASS SUPPORT VARIABLES
var debug_classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployedc'];
var debug_parties = Q.parties ? Q.parties.filter(function(p){ return p !== 'other'; }) : [];
var debug_missing = [];
var debug_nan = [];
var debug_zero = [];

for (var di = 0; di < debug_parties.length; di++) {
    for (var dj = 0; dj < debug_classes.length; dj++) {
        var debug_key = debug_classes[dj] + '_' + debug_parties[di];
        var debug_val = Q[debug_key];
        if (debug_val === undefined || debug_val === null) debug_missing.push(debug_key);
        else if (isNaN(debug_val)) debug_nan.push(debug_key + '=NaN');
        else if (debug_val === 0) debug_zero.push(debug_key + '=0');
    }
}

console.log("2. MISSING class vars:", JSON.stringify(debug_missing));
console.log("2. NaN class vars:", JSON.stringify(debug_nan));
console.log("2. Zero class vars:", JSON.stringify(debug_zero));

// 3. PARTY RELATIONS
if (!Q.party_relations) {
    console.log("3. party_relations: UNDEFINED OR NULL");
} else {
    var pr_keys = Object.keys(Q.party_relations);
    console.log("3. party_relations top keys:", JSON.stringify(pr_keys));
    var pr_missing = [];
    var pr_nan = [];
    var pr_zero = [];
    for (var pk = 0; pk < pr_keys.length; pk++) {
        var p1 = pr_keys[pk];
        var p2_keys = Object.keys(Q.party_relations[p1]);
        for (var pl = 0; pl < p2_keys.length; pl++) {
            var p2 = p2_keys[pl];
            var pr_val = Q.party_relations[p1][p2];
            if (pr_val === undefined || pr_val === null) pr_missing.push(p1+'->'+p2);
            else if (isNaN(pr_val)) pr_nan.push(p1+'->'+p2+'=NaN');
            else if (pr_val === 0) pr_zero.push(p1+'->'+p2+'=0');
        }
    }
    console.log("3. party_relations MISSING:", JSON.stringify(pr_missing));
    console.log("3. party_relations NaN:", JSON.stringify(pr_nan));
    console.log("3. party_relations Zero:", JSON.stringify(pr_zero));
}

// 4. COALITION BLOCKS
if (!Q.coalition_blocks) {
    console.log("4. coalition_blocks: UNDEFINED OR NULL");
} else {
    var cb_keys = Object.keys(Q.coalition_blocks);
    var cb_weird = [];
    for (var ci = 0; ci < cb_keys.length; ci++) {
        var cb_val = Q.coalition_blocks[cb_keys[ci]];
        if (cb_val !== true && cb_val !== false) cb_weird.push(cb_keys[ci] + '=' + cb_val);
    }
    console.log("4. coalition_blocks total keys:", cb_keys.length);
    console.log("4. coalition_blocks non-boolean:", JSON.stringify(cb_weird));
}

// 5. CHALLENGE FLAGS
console.log("5. inverted_challenge:", Q.inverted_challenge);
console.log("5. gang_challenge:", Q.gang_challenge);
console.log("5. spartac_challenge:", Q.spartac_challenge);
console.log("5. duel_challenge:", Q.duel_challenge);
console.log("5. dice_challenge:", Q.dice_challenge);
console.log("5. vn_challenge:", Q.vn_challenge);
console.log("5. dem_challenge:", Q.dem_challenge);
console.log("5. cmr_challenge:", Q.cmr_challenge);
console.log("5. new_partei_challenge:", Q.new_partei_challenge);
console.log("5. peasant_revolution:", Q.peasant_revolution);
console.log("5. april_challenge:", Q.april_challenge);
console.log("5. hindenburg_challenge:", Q.hindenburg_challenge);

// 6. REICHSTAG _r VARS
var r_missing = [];
var r_nan = [];
for (var ri = 0; ri < debug_parties.length; ri++) {
    var r_key = debug_parties[ri] + '_r';
    var r_val = Q[r_key];
    if (r_val === undefined || r_val === null) r_missing.push(r_key);
    else if (isNaN(r_val)) r_nan.push(r_key + '=NaN');
    else console.log("6. " + r_key + " =", r_val);
}
console.log("6. MISSING _r vars:", JSON.stringify(r_missing));
console.log("6. NaN _r vars:", JSON.stringify(r_nan));

// 7. RELATION VARS
var rel_missing = [];
var rel_nan = [];
for (var reli = 0; reli < debug_parties.length; reli++) {
    var rel_key = debug_parties[reli] + '_relation';
    var rel_val = Q[rel_key];
    if (rel_val === undefined || rel_val === null) rel_missing.push(rel_key);
    else if (isNaN(rel_val)) rel_nan.push(rel_key + '=NaN');
    else console.log("7. " + rel_key + " =", rel_val);
}
console.log("7. MISSING _relation vars:", JSON.stringify(rel_missing));
console.log("7. NaN _relation vars:", JSON.stringify(rel_nan));

// 8. FULL NaN SWEEP
var all_nan_keys = [];
var q_keys = Object.keys(Q);
for (var qi = 0; qi < q_keys.length; qi++) {
    if (typeof Q[q_keys[qi]] === 'number' && isNaN(Q[q_keys[qi]])) {
        all_nan_keys.push(q_keys[qi]);
    }
}
console.log("8. ALL NaN keys in Q:", JSON.stringify(all_nan_keys));

// 9. CRITICAL VARS
var crit_list = ['workers','old_middle','new_middle','rural','unemployed',
    'nationalism','socialism','pro_republic',
    'spd_r','kpd_r','z_r','ddp_r','dvp_r','dnvp_r','nsdap_r',
    'budget','resources','dissent'];
for (var cri = 0; cri < crit_list.length; cri++) {
    var crit_val = Q[crit_list[cri]];
    if (crit_val === undefined) console.log("9. MISSING: " + crit_list[cri]);
    else if (isNaN(crit_val)) console.log("9. NaN: " + crit_list[cri]);
    else console.log("9. OK: " + crit_list[cri] + " =", crit_val);
}

console.log("=== DEBUG COMPLETE ===");
!}
go-to: sandbox_menu

@developermode
on-display: {!
if (Q.developer_mode) {
    document.getElementById('dev-console').innerHTML =
        '<p style="color:lime;font-family:monospace;">✓ Developer mode active.</p>';
    return;
}

var container = document.getElementById('dev-console');
container.innerHTML = '';

var input = document.createElement('input');
input.type        = 'password';
input.placeholder = 'Enter access code…';
input.style.cssText =
    'background:#111; color:#0f0; border:1px solid #0f0;' +
    'padding:6px 10px; font-family:monospace; font-size:13px;' +
    'width:220px; outline:none; border-radius:2px;';

var btn = document.createElement('button');
btn.textContent  = 'Confirm';
btn.style.cssText =
    'margin-left:8px; background:#0f0; color:#000; border:none;' +
    'padding:6px 12px; font-family:monospace; font-size:13px;' +
    'cursor:pointer; border-radius:2px;';

var msg = document.createElement('p');
msg.style.cssText = 'color:#f55; font-size:12px; margin-top:6px; height:16px;';

btn.addEventListener('click', function() {
    if (input.value === '1920Luxembourg') {
        Q.developer_mode = 1;
        container.innerHTML =
            '<p style="color:lime;font-family:monospace;">✓ Access granted. Developer mode enabled.</p>';
    } else {
        msg.textContent = '✗ Incorrect code.';
        input.value = '';
    }
});

input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') btn.click();
});

container.appendChild(input);
container.appendChild(btn);
container.appendChild(msg);

!}
