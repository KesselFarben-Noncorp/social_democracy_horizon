@party
title: Party Affairs
card-image: img/Vorwaerts_nr_1.png
is-deck: true

- #party_affairs

@govt
title: Government Affairs
view-if: time >= 12 and (spd_in_government = 1 or spd_toleration = 1)
card-image: img/reichstag_2.jpg
is-deck: true

- #govt_affairs

@intel
title: Intelligence Network
view-if: intelligence_proposal_seen = 1
card-image: img/reichstag_2.jpg
is-deck: true

- #intel_affairs

@reichstag
title: Reichstag Affairs
view-if: spd_in_government = 1 and time >= 12 and developer_mode = 1
is-deck: true

- #reichstag_affairs
